@inproceedings{ WOS:000767967000024,
Author = {Gao, Yingying and Janssen, Marijn},
Editor = {Pereira, GV and Janssen, M and Lee, H and Lindgren, I and Bolivar, MPR and Scholl, HJ and Zuiderwijk, A},
Title = {Generating Value from Government Data Using AI: An Exploratory Study},
Booktitle = {ELECTRONIC GOVERNMENT (EGOV 2020)},
Series = {Lecture Notes in Computer Science},
Year = {2020},
Volume = {12219},
Pages = {319-331},
Note = {19th IFIP WG 8.5 International Conference on Electronic Government
   (EGOV), ELECTR NETWORK, AUG 31-SEP 02, 2020},
Organization = {IFIP WG 8 5},
Abstract = {Open government data initiatives have gained popularity around the
   world. Artificial Intelligence (AI) has the potential to make better use
   of data. Combining the OGD and AI is crucial to generate more value from
   data. In this paper we investigate what kind of value was generated
   through AI and how. A context-input-process-output/outcome (CIPO)
   framework is developed to describe and compare three cases. The overview
   of cases shows the huge potential of AI, but it also suggests that AI is
   hardly used by the public to create value from open data. The objectives
   of the three cases are efficiency, innovation and crime prevention,
   whereas common open government objectives like transparency,
   accountability and participation are given less attention. By using AI,
   the risks of data privacy and arriving at biased or wrong conclusions
   become more prominent. With the rise of data collection from Internet of
   Things, complying with the 5-stars of Berners-Lee becomes more
   important. We recommend policy makers to stimulate AI projects
   contributing to the open government goals and ensure that open data
   meets the 5-star requirements.},
