@inproceedings{ WOS:000426895800145,
Author = {Costantino, Gianpiero and La Marra, Antonio and Martinelli, Fabio and
   Saracino, Andrea and Sheikhalishahi, Mina},
Book-Group-Author = {IEEE},
Title = {Privacy-Preserving Text Mining as a Service},
Booktitle = {2017 IEEE SYMPOSIUM ON COMPUTERS AND COMMUNICATIONS (ISCC)},
Series = {IEEE Symposium on Computers and Communications ISCC},
Year = {2017},
Pages = {890-897},
Note = {IEEE Symposium on Computers and Communications (ISCC), Heraklion,
   GREECE, JUL 03-07, 2017},
Abstract = {Text mining is the process to automatically infer relevant information
   from semantically related text documents. This technique, which has
   applications from business intelligence to homeland security, terrorism
   and crime fight, might bring noticeable privacy issues when analyzed
   documents contain privacy sensitive information. In this paper, we
   propose a framework for privacy-preserving text analysis, which exploits
   Homomorphic Encryption, to analyze text documents in a privacy
   preserving manner. The proposed framework is designed to ensure that
   there is no disclosure of privacy sensitive information contained in the
   document to any party, including the analysis engine itself.
   Furthermore, we present two use cases of analysis based on bag-of-words
   classification, where the proposed framework manages to obtain good
   classification results without information disclosure. In particular the
   two different settings that are considered are: tweet analysis for
   detection of terrorist Twitter accounts, and out-box email analysis for
   detection of bot infected devices. Accuracy results with different
   classifiers, performances and a security analysis of our approach are
   presented and discussed.},
