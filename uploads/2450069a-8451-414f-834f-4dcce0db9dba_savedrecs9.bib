Title = {Benchmark Analysis of YOLOv8 for Edge AI Video-Surveillance Applications},
Booktitle = {2024 20TH IEEE/ASME INTERNATIONAL CONFERENCE ON MECHATRONIC AND EMBEDDED
   SYSTEMS AND APPLICATIONS, MESA 2024},
Series = {IEEE ASME International Conference on Mechtronic and Embedded Systems
   and Applications MESA},
