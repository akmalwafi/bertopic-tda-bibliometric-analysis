@inproceedings{ WOS:000530212403076,
Author = {Smith, Julie M.},
Editor = {Chova, LG and Martinez, AL and Torres, IC},
Title = {COMPUTATIONAL THINKING WITHOUT ALGORITHMIC BIAS},
