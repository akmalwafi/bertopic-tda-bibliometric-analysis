@inproceedings{ WOS:001322498600016,
Author = {Ghosh, Sharmistha and Saha, Soumyabrata and DasGupta, Suparna and Nath,
   Sudarshan},
Editor = {Saeed, K and Dvorsky, J},
Title = {Machine Learning Based Approach for Crime Analysis in India with an
   Emphasis on Women Safety},
Booktitle = {COMPUTER INFORMATION SYSTEMS AND INDUSTRIAL MANAGEMENT, CISIM 2024},
