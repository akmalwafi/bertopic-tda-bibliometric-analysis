@inproceedings{ WOS:001209046800032,
Author = {Rai, Abhay Kumar and Yadav, Rahul Kumar and Tripathi, Shashi Prakash and
   Singh, Pawan and Sharma, Apurva},
Editor = {Choi, BJ and Singh, D and Tiwary, US and Chung, WY},
Title = {A Novel Similarity-Based Method for Link Prediction in Complex Networks},
Booktitle = {INTELLIGENT HUMAN COMPUTER INTERACTION, IHCI 2023, PT II},
Series = {Lecture Notes in Computer Science},
Year = {2024},
Volume = {14532},
Pages = {309-318},
Note = {15th International Conference on Intelligent Human-Computer Interaction
   (IHCI), Daegu, SOUTH KOREA, NOV 08-10, 2023},
Abstract = {yIn complex systems with interactive elements, link prediction plays an
   important role. It forecasts future or missing associations among
   entities of a complex system using the current network information.
   Predicting future or missing links has a wide variety of application
   areas in several domains like social, criminal, biological, and academic
   networks. This paper presents a novel method for finding missing or
   future links that uses the concepts of proximity between the vertices of
   a network and the number of associations of the common neighbors. We
   test the performance of our method on four real networks of varying
   sizes. We tested it against six state-of-the-art similarity-based
   algorithmss. The outcomes of the experimental evaluation demonstrate
   that the proposed strategy outperforms others. It remarkably improves
   the prediction accuracy in considerable computing time.},
Publisher = {SPRINGER INTERNATIONAL PUBLISHING AG},
Address = {GEWERBESTRASSE 11, CHAM, CH-6330, SWITZERLAND},
