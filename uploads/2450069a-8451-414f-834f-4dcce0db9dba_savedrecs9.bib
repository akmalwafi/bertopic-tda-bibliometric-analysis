@inproceedings{ WOS:001196170500071,
Author = {Day, Min-Yuh},
Editor = {Coscia, M and Cuzzocrea, A and Shu, K},
Title = {Artificial Intelligence for Knowledge Graphs of Cryptocurrency
   Anti-money Laundering in Fintech},
Booktitle = {PROCEEDINGS OF THE 2021 IEEE/ACM INTERNATIONAL CONFERENCE ON ADVANCES IN
   SOCIAL NETWORKS ANALYSIS AND MINING, ASONAM 2021},
