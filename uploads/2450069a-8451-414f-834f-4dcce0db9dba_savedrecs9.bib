@inproceedings{ WOS:000782422800023,
Author = {Chugh, Neha},
Editor = {Caron, B and Schmitt, KA and Pearl, Z and Dara, R and Love, HA},
Title = {Risk assessment tools on trial: Lessons learned for ``Ethical AI{''} in
   the criminal justice system},
Booktitle = {2021 IEEE INTERNATIONAL SYMPOSIUM ON TECHNOLOGY AND SOCIETY (ISTAS21):
   TECHNOLOGICAL STEWARDSHIP \& RESPONSIBLE INNOVATION},
Series = {IEEE International Symposium on Technology and Society},
Year = {2021},
Note = {IEEE International Symposium on Technology and Society (ISTAS) -
   Technological Stewardship and Responsible Innovation, Univ Waterloo,
   Ontario, CANADA, OCT 28-31, 2021},
Organization = {Univ Guelph; IEEE Soc Social Implicat Technol},
Abstract = {In 2018, the Supreme Court decision of Ewert v Canada confirmed that
   risk assessment tools such as the psychopathy checklists used by
   Correctional Services of Canada (CSC), failed to account for cultural
   heritage of the offender, specifically Indigeneity and the impact of
   colonialism on Canada's Aboriginal communities. A further review of
   Canadian case-law post-Ewert reveals that Canadian courts continue their
   reliance on risk assessment tools despite the critiques from the legal
   community and from the Supreme Court of Canada. This paper reviews
   lessons learned from the Canadian experience of Ewert's challenge of
   risk assessment tools and to highlight ethical concerns that are being
   considered in the implementation of artificial intelligence in the
   criminal justice system.},
