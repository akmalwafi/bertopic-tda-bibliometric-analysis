@inproceedings{ WOS:000259178400054,
Author = {Ozgul, Fatih and Aksoy, Hakan and Bowerman, Chris},
Editor = {Banissi, E and Stuart, L and Jern, M and Andrienko, G and Marchese, FT and Memon, N and Alhajj, R and Wyeld, TG and Burkhard, RA and Grinstein, G and Groth, D and Ursyn, A and Maple, C and Faiola, A and Craft, B},
Title = {Theft gang discovery using co-offending knowledge and SNA},
Booktitle = {PROCEEDINGS OF THE 12TH INTERNATIONAL INFORMATION VISUALISATION},
Series = {IEEE International Conference on Information Visualization},
Year = {2008},
Pages = {347+},
Note = {12th International Conference Information Visualisation 2008, London,
   ENGLAND, JUL 09-11, 2008},
Organization = {CPS; IEEE Comp Soc},
Abstract = {A link mining study on a theft network is done in cooperation with Bursa
   Police Department in Turkey on more than 100.000 crimes and 6.000
   persons. Group Detection Model (GDM) is based on co-occurrences of
   offenders in police arrest records for generating possible theft
   networks. Out of thousands of groups detected, only 63 ad-hoc theft
   groups are selected and introduced to the police experts. To evaluate
   these findings, one theft network is focused, a preliminary judge
   decision is obtained for phone tapping and group members phone
   conversations are eavesdropped for ten weeks. After verification of
   evidences, Operation Cash is launched. The police arrested 17 people,
   recovered worth \$200.000 of stolen goods, and cash worth \$180.000.
   Conviction and evidence showed that ruling members in offender networks
   can be detected using GDM. GDM uses a graph generative model and Social
   Network Analysis (SNA) for link mining in crime data.},
Publisher = {IEEE COMPUTER SOC},
Address = {10662 LOS VAQUEROS CIRCLE, PO BOX 3014, LOS ALAMITOS, CA 90720-1264 USA},
