@article{ WOS:001509684800001,
Author = {Omotoso, Sharon Adetutu and Opesade, Adeola Omobola},
Title = {Sexuality as a medium for political communication in Nigeria's EndSARS
   protest},
Journal = {FEMINIST MEDIA STUDIES},
Year = {2025},
Volume = {25},
Number = {6, SI},
Pages = {1454-1479},
Month = {AUG 18},
Abstract = {The October 2020 EndSARS protest spotlighted social media dimensions and
   unfolding impacts to protest culture in Nigeria. Of specific interest to
   this study is how words depicting sexuality during protests mediate
   between political actors and processes, ultimately morphing into
   political communication. This study adopts a mixed critical content
   analysis research method. To highlight embodied mediatization as
   political communication, we engage critical qualitative analysis of the
   tweets that contained the selected keywords such as ``breast,{''}
   ``buttock,{''} ``hair,{''} ``rape,{''} ``beat{''} during the EndSARS
   protest. These keywords thematized under sexual identities and violence
   were drawn through the review of extant literature and engaged to
   formulate the search term used in retrieval of the counts and contents
   of tweets posted on twitter (Now X) between August and December 2020.
   Quantitative analyses in the form of descriptive and textual data mining
   analyses were carried out on the collected data using Microsoft Excel
   2013 and Orange Data Mining Tool, respectively. Findings reveal an
   alignment of the sensual, the intimate and the sexualized, demonstrating
   how the body, which is often targeted as a site of policing can also be
   redeployed to challenge such oppressions and transgress the dichotomy
   between the public and the private.},
