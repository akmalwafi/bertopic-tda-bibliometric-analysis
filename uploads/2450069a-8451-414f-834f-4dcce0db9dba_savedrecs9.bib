@inproceedings{ WOS:000184834200018,
Author = {Xu, J and Chen, HC},
Editor = {Chen, H and Zeng, DD and Schroeder, J and Miranda, R and Demchak, C and Madhusudan, T},
Title = {Untangling criminal networks: A case study},
Booktitle = {INTELLIGENCE AND SECURITY INFORMATICS, PROCEEDINGS},
Series = {Lecture Notes in Computer Science},
