   Qamar, Attia, Natl Coll Business Adm \& Econ, Rahim Yar Khan, Pakistan.
   Karim, Ahmad, Bahauddin Zakariya Univ, Dept Informat Technol, Multan, Pakistan.
   Chang, Victor, Xian Jiaotong Liverpool Univ, Int Business Sch Suzhou, Xian, Shaanxi, Peoples R China.},
DOI = {10.1016/j.future.2019.03.007},
ISSN = {0167-739X},
EISSN = {1872-7115},
Keywords = {Mobile malware; Malware; Mobile malware detection; Android malware;
   Machine learning; Forensics},
