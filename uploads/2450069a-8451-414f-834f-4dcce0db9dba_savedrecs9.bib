@article{ WOS:000364485400010,
Author = {Huang, Wenliang and Chen, Zhen and Dong, Wenyu and Li, Hang and Cao, Bin
   and Cao, Junwei},
Title = {Mobile Internet Big Data Platform in China Unicom},
