@inproceedings{ WOS:000387961100034,
Author = {Teing, Yee-Yang and Dehghantanha, Ali and Choo, Kim-Kwang Raymond and
   Muda, Zaiton and Abdullah, Mohd Taufik and Chai, Wee-Chiat},
Editor = {Wang, G and Ray, I and Calero, JMA and Thampi, SM},
Title = {A Closer Look at Syncany Windows and Ubuntu Clients' Residual Artefacts},
