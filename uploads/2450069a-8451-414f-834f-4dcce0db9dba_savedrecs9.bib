@inproceedings{ WOS:000337298700034,
Author = {Rygl, Jan and Horak, Ales},
Editor = {Sojka, P and Horak, A and Kopecek, I and Pala, K},
Title = {Authorship Attribution: Comparison of Single-Layer and Double-Layer
   Machine Learning},
