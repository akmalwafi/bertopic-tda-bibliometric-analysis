@article{ WOS:000799548500001,
Author = {Bergman, Tommy and Kloeden, Martin and Dressler, Jan and Labudde, Dirk},
Title = {Automatic Classification of Bloodstains with Deep Learning Methods},
Journal = {KUNSTLICHE INTELLIGENZ},
Year = {2022},
Volume = {36},
Number = {2, SI},
Pages = {135-141},
Month = {SEP},
Abstract = {The classification of detected bloodstains into predetermined categories
   is a crucial component of the so-called bloodstain pattern analysis. As
   in other forensic disciplines, deep learning methods may help to reduce
   human subjectivity within this process, may increase the classification
   accuracy, shorten the calculation time and thus, enable high-throughput
   analysis. In this work, an approach is presented in which a
   convolutional neural network (Inception v3) was trained from 965 drip
   stains (passive origin) and 1595 blood spatters (active origin). The
   trained CNN was evaluated with a test data set consisting of 366 images
   of drip stains and blood spatters. The success rate was 99.73\% which
   suggests that neural networks could also be used to automatically
   classify other classes of bloodstain patterns to speed up the
   investigation process in the future.},
