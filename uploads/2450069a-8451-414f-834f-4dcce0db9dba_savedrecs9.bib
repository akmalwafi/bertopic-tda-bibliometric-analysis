@inproceedings{ WOS:001456038300010,
Author = {Diaz, Jose Edgar Garcia and Romero, Wilder Suarez and Rodriguez, Ciro
   and de la Cruz, Jorge Puga and Yalan, Victor Manuel Cabrejos and
   Temoche, Isis Ayme Moran and Carranza, Jhon Charlie Martinez},
Editor = {Guerrero, G and SanMartin, J and Meneses, E and Hernandez, CJB and Osthoff, C and Diaz, JMM},
Title = {Web System for Recognizing Actions of Physical Violence in Urban Spaces
   Using CNN with Transfer Learning},
Booktitle = {HIGH PERFORMANCE COMPUTING, CARLA 2024},
Series = {Communications in Computer and Information Science},
