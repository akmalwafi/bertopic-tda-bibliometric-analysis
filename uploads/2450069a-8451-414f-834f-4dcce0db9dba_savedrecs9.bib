@inproceedings{ WOS:000655510300011,
Author = {Kuang, Xiaohui and Zhang, Ming and Li, Hu and Zhao, Gang and Cao,
   Huayang and Wu, Zhendong and Wang, Xianmin},
Editor = {Vaidya, J and Zhang, X and Li, J},
Title = {DeepWAF: Detecting Web Attacks Based on CNN and LSTM Models},
Booktitle = {CYBERSPACE SAFETY AND SECURITY, PT II},
Series = {Lecture Notes in Computer Science},
Year = {2019},
Volume = {11983},
Pages = {121-136},
Note = {11th International Symposium on Cyberspace Safety and Security (CSS),
   Guangzhou, PEOPLES R CHINA, DEC 01-03, 2019},
Organization = {Guangzhou Univ},
Abstract = {The increasing popularity of web applications makes the web a main venue
   for attackers engaging in a myriad of cybercrimes. With large quantities
   of information processing and sharing by web applications, the situation
   for web attack detection or prevention becomes increasingly severe. We
   present a prototype implementation called DeepWAF to detect web attacks
   based on deep learning techniques. We systematically discuss the
   approach for effective use of the currently popular CNN and LSTM models,
   and their combinational models CNN-LSTM and LSTM-CNN. The experimental
   results on the dataset of HTTP DATASET CSIC 2010 demonstrate that our
   proposed four types of detection models all achieve satisfactory
   results, with the detection rate of approximately 95\% and the false
   alarm rate of approximately 2\%. We also carried out case studies to
   analyze the causes of false negatives and false positives, which can be
   used for further improvements. Our work further illustrates that machine
   learning has a promising application prospect in the field of web attack
   detection.},
Publisher = {SPRINGER INTERNATIONAL PUBLISHING AG},
Address = {GEWERBESTRASSE 11, CHAM, CH-6330, SWITZERLAND},
Type = {Proceedings Paper},
