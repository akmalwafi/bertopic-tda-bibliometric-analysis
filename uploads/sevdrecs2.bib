@inproceedings{ WOS:000346239200003,
Author = {van Banerveld, Maarten and Nhien-An Le-Khac and Kechadi, M-Tahar},
Editor = {Dang, TK and Wagner, R and Neuhold, E and Takizawa, M and Kung, J and Thoai, N},
Title = {Performance Evaluation of a Natural Language Processing Approach Applied
   in White Collar Crime Investigation},
Booktitle = {FUTURE DATA AND SECURITY ENGINEERING, FDSE 2014},
Series = {Lecture Notes in Computer Science},
Year = {2014},
Volume = {8860},
