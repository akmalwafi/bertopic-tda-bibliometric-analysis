Pages = {441-464},
Month = {AUG},
Abstract = {`AI \& Law' research has been around since the 1970s, even though with
   shifting emphasis. This is an overview of the contributions of digital
   technologies, both artificial intelligence and non-AI smart tools, to
   both the legal professions and the police. For example, we briefly
   consider text mining and case-automated summarization, tools supporting
   argumentation, tools concerning sentencing based on the technique of
   case-based reasoning, the role of abductive reasoning, research into
   applying AI to legal evidence, tools for fighting crime and tools for
   identification.},
