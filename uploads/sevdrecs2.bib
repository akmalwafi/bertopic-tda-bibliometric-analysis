@inproceedings{ WOS:001103175600031,
Author = {Lettieri, Nicola and Guarino, Alfonso and Malandrino, Delfina and
   Zaccagnino, Rocco and Del Piano, Salvatore},
Editor = {Banissi, E and Siirtola, H and Ursyn, A and Pires, JM and Datia, N and Nazemi, K and Kovalerchuk, B and Andonie, R and Nakayama, M and Temperini, M and Sciarrone, F and Nguyen, QV and Mabakane, MS and Rusu, A and Cvek, U and Trutschl, M and Mueller, H and Francese, R and Bouali, F and Venturini, G},
Title = {Giving Shape to Words: Visual Knowledge Discovery for Textual Contents
   in Legal Scenarios},
Booktitle = {2023 27TH INTERNATIONAL CONFERENCE INFORMATION VISUALISATION, IV},
Series = {IEEE International Conference on Information Visualization},
Year = {2023},
Pages = {188-193},
Note = {27th International Conference on Information Visualisation (IV) / 19th
   International Conference Computer Graphics, Imaging and Visualization
   (CGiV), Tampere, FINLAND, JUL 25-28, 2023},
Abstract = {Visual Knowledge Discovery (VKD), the emerging research field exploring
   the integration between Artificial Intelligence and Visual Analytics is
   impacting a growing number of contexts. This paper dwells on the
   potential intersections between the VKD perspective and the legal world,
   a scenario for many reasons drawn by the idea of combining empirical
   insights offered by computation with intuitive, visually-enhanced forms
   of data mining. We will focus on criminal justice, taking the cue from
   an ongoing experimental research project that investigates novel
   applications of computational social science methods - complex network
   analysis - to analyze criminal organizations for both scientific and
   investigative purposes. The work will describe the VKD solutions devised
   to allow public prosecutors to visually browse the content of phone
   calls and environmental tapping gathered during preliminary inquiries.
   We will discuss how given visualizations - graph-based visualizations in
   the first place - can enhance text mining techniques helping to capture
   in-a-glance communication flows, discussions' topics and both structural
   and functional features of criminal networks at hand.},
