@article{ WOS:000904724800001,
Author = {Hall, Stuart W. and Sakzad, Amin and Choo, Kim-Kwang Raymond},
Title = {Explainable artificial intelligence for digital forensics},
Journal = {WILEY INTERDISCIPLINARY REVIEWS: FORENSIC SCIENCE},
Year = {2022},
Volume = {4},
Number = {2},
Month = {MAR-APR},
Abstract = {EXplainable artificial intelligence (XAI) is an emerging research area
   relating to the creation of machine learning algorithms from which
   explanations for outputs are provided. In many fields, such as law
   enforcement, it is necessary that decisions made by and with the
   assistance of artificial intelligence (AI)-based tools can be justified
   and explained to a human. We seek to explore the potential of XAI to
   further enhance triage and analysis of digital forensic evidence, using
   examples of the current state of the art as a starting point. This
   opinion letter will discuss both practical and novel ideas as well as
   controversial points for leveraging XAI to improve the efficacy of
   digital forensic (DF) analysis and extract forensically sound pieces of
   evidence (also known as artifacts) that could be used to assist
   investigations and potentially in a court of law.
   This article is categorized under: Digital and Multimedia Science >
   Artificial Intelligence Digital and Multimedia Science > Cybercrime
   Investigation},
