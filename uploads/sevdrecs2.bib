@article{ WOS:000439135500005,
Author = {Degeling, Martin and Berendt, Bettina},
Title = {What is wrong about Robocops as consultants? A technology-centric
   critique of predictive policing},
Journal = {AI \& SOCIETY},
Year = {2018},
Volume = {33},
Number = {3, SI},
Pages = {347-356},
Month = {AUG},
Abstract = {Fighting crime has historically been a field that drives technological
   innovation, and it can serve as an example of different governance
   styles in societies. Predictive policing is one of the recent
   innovations that covers technical trends such as machine learning,
   preventive crime fighting strategies, and actual policing in cities.
   However, it seems that a combination of exaggerated hopes produced by
   technology evangelists, media hype, and ignorance of the actual problems
   of the technology may have (over-)boosted sales of software that
   supports policing by predicting offenders and crime areas. In this paper
   we analyse currently used predictive policing software packages with
   respect to common problems of data mining, and describe challenges that
   arise in the context of their socio-technical application.},
