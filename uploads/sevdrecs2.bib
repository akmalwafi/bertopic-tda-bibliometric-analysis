@inproceedings{ WOS:000558710000016,
Author = {Averkin, Alexey N. and Bazarkina, Darya Yu and Pantserev, Konstantin A.
   and Pashentsev, Evgeny N.},
Editor = {Novak, V and Marik, V and Stepnicka, M and Navara, M and Hurtik, P},
Title = {Artificial Intelligence in the Context of Psychological Security:
   Theoretical and Practical Implications},
Booktitle = {PROCEEDINGS OF THE 11TH CONFERENCE OF THE EUROPEAN SOCIETY FOR FUZZY
   LOGIC AND TECHNOLOGY (EUSFLAT 2019)},
