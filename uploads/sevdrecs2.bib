@article{ WOS:000686127700014,
Author = {Silva, Iaslan and do Valle, Joao Marcos and Souza, Gabriel and Budke,
   Jaine and Araujo, Daniel and Carvalho, Bruno and Cacho, Nelio and Sales,
   Henrique and Lopes, Frederico and Silva Junior, Rivaldo},
Title = {Using micro-services and artificial intelligence to analyze images in
   criminal evidences},
Journal = {FORENSIC SCIENCE INTERNATIONAL-DIGITAL INVESTIGATION},
Year = {2021},
Volume = {37},
