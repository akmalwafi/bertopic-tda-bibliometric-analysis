@article{ WOS:000773954200003,
Author = {Dremliuga, I, Roman},
Title = {PREDICTIVE POLICING ALGORITHMS: ISSUE OF ACCOUNTABILITY},
Journal = {JOURNAL OF LAW AND POLITICAL SCIENCES},
Year = {2022},
Volume = {33},
Number = {2},
Pages = {50-64},
Month = {MAR},
Abstract = {Advances in crime prediction by the systems of artificial intelligence
   (AI) look very promising. The potential uses of machine learning and AI
   in the public security domain and prediction of crimes can help decrease
   the costs, increase efficiency, and address the problem of occurrence of
   irreversible consequences of crime commitment. However, this positive
   application of technologies may also have possible negative effects that
   have different manifestations. In fact, there are multiple examples of
   the situations when the use of predictive policing software provokes
   legal and ethical disputes.
   This paper focuses on the problem of opacity of predictive policing
   systems, because it is the main challenge to accountability of such
   systems. Because ``opacity{''} is an ambiguous and often enigmatic term,
   scholars discuss opacity as prerequisite for accountability. They
   identify several types of opacity of predictive policing systems, which
   require public attention. In this article, a reader may find references
   to the existing approaches to the problem of opacity of such systems in
   the context of their accountability. Authors suggest that some legal
   measures could be very useful in terms of decreasing the opacity of
   predictive policing software.},
