@incollection{ WOS:000448511700018,
Author = {Brayne, Sarah},
Editor = {MacCoun, RJ},
Title = {The Criminal Law and Law Enforcement Implications of Big Data},
Booktitle = {ANNUAL REVIEW OF LAW AND SOCIAL SCIENCE, VOL 14},
Series = {Annual Review of Law and Social Science},
Year = {2018},
Volume = {14},
Pages = {293-308},
Abstract = {Law enforcement agencies increasingly use big data analytics in their
   daily operations. This review outlines how police departments leverage
   big data and new surveillant technologies in patrol and investigations.
   It distinguishes between directed surveillance-which involves the
   surveillance of individuals and places under suspicion- and dragnet
   surveillance-which involves suspicionless, unparticularized data
   collection. Law enforcement's adoption of big data analytics far
   outpaces legal responses to the new surveillant landscape. Therefore,
   this review highlights open legal questions about data collection,
   suspicion requirements, and police discretion. It concludes by offering
   suggestions for future directions for researchers and practitioners.},
