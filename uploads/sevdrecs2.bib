@article{ WOS:000421313700008,
Author = {Horjam, Ana-Marija and Krnjasic, Sasa},
Title = {The Social Network Analysis of Organized Criminal Groups in the Republic
   of Croatia},
Journal = {POLICIJA I SIGURNOST-POLICE AND SECURITY},
Year = {2012},
Volume = {21},
Number = {3},
Pages = {610-634},
Abstract = {This paper provides an overview of the methodology of the Criminal
   Police of the MoI of the Republic of Croatia in the definition of
   organized criminal groups with an explanation of mandatory and optional
   parameters that define each particular group. For the easier monitoring
   of the level of organization of the group the characteristics of
   organized criminal groups operating in the Republic of Croatia at the
   national level are explained by attributes based on the Sleipnir model.
   Organized criminal groups are the responsibility of the National Police
   Office for Suppression of Corruption and Organized Crime, and successful
   concept of conducting is based on the European model of intelligence led
   policing with the necessary inter-agency cooperation.},
