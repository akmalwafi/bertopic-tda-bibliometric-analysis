@inproceedings{ WOS:000783799800082,
Author = {Parolin, Erick Skorupa and Khan, Latifur and Osorio, Javier and Brandt,
   Patrick T. and D'Orazio, Vito and Holmes, Jennifer},
Book-Group-Author = {IEEE},
Title = {3M-Transformers for Event Coding on Organized Crime Domain},
Booktitle = {2021 IEEE 8TH INTERNATIONAL CONFERENCE ON DATA SCIENCE AND ADVANCED
   ANALYTICS (DSAA)},
Year = {2021},
Note = {8th IEEE International Conference on Data Science and Advanced Analytics
   (DSAA), ELECTR NETWORK, OCT 06-09, 2021},
Organization = {IEEE; ACM; Amer Stat Assoc},
Abstract = {Political scientists and security agencies increasingly rely on
   computerized event data generation to track conflict processes and
   violence around the world. However, most of these approaches rely on
   pattern-matching techniques constrained by large dictionaries that are
   too costly to develop, update, or expand to emerging domains or
   additional languages. In this paper, we provide an effective solution to
   those challenges. Here we develop the 3M-Transformers (Multilingual,
   Multi-label, Multi-task) approach for Event Coding from domain specific
   multilingual corpora, dispensing external large repositories for such
   task, and expanding the substantive focus of analysis to organized
   crime, an emerging concern for security research. Our results indicate
   that our 3M-Transformers configurations outperform state-of-the-art
   usual Transformers models (BERT and XLM-RoBERTa) for coding events on
   actors, actions and locations in English, Spanish, and Portuguese
   languages.},
