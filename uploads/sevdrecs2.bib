@inproceedings{ WOS:000680655200023,
Author = {Kurshan, Eren and Shen, Hongda and Yu, Haojie},
Book-Group-Author = {IEEE},
Title = {Financial Crime \& Fraud Detection Using Graph Computing: Application
   Considerations \& Outlook},
Booktitle = {2020 SECOND INTERNATIONAL CONFERENCE ON TRANSDISCIPLINARY AI (TRANSAI
   2020)},
Year = {2020},
Pages = {125-130},
Note = {2nd IEEE International Conference on Transdisciplinary Artificial
   Intelligence (TransAI), ELECTR NETWORK, SEP 21-23, 2020},
Organization = {IEEE Comp Soc},
Abstract = {In recent years, the unprecedented growth in digital payments fueled
   consequential changes in fraud and financial crimes. In this new
   landscape, traditional fraud detection approaches such as rule-based
   engines have largely become ineffective. AI and machine learning
   solutions using graph computing principles have gained significant
   interest. Graph neural networks and emerging adaptive solutions provide
   compelling opportunities for the future of fraud and financial crime
   detection. However, implementing the graph-based solutions in financial
   transaction processing systems has brought numerous obstacles and
   application considerations to light. In this paper, we overview the
   latest trends in the financial crimes landscape and discuss the
   implementation difficulties current and emerging graph solutions face.
   We argue that the application demands and implementation challenges
   provide key insights in developing effective solutions.},
