Title = {Recognition of Antisocial Behavior in Online Discussions},
Booktitle = {INFORMATION SYSTEMS ARCHITECTURE AND TECHNOLOGY, ISAT 2019, PT II},
Series = {Advances in Intelligent Systems and Computing},
Year = {2020},
Volume = {1051},
