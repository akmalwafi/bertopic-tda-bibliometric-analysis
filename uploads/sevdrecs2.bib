@inproceedings{ WOS:000679075800002,
Author = {Kawamura, Takahiro and Egami, Shusaku and Tamura, Koutarou and Hokazono,
   Yasunori and Ugai, Takanori and Koyanagi, Yusuke and Nishino, Fumihito
   and Okajima, Seiji and Murakami, Katsuhiko and Takamatsu, Kunihiko and
   Sugiura, Aoi and Shiramatsu, Shun and Zhang, Xiangyu and Kozaki, Kouji},
Editor = {Wang, X and Lisi, FA and Xiao, G and Botoeva, E},
Title = {Report on the First Knowledge Graph Reasoning Challenge 2018 Toward the
   eXplainable AI System},
