@inproceedings{ WOS:001430735300055,
Author = {Jain, Bhanu and Elmasri, Ramez A. and Huber, Manfred and Fegaras,
   Leonidas},
Book-Group-Author = {ACM},
Title = {Reducing Race-Based Bias and Increasing Recidivism Prediction Accuracy
   by using Past Criminal History Details},
Booktitle = {13TH ACM INTERNATIONAL CONFERENCE ON PERVASIVE TECHNOLOGIES RELATED TO
   ASSISTIVE ENVIRONMENTS, PETRA 2020},
Year = {2020},
Pages = {404-411},
