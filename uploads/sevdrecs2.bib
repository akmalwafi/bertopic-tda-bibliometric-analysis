@article{ WOS:000214481200008,
Author = {Cockbain, Eleanor and Brayley, Helen and Laycock, Gloria},
Title = {Exploring Internal Child Sex Trafficking Networks Using Social Network
   Analysis},
Journal = {POLICING-A JOURNAL OF POLICY AND PRACTICE},
Year = {2011},
Volume = {5},
Number = {2},
Pages = {144-157},
Month = {JUN},
Abstract = {This article explores the potential of social network analysis as a tool
   in supporting the investigation of internal child sex trafficking in the
   UK. In doing so, it uses only data, software, and training already
   available to UK police. Data from two major operations are analysed
   using in-built centrality metrics, designed to measure a network's
   overarching structural properties and identify particularly powerful
   individuals. This work addresses victim networks alongside offender
   networks. The insights generated by SNA inform ideas for targeted
   interventions based on the principles of Situational Crime Prevention.
   These harm-reduction initiatives go beyond traditional enforcement to
   cover prevention, disruption, prosecution, etc. This article ends by
   discussing how SNA can be applied and further developed by frontline
   policing, strategic policing, prosecution, and policy and research.},
