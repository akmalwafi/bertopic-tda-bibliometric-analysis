Title = {Directions of the Formation of the Model of Sustainability of the
   Aerospace Complex of Ukraine},
Booktitle = {INTEGRATED COMPUTER TECHNOLOGIES IN MECHANICAL ENGINEERING-2023, VOL 2,
   ICTM 2023},
