@inproceedings{ WOS:000475685900005,
Author = {Hu, Yong},
Book-Group-Author = {IEEE},
Title = {Intelligent Procuratorate Depends on Big Data Investigation Technology},
Booktitle = {2019 IEEE 4TH INTERNATIONAL CONFERENCE ON CLOUD COMPUTING AND BIG DATA
   ANALYSIS (ICCCBDA)},
Year = {2019},
Pages = {20-23},
Note = {4th IEEE International Conference on Cloud Computing and Big Data
   Analysis (ICCCBDA), Chengdu, PEOPLES R CHINA, APR 12-15, 2019},
Organization = {IEEE; Sichuan Inst Elect; Xihua Univ},
Abstract = {With the change of the times and the advent of the era of wisdom, it is
   urgent for procuratorial organs to apply big data investigation
   technology to solve difficult problems in their work. Big data can
   discover deep-seated rules and connections of data through valuable data
   processing. Big data investigation is different from the traditional
   reconstructing criminal process by consequence traceability. It is a
   process of mining effective clues on the basis of analyzing and dealing
   with the links between various clues. It is an effective investigation
   model based on a large number of data, which can make certain prediction
   of the direction of investigation. This is a change for ex post
   investigation and passive investigation in the past. It will also change
   the single-thread investigation mode to multi-clue cooperative
   investigation, which will surely lead the future development direction
   of investigation.},
