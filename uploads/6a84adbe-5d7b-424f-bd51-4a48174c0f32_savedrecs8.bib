@inproceedings{ WOS:001327167900135,
Author = {Xi, Jian and Jaeckel, Lukas and Spranger, Michael and Siegel, Melanie
   and Labudde, Dirk},
Book-Group-Author = {IEEE},
Title = {Forensic Communication Analysis: Challenges and Opportunities},
Booktitle = {2024 IEEE INTERNATIONAL CONFERENCE ON CYBER SECURITY AND RESILIENCE, CSR},
Year = {2024},
Pages = {878-883},
Note = {4th IEEE Annual International Conference on Cyber Security and
   Resilience (IEEE CSR), London, ENGLAND, SEP 02-04, 2024},
Organization = {IEEE; IEEE Syst, Man, \& Cybernet Soc; Logos Res \& Innovat; IEEE United
   Kingdom \& Ireland Sect; IEEE SMC Tech Comm Homeland Secur; IEEE SMC
   Tech Comm Cyber Humanities; MITRE; Univ Portsmouth; Univ Peloponnese;
   Univ Roma Tre, Digital Humanities Lab; Summit TEC Grp Ltd; IEEE Transact
   Emerging Top Comp},
Abstract = {Recently, mobile forensics has received considerable attention from
   researchers and practitioners due to its significant role in our
   society. With the advent of mobile devices and the breakthroughs in new
   communication technologies, various devices have risen to prominence in
   daily communication, where the intermingling of text, images, videos,
   audio, and calls occurs across different communication channels,
   resulting in massive data dumps. While this heterogeneity enriches the
   communication experience, it challenges Law Enforcement Agencies (LEAs)
   and Digital Forensic Practitioners (DFPs) to inspect and find evidence
   in the communication data dumps automatically. However, despite the rich
   diversity of existing tools and methodologies in analyzing mobile
   forensic data, there are several problems that these existing tools have
   in common, which are related to data analysis in evidence collection.
   Therefore, this study discusses the current forensic solutions and new
   approaches from a practical point of view. Based on this, and
   considering the investigative work experience with LEAs in Germany, we
   share our expectations and knowledge about tackling big mobile forensic
   data. Instead of providing a step-by-step guide for conducting a
   specific forensic investigation, this study aims to inform the reader
   about the technologies and tools used for data analysis in mobile
   forensics, along with new research directions.},
Publisher = {IEEE},
Address = {345 E 47TH ST, NEW YORK, NY 10017 USA},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Xi, J (Corresponding Author), Univ Appl Sci Mittweida, Forens Sci Invest Lab FoSIL, Mittweida, Germany.
   Xi, Jian; Jaeckel, Lukas; Spranger, Michael; Labudde, Dirk, Univ Appl Sci Mittweida, Forens Sci Invest Lab FoSIL, Mittweida, Germany.
   Siegel, Melanie, Univ Appl Sci Darmstadt, Darmstadt, Germany.},
DOI = {10.1109/CSR61664.2024.10679503},
ISBN = {979-8-3503-7536-7},
