@article{ WOS:000545363400001,
Author = {Horten, Barbara and Graeber, Marleen},
Title = {Cybercrime Overview of current and future manifestations},
Journal = {FORENSISCHE PSYCHIATRIE PSYCHOLOGIE KRIMINOLOGIE},
