@inproceedings{ WOS:000945452000038,
Author = {Manish, G. Venkata and Simran and Kumar, Jitendra and Choubey, Dilip
   Kumar},
Editor = {Garg, L and Sisodia, DS and Kesswani, N and Vella, JG and Brigui, I and Xuereb, P and Misra, S and Singh, D},
Title = {Identification of Hotspot of Rape Cases in NCT of Delhi: A Data Science
   Perspective},
