@article{ WOS:001537527400004,
Author = {Nikuradze, N. O. and Mishchenko, E. V. and Marina, E. A.},
Title = {Scientific and practical view on digitalization of the criminal process:
   Russian and international aspects},
Journal = {VESTNIK OF SAINT PETERSBURG UNIVERSITY-LAW-VESTNIK SANKT-PETERBURGSKOGO
   UNIVERSITETA-PRAVO},
Year = {2025},
Volume = {16},
Number = {2},
Pages = {514-530},
Abstract = {Technologies of video conferencing, audio and video recording,
   electronic document management, automated information systems, etc. are
   not new in criminal proceedings. Scientists and practitioners discuss
   more progressive and large-scale changes related to artificial
   intelligence, electronic production, online justice (remote), virtual
   reality, which is expected to arouse interest. The conducted research is
   aimed at identifying promising and problematic aspects of the
   introduction of electronic criminal proceedings technologies, remote
   justice and artificial intelligence into the Russian criminal process
   from the perspective of domestic and foreign scientists and
   practitioners. The methodological basis of the research was the
   dialectical method of cognition, the method of comparative legal
   analysis of legislation and law enforcement practice of using electronic
   production technologies, remote justice and artificial intelligence in
   criminal proceedings of foreign countries; the method of surveying
   practitioners on the subject of prospects, potential threats and ways to
   overcome them, the introduction of the studied technologies into
   domestic criminal proceedings; formal-legal and logical-legal methods
   aimed at formulating the main conclusions and results of the research.
   The conducted research made it possible to determine the directions of
   digital development of domestic criminal proceedings from the
   perspective of scientists and practitioners, to identify potentially
   possible negative consequences of the introduction of electronic
   production technologies, artificial intelligence and online justice and
   to determine possible ways to overcome them. The essence and
   significance of digital development of criminal proceedings are
   revealed.},
