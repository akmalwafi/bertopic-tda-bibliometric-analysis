Title = {Estimating Biological Gender from Panoramic Dental X-Ray Images},
Booktitle = {PROCEEDINGS OF THE 2019 11TH INTERNATIONAL SYMPOSIUM ON IMAGE AND SIGNAL
   PROCESSING AND ANALYSIS (ISPA 2019)},
Series = {International Symposium on Image and Signal Processing and Analysis},
Year = {2019},
