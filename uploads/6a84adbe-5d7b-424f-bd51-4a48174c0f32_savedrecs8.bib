Title = {Next Generation Antivirus Applied to Jar Malware Detection based on
   Runtime Behaviors using Neural Networks},
Booktitle = {PROCEEDINGS OF THE 2019 IEEE 23RD INTERNATIONAL CONFERENCE ON COMPUTER
   SUPPORTED COOPERATIVE WORK IN DESIGN (CSCWD)},
