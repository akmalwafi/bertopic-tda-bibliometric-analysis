@article{ WOS:000582655500001,
Author = {Rhee, Kang Hyeon},
Title = {Composition of Visual Feature Vector Pattern for Deep Learning in Image
   Forensics},
Journal = {IEEE ACCESS},
Year = {2020},
Volume = {8},
Pages = {188970-188980},
Abstract = {In image forensics, to determine whether the image is impurely
   transformed, it extracts and examines the features included in the
   suspicious image. In general, the features extracted for the detection
   of forgery images are based on numerical values, so it is somewhat
   unreasonable to use in the CNN structure for image classication. In this
   paper, the extraction method of a feature vector is using a
   least-squares solution. Treat a suspicious image like a matrix and its
   solution to be coeffcients as the feature vector. Get two solutions from
   two images of the original and its median lter residual (MFR).
   Subsequently, the two features were formed into a visualized pattern and
   then fed into CNN deep learning to classify the various transformed
   images. A new structure of the CNN net layer was also designed by hybrid
   with the inception module and the residual block to classify visualized
   feature vector patterns. The performance of the proposed image forensics
   detection (IFD) scheme was measured with the seven transformed types of
   image: averagetered (window size: 3 x3), gaussianltered (window size: 3X
   3), JPEG compressed (quality factor: \{90, 70\}), medianltered (window
   size: \{3 x 3, 5 x 5\}), and unaltered. The visualized patterns are fed
   into the image input layer of the designed CNN hybrid model. Throughout
   the experiment, the accuracy of median ltering detection was 98\% over.
   Also, the area under the curve (AUC) by sensitivity (TP: true positive
   rate) and 1specicity (FP: false positive rate) results of the proposed
   IFD scheme approached to 1' on the designed CNN hybrid model.
   Experimental results show high efciency and performance to classify the
   various transformed images. Therefore, the grade evaluation of the
   proposed scheme is ``Excellent (A).''},
