Title = {Criminal Network Construction and Analysis from Italian Civil Cases: A
   Case Study},
Booktitle = {COMPLEX NETWORKS \& THEIR APPLICATIONS XIII, COMPLEX NETWORKS 2024-VOL 3},
Series = {Studies in Computational Intelligence},
Year = {2025},
Volume = {1189},
Pages = {181-193},
Note = {13th International Conference on Complex Networks and their
   Applications-COMPLEX NETWORKS-Annual, San Francisco, CA, FEB 16-20, 2024},
Organization = {Institute of Electrical and Electronics Engineers Inc; University of
   Pennsylvania},
Abstract = {Criminal networks are complex systems that exploit social connections
   among their members. Analyzing these networks presents challenges,
   especially concerning data management. Researchers typically use either
   micro or macro approaches for criminal network analysis. The micro
   approach involves examining small criminal groups or organizations using
   judicial documents, intelligence reports, or investigation files.
   Conversely, the macro approach deals with larger networks at regional,
   national, or international levels, utilizing intelligence databases or
   archives. This paper employs institutional databases and open source
   intelligence to generate two networks: a large network from civil cases
   in the Court of a Sicilian city (in the period 2010-2014), and a smaller
   criminal network involved in a fraud case against the Public
   Administration. A preliminary analysis is conducted to identify key
   figures and communities in the criminal network.},
