Volume = {37},
Number = {2},
Pages = {113-122},
Month = {MAR},
Abstract = {The formation of organisational tacit knowledge has been studied in the
   most part using only qualitative explanations such as case studies
   including those on the workings of communities of practice. From this
   perspective, tacit knowledge is submersed and consequently it is
   difficult to quantify. In our community of communities of practice case
   study we use quantitative social network analysis techniques to explore
   the process of tacit knowledge exchange among expert knowledge workers -
   forensic scientists. Conceptually, we search for more structured
   relational mechanisms that shape tacit knowledge flows occurring between
   participant actors in communities of practice, in their day-to-day
   knowledge intensive environments.},
