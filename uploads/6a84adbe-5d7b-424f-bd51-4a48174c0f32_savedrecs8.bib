@article{ WOS:001470348800009,
Author = {Strmecki, Simona and Pejakovic-Dipic, Silvija and Filipovic, Hrvoje},
Title = {AI as the Source of Obtaining Location Data for Law Enforcement
   Authorities in the Republic of Croatia},
Journal = {IPSI BGD TRANSACTIONS ON INTERNET RESEARCH},
Year = {2025},
Volume = {21},
Number = {1, SI},
Pages = {101-106},
Month = {JAN},
Abstract = {The paper problematises the implications of increasingly strong
   intentions to ban technologies with artificial intelligence methods in
   predictive or preventive police activities. If GIS technologies with
   artificial intelligence (AI) methods were exempted from (proactive) use
   or continuously improved ICT solutions intended for law enforcement
   authorities, the question arises of how the right to privacy would equal
   another fundamental right to security (or safety?). In order to
   determine the best possible measure of the proportionality of the
   protection of two fundamental rights- the right to privacy and the right
   to security (or safety?) in the police use of GIS technologies that
   include artificial intelligence methods- research was conducted on the
   voluntary provision of location data in different situations of their
   use for law enforcement activities. After processing the results, the
   voluntary provision of location data was analysed and compared to the
   security context and concerning situations that do not imply an
   increased sense of protection of the right to security. The security
   context was analysed separately with regard to personal safety and
   general security. The results obtained on N = 310 participants showed
   that the majority of them (70.3\%) would never provide their location
   data, regardless of the collection method. If the artificial
   intelligence methods are utilised for data collection, a total of
   16.3\%, of participants would provide their location data for ensuring
   personal safety or general security, while 25,4 \% of participants would
   give a voluntary provision of their location data, for security reasons,
   regardless to the data collection method. The main conclusion of this
   research is that the use of technologies with artificial intelligence
   methods in police work does not affect the respondents'need for better
   protection of their location data.},
Publisher = {IPSI BELGRADE LTD},
