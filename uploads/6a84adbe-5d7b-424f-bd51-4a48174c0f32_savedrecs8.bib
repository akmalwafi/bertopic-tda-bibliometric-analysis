Title = {Design and Modelling of a Machine Learning Based Face Recognition Model
   for Access Control in an Electrical Plant Control Room},
Booktitle = {2025 33RD SOUTHERN AFRICAN UNIVERSITIES POWER ENGINEERING CONFERENCE,
   SAUPEC},
Year = {2025},
Pages = {509-514},
Note = {33rd Southern African Universities Power Engineering
   Conference-SAUPEC-Annual, Pretoria, SOUTH AFRICA, JAN 29-30, 2025},
Organization = {Tshwane University Of Technology},
Abstract = {This paper discusses an enhancement of security measures in South Africa
   through the development of a facial recognition system designed to
   accurately and efficiently identify individuals, thereby aiding law
   enforcement in mitigating crime. The system is optimized to minimize
   errors such as overlapping and underlapping. The real time application
   of this system will facilitate rapid identification and alerting of
   police during criminal incidents, significantly aiding in solving cases.
   This paper explores advanced methodologies and techniques in facial
   recognition technology, focusing on preprocessing and classification
   using convolutional neural network (CNN) based on Googlenet architecture
   and utilizing transfer learning. The system is trained and tested using
   MATLAB, achieving an accuracy of 91.59\% by utilizing labeled faces
   dataset of Steve Harvey and Cristiano Ronaldo, and incorporating robust
   neural network models. The results are presented in graph forms. Future
   improvements are anticipated as increasing the datasets size would
   likely enhance the model's accuracy and robustness, further contributing
   to public safety in South Africa.},
