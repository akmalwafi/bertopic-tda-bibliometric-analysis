@article{ WOS:000382004300007,
Author = {Demers, Simon and Langan, Cynthia},
Title = {A note on the square root law for urban police travel times},
Journal = {JOURNAL OF THE OPERATIONAL RESEARCH SOCIETY},
Year = {2016},
Volume = {67},
Number = {7},
Pages = {989-1000},
Month = {JUL},
Abstract = {The classical Square Root Law formula for emergency travel times
   consists of one observable component, the density of patrol coverage,
   and one unknown component that must be estimated empirically, the
   effective travel speed. The effective travel speed is typically assumed
   to be an empirical constant. We test whether this simplifying assumption
   is justified empirically. We propose a modern machine-learning approach
   and a Least Absolute Shrinkage and Selection Operator regression to
   incorporate into a travel speed model various exogenous factors such as
   call type, incident location, weather conditions and traffic congestion.
   The value of the proposed analytical approach and some practical
   implications are demonstrated using operational data from a large urban
   police jurisdiction based in British Columbia, Canada. Although the
   analysis is framed within the context of urban emergency police
   operations, the proposed approach has the potential to be useful for
   other emergency services or roving business units that deal with
   unscheduled service calls.},
Publisher = {PALGRAVE MACMILLAN LTD},
Address = {BRUNEL RD BLDG, HOUNDMILLS, BASINGSTOKE RG21 6XS, HANTS, ENGLAND},
Type = {Article},
