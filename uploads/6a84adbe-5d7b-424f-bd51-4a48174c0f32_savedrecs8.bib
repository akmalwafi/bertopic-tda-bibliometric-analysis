Title = {Estimating countries' peace index through the lens of the world news as
   monitored by GDELT},
Booktitle = {2020 IEEE 7TH INTERNATIONAL CONFERENCE ON DATA SCIENCE AND ADVANCED
   ANALYTICS (DSAA 2020)},
Series = {Proceedings of the International Conference on Data Science and Advanced
   Analytics},
Year = {2020},
