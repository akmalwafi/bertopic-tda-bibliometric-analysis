@article{ WOS:001430883700001,
Author = {Sadaba-Campo, Nerea and Gomez-Moreno, Hilario},
Title = {Exploration of Generative Neural Networks for Police Facial Sketches},
Journal = {BIG DATA AND COGNITIVE COMPUTING},
