@article{ WOS:000986134500001,
Author = {Abadias Selma, Alfredo},
Title = {THE CRIMINAL PROTECTION OF WORKERS AGAINST ARTIFICIAL INTELLIGENCE IN
   THE FIELD OF LABOR DISCRIMINATION CRIME},
Journal = {REVISTA GENERAL DE DERECHO PENAL},
Year = {2023},
Number = {39},
Month = {MAY},
Abstract = {the rights to equality and non-discrimination are essential constituent
   elements of an advanced society presided over by democratic principles
   that find their origin in the Enlightenment.
   The importance of these rights encompasses multiple vital facets and one
   of the most important are the labor relations, where we find a fertile
   ground for tension and the possible compromise of these.
   Much has been written about discrimination because of the importance it
