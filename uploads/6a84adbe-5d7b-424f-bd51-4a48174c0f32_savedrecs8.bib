@inproceedings{ WOS:000674966300026,
Author = {Tajuddin, Taniza and Abd Manaf, Azizah and Awang, Nor Fatimah and Dawam,
   Siti Rafidah Muhamat and Ali, Noor Rasidah and Amat, Rafidah},
Book-Group-Author = {IEEE},
Title = {Crime Suspect Profiling (CSP) for Forensic Investigation on Smartphone},
