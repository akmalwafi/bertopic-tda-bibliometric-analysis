@article{ WOS:001563964400012,
Author = {Lukoshkina, Svetlana V. and Bufetova, Maryam Sh.},
Title = {PROBLEMATIC ASPECTS OF USING ARTIFICIAL INTELLIGENCE FOR FORENSIC
   EXAMINATIONS IN THE CONDITIONS OF CRIMNAL PROCEEDINGS' DIGITALIZATION},
Journal = {RUSSIAN JOURNAL OF CRIMINOLOGY},
Year = {2025},
Volume = {19},
Number = {3},
Pages = {348-355},
Abstract = {Forensic activities play an important role in detecting and
   investigating crimes, as well as obtaining proofs in the form of expert
   opinions. It is stated that forensic activities are involved in the
   ongoing process of criminal proceedings' digitization, in connection
   with which the authors discuss the digitization of an expert's work
   through the use of artificial intelligence (AI) and neural networks. The
   research of proceduralists and criminalists makes it possible to
   conclude that AI, undoubtedly, opens new opportunities in forensic work
   and poses fundamentally new questions: could the conclusion prepared by
   a neural network be viewed as an expert's opinion, will it correspond to
   the criterion of admissibility, and what are the future prospects of
   using AI and neural networks in forensic work? It is concluded that
   neural networks and AI could be viewed as instruments of forensic
   examination, however, currently AI cannot replace experts and their
   opinions, which should be substantiated and based on the aggregate of
   scientific methods. Besides, as a result of their research, the authors
   have developed principled positions regarding the contents and limits of
   using neural networks during forensic examinations, as well as the
   format of such use.},
