@article{ WOS:000364111300001,
Author = {Gallupe, Owen and Bouchard, Martin and Davies, Garth},
Title = {Delinquent Displays and Social Status among Adolescents},
Journal = {CANADIAN JOURNAL OF CRIMINOLOGY AND CRIMINAL JUSTICE},
Year = {2015},
Volume = {57},
Number = {4},
Pages = {439-474},
Month = {OCT},
Abstract = {Adolescents with high social status are more important than others in
   determining the delinquent involvement of the peer group. Yet relatively
   little is known about how delinquency and analogous acts and traits
   affect social status. We examine whether adolescents who display a
   capacity for delinquency enjoy greater social status
   (popularity/centrality). Two models of delinquency display are proposed
   to explain social status among adolescents: the illicit behaviour model
   and the delinquent potential model (which does not require any
   delinquent involvement). Data from the saturation sample of the National
   Longitudinal Study of Adolescent to Adult Health are used (n = 1,514).
   The results show that adolescents who display a potential for
   delinquency by associating with delinquent peers tend to have higher
   status while actual involvement in illicit acts (violence) hurts social
   status.},
Publisher = {UNIV TORONTO PRESS INC},
