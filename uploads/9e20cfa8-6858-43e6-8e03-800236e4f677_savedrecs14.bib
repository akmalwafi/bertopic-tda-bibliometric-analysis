@inproceedings{ WOS:000894108100012,
Author = {Saaim, Kunwar Muhammed and Felemban, Muhamad and Alsaleh, Saleh and
   Almulhem, Ahmad},
Editor = {Meng, W and Fischer-Hubner, S and Jensen, CD},
Title = {Light-Weight File Fragments Classification Using Depthwise Separable
   Convolutions},
Booktitle = {ICT SYSTEMS SECURITY AND PRIVACY PROTECTION (SEC 2022)},
Series = {IFIP Advances in Information and Communication Technology},
Year = {2022},
Volume = {648},
Pages = {196-211},
Note = {37th IFIP TC 11 International Conference on ICT Systems Security and
   Privacy Protection (IFIP SEC), Copenhagen, DENMARK, JUN 13-15, 2022},
Organization = {Tech Univ Denmark; Int Federat Informa Proc, Tech Comm 11 Informat Secur
   \& Privacy Protect Informat Proc Syst},
Abstract = {In digital forensics, classification of file fragments is an important
   step to complete the file carving process. There exist several
   approaches to identify the type of file fragments without relying on
   metadata. Examples of such approaches are using features like
   header/footer and N-gram to identify the fragment type. Recently, deep
   learning models have been successfully used to build classification
   models to achieve this task. In this paper, we propose a light-weight
   file fragment classification using depthwise separable convolutional
   neural network model. We show that our proposed model does not only
   yield faster inference time, but also provide higher accuracy as
   compared to the state-of-art convolutional neural network based models.
   In particular, our model achieves an accuracy of 78.45\% on the FFT-75
   dataset with 100K parameters and 167M FLOPs, which is 24x faster and
   4-5x smaller than the state-ofthe-art classifier in the literature.},
