Author = {Abdullah, Saqueeb and Nibir, Farah Idid and Salam, Suraiya and Dey,
   Akash and Alam, Md Ashraful and Reza, Md Tanzim},
Book-Group-Author = {IEEE},
Title = {Intelligent Crime Investigation Assistance Using Machine Learning
   Classifiers on Crime and Victim Information},
Booktitle = {2020 23RD INTERNATIONAL CONFERENCE ON COMPUTER AND INFORMATION
   TECHNOLOGY (ICCIT 2020)},
Series = {International Conference on Computer and Information Technology},
