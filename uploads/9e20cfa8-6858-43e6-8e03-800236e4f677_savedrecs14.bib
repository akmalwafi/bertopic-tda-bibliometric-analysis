@inproceedings{ WOS:000904477600056,
Author = {Beauregard, Melissa Stewart and Mayercsik, Nathan Paul and Pietersen,
   Randall Alan},
Editor = {Liu, R and Mulea, CC and Parfit, MK and Cavalline, TL},
Title = {A Critical Assessment of Unmanned Aerial System Usage and Data Analysis
   in Forensic Assessment},
Booktitle = {FORENSIC ENGINEERING 2022: ELEVATING FORENSIC ENGINEERING},
Year = {2022},
Pages = {537-550},
Note = {9th Forensic Engineering Congress, Denver,, CO, NOV 04-07, 2022},
Organization = {Amer Soc Civil Engineers, Forens Engn Div; Amer Soc Civil Engineers},
Abstract = {In forensic assessment, new technologies are being developed and
   implemented at a rate which far outpaces typical updates to design
   standards. The speed of this technological development and
   implementation may prove challenging for the field of civil engineering,
   which relies heavily on considerations from standard of practice,
   because there must be a strong technical understanding of the precision,
   bias, and repeatability of a new assessment tool before it may be
   successfully used for forensic assessment. This paper presents a
   discussion on unmanned aerial systems (UAS), which are the leading
   platform for advances in technologies, such as near-infrared
   thermography, image processing, and machine learning. Advances in these
   areas are reviewed in this report. While UASs were found to be useful
   for certain nondestructive forensic assessments, several shortfalls, and
   common misunderstandings associated with these potential forensic tools
   were identified and discussed in this report.},
