@inproceedings{ WOS:000706232700033,
Author = {Shrivastava, Rajesh Kumar and Bashir, Bazila and Hota, Chittaranjan},
Editor = {Fahrnberger, G and Gopinathan, S and Parida, L},
Title = {Attack Detection and Forensics Using Honeypot in IoT Environment},
Booktitle = {DISTRIBUTED COMPUTING AND INTERNET TECHNOLOGY, ICDCIT 2019},
Series = {Lecture Notes in Computer Science},
Year = {2019},
Volume = {11319},
