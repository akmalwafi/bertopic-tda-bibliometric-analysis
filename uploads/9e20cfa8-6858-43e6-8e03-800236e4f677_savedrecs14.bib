@article{ WOS:001098077200034,
Author = {Ding, Feng and Shen, Zhangyi and Zhu, Guopu and Kwong, Sam and Zhou,
   Yicong and Lyu, Siwei},
Title = {ExS-GAN: Synthesizing Anti-Forensics Images via Extra Supervised GAN},
Journal = {IEEE TRANSACTIONS ON CYBERNETICS},
Year = {2023},
Volume = {53},
Number = {11},
Pages = {7162-7173},
Month = {NOV},
Abstract = {So far, researchers have proposed many forensics tools to protect the
   authenticity and integrity of digital information. However, with the
   explosive development of machine learning, existing forensics tools may
   compromise against new attacks anytime. Hence, it is always necessary to
   investigate anti-forensics to expose the vulnerabilities of forensics
   tools. It is beneficial for forensics researchers to develop new tools
   as countermeasures. To date, one of the potential threats is the
   generative adversarial networks (GANs), which could be employed for
   fabricating or forging falsified data to attack forensics detectors. In
   this article, we investigate the anti-forensics performance of GANs by
   proposing a novel model, the ExS-GAN, which features an extra
   supervision system. After training, the proposed model could launch
   anti-forensics attacks on various manipulated images. Evaluated by
   experiments, the proposed method could achieve high anti-forensics
   performance while preserving satisfying image quality. We also justify
   the proposed extra supervision via an ablation study.},
