@inproceedings{ WOS:000250750200010,
Author = {Len, Fang-Yie and Hu, Kai-Wei and Jiang, Fuu-Cheng},
Editor = {Miyaji, A and Kikuchi, H and Rannenberg, K},
Title = {Intrusion detection and identification system using data mining and
   forensic techniques},
Booktitle = {ADVANCES IN INFORMATION AND COMPUTER SECURITY, PROCEEDINGS},
Series = {Lecture Notes in Computer Science},
Year = {2007},
Volume = {4752},
