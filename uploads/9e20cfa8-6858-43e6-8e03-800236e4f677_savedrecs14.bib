@article{ WOS:000923647500001,
Author = {Fan, Fei and Ke, Wenchi and Dai, Xinhua and Shi, Lei and Liu, Yuanyuan
   and Lin, Yushan and Cheng, Ziqi and Zhang, Yi and Chen, Hu and Deng,
   Zhenhua},
Title = {Semi-supervised automatic dental age and sex estimation using a hybrid
   transformer model},
Journal = {INTERNATIONAL JOURNAL OF LEGAL MEDICINE},
Year = {2023},
Volume = {137},
Number = {3},
Pages = {721-731},
Month = {MAY},
Abstract = {Teeth-based age and sex estimation is an important task in mass
   disasters, criminal scenes, and archeology. Although various methods
   have been proposed, most of them are subjective and influenced by
   observers' experiences. In this study, we aimed to develop a deep
   learning model for automatic dental age and sex estimation from
   orthopantomograms (OPGs) and compare to manual methods. A large dataset
   of 15,195 OPGs (age range, 16 similar to 50 years; mean age, 29.65 years
   +/- 9.36 {[}SD]; 10,218 females) was used to train and test a hybrid
   deep learning model which is a combination of convolutional neural
   network and transformer model. The final performance of this model was
   evaluated on additional independent 100 OPGs and compared to the manual
   method for external validation. In the test of 1413 OPGs, the mean
   absolute error (MAE) of age estimation was 2.61 years by this model. The
   accuracy and the area under the receiver operating characteristic curve
   (AUC) of sex estimation were 95.54\% and 0.984. The heatmap indicated
   that the crown and pulp chamber of premolars and molars contain the most
   age-related information. In the additional independent 100 OPGs, this
   model achieved an MAE of 3.28 years for males and 3.79 years for
   females. The accuracy of this model was much higher than that of the
   manual models. Therefore, this model has the potential to assist
   radiologists in automated age and sex estimation.},
