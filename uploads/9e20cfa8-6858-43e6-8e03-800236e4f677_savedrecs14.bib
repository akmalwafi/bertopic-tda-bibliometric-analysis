@inproceedings{ WOS:000511402300107,
Author = {Chiang, Pai-Song and Chien, Chiang-Ju},
Editor = {Su, R},
Title = {Using Electromagnetic Parameters of Targets and R Language to Enhance
   the Accurate and Rapid Judgment},
