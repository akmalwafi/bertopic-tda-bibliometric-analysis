@inproceedings{ WOS:001339362100018,
Author = {Sumi, Lucy and Dey, Shouvik},
Book-Group-Author = {IEEE},
Title = {A Deep Learning Approach to Gun Detection in Surveillance System using
   YOLOv9},
Booktitle = {2024 CONTROL INSTRUMENTATION SYSTEM CONFERENCE, CISCON 2024},
Year = {2024},
Note = {Control Instrumentation System Conference (CISCON) - Guiding Tomorrow -
   Emerging Trends in Control, Instrumentation, and Systems Engineering,
   Manipal, INDIA, AUG 02-03, 2024},
Organization = {Manipal Inst Technol, Dept Instrumentat \& Control Engn; IEEE Bangalore
   Sect; ARK; Sci \& Engn Res Board; Cent Bank},
Abstract = {The escalating firearm related crimes including open firing, robbery,
   suicides, mass shootings, homicides, threatening at gun point, etc. has
   underscored the growing importance of timely detection of weapons. This
   paper presents a gun detection system based on YOLOv9, a
   state-of-the-art object detection model not previously utilized in
   literature for gun detection applications. We conduct a comparative
   analysis with its predecessor versions of YOLOv9, namely YOLOv5, YOLOv6,
   YOLOv7 and YOLOv8 to assess their performance in gun detection. Our
   experiments, conducted on a Gun Movie database, reveal that YOLOv9
   consistently outperforms its predecessors, demonstrating that YOLOv9 has
   a good generalizability in detecting firearms in real-time. Particularly
   noteworthy are the precision and recall values achieved by YOLOv9,
   reaching 99.6\% and 99\%, respectively, demonstrating its superior
   efficacy in accurately identifying guns.},
