@inproceedings{ WOS:000890320100009,
Author = {Hariprasad, Yashas and Kumar, K. J. Latesh and Suraj, L. and Iyengar, S.
   S.},
Editor = {Arai, K},
Title = {Boundary-Based Fake Face Anomaly Detection in Videos Using Recurrent
   Neural Networks},
Booktitle = {INTELLIGENT SYSTEMS AND APPLICATIONS, VOL 2},
Series = {Lecture Notes in Networks and Systems},
Year = {2023},
Volume = {543},
Pages = {155-169},
Note = {Intelligent Systems Conference (IntelliSys), Amsterdam, NETHERLANDS, SEP
   01-02, 2022},
Abstract = {With the surge in the videos over the internet and the spread of digital
   communications, the attackers are greatly benefited by creating and
   publishing the fake distorted videos and images known as Deepfakes. The
   recent trends, Machine Learning powered applications are highly implied
   to create deepfakes that leads to fallacious arguments. To detect such
   an instance, there are several existing techniques that uses
   convolutional neural networks and machine learning methods which are
   limited to identify the larger details of the deepfake created. We
   propose a novel anomaly detection technique for face areas in videos
   using recurrent neural networks based on boundary marking and hashing
   technique which is efficient in detecting the deepfakes over a smaller
   face boundary regions. The proposed method is evaluated, and the results
   show promising performance for deepfake detection in the face area based
   on the boundaries. Our proposed method revealed good accuracy in
   detecting the smaller frame 8 x 8 raster based anomalies in videos.},
Publisher = {SPRINGER INTERNATIONAL PUBLISHING AG},
Address = {GEWERBESTRASSE 11, CHAM, CH-6330, SWITZERLAND},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Hariprasad, Y (Corresponding Author), Florida Int Univ, Miami, FL 33174 USA.
   Hariprasad, Yashas; Kumar, K. J. Latesh; Suraj, L.; Iyengar, S. S., Florida Int Univ, Miami, FL 33174 USA.},
