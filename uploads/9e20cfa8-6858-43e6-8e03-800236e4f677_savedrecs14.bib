@article{ WOS:001538713000014,
Author = {Pulido, Irene Gonzalez},
Title = {SEXUAL CYBERCRIME AND UNDERCOVER INVESTIGATION: SUPRANATIONAL
   LEGISLATIVE STRATEGIES},
Journal = {REVISTA GENERAL DE DERECHO PROCESAL},
Year = {2025},
Number = {66},
Month = {MAY},
Abstract = {In recent years, cybercrime has become one of the top threats facing the
   international community. For several decades, efforts have been made to
   strengthen the regulation and training of law enforcement and judicial
   authorities in the field of investigation. However, technological
   developments, particularly the exponential evolution of AI, have led to
   a significant increase and transformation in certain forms of
   cybercrime, such as online child sexual exploitation and abuse. These
   criminal typologies present characteristics that require exhaustive
   legal provisions, closely tied to the special protection of these
   particularly vulnerable victims. Consequently, this study will focuses
   on the role of the undercover agent, given its proven success in various
   investigations, analysing the main shortcomings and challenges faced by
   authorities in ensuring effective and legally sound investigations into
   this type of criminal activity.},
