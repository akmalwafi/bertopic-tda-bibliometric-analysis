Title = {Transformer Ensemble for Synthesized Speech Detection},
Booktitle = {FIFTY-SEVENTH ASILOMAR CONFERENCE ON SIGNALS, SYSTEMS \& COMPUTERS,
   IEEECONF},
Series = {Conference Record of the Asilomar Conference on Signals Systems and
