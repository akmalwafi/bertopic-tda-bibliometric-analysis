Title = {AI-ARC Baltic Demo: Detecting Illegal Activities at Sea},
Booktitle = {2024 27TH INTERNATIONAL CONFERENCE ON INFORMATION FUSION, FUSION 2024},
Year = {2024},
Note = {27th International Conference on Information Fusion (FUSION), San Globbe
   Econ Campus, Venice, ITALY, JUL 07-11, 2024},
Organization = {IEEE; IEEE AESS; ISIF},
Abstract = {We describe the AI-ARC (Artificial Intelligence-based Virtual Control
   Room for the Arctic) system, which aims to enhance maritime domain
   awareness and surveillance. The system is micro-service based and fuses
   data from various sources, utilizing AI-driven micro-services and an
   advanced visualization platform to increase the situation awareness of
   maritime surveillance operators. The results of the Baltic sea
   demonstration, aiding in the detection of illegal activities,
   environmental protection, are presented. The system was evaluated using
   historical data from real criminal incidents. The results show that the
   AI-ARC approach could help increase the situation awareness of law
   enforcement operators.},
