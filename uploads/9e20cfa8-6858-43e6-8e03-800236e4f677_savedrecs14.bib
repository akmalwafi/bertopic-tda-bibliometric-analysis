   Fabio Valerio and Passalis, Nikolaos and Tefas, Anastasios and
   Trivilini, Alessandro and Vairo, Claudio},
Editor = {Varol, A and Karabatak, M and Varol, C and Teke, S},
Title = {Face Verification and Recognition for Digital Forensics and Information
   Security},
