@article{ WOS:001487513500001,
Author = {Rich, Marshall S. and Aiken, Mary P.},
Title = {An Interdisciplinary Approach to Enhancing Cyber Threat Prediction
   Utilizing Forensic Cyberpsychology and Digital Forensics},
Journal = {FORENSIC SCIENCES},
