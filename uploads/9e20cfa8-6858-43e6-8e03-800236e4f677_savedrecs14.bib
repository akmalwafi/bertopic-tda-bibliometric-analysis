Author = {Mishra, Ved Prakash and Shukla, Balvinder},
Editor = {Singh, D and Raman, B and Luhach, AK and Lingras, P},
Title = {Process Mining in Intrusion Detection-The Need of Current Digital World},
Booktitle = {ADVANCED INFORMATICS FOR COMPUTING RESEARCH, ICAICR 2017},
Series = {Communications in Computer and Information Science},
