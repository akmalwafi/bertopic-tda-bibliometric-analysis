@inproceedings{ WOS:001447627200173,
Author = {Das, Priyanka and Munshi, Anuvab and Naha, Annwesha and Dey, Adrija and
   Chakraborty, Sriparno},
Editor = {Tomar, GS},
Title = {Graph based Keywords Extraction from Crime Data},
Booktitle = {2024 IEEE 16TH INTERNATIONAL CONFERENCE ON COMPUTATIONAL INTELLIGENCE
   AND COMMUNICATION NETWORKS, CICN},
Series = {International Confernce on Computational Intelligence and Communication
   Networks},
Year = {2024},
