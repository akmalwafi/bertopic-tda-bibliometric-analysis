@article{ WOS:001367120800006,
Author = {Pawnday, Savita},
Title = {Digital Technologies and Atrocity Risks},
Journal = {GLOBAL RESPONSIBILITY TO PROTECT},
Year = {2024},
Volume = {16},
Number = {4},
Pages = {426-429},
Month = {OCT},
Abstract = {From a practitioner's perspective the intervention explores how digital
   technologies have enhanced the capacities of policy-makers in
   anticipating and responding to atrocity crimes including through
   development and access to sophisticated technologies to collect and
   verify evidence of crimes for justice and accountability. Digital
   technologies have also provided perpetrators with enhanced tools to
   target populations with greater precision and commit atrocities against
   them. The intervention argues that the harm perpetuated by digital
   technologies can be mitigated by holding developers of these
   technologies accountable for creating operating environments that are
   safe and by naming and shaming governments that use new technologies to
   target populations.},
