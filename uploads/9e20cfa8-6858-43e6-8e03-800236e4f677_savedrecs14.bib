Title = {Satin Bowerbird Optimization-Based Classification Model for Heart
   Disease Prediction Using Deep Learning in E-Healthcare},
Booktitle = {2023 IEEE/ACM 23RD INTERNATIONAL SYMPOSIUM ON CLUSTER, CLOUD AND
   INTERNET COMPUTING WORKSHOPS, CCGRIDW},
Year = {2023},
