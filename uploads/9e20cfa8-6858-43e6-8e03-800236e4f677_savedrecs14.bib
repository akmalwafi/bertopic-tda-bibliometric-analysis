Booktitle = {RESEARCH AND DEVELOPMENT IN INTELLIGENT SYSTEMS XXVIII: INCORPORATING
   APPLICATIONS AND INNOVATIONS IN INTELLIGENT SYSTEMS XIX},
Year = {2011},
Pages = {311-324},
Note = {31st SGAI International Conference on Innovative Techniques and
   Applications of Artificial Intelligence, Cambridge, ENGLAND, DEC 13-15,
   2011},
Organization = {SGAI, British Comp Soc Specialist Grp Artificial Intelligence},
Abstract = {The DScentTrail System has been created to support and demonstrate
   research theories in the joint disciplines of computational inference,
   forensic psychology and expert decision-making in the area of
   counter-terrorism. DScentTrail is a decision support system,
   incorporating artificial intelligence, and is intended to be used by
   investigators. The investigator is presented with a visual
   representation of a suspect's behaviour over time, allowing them to
   present multiple challenges from which they may prove the suspect guilty
   outright or receive cognitive or emotional clues of deception. There are
   links into a neural network, which attempts to identify deceptive
   behaviour of individuals; the results are fed back into DScentTrail
   hence giving further enrichment to the information available to the
   investigator.},
