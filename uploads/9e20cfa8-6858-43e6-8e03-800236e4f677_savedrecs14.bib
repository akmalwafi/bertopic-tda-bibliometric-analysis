@article{ WOS:001479747600001,
Author = {Elyamany, Nashwa and Youssef, Yasser Omar and Abbas, Noorhan},
Title = {Forensic analysis of populist discourse and multimodal craft of
   consensus in Netanyahu's July 2024 Congressional address},
Journal = {SOCIAL SEMIOTICS},
Year = {2025},
Month = {2025 APR 26},
Abstract = {This study employs Natural Language Processing and semio-discursive
   tools to analyze the Israeli Prime Minister Benjamin Netanyahu's
   Congressional speech on July 2024, within the context of populist
   communication. The research work examines the multimodal - linguistic,
   auditory, and visual - elements of Netanyahu's speech to uncover the
   underlying rhetorical and communicative techniques. Grounded in the
   conceptualization of populism as an ideational/communicative phenomenon,
   the study investigates the key radical right-wing populist frames and
   strategies Netanyahu incorporates in his address and how these frames
   and strategies interact with media dynamics and citizen engagement,
   particularly in a hybrid media environment characterized by a
   convergence of mass and interpersonal communication. The findings aim to
   advance Forensic Linguistics by demonstrating the potential of a
   mixed-methods research design in dissecting complex political rhetoric,
   offering valuable insights for scholars, media analysts, and GenAI
   researchers interested in the interplay of technology, media, and
   populist communication.},
Publisher = {ROUTLEDGE JOURNALS, TAYLOR \& FRANCIS LTD},
