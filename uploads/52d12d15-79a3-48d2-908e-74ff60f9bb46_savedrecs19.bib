@inproceedings{ WOS:000884323100016,
Author = {Alghamdi, Jawaher and Huang, Zi},
Editor = {Qiao, M and Vossen, G and Wang, S and Li, L},
Title = {Modeling Daily Crime Events Prediction Using Seq2Seq Architecture},
Booktitle = {DATABASES THEORY AND APPLICATIONS (ADC 2021)},
Series = {Lecture Notes in Computer Science},
Year = {2021},
Volume = {12610},
Pages = {192-203},
Note = {32nd Australasian Database Conference (ADC) Held as Part of Australasian
   Computer Science Week (ACSW), Otago Univ, ELECTR NETWORK, JAN 29-FEB 05,
   2021},
Abstract = {Early prediction of the crime occurrence reduces its impact. Several
   studies have been conducted to forecast crimes. However, these studies
   are not highly accurate, particularly in short-term forecasting such as
   over one week. To respond to this, we examine sequence to sequence
   (Seq2Seq) based encoder-decoder LSTM model using two real-world crime
   datasets of Brisbane and Chicago, extracted from the open data portal,
   to make one week ahead of total daily crime forecasting. We have built
   an ARIMA statistical model and three machine learning-based regression
   models that differ in their architecture, namely, simple RNN, LSTM, and
   ConvlD with a novel approach of walk-forward validation. Using a grid
   search strategy, the hyperparameters of the models are optimized. The
   obtained results demonstrate that the proposed Seq2Seq model is highly
   effective, if not superior, compared to its counterparts and other
   algorithms. This proposed model achieves state-of-the-art results with a
   relatively Root Mean Squared Error (RMSE) of 0.43 and 0.86 on both
   datasets, respectively.},
Publisher = {SPRINGER INTERNATIONAL PUBLISHING AG},
Address = {GEWERBESTRASSE 11, CHAM, CH-6330, SWITZERLAND},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Alghamdi, J (Corresponding Author), Univ Queensland, Sch Informat Technol \& Elect Engn, Brisbane, Qld, Australia.
   Alghamdi, Jawaher; Huang, Zi, Univ Queensland, Sch Informat Technol \& Elect Engn, Brisbane, Qld, Australia.},
DOI = {10.1007/978-3-030-69377-0\_16},
ISSN = {0302-9743},
EISSN = {1611-3349},
ISBN = {978-3-030-69377-0; 978-3-030-69376-3},
