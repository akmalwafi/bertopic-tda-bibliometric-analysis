@inproceedings{ WOS:000356489200266,
Author = {Fulton, Steven and Schweitzer, Dino and Dressler, Judson},
Book-Group-Author = {IEEE},
Title = {What Are We Teaching In Cyber Competitions?},
Booktitle = {2012 FRONTIERS IN EDUCATION CONFERENCE (FIE)},
