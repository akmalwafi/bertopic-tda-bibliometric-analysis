@inproceedings{ WOS:000468383400292,
Author = {Kwon, Beom and Gong, Myongsik and Huh, Jungwoo and Lee, Sanghoon},
Book-Group-Author = {IEEE},
Title = {IDENTIFICATION AND RESTORATION OF LZ77 COMPRESSED DATA USING A MACHINE
