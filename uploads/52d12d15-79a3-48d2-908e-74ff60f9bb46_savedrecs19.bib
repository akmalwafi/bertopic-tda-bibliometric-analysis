@article{ WOS:001012763500001,
Author = {Ghanizadeh, Ali Reza and Amlashi, Amir Tavana and Dessouky, Samer},
Title = {A novel hybrid adaptive boosting approach for evaluating properties of
   sustainable materials: A case of concrete containing waste foundry sand},
Journal = {JOURNAL OF BUILDING ENGINEERING},
Year = {2023},
Volume = {72},
Month = {AUG 1},
Abstract = {Ensemble learning (EL) has gained popularity in recent investigations
   because of its higher prediction accuracy than conventional machine
   learning (ML) methods. Regressors and EL algorithms, use ML methods to
   train weak learners and then assemble strong learners from weak ones.
   Therefore, EL-based models are expected to be more efficient and
   practical in modeling the complex nature of various types of sustainable
   materials like eco-friendly concrete than single ML methods. However,
   due to the large number of hyperparameters that can be used to design an
   EL model, developing good approaches is not easy. Then, optimizing
   hyperparameters using metaheuristics reduces the time and memory
   required to address this issue. This study aims to implement a novel
   hybrid EL method based on a hybridization of adaptive boosting
   (AdaBoost) and forensic-based investigation optimization (FBIO)
   algorithm to predict strength and workability characteristics of
   concrete containing waste foundry sand (CCWFS) which is introduced by
   replacing WFS as a concrete aggregate substitute, to reduce the problems
   associated with their disposal, CO2 emissions, and concrete production
   costs. For this purpose, 108, 406, 146, 343, and 169 data for the slump,
   compressive strength (CS), elasticity modulus (E), splitting tensile
   strength (STS), and flexural strength (FS) of CCWFS were collected from
   30 published papers. AdaBoost-FBIO was found to be superior to other
   classical single ML approaches (for instance, support vector machine
   (SVM), and multivariate adaptive regression spline (MARS)) and famous EL
   method of random forest (RF). The majority of the presented models had
   R2 values above 0.90, and only less than 10\% of the records were
   predicted using AdaBoost-FBIO models with more than 20\% deviation from
   the observed values. Also, uncertainty analyses of the models
   demonstrated they were all within the permissible performance range.
   Taking into account the performance assessment of implemented models in
   this research, AdaBoost-FBIO can be widely used for predicting various
   properties of eco-friendly engineering materials with a high degree of
   accuracy and reliability.},
Publisher = {ELSEVIER},
