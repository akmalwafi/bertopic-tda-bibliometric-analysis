@article{ WOS:001087944500001,
Author = {Almehmadi, Lamyaa M. and Lednev, Igor K.},
Title = {Stand-off Raman spectroscopy is a promising approach for the detection
   and identification of bloodstains for forensic purposes},
Journal = {JOURNAL OF RAMAN SPECTROSCOPY},
Year = {2024},
Volume = {55},
Number = {2, SI},
Pages = {227-231},
Month = {FEB},
Abstract = {Stand-off Raman spectroscopy combined with chemometrics was demonstrated
   to have great potential for detecting and identifying biological stains
   from a distance for forensic purposes. Bloodstain spectra were collected
   using a handheld Raman spectrometer equipped with a stand-off attachment
   and compared with spectra acquired with a benchtop Raman microscope. The
   two sets of spectra were visually similar, supporting the potential use
   of a handheld Raman spectrometer with stand-off attachment for blood
   detection at the scene of crime. In addition, the stand-off Raman
   spectra of bloodstains were correctly identified using a previously
   built SVM-DA model for the identification of all main body fluids (Muro
   et al., Forensic Chemistry, 2016). Stand-off Raman spectroscopy opens a
   new potential opportunity for further development of Raman spectroscopy
   as a universal tool for detecting and identifying body fluid traces for
   forensic purposes.
   Stand-off Raman spectroscopy, in conjunction with chemometrics, was
   employed to detect and identify bloodstains from a distance. Bloodstain
   spectra were acquired using a handheld spectrometer equipped with a
   stand-off attachment and compared to those obtained with a benchtop
   Raman microscope. Notably, the spectra collected from both instruments
   were visually similar. Furthermore, bloodstain samples were accurately
   identified utilizing a previously built model designed to identify all
   main body fluids.image},
