@inproceedings{ WOS:000691572200008,
Author = {Wang, Wubing and Chen, Guoxing and Cheng, Yueqiang and Zhang, Yinqian
   and Lin, Zhiqiang},
Editor = {Bilge, L and Cavallaro, L and Pellegrino, G and Neves, N},
Title = {SPECULARIZER: Detecting Speculative Execution Attacks via Performance
   Tracing},
Booktitle = {DETECTION OF INTRUSIONS AND MALWARE, AND VULNERABILITY ASSESSMENT, DIMVA
   2021},
Series = {Lecture Notes in Computer Science},
Year = {2021},
Volume = {12756},
