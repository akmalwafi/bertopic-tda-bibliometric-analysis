@inproceedings{ WOS:000984502600009,
Author = {Parlak, Mehmet and Altunel, Nurkan Fatih and Akkas, Utku Ayaz and Arici,
   Emir Tarik},
Book-Group-Author = {IEEE},
Title = {Tamper-Proof Evidence via Blockchain for Autonomous Vehicle Accident
   Monitoring},
Booktitle = {2022 IEEE 1ST GLOBAL EMERGING TECHNOLOGY BLOCKCHAIN FORUM: BLOCKCHAIN \&
   BEYOND, IGETBLOCKCHAIN},
Year = {2022},
Note = {IEEE 1st Global Emerging Technology Blockchain Forum - Blockchain and
   Beyond, (IGETblockchain), Irvine, CA, NOV 07-11, 2022},
Organization = {IEEE},
Abstract = {In case of an accident between two autonomous vehicles equipped with
   emerging technologies, how do we apportion liability among the various
   players? A special liability regime has not even yet been established
   for damages that may arise due to the accidents of autonomous vehicles.
   Would the immutable, time-stamped sensor records of vehicles on
   distributed ledger help define the intertwined relations of liability
   subjects right through the accident? What if the synthetic media created
   through deepfake gets involved in the insurance claims? While
   integrating AI-powered anomaly or deepfake detection into automated
   insurance claims processing helps to prevent insurance fraud, it is only
   a matter of time before deepfake becomes nearly undetectable even to
   elaborate forensic tools. This paper proposes a blockchain-based
   insurtech decentralized application to check the authenticity and
   provenance of the accident footage and also to decentralize the
   loss-adjusting process through a hybrid of decentralized and centralized
   databases using smart contracts.},
