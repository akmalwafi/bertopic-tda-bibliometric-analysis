@inproceedings{ WOS:001099483000006,
Author = {Shen, Dongyao and Zhao, Youjian and Quan, Chengbin},
Book-Group-Author = {ACM},
Title = {Identity-Referenced Deepfake Detection with Contrastive Learning},
Booktitle = {PROCEEDINGS OF THE 2022 ACM WORKSHOP ON INFORMATION HIDING AND
   MULTIMEDIA SECURITY, IH-MMSEC 2022},
Year = {2022},
Pages = {27-32},
Note = {10th ACM Workshop on Information Hiding and Multimedia Security
   (IH-MMSec), Univ Calif, Santa Barbara Campus, Marine Sci Inst, ELECTR
   NETWORK, JUN 27-28, 2022},
Organization = {Assoc Comp Machinery; ACM SIGMM},
Abstract = {With current advancements in deep learning technology, it is becoming
   easier to create high-quality face forgery videos, causing concerns
   about the misuse of deepfake technology. In recent years, research on
   deepfake detection has become a popular topic. Many detection methods
   have been proposed, most of which focus on exploiting image artifacts or
   frequency domain features for detection. In this work, we propose using
   real images of the same identity as a reference to improve detection
   performance. Specifically, a real image of the same identity is used as
   a reference image and input into the model together with the image to be
   tested to learn the distinguishable identity representation, which is
   achieved by contrastive learning. Our method achieves superior
   performance on both Face-Forensics++ and Celeb-DF with relatively little
   training data, and also achieves very competitive results on
   cross-manipulation and cross-dataset evaluations, demonstrating the
   effectiveness of our solution.},
