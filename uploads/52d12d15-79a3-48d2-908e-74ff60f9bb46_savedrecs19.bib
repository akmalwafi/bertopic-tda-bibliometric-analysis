@article{ WOS:001461597900002,
Author = {Tekade, Arti and Vijayan, T. and Karthik, B. and Mahajan, Anurag},
Title = {Person identification using novel local triangular binary pattern-based
   texture descriptor},
Journal = {EURASIP JOURNAL ON ADVANCES IN SIGNAL PROCESSING},
Year = {2025},
Volume = {2025},
Number = {1},
Month = {MAR 10},
Abstract = {Human authentication is a crucial part of most computer vision
   automation systems. Conventional fingerprint, iris, face, or palm
   print-based systems cannot identify individuals when their external
   biometric components are destroyed, such as by severe burns, rashes, or
   wounds. The main elements of any person authentication system are
   non-forgery, security, resilience, and privacy. The local texture
   descriptor is vital in describing hand radiographic images' texture.
   This paper presents the novel local triangular binary pattern based
   texture descriptor to provide a local texture description of the hand
   radiographic images. The performance of the proposed descriptor is
   assessed using different machine learning classifiers such as K-nearest
   neighbor (KNN), support vector machine (SVM), radial basis function-SVM
   (RBF-SVM), classification tree (CT), and random forest (RF) for
   authentication of the 20 users based on hand radiographs. The suggested
   system provides an overall accuracy of 84.17\% for KNN, 90\% for SVM,
   91.35\% for RBF-SVM, 92.50\% for CT, and 96.67\% for RF for the 20 users
   for the In-house hand radiographic dataset.},
