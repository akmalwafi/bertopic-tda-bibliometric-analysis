@inproceedings{ WOS:000848755600019,
Author = {Esquivel, Nicolas and Nicolis, Orietta and Peralta Marquez, Billy},
Book-Group-Author = {IEEE},
Title = {Predicting Motor Vehicle Theft in Santiago de Chile using
   Graph-Convolutional LSTM},
Booktitle = {2020 39TH INTERNATIONAL CONFERENCE OF THE CHILEAN COMPUTER SCIENCE
   SOCIETY (SCCC)},
Series = {Proceedings of the International Conference of the Chilean Computer
   Science Society},
Year = {2020},
