@inproceedings{ WOS:000286902900006,
Author = {Levett, Chris and Jhumka, Arshad and Anand, Sarabjot Singh},
Book-Group-Author = {ACM},
Title = {Towards Event Ordering in Digital Forensics},
Booktitle = {MM\&SEC 2010: 2010 ACM SIGMM MULTIMEDIA AND SECURITY WORKSHOP,
