Title = {CASTNet: Community-Attentive Spatio-Temporal Networks for Opioid
   Overdose Forecasting},
Booktitle = {MACHINE LEARNING AND KNOWLEDGE DISCOVERY IN DATABASES, ECML PKDD 2019,
   PT III},
