@article{ WOS:000360794500005,
Author = {Koc, Levent and Carswell, Alan D.},
Title = {Application of an AODE Based Classifier to Detect DOS Attacks},
Journal = {INTERNATIONAL JOURNAL OF COMPUTER SCIENCE AND NETWORK SECURITY},
Year = {2015},
Volume = {15},
Number = {2},
Pages = {24-28},
Month = {FEB 28},
Abstract = {Digital forensics often utilize network intrusion detection systems
   based on various data mining methods to detect and collect evidence on
   intrusion events such as Denial of Service (DOS) attacks. Findings of
   our experiments reveal that a classification model based on averaged
   one-dependence estimators (AODE) can be used for this purpose. AODE is
   an extension of Naive Bayes method which relies on conditional
   independence assumption. A multiclass classifier model based on AODE is
   proposed for accurate detection of DOS attacks. Results of the
   experiments using KDD'99 intrusion detection dataset indicate the
   proposed classifier based on AODE model performs better than the
   classifier model based on traditional Naive Bayes method in terms of
   accuracy to detect DOS attacks.},
Publisher = {INT JOURNAL COMPUTER SCIENCE \& NETWORK SECURITY-IJCSNS},
