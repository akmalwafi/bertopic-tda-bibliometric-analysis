@article{ WOS:001054440800001,
Author = {Kabealo, Ruksana and Wyatt, Steven and Aravamudan, Akshay and Zhang, Xi
   and Acaron, David N. and Dao, Mawaba P. and Elliott, David and Smith,
   Anthony O. and Otero, Carlos E. and Otero, Luis D. and Anagnostopoulos,
   Georgios C. and Peter, Adrian M. and Jones, Wesley and Lam, Eric},
Title = {A multi-firearm, multi-orientation audio dataset of gunshots},
Journal = {DATA IN BRIEF},
Year = {2023},
Volume = {48},
Month = {JUN},
Abstract = {Early detection of firearm discharge has become increasingly critical
   for situational awareness in both civilian and military domains. The
   ability to determine the location and model of a discharged firearm is
   vital, as this can inform effective response plans. To this end, several
   gunshot audio datasets have been released that aim to facilitate gunshot
   detection and classification of a discharged firearm based on acoustic
   signatures. However, these datasets often suffer from a lack of variety
   in the orientations of recording devices around the source of the
   gunshot. Additionally, these datasets often suffer from the absence of
   proper time synchronization, which prevents the usage of these datasets
   for determining the Direction of Arrival (DoA) of the sound. In this
   paper, we present a multi-firearm, multi-orientation time-synchronized
   audio dataset collected in a semi-controlled real-world setting -
   providing us a degree of supervision - using several edge devices
   positioned in and around an outdoor firing range.},
