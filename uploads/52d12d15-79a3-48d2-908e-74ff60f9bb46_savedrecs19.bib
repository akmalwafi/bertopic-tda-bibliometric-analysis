@inproceedings{ WOS:000448205000203,
Author = {Bablani, Annushree and Edla, Damodar Reddy and Kuppili,
   Venkatanareshbabu},
Book-Group-Author = {IEEE},
Title = {Deceit Identification Test on EEG Data using Deep Belief Network},
Booktitle = {2018 9TH INTERNATIONAL CONFERENCE ON COMPUTING, COMMUNICATION AND
   NETWORKING TECHNOLOGIES (ICCCNT)},
Series = {International Conference on Computing Communication and Network
   Technologies},
Year = {2018},
Note = {9th International Conference on Computing, Communication and Networking
   Technologies (ICCCNT), IISC, Bengaluru, INDIA, JUL 10-12, 2018},
Abstract = {With the increasing rate of crime, deceit identification has become an
   issue of concern. The main task here is to classify the EEG data
   recorded for lie detection, into innocent and guilty. Although various
   methods have been developed in past to classify EEG data, deep belief
   nets are rarely used. This paper uses a deep learning technique using
   the restricted Boltzmann machine with wavelet to obtain the time and
   frequency domain information of signals. A deep belief network is
   developed with four RBMs stacked together. Softmax regression is
   utilized at output layer to classify EEG data into guilty and innocent.
   An experiment has been performed on EEG data recorded by performing a
   ``Concealed Information Test{''}. The test consists of a mock crime
   scenario where some relevant and irrelevant images are presented in
