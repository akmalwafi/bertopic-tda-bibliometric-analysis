@inproceedings{ WOS:000389502100040,
Author = {Yang, Bin and Guo, Honglei},
Editor = {Sun, X and Liu, A and Chao, HC and Bertino, E},
Title = {An Efficient Forensic Method Based on High-speed Corner Detection
   Technique and SIFT Descriptor},
