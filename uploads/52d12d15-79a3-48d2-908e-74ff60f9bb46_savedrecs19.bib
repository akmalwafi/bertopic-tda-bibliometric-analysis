@inproceedings{ WOS:001477754700114,
Author = {Lakhani, Rameen A. S. and Moloto, Revinah and Gomes, Chandima},
Book-Group-Author = {IEEE},
Title = {Forensic Analysis of Lightning Damage to Masonry},
Booktitle = {2025 33RD SOUTHERN AFRICAN UNIVERSITIES POWER ENGINEERING CONFERENCE,
   SAUPEC},
