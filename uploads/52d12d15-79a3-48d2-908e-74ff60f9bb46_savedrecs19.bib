@inproceedings{ WOS:001437351800006,
Author = {Kato, Makoto P. and Imrattanatrai, Wiradee and Yamamoto, Takehiro and
   Ohshima, Hiroaki and Tanaka, Katsumi},
Editor = {Jose, JM and Yilmaz, E and Magalhaes, J and Castells, P and Ferro, N and Silva, MJ and Martins, F},
Title = {Context-Guided Learning to Rank Entities},
