@inproceedings{ WOS:000401653300001,
Author = {Kuo, Nathan and Chang, Chun-Ming and Chen, Kuan-Ta},
Editor = {Nguyen, NT and Tojo, S and Nguyen, LM and Trawinski, B},
Title = {Exploring Spatial and Social Factors of Crime: A Case Study of Taipei
   City},
Booktitle = {INTELLIGENT INFORMATION AND DATABASE SYSTEMS (ACIIDS 2017), PT II},
