Title = {Where are the People? A Multi-Stream Convolutional Neural Network for
   Crowd Counting via Density Map from Complex Images},
Booktitle = {PROCEEDINGS OF 2019 INTERNATIONAL CONFERENCE ON SYSTEMS, SIGNALS AND
   IMAGE PROCESSING (IWSSIP 2019)},
