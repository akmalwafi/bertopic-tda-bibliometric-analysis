@article{ WOS:000806137100003,
Author = {Bhagtani, Hemlata and Khatana, Sunita Singh},
Title = {INFLUENCE OF SOCIAL MEDIA AND INTERNET ON CHILDREN EDUCATION WITH RISING
   CYBERCRIMES: ANOVERVIEW},
Journal = {INTERNATIONAL JOURNAL OF EARLY CHILDHOOD SPECIAL EDUCATION},
Year = {2022},
Volume = {14},
Number = {2},
Pages = {4742-4747},
Abstract = {With the advent of technology and increasing demands of time, internet
   and computer literacy has become an integral part of everyone's life. If
   we look around in today's time a child is born with the technological
   know-how and knows to operate almost every electronic device available,
   especially devices connected to internet. Mentoring child for the
   correct use of internet is a must. Technology carries more number of
   disadvantages over its advantages. Negative use of internet can easily
   lead to diverting a child's mind in the wrong direction. Children, due
   to their tender years of age misuse the information communication
   technology (ICT).Trend to be popular on social media has taken a speed
   and toll on the mental health of teenagers. It is commonly observed that
   children create accounts on social media faking the age brackets set by
   the companies. They try to portray a trendy image on social media which
   has led the students to live a faking life and this is also pulling them
   away from their studies. Children have become prone to expose their
   personal lives on social media and in turn fall prey to wrong
   friendships, leading them nowhere. Bios Lockeroom from Instagram, is a
   very recent example for the same. Parents as well portray a wrong
   example by keeping themselves updated with the new versions of gadgets
   available in the market always. In some families parents must not be
   computer literates but their kids are exposed to computers, smart phones
   and internet as it has become need of the hour.Due to increase in
   disposable incomes, access to internet and smart phones with the updated
   technology are available and easily affordable to the people.
   Child is automatically trained by the artificial intelligence and
   technological updates to get trapped into cybercrimes like child
   pornography and distractive gaming technology, phishing and easily catch
   habits of hacking. Through this paper the researcher aims to analyse the
   role of media, technology in misleading children through various
   cybercrimes and show them the path where they tend to deviate. In these
   crimes the culprits can be children themselves and the adults as well.
   Also the paper will analyse the reasons for happening of such crimes and
   will offer solutions that can be adopted by various educational
   institutions and parents as well to mentor the children in right
   direction.},
