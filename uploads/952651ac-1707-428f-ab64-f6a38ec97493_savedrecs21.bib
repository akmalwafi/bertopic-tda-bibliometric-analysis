@article{ WOS:001456198200012,
Author = {Li, Mengyao and Yang, Zhibang and Zhou, Xu and Fang, Yixiang and Li,
   Kenli and Li, Keqin},
Title = {Clustering on Attributed Graphs: From Single-view to Multi-view},
Journal = {ACM COMPUTING SURVEYS},
