@article{ WOS:000326678200007,
Author = {Thammaboosadee, Sotarat and Watanapa, Bunthit},
Title = {IDENTIFICATION OF CRIMINAL CASE DIAGNOSTIC ISSUES: A MODULAR ANN
   APPROACH},
Journal = {INTERNATIONAL JOURNAL OF INFORMATION TECHNOLOGY \& DECISION MAKING},
