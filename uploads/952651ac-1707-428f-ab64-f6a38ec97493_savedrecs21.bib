Title = {Ponzi Scheme Identification of Smart Contract Based on Multi Feature
   Fusion},
Booktitle = {ADVANCED INTELLIGENT COMPUTING TECHNOLOGY AND APPLICATIONS, ICIC 2023,
   PT IV},
