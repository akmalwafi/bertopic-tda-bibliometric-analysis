DOI = {10.1109/SIU55565.2022.9864893},
ISSN = {2165-0608},
ISBN = {978-1-6654-5092-8},
Keywords = {Anomaly detection; recurrent neural networks; regression analysis},
Research-Areas = {Computer Science; Engineering; Telecommunications},
