@article{ WOS:001535231300001,
Author = {Fang, Tingting and Zhuo, Feng and Xie, Xinran and Yang, Ying and Kong,
   Linghua},
Title = {Is social phobia associated with cyber-deviance and negative emotions in
   adolescents? A network analysis based on large cluster sampling},
Journal = {CURRENT PSYCHOLOGY},
Year = {2025},
Month = {2025 JUL 23},
Abstract = {With the rapid expansion of internet usage, cyber-deviance has emerged
   as a significant public health challenge, particularly among
   adolescents. Cyber-deviance often co-occurs with psychological issues
   such as depression and anxiety. The core symptoms and symptom
   relationship between them are still unknown. This study examines the
   complex interrelations between cyber-deviance, depression, and anxiety
   in adolescents, with a focus on gender differences to inform targeted
   intervention strategies. A cross-sectional study recruited 19,249
   Chinese adolescents aged 11 to 19 years (mean age = 14.8, SD = 1.4).
   Cyber-deviance, depression, and anxiety were assessed using the Scale
   for Adolescent Internet Deviance (SAID), Children's Depression Inventory
   (CDI), and Multidimensional Anxiety Scale for Children (MASC),
   respectively. Propensity score matching (PSM) was employed to mitigate
   confounding variables, resulting in a balanced cohort of 14,322
   participants (7,161 males, 7,161 females). Network analysis identified
   central and bridging symptoms, while Network Comparison Test (NCT)
   assessed gender differences in network structure and strength. A
   sensitivity analysis was conducted to evaluate grade-level differences.
   ``Social phobia{''} emerged as the central symptom with the highest
   strength, expected influence, and bridge strength in the overall
   network, linking cyber-deviance with depression and anxiety.
   Gender-specific analyses revealed distinct patterns: males exhibited
   stronger connections between ``Internet aggressive behavior{''} and
   ``cyber deception{''}, while females demonstrated stronger associations
   between ``negative mood{''} and ``negative self-esteem{''}. Significant
   gender differences were observed in global network strength (males =
   6.061, females = 5.661, S = 0.400, p < 0.05) and structure (M = 0.126, p
   < 0.05). Sensitivity analysis further highlighted grade-specific
   variations in network strength across genders. This study underscores
   that ``social phobia{''} is associated with cyber-deviance, depression,
   and anxiety among adolescents. Gender-specific vulnerabilities were
   identified, with males showing heightened risks related to aggressive
   online behavior and deception, while females were more prone to
   depression. These findings emphasize the importance of gender-sensitive
   approaches in designing interventions targeting key symptoms and network
   pathways to effectively mitigate the impact of cyber-deviance and its
   comorbidities.},
Publisher = {SPRINGER},
