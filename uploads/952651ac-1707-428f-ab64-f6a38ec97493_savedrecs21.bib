@inproceedings{ WOS:000771923700026,
Author = {Komalova, Liliya and Glazkova, Anna and Morozov, Dmitry and Epifanov,
   Rostislav and Motovskikh, Leonid and Mayorova, Ekaterina},
Editor = {Alexandrov, DA and Boukhanovsky, AV and Chugunov, AV and Kabanov, Y and Koltsova, O and Musabirov, I and Pashakhin, S},
Title = {Automated Classification of Potentially Insulting Speech Acts on Social
   Network Sites},
Booktitle = {DIGITAL TRANSFORMATION AND GLOBAL SOCIETY, DTGS 2021},
