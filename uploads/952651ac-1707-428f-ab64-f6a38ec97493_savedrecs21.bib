@article{ WOS:001211241000001,
Author = {Zhang, Guangle and Zhang, Yuan and Li, Ling and Zhou, Jiaying and Chen,
   Honglin and Ji, Jinwen and Li, Yanru and Cao, Yue and Xu, Zhihui and
   Pian, Cong},
Title = {Exploring Novel Fentanyl Analogues Using a Graph-Based Transformer Model},
