@inproceedings{ WOS:001315691505065,
Author = {Zhang, Lei and Chen, Hao and Hu, Shu and Zhu, Bin and Lin, Ching-Sheng
   and Wu, Xi and Hu, Jinrong and Wang, Xin},
Book-Group-Author = {IEEE},
Title = {X-Transfer: A Transfer Learning-Based Framework for GAN-Generated Fake
   Image Detection},
Booktitle = {2024 INTERNATIONAL JOINT CONFERENCE ON NEURAL NETWORKS, IJCNN 2024},
Series = {IEEE International Joint Conference on Neural Networks (IJCNN)},
Year = {2024},
Note = {International Joint Conference on Neural Networks (IJCNN), Yokohama,
