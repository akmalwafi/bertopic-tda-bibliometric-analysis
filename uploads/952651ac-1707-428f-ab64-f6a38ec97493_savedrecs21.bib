@inproceedings{ WOS:000900724505099,
Author = {Zeng, Qingcheng and Chong, Dading and Zhou, Peilin and Yang, Jie},
Book-Group-Author = {Int Speech Commun Assoc},
Title = {Low-resource Accent Classification in Geographically-proximate Settings:
   A Forensic and Sociophonetics Perspective},
