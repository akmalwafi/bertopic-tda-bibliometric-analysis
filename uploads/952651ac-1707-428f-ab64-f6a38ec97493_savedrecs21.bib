@inproceedings{ WOS:000521754700005,
Author = {Huang, Yongjie and Qin, Jinghui and Wen, Wushao},
Book-Group-Author = {IEEE},
Title = {Phishing URL Detection Via Capsule-Based Neural Network},
Booktitle = {PROCEEDINGS OF 2019 IEEE 13TH INTERNATIONAL CONFERENCE ON
   ANTI-COUNTERFEITING, SECURITY, AND IDENTIFICATION (IEEE-ASID'2019)},
Series = {Proceedings of the International Conference on Anti-counterfeiting
   Security and Identification},
