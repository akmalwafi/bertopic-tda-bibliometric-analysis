@inproceedings{ WOS:001283894700114,
Author = {Amna, Shifa and Ronan, Kennedy and Naveed, Mamoona Asghar},
Book-Group-Author = {ASSOC COMPUTING MACHINERY},
Title = {GDPR-compliant Video Search and Retrieval System for Surveillance Data},
Booktitle = {19TH INTERNATIONAL CONFERENCE ON AVAILABILITY, RELIABILITY, AND
   SECURITY, ARES 2024},
Year = {2024},
Note = {19th International Conference on Availability, Reliability, and Security
   (ARES), Vienna, AUSTRIA, JUL 30-AUG 02, 2024},
Abstract = {The widespread deployment of surveillance cameras, responding to the
   increasing demand for scene investigation, video forensics, and
   analytics in urban environments, necessitates the storage and accurate
   retrieval of required video shots for post-verification. Conventional
   CCTV systems lack intelligent data storage, resulting in substantial
   volumes of data. This massive volume of video data (big data) poses a
   challenge in searching and retrieving needed information for video
   content analysis (VCA). Moreover, surveillance videos often contain
   sensitive Personally Identifiable Information (PII) about individuals,
   raising concerns about privacy and data protection. Data protection is
   vital for ethics and a fundamental human right. European regulatory
   authorities have enforced the General Data Protection Regulation (GDPR)
   to safeguard individuals' privacy rights and mitigate security threats.
   GDPR emphasises data minimisation by collecting the minimum amount of
   personal data needed to deliver an individual service element.
   Therefore, several ethical and regulatory concerns arise, which limit
   the use of automated surveillance systems. This work proposes a
   multi-layered security framework by integrating summarisation and
   attribute-based searchable encryption to provide optimal secure storage
   and intelligently filter out desired video clips from the encrypted
   videos by employing a text-to-video retrieval technique, making it a
   resource-efficient and GDPR-compliant secure evidence management system.},
Publisher = {ASSOC COMPUTING MACHINERY},
Address = {1601 Broadway, 10th Floor, NEW YORK, NY, UNITED STATES},
