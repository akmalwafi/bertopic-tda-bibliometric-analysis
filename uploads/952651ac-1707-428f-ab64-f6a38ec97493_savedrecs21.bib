   hab5d@virginia.edu},
Affiliations = {University of Virginia},
Funding-Acknowledgement = {United States Department of Defense; University of Virginia, School of
   Data Science},
Funding-Text = {The research for this paper was sponsored by the United States
   Department of Defense and the University of Virginia, School of Data
   Science. We would like to express our appreciation to the representative
   from the DoD, who wishes to remain anonymous, for all of the time they
   invested in us. We would also like to thank Dr. John Van Horn for his
