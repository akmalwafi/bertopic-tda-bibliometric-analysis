Year = {2021},
Volume = {53},
Month = {NOV},
Abstract = {Chongqing Han is an important southern Han group, but investigations on
   its paternal genetic structure are still limited. Here, we analyzed the
   forensic and phylogenetic characteristics of the Chongqing Han
   population based on 27 Y-STR and predicted Y-SNP markers. Based on
   AMOVA, haplogroup distribution and network analysis, we explored the
   genetic relationship between Chongqing Han, other Chinese groups and
   some southern indigenous groups (speaking Kra-Dai, Austronesian, etc).},
