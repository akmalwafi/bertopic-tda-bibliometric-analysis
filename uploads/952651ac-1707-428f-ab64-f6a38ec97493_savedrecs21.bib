@inproceedings{ WOS:000525734200031,
Author = {Bellekens, Xavier and Paul, Greig and Tachtatzis, Christos and Irvine,
   James and Atkinson, Robert},
Editor = {Shahriar, H and Vaidya, J and Elci, A},
Title = {Strategies for Protecting Intellectual Property when Using CUDA
   Applications on Graphics Processing Units},
Booktitle = {SECURITY OF INFORMATION AND NETWORKS (SIN'16)},
Year = {2016},
