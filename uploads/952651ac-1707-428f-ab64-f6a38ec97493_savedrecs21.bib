   Zhenze},
Editor = {Lan, X and Mei, X and Jiang, C and Zhao, F and Tian, Z},
Title = {An Indirect Dataset Labeling Strategy of Acupoint Recognition with
   High-Precision and High-Efficiency for Physiotherapy Robot},
Booktitle = {INTELLIGENT ROBOTICS AND APPLICATIONS, ICIRA 2024, PT VII},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2025},
Volume = {15207},
