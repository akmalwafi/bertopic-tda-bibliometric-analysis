@inproceedings{ WOS:000612997400073,
Author = {Bin Ahmadon, Mohd Anuaruddin and Yamaguchi, Shingo},
Book-Group-Author = {IEEE},
Title = {Process-Based Anomaly Detection and Analysis for Cyber-Physical System
   with MQTT Protocol},
Booktitle = {2020 IEEE INTERNATIONAL CONFERENCE ON CONSUMER ELECTRONICS (ICCE)},
Series = {International Conference on Consumer Electronics},
Year = {2020},
Pages = {263-268},
Note = {IEEE International Conference on Consumer Electronics (ICCE), Las Vegas,
   NV, JAN 04-06, 2020},
Organization = {IEEE},
Abstract = {In this research, we proposed a process-based anomaly detection method
   for Cyber-Physical System (CPS). Our method performs relaxation on
   monitoring the data and focuses more on the relationship of the
   execution order of message passing between the devices in the MQTT-based
   network. First, we performed a `bird's eye' monitoring technique to
   discover the execution order of message passing in the MQTT network with
   process mining. Then, we grasp the structure of the process model with a
   tree model called a process tree. Using the process tree, we check the
   deviations of normal behavior's process tree and the monitored
   behavior's process tree. Since CPS is a closed-loop system and MQTT
   protocol has pre-specified execution, we can easily detect deviations in
   the process tree as an anomaly. However, it is still hard to perform
   forensic analysis. Next, we proposed a forensic analysis method, which
   comes as an advantage of this approach compared to the black-boxed
   detection method, such as machine learning. The process-based approach
   can backtrack message passing by traversing the process tree and
   identify the execution operator in the parent nodes to find a ffected
   devices and execution order related to the incident. Finally, we showed
   an application example and evaluation of our method.},
