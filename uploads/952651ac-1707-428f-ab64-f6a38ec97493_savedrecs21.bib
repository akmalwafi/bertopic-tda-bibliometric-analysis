@inproceedings{ WOS:000462605900004,
Author = {Embarak, Ossama H.},
Book-Group-Author = {IEEE},
Title = {Debrief students personality to detect the best computing major},
Booktitle = {2018 FIFTH HCT INFORMATION TECHNOLOGY TRENDS (ITT): EMERGING
   TECHNOLOGIES FOR ARTIFICIAL INTELLIGENCE},
Year = {2018},
Pages = {18-22},
Note = {5th International Conference on HCT Information Technology Trends (ITT),
   Higher Coll Technol, Dubai Womens Campus, Dubai, U ARAB EMIRATES, NOV
   28-29, 2018},
Organization = {Higher Coll Technol; Higher Coll Technol, Fac Comp Informat Sci; Higher
   Coll Technol, Comp Informat Sci Div},
Abstract = {The selection of students' right career starts from the selection of
   their concentration. Many factors are affecting students' decision to
   select specific program than the others, including the personality, the
   family, friends, religious figures, passion, salary, past experiences or
   any role models in a student's life. Although all these factors have a
   direct or indirect impact on students' selection of a specific academic
   major, students' personality patterns are the most important factor that
   makes student successfully continue in specific concentration and hence
   being a future successful employee. This research tries to answer a few
   related questions which are what major fits more specific student
   according to his/her personality patterns? Are there significant
   patterns in personality which can be used as a guide for accurate
   concentration selection in higher colleges of technology (HCT)? In this
   research, a set of students from different CIS concentrations;
   specifically, security forensics, Networking, and Application
   development, are involved in the study and have been requested to
   complete Myers-Briggs Type Indicator (MBTI). The used instrument is
   tested by ran the test twice on different platforms and in different
   periods to figure out any random answers might happen by the
   participants. All found anomalies are removed and only quit fair data
   are kept for processing. This paper implements Chi-square to find the
   significant differences in students' personality types in three CIS
   majors.},
