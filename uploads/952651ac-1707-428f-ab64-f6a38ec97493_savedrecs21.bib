@inproceedings{ WOS:000310764702140,
Author = {Raj, S. Benson Edwin and Shalini, R.},
Editor = {Yuan, L},
Title = {A Novel Approach for the Early Detection and Identification of Botnets},
Booktitle = {MEMS, NANO AND SMART SYSTEMS, PTS 1-6},
