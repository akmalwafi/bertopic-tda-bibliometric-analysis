@inproceedings{ WOS:001539972000070,
Author = {Cui, Zelin and Dong, Pu and Han, Dongxu and Jiang, Bo and Lu, Zhigang
   and Feng, Huamin},
Editor = {Abel, MH and Shen, W and Matta, N and Barthes, JP and Luo, J and Zhang, J and Zhu, H and Peng, K},
Title = {Cross Page Recognition Methods For Fincrypted Web Application
   Fingerprinting},
Booktitle = {2025 28TH INTERNATIONAL CONFERENCE ON COMPUTER SUPPORTED COOPERATIVE
   WORK IN DESIGN, CSCWD},
