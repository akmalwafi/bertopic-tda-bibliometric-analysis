@inproceedings{ WOS:000947347200041,
Author = {Contardo, Paolo and Di Lorenzo, Emanuele and Falcionelli, Nicola and
   Dragoni, Aldo Franco and Sernani, Paolo},
Book-Group-Author = {IEEE},
Title = {Analyzing the impact of police mugshots in face verification for crime
   investigations},
Booktitle = {2022 IEEE INTERNATIONAL CONFERENCE ON METROLOGY FOR EXTENDED REALITY,
   ARTIFICIAL INTELLIGENCE AND NEURAL ENGINEERING (METROXRAINE)},
Year = {2022},
