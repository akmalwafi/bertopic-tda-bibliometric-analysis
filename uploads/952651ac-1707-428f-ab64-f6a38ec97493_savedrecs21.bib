@inproceedings{ WOS:000857451300035,
Author = {Ibrahim, Muhammad Amien and Sagala, Noviyanti Tri Maretta and Arifin,
   Samsul and Nariswari, Rinda and Murnaka, Nerru Pranuta and Prasetyo,
   Puguh Wahyu},
