@article{ WOS:001367955000001,
Author = {Ding, Xiangling and Nie, Yuchen},
Title = {Spectral information guidance network for tampering localization of
   high-resolution satellite map},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2025},
Volume = {264},
Month = {MAR 10},
Abstract = {Remote-sensing satellite-maps play an attractive and important issue in
   remote sensing applications, which are widely applied in monitoring,
   managing, and keeping track of natural disasters. However, the
   omnipresence of image editors and the maturation of image processing
   technologies have made satellite-map forgery relatively easy, causing
   incalculable and serious consequences. Asa result, many satellite-map
   forensic methods have been designed to locate tampered regions in
   satellite maps to verify their integrity and authenticity. Still, they
   usually ignore the spectral characteristics of the satellite-map itself.
   In this paper, based on the change analysis of spectral profiles, we
   have designed a novel U-shaped encoder-decoder network, namely the
   Spectral Information Guidance Network (SIGNet), which uses vegetation
   indices as spectral indices to guide the tampering localization of
   satellite-maps. Extensive experimental results demonstrate that the
   proposed SIGNet can effectively localize spliced objects with different
   sizes and shapes in satellite-maps, and the generated prediction masks
   have clear boundaries, surpassing existing algorithms. Finally, a
   forgery satellite- map dataset of 1K pairs is constructed for future
   research. The dataset is available at https://pan.baidu.com/
   s/12Gc8atDdHl8iYwwz\_EwgaQ with password 1234.},
