@article{ WOS:000512696500001,
Author = {Shen, Zhangyi and Ding, Feng and Shi, Yunqing},
Title = {Digital Forensics for Recoloring via Convolutional Neural Network},
Journal = {CMC-COMPUTERS MATERIALS \& CONTINUA},
