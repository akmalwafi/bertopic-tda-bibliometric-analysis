   Rihacek, Tomas; Ladmanova, Michaela, Masaryk Univ, Fac Social Studies, Dept Psychol, Jostova 10, Brno 60200, Czech Republic.
   Elliott, Robert, Univ Strathclyde, Sch Psychol Sci \& Hlth, Counselling Unit, Glasgow, Scotland.
   Owen, Jesse, Univ Denver, Morgridge Coll Educ, Counseling Psychol Dept, Denver, CO USA.},
DOI = {10.1037/int0000331},
ISSN = {1053-0479},
EISSN = {1573-3696},
Keywords = {session reactions; session impacts; client experience; longitudinal
