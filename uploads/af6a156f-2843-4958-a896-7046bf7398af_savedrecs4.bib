@article{ WOS:000495549900001,
Author = {Poyhtari, Reeta and Nelimarkka, Matti and Nikunen, Kaarina and Ojala,
   Markus and Pantti, Mervi and Paakkonen, Juho},
Title = {Refugee debate and networked framing in the hybrid media environment},
Journal = {INTERNATIONAL COMMUNICATION GAZETTE},
Year = {2021},
Volume = {83},
Number = {1, SI},
Pages = {81-102},
Month = {FEB},
Abstract = {In this article, we analyse how the debate on the `refugee crisis' has
   been constructed in Finnish news media and social media by using big
   data analytics. The study applies big data with the aim of exploring the
   dynamics between the mainstream news media and social media and the ways
   in which these dynamics shape and strategically amplify different
   understandings of the refugee crisis. The research highlights
   over-emphasis of crime and threat-oriented themes on refugee issues in
   social media, as well as illuminates the distinct role of social media
   platforms in shaping debates through user practices of hyperlink sharing
   and networked framing. Together these findings suggest that the hybrid
   media environment provides a possible arena for polarization of the
   refugee debate that could also be used for political ends.},
