@inproceedings{ WOS:000662554702032,
Author = {Golbin, Ilana and Rao, Anand S. and Hadjarian, Ali and Krittman, Daniel},
Editor = {Wu, XT and Jermaine, C and Xiong, L and Hu, XH and Kotevska, O and Lu, SY and Xu, WJ and Aluru, S and Zhai, CX and Al-Masri, E and Chen, ZY and Saltz, J},
Title = {Responsible AI: A Primer for the Legal Community},
