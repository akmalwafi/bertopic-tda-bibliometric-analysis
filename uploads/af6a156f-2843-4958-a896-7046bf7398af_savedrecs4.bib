Booktitle = {2021 15TH IEEE INTERNATIONAL CONFERENCE ON SERVICE-ORIENTED SYSTEM
   ENGINEERING (SOSE 2021)},
Series = {IEEE International Symposium on Service-Oriented System Engineering},
