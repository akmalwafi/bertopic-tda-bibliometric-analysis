@article{ WOS:000308869000004,
Author = {Nissan, Ephraim},
Title = {AN OVERVIEW OF DATA MINING FOR COMBATING CRIME},
Journal = {APPLIED ARTIFICIAL INTELLIGENCE},
Year = {2012},
Volume = {26},
Number = {8},
Pages = {760-786},
Abstract = {Artificial Intelligence (AI) and Law has been a burgeoning domain since
   the 1980s, but it was not until the 2000s that models of reasoning about
   legal evidence started to feature prominently. With regard to data
   mining, it has been applied to legal databases, as well as to law
   enforcement. We survey forensic applications of data mining to fraud and
   otherwise to crime intelligence or investigation. Traditionally a field
   separate from AI and Law, the two are now coming together. Success has
   been achieved especially in unravelling networks and in detecting fraud.},
