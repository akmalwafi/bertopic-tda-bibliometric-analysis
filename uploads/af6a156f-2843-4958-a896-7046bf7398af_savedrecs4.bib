@article{ WOS:001571282500001,
Author = {Markey, Patrick M. and Dapice, Jennie and Wickham, Brittany},
Title = {Linguistic Cues and Deception: A Replication Study of 911 Homicide Calls},
Journal = {PSYCHOLOGY PUBLIC POLICY AND LAW},
Year = {2025},
Month = {2025 SEP 15},
Abstract = {This study aimed to replicate Burns and Moffitt's 2014 investigation
   into using linguistic markers to detect deception in 911 homicide calls.
   Linguistic analysis and machine learning models, including logistic
   model tree induction, na \& iuml;ve Bayes, neural networks, random
   forests, and discriminant analysis, were applied to an independent and
   larger sample of 148 calls. The sample was evenly divided between false
   allegation callers and true report callers. These analyses utilized the
   linguistic inquiry and word count software to assess model accuracy,
   sensitivity, and specificity through cross-validation techniques.
   Although certain linguistic markers such as first-person singular
   pronouns, anxiety, and negation words showed statistically significant
   associations with deception, many of the associations identified by
   Burns and Moffitt were not replicated. The five models in the current
   study yielded an average accuracy of 57.0\%, with an average sensitivity
   of 57.2\% and specificity of 57.4\%, which are substantially lower than
   the original study's reported averages of 77.6\% accuracy, 80.8\%
   sensitivity, and 74.8\% specificity.},
