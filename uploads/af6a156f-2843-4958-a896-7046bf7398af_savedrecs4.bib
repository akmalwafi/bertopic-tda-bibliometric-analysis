@article{ WOS:000878812800001,
Author = {Circo, Giovanni M. and Wheeler, Andrew P.},
Title = {An Open Source Replication of a Winning Recidivism Prediction Model},
Journal = {INTERNATIONAL JOURNAL OF OFFENDER THERAPY AND COMPARATIVE CRIMINOLOGY},
Year = {2022},
Month = {2022 NOV 3},
Abstract = {We present results of our winning solution to the National Institute of
   Justice recidivism forecasting challenge. Our team, ``MCHawks,{''}
   placed highly in both terms of accuracy (as measured via the Brier
   score), as well as the fairness criteria (weighted by differences in
   false positive rates between White and Black parolees). We used a
   non-linear machine learning model, XGBoost, although we detail our
   search of different model specifications, as many different models'
   predictive performance is very similar. Our solution to balancing false
   positive rates is trivial; we bias predictions to always be ``low
   risk{''} so false positive rates for each racial group are zero. We
   discuss changes to the fairness metric to promote non-trivial solutions.
   By providing open-source replication materials, it is within the
   capabilities of others to build just as accurate models without
   extensive statistical expertise or computational resources.},
Publisher = {SAGE PUBLICATIONS INC},
Address = {2455 TELLER RD, THOUSAND OAKS, CA 91320 USA},
