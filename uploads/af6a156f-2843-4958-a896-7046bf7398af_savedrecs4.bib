Year = {2017},
Volume = {21},
Number = {2},
Pages = {133-158},
Month = {MAY},
Abstract = {Integrating crime pattern theory with tenets of social network theory,
   we argue that linking people who frequent the same places reveals
   intersecting behavioral patterns illustrative of case connectivity.
   Using the Green River serial murder investigation as a case study, we
   demonstrate that structural statistics may be useful in focusing
   investigative efforts. Significant shifts in the centrality of suspects
   emerge when we track the evolution of this case at 6-month increments,
   suggesting that the initial working case hypothesis misled
   investigators. Continued exploration into the utility of social network
   analysis (SNA) for tactical purposes will help advance applied
   criminology.},
