@inproceedings{ WOS:001119021700024,
Author = {Middleton, Stuart E. and Lavorgna, Anita and Neumann, Geoff and
   Whitehead, David},
Book-Group-Author = {ACM},
Title = {Information Extraction from the Long Tail A Socio-Technical AI Approach
   for Criminology Investigations into the Online Illegal Plant Trade},
Booktitle = {COMPANION OF THE 12TH ACM CONFERENCE ON WEB SCIENCE, WEBSCI 2020},
