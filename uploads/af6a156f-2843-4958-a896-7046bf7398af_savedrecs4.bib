@article{ WOS:000729442200001,
Author = {Bibi, Sumaira and Abbasi, Almas and Ul Haq, Ijaz and Baik, Sung Wook and
   Ullah, Amin},
Title = {Digital Image Forgery Detection Using Deep Autoencoder and CNN Features},
Journal = {HUMAN-CENTRIC COMPUTING AND INFORMATION SCIENCES},
Year = {2021},
Volume = {11},
Month = {AUG 15},
Abstract = {In this digital era, forgery in images is very common, where copy-move
   and splicing forgery are the most popular types of image forgeries. In
   the current literature, most of the existing techniques detect these
   types of forgeries. However, most researchers have targeted only JPEG
   compressed images. Though, digital forensic techniques should not be
   particular to any image format. In deep learning, the convolutional
   neural network (CNN) and autoencoder are very popular methods to extract
   complex visual features in digital images. In the proposed method,
   multiple structures stacked autoencoders (SAE) are introduced for
   forgery detection in various image compression techniques, where the
   pre-trained AlexNet and VGG16 are utilized for image features
   extraction. The Ensemble Subspace Discriminant classifier is utilized
   for authentic and forged image classification. We performed an extensive
   ablation study on two CASIA datasets, where the results with two
   autoencoders and AlexNet features are dominant over all architectures
   and state-of-the-art methods, it achieved 95.9\% accuracy for JPEG
   images and 93.3\% for TIFF images.},
Publisher = {Korea Computer Industry Assoc-KCIA},
Address = {C29, 7F, 11-9, Teheran-ro 77-gil, Gangnam-gu, Seoul, SOUTH KOREA},
Type = {Article},
Language = {English},
Affiliation = {Baik, SW (Corresponding Author), Sejong Univ, Seoul, South Korea.
