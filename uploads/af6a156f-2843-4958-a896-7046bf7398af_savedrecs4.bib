@article{ WOS:001557778000001,
Author = {Rodrigo-Guillen, Rafael and Garcia-D'Urso, Nahuel and Mora-Mora, Higinio
   and Azorin-Lopez, Jorge},
Title = {Detecting Abnormal Behavior Events and Gatherings in Public Spaces Using
   Deep Learning: A Review},
Journal = {JOURNAL OF SENSOR AND ACTUATOR NETWORKS},
Year = {2025},
Volume = {14},
Number = {4},
Month = {JUL 2},
Abstract = {Public security is a crucial aspect of maintaining social order.
   Although crime rates in Western cultures may be considered socially
   acceptable, it is important to continually improve security measures to
   prevent potential risks. With the advancements in artificial
   intelligence methods, particularly in deep learning and computer vision,
   it has become possible to detect abnormal event patterns in groups of
   people. This paper presents a review of the deep learning techniques
   employed for identifying gatherings of people and detecting anomalous
   events to enhance public security. Some of the open research areas are
   identified, including the lack of works addressing multiple cases of
   anomalies in large concentrations of people, which leaves open an
   important avenue for future scientific work.},
