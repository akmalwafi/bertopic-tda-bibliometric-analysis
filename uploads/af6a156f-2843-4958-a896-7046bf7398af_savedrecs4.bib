@article{ WOS:000517801600003,
Author = {Spanou, Kyriaki and Bekiari, Alexandra},
Title = {Analyzing Social Networks of Destructive Behaviours in Universities},
Journal = {INTERNATIONAL JOURNAL OF SOCIOLOGY OF EDUCATION},
