@inproceedings{ WOS:001498560400008,
Author = {Acampora, Giovanni and Vitiello, Autilia},
Book-Group-Author = {IEEE},
Title = {Local Interpretable Model-agnostic Explanations for Crime Prediction},
Booktitle = {2025 IEEE SYMPOSIUM ON TRUSTWORTHY, EXPLAINABLE AND RESPONSIBLE
   COMPUTATIONAL INTELLIGENCE, CITREX COMPANION},
Year = {2025},
Note = {2025 Symposium on Explainable, Responsible, and Trustworthy
   Computational Intelligence-CITREx, Trondheim, NORWAY, MAR 17-20, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; IEEE
   Computational Intelligence Society},
Abstract = {Crime is one of the most significant societal challenges, that poses a
   serious threat to public safety and individuals. Predicting crime
   accurately can assist governments, law enforcement, and communities in
   implementing effective crime prevention strategies. For this reason,
   recently, machine learning approaches have been applied to identify
   patterns and trends in crime occurrences and, as a consequence, predict
   crimes. However, these techniques, despite their good performance, have
   the drawback of producing incomprehensible decisions, which could limit
   their use in the real context. To address this limitation, this paper
   introduces the use of an explainable artificial intelligence technique,
   namely Local Interpretable Model-agnostic Explanations (LIME), to
   provide explanations for crime predictions generated by neural networks.
   The experimental results demonstrate that LIME is a good approach to
   understand the rationale behind machine learning-based crime prediction.},
