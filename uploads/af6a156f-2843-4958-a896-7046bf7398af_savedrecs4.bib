@article{ WOS:001450421900001,
Author = {Ding, Xin-Qian and Chen, Hui and Liu, Jie and Liu, Yu-Zhan and Wang,
   Xiao-Hua (Frank)},
Title = {AI-induced behaviors: bridging proactivity and deviance through
   motivational insights},
Journal = {JOURNAL OF MANAGERIAL PSYCHOLOGY},
Year = {2025},
Month = {2025 MAR 25},
Abstract = {PurposeDrawing on the approach-avoidance framework, this paper examines
   the effects of artificial intelligence (AI) usage on employee proactive
   behavior and deviant behavior by focusing on the mediating role of
   AI-related approach motivation and AI-related avoidance
   motivation.Design/methodology/approachTime-lagged data were collected
   using a field survey research design. The participants included 587
   employees from over a dozen Internet companies, technology firms,
   intelligent medical and smart city companies in Beijing and Hebei,
   China.FindingsAI usage is positively related to both AI-related approach
   motivation and AI-related avoidance motivation. In addition, AI-related
   approach motivation mediates the positive relationship between AI usage
   and proactive behavior, AI-related avoidance motivation mediates the
   positive relationship between AI usage and deviant
   behavior.Originality/valueFirst, this paper examines the double-edged
   sword effect of AI usage, reconciling the contradictory findings in
   previous research and providing a more comprehensive and balanced
   perspective for understanding the impacts of AI usage on employees.
   Second, this paper identified proactive behavior and deviant behavior as
   two novel outcomes of AI usage. Third, this paper further extends the
   application of the approach-avoidance framework in the management
   literature.},
