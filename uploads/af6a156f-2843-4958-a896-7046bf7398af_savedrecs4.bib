@inproceedings{ WOS:001511158700471,
Author = {Alshamsi, Abdulla and Abu Ali, Najah},
Book-Group-Author = {IEEE},
Title = {Detection of Anomalies in Crowds using Smart City Infrastructure and
   Machine Learning},
Booktitle = {GLOBECOM 2024-2024 IEEE GLOBAL COMMUNICATIONS CONFERENCE},
Series = {IEEE Global Telecommunications Conference (Globecom)},
Year = {2024},
