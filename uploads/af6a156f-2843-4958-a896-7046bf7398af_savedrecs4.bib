@inproceedings{ WOS:000474459000003,
Author = {Siddiqui, Sarah Ali and Mahmood, Adnan},
Book-Group-Author = {ACM},
Title = {Towards Fog-based Next Generation Internet of Vehicles Architecture},
Booktitle = {PROCEEDINGS OF THE 1ST INTERNATIONAL WORKSHOP ON COMMUNICATION AND
   COMPUTING IN CONNECTED VEHICLES AND PLATOONING (C3VP'18)},
Year = {2018},
Pages = {15-21},
Note = {1st MobiCom International Workshop on Communication and Computing in
   Connected Vehicles and Platooning (C3VP), New Delhi, INDIA, OCT 29, 2018},
Organization = {Assoc Comp Machinery; ACM SIGMOBILE; MobiCom},
Abstract = {Internet of Vehicles (IoV) is an integral component of the Intelligent
   Transportation System (ITS) with the vision to acquire and process data
   for improving traffic safety. In IoV, vehicles communicate by exchanging
   messages with other vehicles and roadside infrastructure subsequently
   generating a large volume of data often referred to as big data, and
   which demands a massive storage and high computational capability with
   minimal possible delay. The aim of this paper is to take a step forward
   in outlining the current state-of-the-art in IoV and analyzing the
   improved data processing and storage features by utilizing big data
   analytics and fog computing paradigm. We further presented a preliminary
   simulation result to demonstrate that the introduction of fog improves
   the overall system performance by ensuring low-latency critical for
   especially vehicular safety applications. Moreover, this paper briefly
   discusses a fog computing based IoV crime assistant and highlight some
