@article{ WOS:000454935900014,
Author = {Casey, Eoghan and Ribaux, Olivier and Roux, Claude},
Title = {The Kodak Syndrome: Risks and Opportunities Created by Decentralization
   of Forensic Capabilities},
Journal = {JOURNAL OF FORENSIC SCIENCES},
Year = {2019},
Volume = {64},
Number = {1},
Pages = {127-136},
Month = {JAN},
Abstract = {Forensic science laboratories are being challenged by the expanding
   decentralization of forensic capabilities, particularly for digital
   traces. This study recommends laboratories undertake digital
   transformations to capitalize on the decentralization movement, develop
   a more comprehensive understanding of crime and security-relevant
   problems, and play a more central role in problem-solving
   collaboratively with law enforcement organizations and other
   stakeholders. A framework for the bilateral transfer of information and
   knowledge is proposed to magnify the impact of forensic science
   laboratories on abating crime, strengthening security, and reinforcing
   the criminal justice system. To accomplish digital transformations,
   laboratories require personnel with different expertise, including
   investigative reasoning, knowledge codification, data analytics, and
   forensic intelligence. Ultimately, this study encourages managers,
   educators, researchers, and policymakers to look beyond the usefulness
   of forensic results for solving individual investigations, and to
   realize the value of combined forensic knowledge and intelligence for
   developing broader strategies to deal with crime in digitalized society.},
