@inproceedings{ WOS:000465766800200,
Author = {Gunes, Omer and Cole, Nicholas and Bates, Sebastian and
   Topp-Mugglestone, Jonas},
Editor = {Tong, H and Li, Z and Zhu, F and Yu, J},
Title = {Ask George Washington on Negotiated Texts with Quill Q\&A},
Booktitle = {2018 18TH IEEE INTERNATIONAL CONFERENCE ON DATA MINING WORKSHOPS (ICDMW)},
Series = {International Conference on Data Mining Workshops},
Year = {2018},
