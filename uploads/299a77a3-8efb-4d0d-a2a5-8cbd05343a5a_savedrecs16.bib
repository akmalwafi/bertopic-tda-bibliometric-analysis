@article{ WOS:001487461100001,
Author = {Golomingi, Raffael and Ebert, Lars and Ehrlich, Claudia and
   Franckenberg, Sabine},
Title = {Big data in forensic medicine - development of a first forensic
   pathology database},
Journal = {AUSTRALIAN JOURNAL OF FORENSIC SCIENCES},
Year = {2025},
Month = {2025 MAY 14},
Abstract = {This article highlights the difficulties that researchers face when
   analysing forensic medical data and how the development of a forensic
   pathology database can help overcome these challenges. The authors
   created a first prototype of a forensic pathology database. The database
   includes various data points, such as sex, age, height, weight,
   examination and autopsy details, for each case. Additionally, data from
   whole-body post-mortem computed tomography were reviewed. The database
   was built using PostgreSQL (c) and a web and desktop user interface. A
   form was created for each report, allowing easy data entry,
   modification, and deletion. The database scheme was designed with a
   primary focus on the main table containing essential case details such
   as age, height, weight, date and time of death (interval). Intermediate
   tables were used to model additional information through a one-to-many
   relationship with the main table. The fully automated analysis enabled
   by the database has the potential to provide new insights into
   unexplained deaths and contribute to the development of new techniques
   and technologies in forensic pathology. The authors anticipate that
   already this database prototype and especially its future updated
   versions will be a valuable resource for researchers seeking to analyse
   forensic medical data and advance the field of forensics.},
