@inproceedings{ WOS:001103230800017,
Author = {Moreira de Morais, Joao Pedro and de Campos Merschmann, Luiz Henrique},
Book-Group-Author = {ACM},
Title = {A Cascade Approach for Gender Prediction from Texts in Portuguese
   Language},
Booktitle = {PROCEEDINGS OF THE 28TH BRAZILIAN SYMPOSIUM ON MULTIMEDIA AND THE WEB,
   WEBMEDIA 2022},
