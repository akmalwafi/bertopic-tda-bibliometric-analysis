Organization = {IEEE; VAIMEE; IEEE Commun Soc},
Abstract = {We analyzed ML-based In-Vehicle Intrusion Detection Systems (IV-IDS).
   Our review of recent automotive forensics studies highlights constraints
   relevant to in-vehicle networks and the associated security/safety
   requirements, revealing gaps in the existing literature. This paper
   contributes to the existing research corpus by addressing AI's
   limitations in IV-IDS. It defines pertinent baseline metrics for
   in-vehicle networked systems, enabling an assessment of the viability of
   AI-based intrusion detection systems.},
