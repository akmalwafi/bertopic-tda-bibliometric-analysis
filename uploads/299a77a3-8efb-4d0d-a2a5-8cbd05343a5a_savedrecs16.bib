Note = {3rd International Conference on Artificial Intelligence and Big Data
   (ICAIBD), ELECTR NETWORK, MAY 28-31, 2020},
Organization = {IEEE; Sichuan Province Comp Federat},
Abstract = {People can access their files for using cloud computing technology
   conveniently and deploy commonly used applications. In the meantime,
   cloud services also can be utilized by criminals to commit malicious
   activities, and the criminal acts is hard to track because the crime
   detail information would be easily lost at the data deluge of cloud
   environment. To perform investigation in cloud efficiently, many digital
   forensics frameworks are used to cloud environment. In this paper we
   present a cloud forensics framework that based on data mining technique,
   and it is divided into four layers: abstract layer, information
   collection layer, data storage layer and information fusion layer. In
   order to analysis and segregate the relevance evidence for proving
   crime, we propose employ fusion clustering algorithm to analyze data
   information in information fusion layer.},
