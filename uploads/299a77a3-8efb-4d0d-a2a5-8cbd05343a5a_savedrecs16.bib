   Olufunmilayo Joyce and Adeniyi, Jide Kehinde},
Editor = {Themistocleous, M and Papadaki, M},
Title = {Naive Bayes Based Classifier for Credit Card Fraud Discovery},
Booktitle = {INFORMATION SYSTEMS (EMCIS 2021)},
