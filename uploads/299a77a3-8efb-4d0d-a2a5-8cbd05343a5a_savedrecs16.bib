@inproceedings{ WOS:000612963500046,
Author = {Bin Yousuf, Saad and Sajid, Hasan and Poon, Simon and Khushi, Matloob},
Editor = {Gedeon, T and Wong, KW and Lee, M},
Title = {IMDB-Attire: A Novel Dataset for Attire Detection and Localization},
