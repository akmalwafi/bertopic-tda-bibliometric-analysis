@article{ WOS:000456066800004,
Author = {Shanken, Andrew M.},
Title = {Unit: A Semantic and Architectural History},
Journal = {REPRESENTATIONS},
Year = {2018},
Number = {143},
Pages = {91-117},
Month = {SUM},
Abstract = {This essay peers through the peephole of the word unit to reveal the
   word's journey across multiple fields from the mid-nineteenth century
   through the present. A keyword hidden in plain sight, unit links science
   and the world of measurement to society (family units), politics
