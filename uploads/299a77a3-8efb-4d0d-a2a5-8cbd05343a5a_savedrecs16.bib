@inproceedings{ WOS:000786794700015,
Author = {Pop, Gheorghe and Burileanu, Dragos},
Book-Group-Author = {IEEE},
Title = {Towards Detection of Synthetic Utterances in Romanian Language Speech
   Forensics},
