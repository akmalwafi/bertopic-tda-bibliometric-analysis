@article{ WOS:001416979700001,
Author = {Xu, Yibin and Yang, Huaquan and Bian, Shan and Wang, Chuntao and Li, Bin
   and Huang, Jiwu},
Title = {Inter-frame residual frequency-based reconstruction learning for deep
   video frame interpolation detection},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2025},
Volume = {269},
Month = {APR 15},
Abstract = {With the emergence of Deep Learning-based Video Frame Interpolation
   techniques (DVFI), faked high frame rate video can be synthesized
   directly or spliced imperceptibly using different frame rate videos
   without visible artifacts. While the existing detectors achieve high
   accuracy in identifying videos generated by traditional VFI models, they
   face two challenges: detecting videos synthesized by deep learning
   models that diminish visual traces, as well as identifying videos
   employing unknown interpolation methods and varying frame rate modes. To
   address these limitations, we propose a novel end-to-end DVFI detection
   framework that emphasizes the consistent representations of original
   videos based on inter-frame residual frequency-based reconstruction
   learning. By forcing the reconstruction module to learn only the
   inter-frame residual frequencies over the original videos, the faked
   high frame rate videos will collapse after reconstruction even if they
   are generated by unknown interpolation methods and frame rate modes. To
   further mine the essential discrepancy between original and interpolated
   frames, we utilize the differences between the latent features from
   different frequency reconstruction modules as guided information to
   build an attention module. Extensive experiments on the DVFI video
   datasets created by five state-of-the-art DVFI methods demonstrate that
   the proposed method outperforms the state-of-the-art approaches.},
