@article{ WOS:000894356000001,
Author = {Palace, Marek and Frankel, Rachel and Shortland, Neil and Jinag, Wenping
   and May, Brandon and Jones, Anthony and Starkey, Jennie},
Title = {CCTV operators' perspectives on protecting soft target terrorist
   locations in England},
Journal = {CRIME PREVENTION \& COMMUNITY SAFETY},
Year = {2023},
Volume = {25},
Number = {1},
Pages = {82-93},
Month = {MAR},
Abstract = {Despite the significant importance of surveillance in counterterrorism,
   the CCTV operators' perspectives appear to be under-researched. To
   explore such perspectives, we conducted a number of semi-structured
   interviews with British security professionals tasked with CCTV
   monitoring of public spaces, and subjected their responses to the
   thematic analysis. Four themes emerged: challenges to the use of CCTV
   systems, criticism of operator roles in counterterrorism, need for
   improvements, and the value of CCTV in counterterrorism. While offering
   a critical view of current CCTV use in soft target (i.e., vulnerable)
   locations, these findings also highlight the value of CCTV in terms of
   deterrence, and support the Actor Actor-Network Theory {[}Terzi, Tesam
   Akad Derg 6(1):213-247]. As national security is increasingly looking to
   even more advanced technology for solutions (e.g., artificial
   intelligence), this exploratory research highlights the need for closer
   integration of human and technological actors, operator empowerment and
   continuous training that must be informed by actual CCTV operators who
   present themselves as marginalised.},
