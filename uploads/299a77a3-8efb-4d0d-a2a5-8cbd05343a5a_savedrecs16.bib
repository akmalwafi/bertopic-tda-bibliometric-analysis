@article{ WOS:001028372000001,
Author = {Roy, Subham and Chowdhury, Indrajit Roy},
Title = {Three Decades of GIS Application in Spatial Crime Analysis: Present
   Global Status and Emerging Trends},
Journal = {PROFESSIONAL GEOGRAPHER},
Year = {2023},
Volume = {75},
Number = {6},
Pages = {882-904},
Month = {NOV 2},
Abstract = {Crime exploration using geographic information systems (GIS) has been a
   topic of interest for decades, but a comprehensive appraisal has yet to
   be published in the domain. This is the first article to thoroughly
   explain crime exploration using GIS from a global perspective, analyze
   its large information base, and assess its evolving dynamics.
   Bibliometric analysis was carried out using the Bibliometric R-tool and
   VOSviewer, which are both software tools that provide a systematic
   overview, assisting scholars in acquiring insights into this domain. For
   this assessment, 755 academic documents published between 1989 and 2022
   were retrieved from the SCOPUS metadata. The database has been examined
   and mapped using various criteria, including yearly publication outputs,
   production and influence assessment, citations, networks, and keyword
   analysis. The search revealed numerous intriguing details like the most
   significant documents, most relevant authors, most notable countries,
   prominent institutions and their areas of research interest, journals
   publishing in the domain, and emerging research trends. The use of
   cluster analysis further delineates three major research areas: the
   relevance of geospatial technology in spatial crime analysis, crime
   mapping and visualization, and crime prediction using advanced machine
   learning techniques. Finally, this bibliometric investigation also
   reveals that crime forecasting is an emerging trend.},
