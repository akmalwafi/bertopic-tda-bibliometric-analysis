@article{ WOS:000772819600001,
Author = {Brodskiy, V, A. and Gorbachev, V. A. and Karpov, O. E. and Konyavsky, V.
   A. and Kuznetsov, N. A. and Raigorodskii, A. M. and Trenin, S. A.},
Title = {Identification in Computer Systems of the Digital Economy},
Journal = {JOURNAL OF COMMUNICATIONS TECHNOLOGY AND ELECTRONICS},
Year = {2021},
Volume = {66},
Number = {SUPPL 1, 1},
Pages = {S1-S7},
Month = {DEC},
Abstract = {In this paper, we propose a new method of interactive identification:
   trusted identification of a person using untrusted devices (for example,
   smartphones, tablets, etc.). It is shown that static, immutable, or
   almost immutable biometric features can be used in forensic science, but
   it is inappropriate for computer systems of the digital economy. As
   signs, the use of fingerprints, the iris and retina of the eye, the
   pattern of the vascular bed, and similar ones are ineffective. On the
   contrary, it is necessary to use dynamic characteristics that are
   immanently inherent in a person and reflected, for example, in reflexes.
   As such, eye movements during reading and/or tracking the stimulus,
   saccades, pulse wave, and others can be used. To make a decision, it is
   proposed to use artificial neural networks.},
