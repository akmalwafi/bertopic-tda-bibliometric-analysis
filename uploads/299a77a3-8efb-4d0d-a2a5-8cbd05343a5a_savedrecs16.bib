   Riegler, Michael A. and Halvorsen, Pal and Johansen, Dag},
Book-Group-Author = {ASSOC COMP MACHINERY},
Title = {Dutkat: A Multimedia System for Catching Illegal Catchers in a
   Privacy-Preserving Manner},
Booktitle = {ICDAR `21: PROCEEDINGS OF THE 2021 WORKSHOP ON INTELLIGENT CROSS-DATA
   ANALYSIS AND RETRIEVAL},
Year = {2021},
