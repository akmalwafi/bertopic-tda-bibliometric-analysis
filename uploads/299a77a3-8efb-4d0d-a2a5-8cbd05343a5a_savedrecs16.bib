@article{ WOS:000695695100027,
Author = {Atlam, Hany F. and Hemdan, Ezz El-Din and Alenezi, Ahmed and Alassafi,
   Madini O. and Wills, Gary B.},
Title = {Internet of Things Forensics: A Review},
Journal = {INTERNET OF THINGS},
Year = {2020},
Volume = {11},
Month = {SEP},
Abstract = {The rapid growth of Internet of Things (IoT) devices brings countless
   benefits, but it also brings new security and forensics challenges. The
   IoT system with billions of devices generates a huge amount of evidence
   which causes big challenges to digital investigators and practitioners
   who are required to interact with IoT devices to investigate cybercrimes
   in a forensically sound and timely fashion. These challenges create more
   opportunities for cybercrimes to attack various IoT application and
   services resulting in a direct impact on IoT users. As the IoT has
   incorporated in most aspects of our life, cybercrimes will literally
   threaten human life, hence, IoT forensics is required to investigate and
   mitigate against such attacks. Therefore, this paper provides a detailed
   review of IoT forensics. It started by providing a comprehensive
   discussion of IoT security involving the need for security by design and
   security challenges of the IoT system. Then, a review of IoT forensics
   is presented by highlighting the need for Artificial Intelligence (AI)
   in IoT forensics, state-of-theart research and recent studies,
   opportunities and key requirements for a successful IoT forensics.
   Challenges and suggested solutions of IoT forensics are also discussed.
   Finally, a discussion of open research directions of IoT forensics is
   presented. (C) 2020 Elsevier B.V. All rights reserved.},
