Booktitle = {DEEP FAKES, FAKE NEWS, AND MISINFORMATION IN ONLINE TEACHING AND
   LEARNING TECHNOLOGIES},
Series = {Advances in Educational Technologies and Instructional Design Book
   Series},
Year = {2021},
Pages = {186-205},
Abstract = {Social media is one of the topmost communications in the present world
   and some discomforts are also hidden in this. Social media is one of the
   platforms for cyberbullying. Teenagers who are not under the guidance of
   their parents are the major victims of cyberstalking and cyber abuses.
   Forensic image processing enhances the digital image using different
   computer techniques. Deep fake uses the technology to superimpose more
   than one image, video, and audio with other images, videos, and audios
   with the well-known artificial intelligence and generative adversarial
   networks (GANs). This technology raises the curtain to create many fake
   images, fake videos, especially porn videos and fake audios of
   celebrities, especially actors and politicians. This chapter explains
   the impacts of deep fakes in social media, especially Facebook and
   Twitter. This chapter proposed a new framework called the
   extended-RACYBDD to detect the deep attacks.},
