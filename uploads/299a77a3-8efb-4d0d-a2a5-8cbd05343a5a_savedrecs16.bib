@article{ WOS:001440881600001,
Author = {Bhavani, Y. V. K. Durga and Pagi, V. B.},
Title = {The NovelHAD algorithm to detect presence of human activity in videos
   based on MediaPipe pose and human landmarks},
Journal = {COGENT SOCIAL SCIENCES},
Year = {2025},
Volume = {11},
Number = {1},
Month = {DEC 31},
Abstract = {Video surveillance is one of the best tools available today for
   detecting and preventing workplace fraud and other unwanted activity.
   This study aims to find the presence of human activity (no activity or
   activity) in the CCTV video footage. This study develops a novel
   algorithm called NovelHAD based on the human kinematic prototype anatomy
   and the MediaPipe Pose (MPP) landmark detector feature extraction
   technique. The movements toward a person's hands and legs indicate human
   activity. The distances between the human landmarks or feature vectors
   (LEFT\_HIP, LEFT\_ELBOW), (RIGHT\_HIP, RIGHT\_ELBOW), and (LEFT\_ANKLE,
   RIGHT\_ANKLE) were measured in Euclidean space to capture the motions.
   The UCF-101 Crime public dataset is used to investigate the presence of
   human activity. The experiment's findings indicate a 95\% accuracy.},
