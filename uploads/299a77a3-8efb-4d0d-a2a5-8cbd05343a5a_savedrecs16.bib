@article{ WOS:001251583500001,
Author = {Raya-Tapia, Alma Yunuen and Ramirez-Marquez, Cesar and Ponce-Ortega,
   Jose Maria},
Title = {Clustering of zones according to the level of gentrification by using an
   unsupervised learning algorithm},
Journal = {CITIES},
Year = {2024},
Volume = {151},
Month = {AUG},
Abstract = {Gentrification occurs when there is a physical displacement of people
   with lower socioeconomic status, because they cannot cope with the
   rising cost of living caused by the influx of new neighbors with higher
   status. This paper proposes to cluster areas according to their degree
   of gentrification based on 46 features, by using the Kmeans machine
   learning algorithm. The methodology was applied to a case study of the
   16 municipalities of Mexico City. When characterizing the profiles of
   each cluster, it was found that municipalities with high gentrification
   have more hotels, restaurants and newcomers, and yet more crimes are
   committed per inhabitant. There is more housing with access to services,
   but above all, they have the highest housing prices and the lowest
   percentage of people with their own homes. More people are affiliated
   with medical services and in a better economic and educational
   situation. Conversely, in municipalities with low gentrification, there
   are more people with low literacy rates and living in poor conditions,
   in addition to having incomes below the poverty line. A dimension
   reduction was applied by using principal component analysis. The first
   principal component distinguishes between high and low gentrification
   municipalities, while the second one distinguishes medium gentrification
   municipalities.},
