Note = {IEEE International Conference on Consumer Electronics (ICCE), Las Vegas,
   NV, JAN 06-08, 2023},
Organization = {IEEE; Telus; Consumer Technol Assoc; IEEE Consumer Technol Soc},
Abstract = {Manipulated images are a threat to consumers worldwide, when they are
   used to spread disinformation. Therefore, Comprint enables forgery
   detection by utilizing JPEGcompression fingerprints. This paper
   evaluates the impact of the training set on Comprint's performance. Most
   interestingly, we found that including images compressed with low
   quality factors during training does not have a significant effect on
   the accuracy, whereas incorporating recompression boosts the robustness.
   As such, consumers can use Comprint on their smartphones to verify the
   authenticity of images.},
