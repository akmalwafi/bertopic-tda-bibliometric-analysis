@inproceedings{ WOS:000330569800085,
Author = {Song, Ming and Xiong, Gang and Li, Zhenzhen and Peng, Junrui and Guo, Li},
Book-Group-Author = {IEEE},
Title = {A De-anonymize attack method based on traffic analysis},
Booktitle = {2013 8TH INTERNATIONAL ICST CONFERENCE ON COMMUNICATIONS AND NETWORKING
   IN CHINA (CHINACOM)},
Year = {2013},
Pages = {455-460},
Note = {8th International ICST Conference on Communications and Networking in
   China (CHINACOM), Guilin, PEOPLES R CHINA, AUG 14-16, 2013},
Organization = {European Alliance Innovat; IEEE; ICST; IEEE Comp Soc},
Abstract = {While providing protection for users' privacy, anonymity network has
   also been exploited by criminals to carry out crime anonymously. We
   study the problem how to break the unlinkability between the senders and
   recipients in order to identify the source of anonymous traffic in this
   paper. Tor, the most widely deployed anonymity network, is selected as
   our target. We develop a de-anonymize attack method based on traffic
   analysis and choose the \{time, stream size\} as features for k-means
   algorithm to mine the association between the first hop traffic and last
   hop traffic of Tor. Experiments show that our method is effective for
   Tor.},
