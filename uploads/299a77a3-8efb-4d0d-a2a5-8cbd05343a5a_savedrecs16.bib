Organization = {The International Society for Optics and Photonics},
Abstract = {In recent years, the rapid advancement of computer science and
   artificial intelligence technology has given rise to numerous digital
   tools, significantly enhancing people's lives. Nevertheless, while
   enhancing convenience, these technologies have simultaneously posed
   numerous new challenges. Many forged images generated by deepfake
   technology are uploaded by criminals to social media for
   telecommunications fraud and new type network-involved crimes, which
   puts forward higher requirements for the public security organs to study
   deepfake detection and counter telecommunications fraud. This paper
   reviews the current development and crime status of deepfake technology,
   studies the technical characteristics of deepfake technology used in
   telecom fraud and network-involved crimes, and tests the feasibility of
   classification and detection of deepfake images using neural network
   model. Finally, from the perspective of public security and social
   governance, it puts forward suggestions on governance and management of
   deepfake in social media. It is hoped that the research content can
   improve the public's understanding of deepfake technology, and improve
   the effectiveness of public security organs in identifying and
   countering telecom fraud and network-involved crimes using deepfake
   technology.},
