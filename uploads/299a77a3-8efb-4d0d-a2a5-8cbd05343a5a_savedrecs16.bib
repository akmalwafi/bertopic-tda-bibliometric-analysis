@article{ WOS:001504330800002,
Author = {Zhu, Mi and He, Maoyun and Chen, Yaoqing and Cai, Yinzhuo and Cao, Dan},
Title = {Forensic identification of tears from different ethnic groups in China
   using portable infrared spectral analysis and swarm intelligence
   algorithms},
Journal = {MICROCHEMICAL JOURNAL},
Year = {2025},
Volume = {214},
Month = {JUL},
Abstract = {The characterization of bio-individual information is a critical aspect
   of forensic anthropology, particularly in the identification of
   geographic origin, gender, age, and ethnicity. Tears, as a form of
   bodily fluid, hold potential forensic value. Even minute tear deposits
   can serve as crucial evidence in cases where other biological materials
   are unavailable, assisting in identity establishment. When additional
   evidence is present, the analysis of tears can provide complementary
   information, contributing to crime scene reconstruction and forensic
   investigations. In this study, we investigated the potential of infrared
   spectral analysis combined with machine learning algorithms for
   identifying tear samples from individuals of different ethnic groups in
   China. Infrared spectral data were collected from tear samples across
   five ethnic groups, revealing distinct spectral differences among ethnic
   groups. To further validate these differences, a PCA-LDA model was
   constructed. To enhance classification accuracy, we employed Support
   Vector Machine (SVM) and Kernel Extreme Learning Machine (KELM) models,
   optimizing them using six swarm intelligence algorithms: Particle Swarm
   Optimization (PSO), Artificial Fish Swarm Algorithm (AFSA), Whale
   Optimization Algorithm (WOA), Elephant Herding Optimization (EHO), Grey
   Wolf Optimization (GWO), and Grasshopper Optimization Algorithm (GOA).
   We systematically analyzed the feasibility of ethnic classification,
   demonstrating the optimization search process and adaptability curves of
   various algorithms. Model performance was evaluated using accuracy,
   F-value, and AUC. Notably, the SVM model optimized by the AFSA algorithm
   achieved the highest accuracy of 99.68 \% across all samples,
   highlighting the efficacy of optimization strategies in improving
   classification performance. The proposed method offers a rapid and
   nondestructive approach for distinguishing trace biological evidence in
   forensic anthropology. Attempt to classify human ethnic groups based on
   tear spectral profiles, offering a new pathway for population
   differentiation using non-invasive micro-trace evidence.},
