@article{ WOS:001502514400002,
Author = {Zhong, Qikang and Fang, Congying and Fu, Hongpeng},
Title = {How does built environment influence outdoor jogging activities in
   high-density cities? New insights using machine learning from 2D/ 3D
   perspectives},
Journal = {SUSTAINABLE CITIES AND SOCIETY},
Year = {2025},
Volume = {128},
Month = {JUN 15},
Abstract = {Current urban environmental assessment methods and the mechanisms
   influencing jogging overlook spatial multidimensionality, which may lead
   to the misallocation of environmental spatial resources and exacerbate
   the differentiation of outdoor jogging activities. This study used
   jogging trajectories and street view data in the main urban areas of
   Hangzhou in 2021 and analyzed 2D and 3D built environments using kernel
   density estimation and CRITIC weighting modeling. By adopting methods
   including random forest and geographic weighted regression modeling, it
   explored the relationship of 2D and 3D built environment factors on
   outdoor jogging activities. The results indicate that: (1) Accessibility
   and coverage of blue-green spaces are the main factors affecting outdoor
   jogging activities in the 2D built environment (2DBE), while green view
   ratio, terrain coverage, pedestrian flow, boundary separation, and
   facade continuity are key factors in the 3D built environment (3DBE).
   (2) High-quality environmental areas have a higher frequency of jogging
   than low-quality environmental areas. (3) Compared to 3DBE, 2DBE shows a
   higher correlation with jogging. (4) There is environmental inequality
   in the study area, with a Gini coefficient of 0.521 overall. The
   empirical results are conducive to formulating and implementing
   sustainable and healthy urban design strategies from two-dimensional and
   three-dimensional environmental perspectives.},
