@article{ WOS:001521025400001,
Author = {Srivastava, Ravi Prakash and Dahiya, Sanjay and Nehra, Aashish},
Title = {IoT-HITS: An IoT Based Human Intrusion DeTection System for Border
   Region Using Deep Learning},
Journal = {IETE JOURNAL OF RESEARCH},
Year = {2025},
Month = {2025 JUL 2},
Abstract = {Invaders are the focus of intrusion detection. Although it is important,
   intrusion detection systems cannot actually detect intrusions; they can
   only identify signs of them. In light of the growing importance of
   security services throughout the internet network ecosystem, traditional
   methods are proving insufficient to keep up with the demand for
   innovative new capabilities and features. Therefore, the drawbacks of
   the intrusion system handled manually by traditional bodies must be
   mentioned when discussing security parameters in border areas. The
   installation of a closed circuit television system has significantly
   improved safety. Of course, this raises the question How Does it work to
   identify criminals and suspicious characters in a given area? It is safe
   to assume that what you will receive is a resounding No in response to
   that inquiry. By merging the strengths of the IoT paradigm with those of
   image processing algorithms, research aims to enhance current intruder
   detection systems. This system will actively interact with the
   controlling agent that does so via the cloud server in order to provide
   the supplementary manageability alert. The preliminary experimental
   findings are encouraging, but there is still a way to go before the goal
   of maximum efficiency is reached. The proposed model has a high
   identification rate of 98.2\% for COCO and 98.5\% for KITTI,
   demonstrating accurate object detection.},
