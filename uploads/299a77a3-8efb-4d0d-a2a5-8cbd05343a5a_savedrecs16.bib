   Cheng, Dawei and Xie, Li and Tian, Huaming},
Editor = {Sheng, QZ and Dobbie, G and Jiang, J and Zhang, X and Zhang, WE and Manolopoulos, Y and Wu, J and Mansoor, W and Ma, C},
Title = {GEM-GNN: Group Enhanced Multi-relation Graph Neural Networks for Fraud
   Detection},
Booktitle = {ADVANCED DATA MINING AND APPLICATIONS, ADMA 2024, PT III},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2025},
Volume = {15389},
