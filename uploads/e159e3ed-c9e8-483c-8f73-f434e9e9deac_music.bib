@inproceedings{ WOS:001160842700061,
Author = {Viramgami, Gaurav and Gandhi, Hitarth and Naik, Hrushti and Mahajan,
   Nipun and Venkatesh, Praveen and Sahni, Shivam and Singh, Mayank},
Book-Group-Author = {ACM},
Title = {Indian Classical Music Synthesis},
