@article{ WOS:001761748100004,
Author = {Suteu, Ligia-Claudia},
Title = {The Intersection of Music Pedagogy and Digital Technology: New
   Epistemological and Methodological Models},
Journal = {INFORMATION AND COMMUNICATION TECHNOLOGY IN MUSICAL FIELD},
Year = {2026},
Volume = {17},
Number = {1},
Pages = {35-44},
Abstract = {Over the past two decades, digitization has transformed musical
   practices, learning repertoires, and the ways knowledge about music is
   produced. This article proposes a theoretically grounded and
   methodologically diverse framework for music pedagogy in the digital
   age. Epistemology is reframed by integrating praxial, sociocultural, and
   cognitive-neuroscientific perspectives with work on epistemic cultures
   and practice-based research. Methodological models are outlined, such as
   learning analytics, and epistemic network analysis to study digitally
   mediated musicking. An integrative matrix aligns TPACK and SAMR with
   composition, performance, improvisation, and listening, including uses
   of generative AI. The article argues for a shift toward inquiry- and
   creativity-centred pedagogies where digital and scalable yet
   context-sensitive research designs.},
