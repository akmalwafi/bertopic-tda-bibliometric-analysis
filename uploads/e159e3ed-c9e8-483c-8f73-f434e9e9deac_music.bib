@article{ WOS:001759825700001,
Author = {Li, Lianghua},
Title = {Application of Artificial Intelligence in Computer-Aided Music
   Composition for Artistic Innovation},
Journal = {JOURNAL OF CASES ON INFORMATION TECHNOLOGY},
Year = {2026},
Volume = {28},
Number = {1},
Abstract = {In recent years, computer-aided composition systems have evolved from
   rule-based approaches to advanced deep neural networks, significantly
   improving both the efficiency and diversity of music creation.
   Artificial intelligence (AI) systems now have the ability to simulate a
   wide range of musical styles, generate melodies, and innovate complex
   structures. This paper provides a comprehensive review of the
   theoretical foundations behind current AI composition models, analyzing
   key challenges in music style transfer, melody generation, and related
   areas. Based on this analysis, a novel multi-level neural network
   composition framework is proposed and experimentally validated. The
   study demonstrates the effectiveness of the proposed method, offering
   new insights into music creation empowered by AI.},
