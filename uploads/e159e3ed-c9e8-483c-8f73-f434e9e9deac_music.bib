   Kasthurirathna, Dharshana},
Book-Group-Author = {IEEE},
Title = {Harmony Verse: Exploring AI-Driven Musical Composition through
   Innovative Approaches},
Booktitle = {2024 4TH INTERNATIONAL CONFERENCE ON COMPUTER COMMUNICATION AND
   ARTIFICIAL INTELLIGENCE, CCAI 2024},
Year = {2024},
Pages = {557-562},
Note = {4th International Conference on Computer Communication and Artificial
   Intelligence (CCAI), Xian, PEOPLES R CHINA, MAY 24-26, 2024},
Organization = {IEEE; Xidian Univ; Beijing CAS Spark Inst Informat Technol},
Abstract = {Music consumption has undergone a radical transformation in the digital
   age, with users having access to vast collections and personalized
   recommendations of music. However, several challenges remain in the
   current music landscape, such as generating new music from existing
   songs, classifying music genres, and visualizing trends, synthesizing
   melodies from user vocals, and displaying music according to user
   emotions. This paper proposes innovative solutions for these challenges
   using artificial intelligence (AI) technologies. A lo-fi generator has
   been developed to create unique tracks from existing songs using machine
   learning techniques. Additionally, a music genre classification system
   offers real-time trend analysis and visualization. A melody synthesis
   system generates new songs based on user vocals. An interactive platform
   displays lo-fi music based on user emotions. Solutions are evaluated
   using various metrics to demonstrate their effectiveness and potential
   in enhancing music consumption experiences. This project contributes to
   the advancement of music generation, recommendation, and emotional
   experience fields, providing users with novel and personalized music
   solutions that cater to their individual preferences and emotions.},
