@inproceedings{ WOS:001285850000106,
Author = {Joung, Haesun and Lee, Kyogu},
Book-Group-Author = {IEEE},
Title = {MUSIC AUTO-TAGGING WITH ROBUST MUSIC REPRESENTATION LEARNED VIA DOMAIN
   ADVERSARIAL TRAINING},
Booktitle = {2024 IEEE INTERNATIONAL CONFERENCE ON ACOUSTICS, SPEECH AND SIGNAL
   PROCESSING, ICASSP 2024},
