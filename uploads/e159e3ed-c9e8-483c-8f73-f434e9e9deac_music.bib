@article{ WOS:000954118200001,
Author = {Yan, Jin and Xia, Xiongjun},
Title = {Interactive Audio-Visual Course Teaching of Music Education Based on VR
   and AI Support},
Journal = {INTERNATIONAL JOURNAL OF HUMAN-COMPUTER INTERACTION},
Year = {2024},
Volume = {40},
Number = {13},
Pages = {3552-3559},
Month = {JUL 2},
Abstract = {People's living standards have gradually improved, people have higher
   and higher requirements at the spiritual level, and music is
   increasingly loved by people. In the process of music development, music
   teaching reform is the focus of the current society. Based on the
   current educational background, the teaching mode of teachers has
   changed, breaking the ecological balance in the traditional classroom,
   which has brought advantages to music teaching. Aesthetic education,
   especially music education, plays a balanced and promoting role in
   intellectual education and even the whole quality education. Music can
   effectively reduce the pressure of intellectual education itself on
   students' bodies and minds, so that intellectual education can achieve
   better results. Virtual reality (VR) and artificial intelligence (AI),
   as the latest technologies in the new century, have been rapidly
   integrated into the music education (ME) industry. By applying VR and AI
   technologies to the music teaching process, students' learning ability
   can be effectively improved. Through the use of VR and AI technology,
   this text has created an interactive curriculum teaching mode and
   verified the feasibility of combining VR and AI technology with music
   teaching through experimental analysis. The experimental results show
   that the recognition of bass signal, midrange signal, and treble signal
   has reached 100, 90, and 100\%, respectively. In general, the
   recognition accuracy of the algorithm in this text is very high, which
   can satisfy the requirements of music signal recognition and can be
   applied to daily music teaching.},
