@inproceedings{ WOS:001737926900005,
Author = {Lozano Murcieg, Alvaro and Jimenez-Bravo, Diego M. and de la Iglesia,
   Daniel Hernandez and Blase, Hector Sanchez San and Villarrubia Gonzalez,
   Gabriel},
Editor = {Rocha, A and Garcia-Penalvo, FJ and Goncalves, R and Garcia-Holgado, A and Moreira, F},
Title = {Artificial Intelligence System for Digitization of Traditional Folk
   Music Performances},
Booktitle = {PROCEEDINGS OF 19TH IBERIAN CONFERENCE ON INFORMATION SYSTEMS AND
   TECHNOLOGIES, CISTI 2024, VOL 5},
Series = {Lecture Notes in Networks and Systems},
Year = {2026},
Volume = {1753},
Pages = {50-61},
Note = {19th Iberian Conference on Information Systems and Technologies-CISTI,
   Salamanca, SPAIN, JUN 25-28, 2024},
Organization = {ISEG Lisbon School of Economics and Management; Information and
   Technology Management Association},
Abstract = {Nowadays, in the field of digital humanities and ethnomusicology, the
   preservation and analysis of traditional European folk music presents
   unique challenges and opportunities. This paper introduces an innovative
   Artificial Intelligence (AI) system designed to address these challenges
   by digitizing performances of traditional European folk music. Employing
   artificial intelligence techniques, the system processes pre-recorded
   video performances to extract crucial musical information, including the
   transcription of audio into musical scores and, where applicable, the
   transcription of lyrics. The core functionality of this system leverages
   state-of-the-art techniques in machine learning in the area of audio
   processing, enabling the interpretation and transcription of complex
   musical compositions and vocal performances. The aim of this research is
   to contribute significantly to the preservation and accessibility of
   traditional folk music, highlighting the potential of AI in
   ethnomusicology and digital humanities. This paper details the proposed
   system's architecture, methodologies for audio and video processing, and
   the challenges encountered in capturing the nuances of traditional folk
   music. Preliminary results of the system on a digital archive of
   traditional music from Portugal are presented, and the effectiveness and
   drawbacks of the system in producing detailed and accurate musical and
   lyric transcriptions are discussed. The tool is publicly available for
   musicians, scholars, and enthusiasts of traditional European folk music.},
