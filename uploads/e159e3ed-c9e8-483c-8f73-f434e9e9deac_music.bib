@article{ WOS:001745621700001,
Author = {Xu, Ke and Xu, Bihai and Xie, Zhongju},
Title = {Beyond composer labels: Aesthetic awe in music composed by humans and AI},
Journal = {COMPUTERS IN HUMAN BEHAVIOR},
Year = {2026},
Volume = {182},
Month = {SEP},
Abstract = {Artificial intelligence (AI) technology for music generation has shown
   potential, yet its output is often perceived as unable to evoke the same
   aesthetic or emotional impact as music composed by humans. The AI
   composers bias effect regarding music-induced awe experience has not
   been thoroughly discussed. Therefore, this study aims to examine whether
   this effect exists by incorporating important moderating factors such as
   the actual composers and music dimensions. We recruited 253
   undergraduate students for a 2 \& times; 2 \& times; 4 preregistered
   mixed-design experiment. All participants listened to 24 music excerpts
   covering four music dimensions (reflective \& complex vs. intense \&
   rebellious vs. upbeat \& conventional vs. energetic \& rhythmic), with
   half actually composed by humans and the other half generated by AI. We
   manipulated composers' identities by informing participants whether the
   music they heard was created by AI or humans. Results from linear mixed
   models showed no significant AI composer bias. However, the interaction
   between the actual composer and the musical dimension was observed.
   Human-composed reflective \& complex music and upbeat \& conventional
   dimension evoked stronger awe experiences than their AI-generated
   counterparts; conversely, for intense \& rebellious music and energetic
   \& rhythmic dimension, AI-generated music elicited higher awe ratings.
   These results show the value of AI in music creation and suggest that
   more rational human-machine collaboration models can be explored in
   artistic production.},
Publisher = {PERGAMON-ELSEVIER SCIENCE LTD},
