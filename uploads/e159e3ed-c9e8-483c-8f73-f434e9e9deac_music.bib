@article{ WOS:001020290600002,
Author = {Han, Xiao and Chen, Fuyang and Ullah, Ijaz and Faisal, Mohammad},
Title = {An evaluation of AI-based college music teaching using AHP and MOORA},
Journal = {SOFT COMPUTING},
Year = {2023},
Month = {2023 JUN 29},
Abstract = {Artificial intelligence has developed and advanced to the point where it
   is now effectively implemented in every domain of life, including music.
   The music business is being fundamentally changed by shrewd,
   intellectual methods that rely on AI. These tools make it very easy for
   musicians to create high-caliber music. Today, sophisticated and clever
   robots are capable of creating and composing music, one of the most
   fascinating and priceless works of human ingenuity. Intelligent programs
   based on artificial intelligence have enabled robots to create beautiful
   music without the involvement of any humans. The proposed article is
   focused on the usage of AI-grounded techniques for the learning of music
   and its classification. It shows that with new technologies, highly
   interactive interfaces and classrooms can now be developed for the
   effective and efficient teaching and learning of music. Almost all of
   the students favor the implementation of such methodologies to improve
   their performance in music learning and composition. The need for time
   to employ AI for the quick improvement of the students' musical talent
   allows them to become professionals in their field. The design of
   animated courses with the integration of virtual reality and artificial
   intelligence can enhance the interest of students in learning and
   developing their skills. The study then acquired various important
   characteristics from the existing literature in the area of research and
   selected the most common ones. Then, with the implementation of the
   analytical hierarchy process (AHP), these features are assigned weights.
   For the ranking of the alternatives, the method of multi-objective
   optimization on the basis of research analysis was utilized. AI-based
   methods in music education have several advantages and are
   revolutionizing how students learn about and interact with music.
   Personalized learning, accessible education, improved practice and
   performance, help with composition and arrangement, and music theory and
   analysis are some of the main benefits.},
