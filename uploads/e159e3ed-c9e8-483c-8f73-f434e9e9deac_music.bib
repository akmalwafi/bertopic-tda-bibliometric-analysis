@article{ WOS:001676923700024,
Author = {Chatzigiannakis, Dimitri and Papadopoulou, Agnes},
Title = {Educational Equity at the Geopolitical Frontier A Music-Based Teacher
   Training Case},
Journal = {IAFOR JOURNAL OF EDUCATION},
Year = {2025},
Volume = {13},
Number = {3},
Pages = {643-672},
Abstract = {This paper presents a case study of a music-centered professional
   development program designed to promote educational equity at a
   geopolitical frontier. Taking place on the island of Lesvos in Greece, a
   transcontinental threshold shaped by migration, marginalization and
   resource disparities, the training brought together 36 primary and
   secondary music teachers to explore creative and inclusive uses of
   open-source and AI-assisted tools. Grounded in design-based research and
   guided by A/r/tographic methodology, the session introduced accessible
   technologies with a focus on AI, music composition, sound editing and
   ethical media sourcing for educational settings. Activities included
   hands-on experimentation with diegetic and nondiegetic music and the use
   of AI-generated soundtracks for school projects. Qualitative data from
   reflections, digital artefacts and participant feedback reveal increased
   teacher confidence in integrating digital tools and a stronger awareness
   of music's role in inclusive pedagogy. Four themes characterized the
   experience: enhanced creative confidence through low-barrier
   experimentation, pedagogical imagination in using sound to support
   belonging and non-verbal expression, ethical and cultural awareness
   around authorship and representation in AI tools and a collaborative
   dynamic that reinforced agency through peer dialogue. Teachers
   highlighted the relevance of these approaches for engaging diverse
   student populations, particularly in classrooms serving marginalized and
   culturally diverse learners. This case study shows how focused teacher
   training can foster inclusive pedagogy and support educational equity in
   regions shaped by social and geographic isolation. It adds to ongoing
   conversations about how AI and open-source tools can enrich arts
   education and suggests that creative, community-rooted professional
   development has the potential to inspire change in Europe's educational
   peripheries.},
