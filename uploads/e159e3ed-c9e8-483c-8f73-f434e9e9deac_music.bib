@inproceedings{ WOS:001727147400036,
Author = {Xiao, Yan},
Book-Group-Author = {IEEE},
Title = {How Authorship Labels Shape Perceptions, Attribution Judgments, and
   Willingness to Pay for AI-Human Co-Created Music},
Booktitle = {2025 IEEE INTERNATIONAL SYMPOSIUM ON TECHNOLOGY AND SOCIETY, ISTAS},
Series = {IEEE International Symposium on Technology and Society},
Year = {2025},
Pages = {248-253},
Note = {2025 International Symposium on Technology and Society-ISTAS-Annual,
   Santa Clara University, Santa Clara, CA, SEP 10-12, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {This study investigated how people interpret authorship in AI-human
   co-created music, by examining four dimensions: perceived authorship
   under different labels, attribution thresholds for assigning primary
   authorship to humans, Preferences for transparency, and their
   label-related willingness to pay. This quantitative research collected
   data from a total of 159 participants. The results showed that
   authorship labels significantly influenced both perceived human
   contribution and willingness to pay: for example, ``Human-created with
   AI-assisted arrangement{''} is rated as most human-led. Participants
   required a clear majority (72\% on average) of human involvement to
   credit humans as the primary creators, reflecting a conservative
   standard. As to transparency, most participants preferred detailed,
   task-specific disclosure. Willingness to pay was also higher for label
   indicating greater human involvement. These findings offer practical
   suggestions for labeling strategies that align with both industry
   practices and audience expectations.},
