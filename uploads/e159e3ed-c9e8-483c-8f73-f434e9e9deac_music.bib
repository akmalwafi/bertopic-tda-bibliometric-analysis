@inproceedings{ WOS:001566297200013,
Author = {Wang, Yu and Zuo, Yuanyang and Zhang, Xiaochen},
Editor = {Degen, H and Ntoa, S},
Title = {The Practice and Challenges of ``Human-AI Co-creation{''} in Music
   Composition},
Booktitle = {ARTIFICIAL INTELLIGENCE IN HCI, AI-HCI 2025, PT II},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2025},
Volume = {15820},
Pages = {219-233},
Note = {6th International Conference on Artificial Intelligence in HCI-AI-HCI,
   Goeteborg, SWEDEN, JUN 22-27, 2025},
Abstract = {With the rapid development of artificial intelligence (AI) technology,
   the application of AI in music composition has gradually shifted from a
   simple tool to a partner, driving the transformation of music creation
   methods. This article explores the practice and challenges of AI
   technology in music creation under the ``Human-AI Co-creation{''} model,
   analyzes the development process of AI composition technology and its
   application in the creative process, focuses on the multi-level
   interaction between AI and humans, and explores the impact of AI in the
   music industry through typical cases. At the same time, this article
   also deeply analyzes the artistic originality, emotional expression, and
   technical ethics issues faced by AI composition technology, and proposes
   future development directions. Through these discussions, this article
   aims to explore how ``human intelligence integration{''} can reshape the
   essence of music creation in the era of artificial intelligence, and
   provide theoretical and practical references for music creators and
   researchers.},
