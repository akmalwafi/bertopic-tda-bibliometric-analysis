@article{ WOS:000990402600001,
Author = {Li, Ping-ping and Wang, Bin},
Title = {Artificial Intelligence in Music Education},
Journal = {INTERNATIONAL JOURNAL OF HUMAN-COMPUTER INTERACTION},
