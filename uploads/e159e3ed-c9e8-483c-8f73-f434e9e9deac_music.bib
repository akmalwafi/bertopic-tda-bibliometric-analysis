@article{ WOS:001407537600001,
Author = {Li, Sinan},
Title = {The impact of AI-driven music production software on the economics of
   the music industry},
Journal = {INFORMATION DEVELOPMENT},
Year = {2025},
Volume = {41},
Number = {3, SI},
Pages = {957-967},
Month = {SEP},
Abstract = {The present study aims to determine the impact of AI technology on music
   composition production and the economic aspect of the music industry,
   specifically profitability. Two Chinese labels were investigated.
   Profitability was measured before and after intervention (the
   experimental group operated with varying degrees of AI involvement). The
   involvement of AI in creating musical compositions positively affected
   profitability. The control group received an average income of 2710
   yuan. The experimental group utilizing AI received an average income of
   7654 yuan. Among the compositions of the experimental group, 9 out of 12
   were selected by the client, of which 4 received high ratings. The
   results were statistically significant at the level of p = 0.000.
   Compositions with a moderate level of AI involvement yielded the highest
   profitability, emphasizing the importance of harmonious collaboration
   between humans and technology. The study demonstrated the prospects and
   advantages of integrating generative AI tools into the music industry.},
