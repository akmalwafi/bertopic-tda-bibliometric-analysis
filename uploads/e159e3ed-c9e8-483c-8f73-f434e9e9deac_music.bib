@inproceedings{ WOS:001364925203144,
Author = {Zhang, Donghui and Li, Xiaobing and Lu, Di and Tie, Yun and Gao, Yan and
   Qi, Lin},
Book-Group-Author = {IEEE},
Title = {Multitrack Emotion-Based Music Generation Network Using Continuous
   Symbolic Features},
Booktitle = {2024 IEEE INTERNATIONAL CONFERENCE ON MULTIMEDIA AND EXPO, ICME 2024},
Series = {IEEE International Conference on Multimedia and Expo},
Year = {2024},
Note = {IEEE International Conference on Multimedia and Expo (ICME), Niagra
   Falls, CANADA, JUL 15-19, 2024},
Organization = {IEEE},
Abstract = {Musicians need an efficient composition process to yield a multitude of
   musical pieces. To enhance the artistry and emotional relevance of
   AI-generated music, a novel MultiTrack Emotion Music Generation model
   (MEMG) is proposed. MEMG minimizes reliance on emotion-labeled datasets,
   instead employing musical features such as conditional pitch histograms
   to signify music emotion attributes. By analyzing music features and
   emotional responses, MEMG facilitates controlled music generation with
   diverse emotions, where specific emotions are mapped based on Russell's
   psychological model. A novel hybrid feedback reward network is
   constructed, integrating music theory rules, discriminator, and musical
   emotion interpretation. Incorporating music theory and embedding music
   emotion as input parameters during generation. Objective music theory
   evaluation and subjective auditory testing validate MEMG's
   competitiveness in composing varied emotional music, coupled with
   exemplary adherence to musical rules.},
