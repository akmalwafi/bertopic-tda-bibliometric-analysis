@article{ WOS:001519344700004,
Author = {Preda-ulita, Anca},
Title = {AI and Metacognition in Instrumental Performance: An Integrative Model
   for Critical Thinking},
Journal = {INFORMATION AND COMMUNICATION TECHNOLOGY IN MUSICAL FIELD},
Year = {2025},
Volume = {16},
Number = {1},
Pages = {41-48},
Abstract = {The integration of artificial intelligence (AI) in music education has
   introduced new approaches to performance analysis and skill development.
   While AI platforms provide real-time feedback and personalized practice
   suggestions, their influence on metacognition-musicians' ability to
   reflect on and regulate their learning-remains underexplored. This
   article examines how AI-based performance analysis tools impact
   pianists' self-reflection and learning strategies. By combining AI
   feedback with metacognitive exercises, we aim to assess whether students
   enhance their awareness of interpretative decisions, technical
   challenges, and structural aspects of their repertoire. Additionally,
   the article explores the potential correlations between AI-generated
   feedback and Schenkerian analysis, a method that reveals hierarchical
   structures in music. The findings highlight AI's role in promoting
   critical thinking, problem-solving, and independent decision-making in
   piano performance. Finally, we discuss recommendations for incorporating
   AI-driven metacognitive strategies into music curricula emphasizing both
   the potential and limitations of AI in music education.},
