@article{ WOS:001648155100006,
Author = {Doerfling, Christina},
Title = {Petrosounds of Pyrophony. Sound stories from, above, and with gas},
Journal = {MUSIKTHEORIE},
Year = {2025},
Volume = {40},
Number = {2},
Pages = {165+},
Abstract = {The use of tools based on artificial intelligence (AI) in music creation
   processes has constantly increased since the beginning of the 2020s.
   This comes along with a central but (so far) largely unsolved question
   for both music creators and music researchers: How can musical
   >knowledge< be >understood< - and hence used - by these applications?
   Looking at sound -generating processes, some specificities of AI tools
   based on corpus-based learning come into focus. Being situated at the
   intersection between artistic ideas and (their) technical
   implementation, the close mutual relationship between the inherent
   (artistic) aim, the interface between human and computing unit, and the
   structure of the implemented processes, as well as the current limits
   and challenges of these tools become clearly visible. How to implement
   AI -based processes in order to not only reproduce sounds from the
   trainings data (with great similarity), but generate new sounds
   according to creative artistic ideas? And what do these tools actually
   learn about the sound - and (re -)produce?},
