@inproceedings{ WOS:001460285200024,
Author = {Ohya, Keishi and Ayedoun, Emmanuel and Tokumaru, Masataka},
Book-Group-Author = {IEEE},
Title = {Evolutionary Music Synthesis: A Generative AI System with Interactive
   User Feedback},
Booktitle = {2024 JOINT 13TH INTERNATIONAL CONFERENCE ON SOFT COMPUTING AND
   INTELLIGENT SYSTEMS AND 25TH INTERNATIONAL SYMPOSIUM ON ADVANCED
   INTELLIGENT SYSTEMS, SCIS\&ISIS},
Year = {2024},
Note = {2024 Joint International Conference on Soft Computing and Intelligent
   Systems and International Symposium on Advanced Intelligent Systems,
   Himeji, JAPAN, NOV 09-12, 2024},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {In this study, a music generation system that reflects user preferences
   by combining music generation AI and interactive evolutionary
   computation is proposed.In recent years, the performance of generative
   AI has been rapidly developing, and it is expected to produce higher
   quality content. On the other hand, it has not been widely discussed how
   generative AI can generate music that matches the user's sensibilities.
   Therefore, this study focuses on interactive evolutionary computation
   and attempts to generate music that takes user preferences into account
   by optimizing the input to the generative AI. In this experiment,
   subjects listen to and evaluate 10 pieces of generated music. The system
   generates new music based on the user's evaluation. By repeating this
   process, the music generated by the AI is made closer to the user's
   intentions. As a result, it was confirmed that approximately 93\% of the
   subjects felt that the optimized music reflected their own tastes.},
