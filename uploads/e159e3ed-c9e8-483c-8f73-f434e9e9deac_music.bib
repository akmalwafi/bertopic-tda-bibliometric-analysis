@inproceedings{ WOS:000380444802023,
Author = {Liu, Chien-Hung and Ting, Chuan-Kang},
Book-Group-Author = {IEEE},
Title = {Music Pattern Mining for Chromosome Representation in Evolutionary
   Composition},
Booktitle = {2015 IEEE CONGRESS ON EVOLUTIONARY COMPUTATION (CEC)},
Series = {IEEE Congress on Evolutionary Computation},
Year = {2015},
Pages = {2145-2152},
Note = {IEEE Congress on Evolutionary Computation (CEC), Sendai, JAPAN, MAY
   25-28, 2015},
Organization = {IEEE},
Abstract = {Artificial intelligence (AI) has bloomed in many novel fields such as
   computational creativity. Recently, research on automatic composition
   using AI technology, especially evolutionary algorithms, has received
   considerable promising results. Traditionally, chromosomes are
   represented as a series of numbers to indicate the notes for
   evolutionary composition. This study attempts to explore the composition
   styles by mining music patterns of a specific composer. The patterns are
   used as genes for chromosome representation. Accordingly, the
   composition styles are considered in generating music by evolutionary
   algorithms. The fitness function is based on music theory to smooth the
   progression between phrases. Experimental results show that the patterns
   mined from compositions can reflect the composer's style and benefit
   generating satisfactory songs by evolutionary algorithms.},
