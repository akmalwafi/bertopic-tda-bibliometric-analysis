@inproceedings{ WOS:001447818200096,
Author = {Wang, Qinyuan and Gu, Bruce and Zhang, He and Li, Yunfeng},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {Fairness of Large Music Models: From a Culturally Diverse Perspective},
Booktitle = {2024 IEEE 9TH INTERNATIONAL CONFERENCE ON DATA SCIENCE IN CYBERSPACE,
   DSC},
Year = {2024},
Pages = {706-712},
Note = {9th International Conference on Data Science in Cyberspace, Jinan,
   PEOPLES R CHINA, AUG 23-26, 2024},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {This paper explores the fairness of large music models in generating
   culturally diverse musical compositions, emphasizing the need for
   inclusivity and equity in AI-generated music. By analyzing popular
   datasets such as the Million Song Dataset and the Lakh MIDI Dataset, we
   identify a significant underrepresentation of non-Western musical
   elements. To address this, we adapt existing models to incorporate
   non-Western scales, rhythms, and instruments. The adapted models
   demonstrate a substantial improvement in generating culturally diverse
   music. Using AI-based synthetic listeners, we evaluate the impact of
   these adaptations on listener perception and engagement. Results
   indicate that music from the adapted models scores higher in terms of
   enjoyment, novelty, cultural resonance, and overall engagement compared
   to the original models. Our findings highlight the importance of
   cultural diversity in enhancing the user experience and ensuring ethical
   AI practices. The study also discusses challenges, such as dataset
   limitations and model adaptation complexity, and suggests directions for
   future research to further promote fairness and inclusivity in music AI.
   This work contributes to the development of more culturally aware and
   representative music generation systems, aiming to enrich the global
   musical landscape and foster greater appreciation of diverse musical
   traditions.},
