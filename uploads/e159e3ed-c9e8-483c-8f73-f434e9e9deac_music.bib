Title = {Real-Time Human-Classified Emotional MIDI Dataset Integration for
   Symbolic Music Generation},
Booktitle = {2024 INTERNATIONAL CONFERENCE ON MACHINE LEARNING AND APPLICATIONS,
   ICMLA},
