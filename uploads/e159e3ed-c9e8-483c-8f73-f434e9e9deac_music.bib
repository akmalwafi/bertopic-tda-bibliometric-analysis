@inproceedings{ WOS:001531835100011,
Author = {Kosugi, Naoko and Ishii, Kentaro and Kodama, Naoki},
Editor = {Haghighi, PD and Gregus, M and Kotsis, G and Khalil, I},
Title = {Research and Development of an AI Music Therapist - Toward Digital
   Therapeutics of Music Therapy},
Booktitle = {INFORMATION INTEGRATION AND WEB INTELLIGENCE, IIWAS 2024, PT II},
Series = {Lecture Notes in Computer Science},
Year = {2025},
Volume = {15343},
Pages = {151-166},
Note = {26th International Conference on Information Integration and Web
   Intelligence-iiWAS, Bratislava, SLOVAKIA, DEC 02-04, 2024},
Organization = {Comenius University Bratislava},
Abstract = {This paper describes research into the development of an artificial
   intelligence (AI) based music therapist (AI music therapist) for elderly
   people with dementia. Music therapy is expected to be effective for the
   `behavioural and psychological symptoms' of dementia and thus contribute
   to reducing the burden of caregiving. However, the number of music
   therapists in Japan is very small compared to the number of elderly
   people with dementia, and not all elderly people with dementia in Japan
   have easy access to music therapy. Therefore, in order to enable elderly
   people with dementia to receive music therapy anytime, anywhere and as
   many times as possible, we are developing a virtual music therapist (AI
   music therapist) called `Satsuki-san', who appears on a computer screen.
   In this paper, we report on the latest version of `Satsuki-san' and
   collect opinions from caregivers actually engaged in the care of elderly
   people with dementia and music therapists with extensive clinical
   practice experience with elderly people with dementia. The opinions of
   the caregivers and music therapists showed a high level of expectation
   for the AI music therapist, but they also pointed out a number of
   problems, for example about Satsuki's speech, such as the need for more
   intonation. The music therapists also pointed out a number of areas for
   improvement with regard to singing accompaniment. In the future, we
   would like to collect a variety of data from the subjects of music
   therapy through the use of the AI music therapists and establish a music
   digital therapeutics that can objectively evaluate the subjects'
   condition and predict the progression of dementia.},
