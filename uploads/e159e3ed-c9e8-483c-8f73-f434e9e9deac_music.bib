@inproceedings{ WOS:001611519700159,
Author = {Long, Phillip and Novack, Zachary and Berg-Kirkpatrick, Taylor and
   McAuley, Julian},
Book-Group-Author = {IEEE},
Title = {PDMX: A Large-Scale Public Domain MusicXML Dataset for Symbolic Music
   Processing},
Booktitle = {2025 IEEE INTERNATIONAL CONFERENCE ON ACOUSTICS, SPEECH AND SIGNAL
   PROCESSING (ICASSP)},
Series = {International Conference on Acoustics Speech and Signal Processing
   ICASSP},
Year = {2025},
Note = {2025 International Conference on Acoustics Speech and Signal
   Processing-ICASSP-Annual, Hyderabad, INDIA, APR 06-11, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; Signal Processing
   Society},
Abstract = {The recent explosion of generative AI-Music systems has raised numerous
   concerns over data copyright, licensing music from musicians, and the
   conflict between open-source AI and large prestige companies. Such
   issues highlight the need for publicly available, copyright-free musical
   data, in which there is a large shortage, particularly for symbolic
   music data. To alleviate this issue, we present PDMX: a large-scale
   open-source dataset of over 250K public domain MusicXML scores collected
   from the score-sharing forum MuseScore, making it the largest available
   copyright-free symbolic music dataset to our knowledge. PDMX
   additionally includes a wealth of both tag and user interaction
   metadata, allowing us to efficiently analyze the dataset and filter for
   high quality user-generated scores. Given the additional metadata
   afforded by our data collection process, we conduct multitrack music
   generation experiments evaluating how different representative subsets
   of PDMX lead to different behaviors in downstream models, and how
   user-rating statistics can be used as an effective measure of data
   quality.},
