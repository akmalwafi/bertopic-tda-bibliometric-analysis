@inproceedings{ WOS:001690442800043,
Author = {Gundavarapu, Mallikarjuna Rao and Pinjary, Affan and Gampala, Bhuvan and
   Kambhampati, Rikhil and Varma, Pericherla Anil},
Book-Group-Author = {IEEE},
Title = {TuneShift: Harnessing Diffusion Models for Music Generation and
   Adaptation},
Booktitle = {2025 IEEE INTERNATIONAL CONFERENCE ON ELECTRONICS, COMPUTING AND
   COMMUNICATION TECHNOLOGIES, CONECCT},
Series = {IEEE International Conference on Electronics Computing and Communication
   Technologies},
Year = {2025},
Note = {11th International Conference on Electronics Computing and Communication
   Technologies-CONECCT-Annual, INDIA, JUL 10-13, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {The advancement of diffusion models for music creation has been marked
   by the innovative and exciting project TuneShift. At its core, the
   project focuses on three transformative capabilities: generating new
   background music based on existing compositions, converting melodies
   from one instrument to another, and blending multiple instrumental
   tracks into a single, cohesive piece. This represents an entirely new
   way of looking at the music composition process because it greatly
   expands the ways musicians can tailor and personalize music to suit
   their unique distinct identity. With new methods of working with mu sic,
   the TuneShift project strives to broaden the limits of what is possible
   in the field of music entrepreneurship through AI. While AI driven music
   generation has been a topic of discussion using various generative
   models, there remains a gap in the application of diffusion models in
   this field. TuneShift, follows the previous research done in this area,
   and seeks to address these issues. Using diffusion models greatly
   improves the control when manipulating the separate consolidated musical
   elements. The striving for greater flexibility improves the overall
   dynamism and creativity of the system. The robustness of the systems
   opens new possibilities for musicians, as well as improves the
   efficiency of traditional music production workflows, saving both time
   and production costs. Best of all, diffusion models owes the beauty of
   their inner working to their ability to be readily adapted to different
   musical requirements and needs, making them perfect for range of
   different creative purposes. Creative processes such as composition and
   production in music will be transformed through greater experimentation
   and innovation because Tune Shift aims to equip composers and musicians
   with tools that enhance their creation. Diffusion models are incredibly
   useful for experimenting with concepts and developing new and exciting
   ways of crafting music because they fulfill a diverse range of musical
   requirements. In order to determine whether or not this idea is
   appropriate and feasible for development as a final year project, we
   conducted a comprehensive viability scan. This included checking the
   current capabilities of diffusion models within the music industry, the
   level of technology needed, and the potential hurdles. We are confident
   that TuneShift will not only be possible, but will also change the
   landscape of AI based music production in the future. By dovetailing the
   growing need for higher levels of creativity with AI, TuneShift promises
   to be the game changing evolution in music creation.},
