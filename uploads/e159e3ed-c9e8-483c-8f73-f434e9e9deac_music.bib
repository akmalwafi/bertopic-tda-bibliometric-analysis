@inproceedings{ WOS:001566302100027,
Author = {Zhu, Yan and Zhang, Zhisheng},
Editor = {Degen, H and Ntoa, S},
Title = {Exploring the Effects of AI-Adaptive Music on Spatial Memory and
   Navigation Performance},
Booktitle = {ARTIFICIAL INTELLIGENCE IN HCI, AI-HCI 2025, PT III},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2025},
Volume = {15821},
Pages = {418-429},
Note = {6th International Conference on Artificial Intelligence in HCI-AI-HCI,
   Goeteborg, SWEDEN, JUN 22-27, 2025},
Abstract = {Recent advancements in AI-generated music have opened possibilities for
   cognitive performance, yet its application in driving contexts remains
   underexplored. This study examines the effects of context-aware
   AI-generated music, dynamically adapted to real-time road conditions, on
   spatial memory and driving navigation performance. Participants
   completed simulated driving tasks under three conditions: AI-adaptive
   music, normal music, and silence. Spatial memory was assessed through
   pre- and post-driving tasks, while navigation performance was evaluated
   based on route accuracy, reaction time, and error rates. Results
   demonstrated that context-aware AI music significantly improved spatial
   memory retention and navigation efficiency compared to normal music or
   silence. The adaptive nature of context-aware AI music, which aligns
   with road complexity, appeared to reduce cognitive load and enhance
   driver focus, which is consistent with questionnaire feedback. These
   findings suggest that integrating AI music with real-time road
   conditions can optimize cognitive performance and driving safety.},
