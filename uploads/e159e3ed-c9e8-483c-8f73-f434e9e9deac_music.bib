@article{ WOS:001505176300007,
Author = {Zaddach, Wolf-Georg},
Title = {Artificial Intelligence and the Creative Practice of Professional
   Songwriting},
Journal = {LIED UND POPULARE KULTUR-SONG AND POPULAR CULTURE},
Year = {2024},
Volume = {69},
Abstract = {This chapter examines the role of AI in the context of professional
   songwriting in pop-ular music. Through interviews conducted with ten
   industry professionals, insights are gleaned and situated within the
   ongoing discourse about AI and music generation. Findings indicate that
   professional songwriters and producers harbour a spectrum of aesthetic,
   artistic, and ethical concerns alongside anticipations regarding
   creative pos-sibilities. Consequently, the discourse reflects a
   transitional phase, underscoring the im-perative for augmented artistic
   and practice-oriented research initiatives and the ensu-ing educational
   implications},
