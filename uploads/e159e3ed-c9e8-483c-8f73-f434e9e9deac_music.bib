Title = {Design and Implementation of a GenAI-Based Music Creation System},
Booktitle = {UBI-MEDIA COMPUTING, PERVASIVE SYSTEMS, ALGORITHMS AND NETWORKS,
   UBI-MEDIA 2025, I-SPAN 2025, PART I},
