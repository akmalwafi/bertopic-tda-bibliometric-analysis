@article{ WOS:001603130600001,
Author = {Hu, Fei},
Title = {AI-curated soundscapes: spatial reconfiguration of intangible cultural
   heritage music in urban China},
Journal = {GEOJOURNAL},
Year = {2025},
Volume = {90},
Number = {6},
Month = {OCT 28},
Abstract = {The rapid urbanization of China has created unprecedented challenges for
   preserving intangible cultural heritage, particularly traditional music
   forms that have defined regional identities for centuries. This study
   examines the innovative application of artificial intelligence
   technologies in curating and spatially redistributing traditional
   Chinese music within urban environments between 2018 and 2023. Through a
   comprehensive analysis of 75 AI-curated soundscape projects across five
   major Chinese cities (Beijing, Shanghai, Guangzhou, Chengdu, and
   Shenzhen), this research reveals significant patterns in public
   engagement, funding mechanisms, and spatial distribution of cultural
   heritage preservation initiatives. Our findings demonstrate a remarkable
   six-fold increase in AI-soundscape projects from 4 in 2018 to 24 in
   2023, accompanied by a substantial rise in urban public engagement from
   55 to 90\%. The study identifies four primary categories of intangible
   cultural heritage music being preserved: Traditional Folk (35\%), Opera
   (25\%), Instrumental (20\%), and Ethnic Chants (20\%). Funding analysis
   reveals a predominant role of local governments (65\%) compared to
   technology companies (22\%) and cultural NGOs (13\%). Statistical
   analysis establishes a strong positive correlation (r = 0.95, p < 0.001)
   between the number of AI soundscape projects and public opinion indices.
   These findings contribute to understanding how emerging technologies can
   facilitate cultural preservation while simultaneously transforming urban
   acoustic environments and enhancing community engagement with
   traditional heritage.},
Publisher = {SPRINGER},
Address = {VAN GODEWIJCKSTRAAT 30, 3311 GZ DORDRECHT, NETHERLANDS},
