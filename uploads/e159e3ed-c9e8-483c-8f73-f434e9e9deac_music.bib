Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {AIMAT (AI Music Artist Toolkit) is a modular, containerized toolkit
   designed to lower technical barriers for musicians experimenting with AI
   music models in their creative practice. By integrating Docker and OSC,
   AIMAT connects unique combinations of generative models with
   artist-friendly platforms like Max/MSP. Preliminary tests validate
   AIMAT's performance and resource efficiency, while its containerization
   approach addresses model obsolescence, preserving these models for
   creative work and experimentation. We present AIMAT as a working proof
   of concept, detailing its design and architecture, and providing a
   technical foundation for future development and broader adoption.},
