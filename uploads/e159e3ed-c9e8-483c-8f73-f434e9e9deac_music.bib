@inproceedings{ WOS:000266771501197,
Author = {Endo, Tsukasa and Ito, Shin-ichi and Mitsukura, Yasue and Fukumi, Minoru},
Book-Group-Author = {IEEE},
Title = {The Music Analysis Method Based on Melody Analysis},
