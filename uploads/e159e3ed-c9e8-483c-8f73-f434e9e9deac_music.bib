EISSN = {1540-6245},
Research-Areas = {Art; Arts \& Humanities - Other Topics; Philosophy},
Web-of-Science-Categories  = {Art; Humanities, Multidisciplinary; Philosophy},
Author-Email = {casey.haskins@purchase.edu},
Affiliations = {State University of New York (SUNY) System; SUNY Purchase College},
Cited-References = {Cave Nick, 2023, RED HAND FILES, P218.
   Chiang T., 2024, New Yorker.
   Clarke E., 2009, Music and mind in everyday life.
