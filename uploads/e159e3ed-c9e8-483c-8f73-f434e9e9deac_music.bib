@article{ WOS:001519344700006,
Author = {Suciu, Magdalena and Botond, Szocs and Tint, Marc Alexandru and
   Dragulin, Stela},
Title = {Cognitive Implications of Digital Tools in Music Practice and
   Performance},
Journal = {INFORMATION AND COMMUNICATION TECHNOLOGY IN MUSICAL FIELD},
Year = {2025},
Volume = {16},
Number = {1},
Pages = {57-67},
Abstract = {This article explores how digital tools impact cognitive processes in
   music practice and performance. Drawing on models of music cognition and
   recent research, it examines how technologies like AI feedback systems
   and tablet-based scores affect memory, attention, and interpretive
   focus. Combining literature review with professional reflections of the
   authors, the article argues that such tools may restructure cognitive
   effort rather than eliminate it, and their value depends on how they are
   framed and used.},
