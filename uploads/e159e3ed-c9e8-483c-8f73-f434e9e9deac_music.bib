@inproceedings{ WOS:001327002400039,
Author = {Micalizzi, Alessandra},
Editor = {Yang, XS and Sherratt, S and Dey, N and Joshi, A},
Title = {Artificial Creativity. Perceptions and Prejudices on AI Music Production},
Booktitle = {PROCEEDINGS OF NINTH INTERNATIONAL CONGRESS ON INFORMATION AND
   COMMUNICATION TECHNOLOGY, VOL 8, ICICT 2024},
Series = {Lecture Notes in Networks and Systems},
Year = {2024},
Volume = {1004},
Pages = {481-491},
Note = {9th International Congress on Information and Communication Technology
   (ICICT), London, ENGLAND, FEB 19-22, 2024},
Organization = {Global Knowledge Res Foundat},
Abstract = {This paper aims at contributing to the ongoing discourse concerning the
   involvement of artificial intelligence (AI) in the realm of music
   production. Previous scholarly inquiries have consistently highlighted
   the prevalence of biases and concerns in AI-mediated creative processes,
   particularly among technicians, experts, and creators. However, studies
   demonstrate that in certain instances of blind listening evaluations,
   individuals exhibit a reduced predisposition toward prejudice,
   demonstrating genuine interest in and approval of creative musical
   outputs generated through AI-mediated processes. We will present the
   primary findings of an empirical study grounded in a tripartite
   experimental framework. Each of the three groups was assigned the task
   of evaluating musical productions, with one originating from human
   creativity and the other stemming from AI-based generative processes.
   This study represents the initial step of a broader research work aimed
   at comprehending how AI tools could be integrated into the creative
   process, whether it engenders a new aura around the creative product, to
   echo Benjamin, and ultimately, the implications for the broader cultural
   industry and its role as a producer of collective imagination.},
