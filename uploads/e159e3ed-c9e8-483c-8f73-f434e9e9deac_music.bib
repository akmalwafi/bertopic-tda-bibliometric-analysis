@article{ WOS:001251573400001,
Author = {Fang, Xie and Wei, Guo},
Title = {Research on entertainment creation robot based on artificial
   intelligence speech recognition in the process of music style analysis},
Journal = {ENTERTAINMENT COMPUTING},
Year = {2024},
Volume = {51},
Month = {SEP},
Abstract = {With the development of artificial intelligence and speech recognition,
   music creation robots are an AI based automated music generation and
   analysis tool that can provide an immersive experience for music
   analysis, as well as a digital entertainment atmosphere. This article
   analyzes the research on the music style analysis process of
   entertainment creative robots based on artificial intelligence speech
   recognition. Data mining technology is used to process and classify the
   extracted features to realize the style classification of music. Through
   the analysis of experimental data, we verify the accuracy and
   reliability of the method. Therefore, this study provides a new data
   mining method based on AI for music style classification, and provides a
   valuable reference for music research and the development of music
   industry.},
