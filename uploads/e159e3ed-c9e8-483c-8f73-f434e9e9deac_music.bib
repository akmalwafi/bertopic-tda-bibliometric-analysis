@article{ WOS:001275380100001,
Author = {Miranda, Eduardo Reck},
Title = {The advent of quantum computer music: mapping the field},
Journal = {REPORTS ON PROGRESS IN PHYSICS},
Year = {2024},
Volume = {87},
Number = {8},
Month = {AUG 1},
Abstract = {Quantum computing technology is developing at a fast pace. The impact of
   quantum computing on the music industry is inevitable. This paper maps
   the emerging field of quantum computer music. Quantum computer music
   investigates, and develops applications and methods to process music
   using quantum computing technology. The paper begins by contextualising
   the field. Then, it discusses significant examples of various approaches
   developed to date to leverage quantum computing to learn, process and
   generate music. The methods discussed range from rendering music using
   data from physical quantum mechanical systems and quantum mechanical
   simulations to computational quantum algorithms to generate music,
   including quantum AI. The ambition to develop techniques to encode audio
   quantumly for making sound synthesisers and audio signal processing
   systems is also discussed.},
