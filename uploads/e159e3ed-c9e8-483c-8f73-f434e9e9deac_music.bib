@inproceedings{ WOS:001451321803039,
Author = {Chaudhuri, Subhrojyoti Roy},
Editor = {Ding, W and Lu, CT and Wang, F and Di, L and Wu, K and Huan, J and Nambiar, R and Li, J and Ilievski, F and Baeza-Yates, R and Hu, X},
Title = {AI Assisted Workflow for Set-list Preparation with Loops for Live
   Musicians},
Booktitle = {2024 IEEE INTERNATIONAL CONFERENCE ON BIG DATA, BIGDATA},
Series = {IEEE International Conference on Big Data},
Year = {2024},
Pages = {3163-3167},
Note = {2024 IEEE International Conference on Big Data, Washington, DC, DEC
   15-18, 2024},
Organization = {Institute of Electrical and Electronics Engineers Inc; National Science
   Foundation; Virginia Tech Corporate Research Center},
Abstract = {The advancement of Artificial Intelligence (AI), specifically in
   generative AI (GenAI) for music, potentially empowers musicians to
   incorporate rich ensembles of musical sounds in their live performances
   with much less effort. Musicians and disk jockeys can now enhance their
   live acts by taking advantage of AI technologies to a) curate a list of
   musical tracks for performance by gathering an understanding of the
   venue of performance and their audience in terms of their musical tastes
   b) enhance the curated playlist with the identification and selection of
   additional musical elements or loops to add to the overall appeal of
   their live performances. Both curating musical playlists as well as
   identifying and generating loops corresponding to tracks in the playlist
   are carried out manually in the current practice and are heavily reliant
   on the musicianship of an artist. In our work, we explore an approach
   that uses GenAI tools to work alongside traditional music production
   platforms such as the Digital Audio Workstations (DAW) to help musicians
   curate their set-list and generate musical loops as per the set-list
   with much less effort. We have developed an initial demonstrator that
   shows promising use of GenAI tools and also points out gaps in the
   available GenAI tools. We share our initial findings in this poster
   paper.},
Publisher = {IEEE COMPUTER SOC},
