@inproceedings{ WOS:000718888200030,
Author = {Kan, Zi Jun and Sourin, Alexei},
Editor = {Sourin, A and Charier, C and Sourina, O and Rosenberger, C},
Title = {Generation of Irregular Music Patterns With Deep Learning},
Booktitle = {2020 INTERNATIONAL CONFERENCE ON CYBERWORLDS (CW 2020)},
Series = {International Conference on Cyberworlds},
