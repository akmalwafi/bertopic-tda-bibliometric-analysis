@article{ WOS:001430427100005,
Author = {Oh, Hee Sook},
Title = {Is AI Music Beautiful? A Study of the AI Composition Model EVOM},
Journal = {INTERNATIONAL REVIEW OF THE AESTHETICS AND SOCIOLOGY OF MUSIC},
Year = {2024},
Volume = {55},
Number = {1},
Month = {JUN},
Abstract = {In the twenty-first century, the emergence of Artificial Intelligence
   (AI) composers has become a notable phenomenon. What kind of music does
   AI produce and how do we comprehend the aesthetic value of music
   composed by AI? With this in mind, this study explores the musical style
   and aesthetics created by AI composition models. EVOM, Korea's first AI
   composition model, was selected as the subject of this research. EVOM
   has produced various works across art and popular music genres. By
   examining EVOM's musical works, this study delves into the aesthetic
   implications of AI- generated music, focusing on the concept of'posthu-
   manism.'},
