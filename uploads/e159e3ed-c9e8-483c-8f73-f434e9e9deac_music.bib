@article{ WOS:001741804000002,
Author = {Wang, Qing},
Title = {Exploration of Cross-Cultural Inheritance and Innovation Paths of
   Traditional Music Based on Computer Technology},
Journal = {INTERNATIONAL JOURNAL OF KNOWLEDGE MANAGEMENT},
Year = {2026},
Volume = {22},
Number = {1},
Abstract = {In the context of globalization and digitalization, traditional music
   faces challenges related to inheritance and cross-cultural
   communication. This study explores how computer technology can aid in
   the preservation and innovation of traditional music through digital
   skill databases, virtual reality/augmented reality (VR/AR) communication
   platforms, and artificial intelligence (AI)-assisted creation. Recent
   data reveals significant improvements: a substantial increase in
   overseas users of multimodal databases, a notable rise in cultural
   understanding via VR channels, and a marked reduction in AI-assisted
   creation cycles. The research constructs a technology
   adaptation-cultural translation-practice implementation path, confirming
   that these technologies help overcome barriers to skill preservation and
   foster deeper cultural integration. This study offers both theoretical
   and practical support for the global continuation of traditional music
   in the digital era.},
