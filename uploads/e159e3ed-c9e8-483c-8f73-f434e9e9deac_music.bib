@inproceedings{ WOS:001285850001053,
Author = {Agarwal, Manvi and Wang, Changhong and Richard, Gael},
Book-Group-Author = {IEEE},
Title = {STRUCTURE-INFORMED POSITIONAL ENCODING FOR MUSIC GENERATION},
Booktitle = {2024 IEEE INTERNATIONAL CONFERENCE ON ACOUSTICS, SPEECH AND SIGNAL
   PROCESSING, ICASSP 2024},
Series = {International Conference on Acoustics Speech and Signal Processing
   ICASSP},
