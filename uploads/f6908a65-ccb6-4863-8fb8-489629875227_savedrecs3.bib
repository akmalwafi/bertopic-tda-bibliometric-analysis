Pages = {65-72},
Month = {APR},
Abstract = {Artificial intelligence application has gained popularity in the last
   decade. Its application is implemented into multiple industries
   including the health sector; however, discipline-specific artificial
   intelligence applications are not widely integrated into the day to day
   practice of forensic pathology in Australia and New Zealand. This
   article gives a brief overview of the medical school education, forensic
   pathology training and service and provides the authors views on the
   current state, potential applications, challenges and future direction
   in integrating artificial intelligence into forensic pathology in
