Year = {2024},
Number = {53},
Pages = {243-260},
Month = {JAN-JUN},
Abstract = {This paper compares two literature reviews on cybersecurity issues
   focused on the mature organisations, business and management field, and
   the embryonic tourism and hospitality area. Hence, we use the general
   study on the former as a benchmark for the narrower review on the
   latter, to map the current trends and identify the corresponding gaps.
   Findings suggest the following topic clusters for future research: (1)
   machine learning, artificial intelligence, blockchain, big data; (2)
   fraud and reputation; (3) phishing and social engineering; (4) human
   security and user education.},
