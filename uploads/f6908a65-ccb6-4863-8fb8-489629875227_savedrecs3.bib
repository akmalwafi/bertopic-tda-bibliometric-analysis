@article{ WOS:001461977200001,
Author = {Girn, Alysha and Bouchard, Martin and Dawson, Krysta},
Title = {Snakes, Ladders, and Brokers: The Role of Social Networks in Rising
   Through the Ranks of an Outlaw Motorcycle Gang},
Journal = {JUSTICE QUARTERLY},
Year = {2025},
Month = {2025 MAR 28},
Abstract = {Contrary to unstructured criminal groups, outlaw motorcycle gangs
   (OMCGs) utilize a three-tiered promotional process. Through these
   stages, members have shown to vary in their ability to advance. The
   current study uses social network analysis (SNA) to investigate the
   influence of network capital on the timing of promotion. We pay
   particular attention as to whether bikers show a capacity to connect and
   work with others, and/or whether the involvement in violence or drug
   trafficking plays a role in the timing of promotion. Using longitudinal
   data, we analyze the promotional trajectories of 62 members. Survival
   analyses indicated that those with an increase in social capital,
   whether that be in the number of contacts or strategic network
   positions, experienced faster promotions. Specifically, how individuals
   positioned themselves the year before promotion was a determining factor
   for advancement. Findings hold important implications for the timing of
   target intervention efforts on individuals involved in OMCGs.},
Publisher = {ROUTLEDGE JOURNALS, TAYLOR \& FRANCIS LTD},
Address = {2-4 PARK SQUARE, MILTON PARK, ABINGDON OX14 4RN, OXON, ENGLAND},
Type = {Article; Early Access},
Language = {English},
Affiliation = {Bouchard, M (Corresponding Author), Simon Fraser Univ, Sch Criminol, Burnaby, BC, Canada.
   Girn, Alysha; Bouchard, Martin; Dawson, Krysta, Simon Fraser Univ, Sch Criminol, Burnaby, BC, Canada.},
DOI = {10.1080/07418825.2025.2486703},
EarlyAccessDate = {MAR 2025},
ISSN = {0741-8825},
EISSN = {1745-9109},
Keywords = {Organized crime; promotion; social network analysis; network capital;
   social capital; human capital},
Keywords-Plus = {DRUG TRAFFICKING; CRIMINAL ACHIEVEMENT; ORGANIZATION; OPPORTUNITIES;
   COMPETENCE; PREDICTORS; CLUBS},
