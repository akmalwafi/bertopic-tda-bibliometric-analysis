Language = {English},
Affiliation = {Sun, IY (Corresponding Author), Univ Delaware, Dept Sociol \& Criminal Justice, Newark, DE 19716 USA.
   Chen, Yunan; Zheng, Xi, Beijing Foreign Studies Univ, Sch Law, Beijing, Peoples R China.
   Sun, Ivan Y.; Ha, Stephanie V., Univ Delaware, Dept Sociol \& Criminal Justice, Newark, DE 19716 USA.
   Wu, Yuning, Wayne State Univ, Dept Criminol \& Criminal Justice, Detroit, MI USA.},
DOI = {10.1177/10986111241275043},
EarlyAccessDate = {AUG 2024},
ISSN = {1098-6111},
EISSN = {1552-745X},
Keywords = {Chinese police officers; organizational support; supervisor justice;
