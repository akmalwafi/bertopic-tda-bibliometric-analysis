@article{ WOS:001471270400001,
Author = {Fernandez-Osorio, Andres Eduardo and Villalba-Garcia, Luisa Fernanda and
   Velandia-Pardo, Elmers Freddy},
Title = {Polycentric governance, big data and artificial intelligence: Tools for
   citizen security in Colombia},
Journal = {REVISTA CRIMINALIDAD},
Year = {2024},
Volume = {66},
Number = {3},
Month = {SEP-DEC},
Abstract = {In the digital era, in which cyber-attacks are becoming increasingly
   sophisticated and persistent, the ability to collect and analyse data in
   real time is essential to respond quickly to emerging threats. However,
   the complexity of managing the various interaction networks, as well as
   the multiplicity of their actors, motivates the search for new
   perspectives in the fight against cybercrime. This article proposes the
   use of polycentric governance in Colombia, supported by tools such as
   big data (BD) and artificial intelligence (AI), to contribute to citizen
   security through new perspectives for data protection. Through a
   qualitative approach, the Colombian cybersecurity and cyber-defence
   scenario is explored to interpret the context of threats in cyberspace
   and identify challenges and opportunities related to the use of
   polycentric governance, BD and AI for strategic anticipation and defence
   of the nation.},
