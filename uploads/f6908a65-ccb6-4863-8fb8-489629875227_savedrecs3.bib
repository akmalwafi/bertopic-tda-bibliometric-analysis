@article{ WOS:000350201700003,
Author = {Laorden, Carlos and Galan-Garcia, Patxi and Santos, Igor and Sanz, Borja
   and Nieves, Javier and Bringas, Pablo G. and Gomez Hidalgo, Jose Maria},
Title = {Negobot: Detecting paedophile activity with a conversational agent based
   on game theory},
