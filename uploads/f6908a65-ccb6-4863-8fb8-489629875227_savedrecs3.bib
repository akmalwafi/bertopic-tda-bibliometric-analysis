Title = {A Step to Achieve Personalized Human Centric Privacy Policy Summary},
Booktitle = {PROCEEDINGS OF THE 18TH INTERNATIONAL CONFERENCE ON EVALUATION OF NOVEL
   APPROACHES TO SOFTWARE ENGINEERING, ENASE 2023},
