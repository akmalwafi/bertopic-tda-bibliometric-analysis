@article{ WOS:000411771300012,
Author = {Hughes, Caitlin E. and Bright, David A. and Chalmers, Jenny},
Title = {Social network analysis of Australian poly-drug trafficking networks:
   How do drug traffickers manage multiple illicit drugs?},
Journal = {SOCIAL NETWORKS},
Year = {2017},
Volume = {51},
Number = {SI},
Pages = {135-147},
Month = {OCT},
Abstract = {International agencies report rising numbers of drug traffickers who
   deal in multiple drugs (poly-drug traffickers). This paper explores how
   product diversification is managed in three Australian poly-drug
   trafficking syndicates. Networks were constructed using judges'
   sentencing comments and social network analysis applied to examine the
   degree of specialisation, resource flows and management structure (if
   any). Each syndicate had a clear management structure, but employed a
   different approach to diversifying including in-house production of
   multiple products (Syndicate 1) and outsourcing to other syndicates
   (Syndicate 3). This suggests traffickers will have multiple avenues for
   product diversification. This may create challenges for their policing.
   (C) 2016 Published by Elsevier B.V.},
Publisher = {ELSEVIER},
Address = {RADARWEG 29, 1043 NX AMSTERDAM, NETHERLANDS},
