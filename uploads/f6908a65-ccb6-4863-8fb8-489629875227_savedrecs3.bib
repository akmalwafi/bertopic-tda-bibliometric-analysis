Title = {A comparison of textual data mining methods for sex identification in
   chat conversations},
Booktitle = {INFORMATION RETRIEVAL TECHNOLOGY},
Series = {Lecture Notes in Computer Science},
Year = {2008},
Volume = {4993},
Pages = {638-643},
Note = {4th Asia Information Retrieval Symposium, Harbin, PEOPLES R CHINA, JAN
   15-18, 2008},
Abstract = {Mining textual data in chat mediums is becoming more important because
   these mediums contain a vast amount of information, which is potentially
   relevant to a society's current interests, habits, social behaviors,
   crime tendency and other tendencies. Here, sex identification is taken
   as a base study in information mining in chat mediums. In order to do
   this, a simple discrimination function and semantic analysis method are
   proposed for sex identification in Turkish chat mediums. Then, the
   proposed sex identification method is compared with the Support Vector
   Machine (SVM) and Naive Bayes (NB) methods. Finally, results show that
   the proposed system has achieved accuracy over 90\% in sex
   identification.},
