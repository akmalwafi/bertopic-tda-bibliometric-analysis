@article{ WOS:001339575000003,
Author = {Khalid, Zainab and Iqbal, Farkhund and Fung, Benjamin C. M.},
Title = {Towards a unified XAI-based framework for digital forensic
   investigations},
Journal = {FORENSIC SCIENCE INTERNATIONAL-DIGITAL INVESTIGATION},
Year = {2024},
