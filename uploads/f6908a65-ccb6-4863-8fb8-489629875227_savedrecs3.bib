@inproceedings{ WOS:000836276100028,
Author = {Lazo Vasquez, Ricardo and Ochoa-Luna, Jose},
Book-Group-Author = {IEEE},
Title = {Transformer-based Approaches for Personality Detection using the MBTI
   Model},
Booktitle = {2021 XLVII LATIN AMERICAN COMPUTING CONFERENCE (CLEI 2021)},
Year = {2021},
Note = {47th Latin American Computing Conference (CLEI), Cartago, COSTA RICA,
   OCT 25-29, 2021},
Organization = {IEEE Electron Devices Soc, R9 Costa Rica; Tecnologico Costa Rica; Univ
   Costa Rica; Univ Nacl Costa Rica; Univ Estatal Distancia; Univ Tecnica
   Nacl; Univ Latinoamericana Ciencia \& Tecnologia; Fidelitas Univ; Univ
   Cenfotec; Univ Latin Costa Rica; FunaTec; Cinde; Sama; Encora; Edify;
   Servicios PSI, Internac S A; Colegio Professionales Informatica \&
   Computac; Hewlett Packard Enterprises; Oracle Acad; P \& G; Hewlett
   Packard Enterprise Co, Aruba; Novcomp; Huawei; Arkkosoft; Equifax;
   Ciencia Datos; Intel},
Abstract = {Personality Detection is a well-known field in Artificial Intelligence.
   Similar to Sentiment Analysis, it classifies a text in various labels
   that denote common patterns according to personality models such as
   Big-5 or Myers-Briggs Type Indicator (MBTI). Personality detection could
   be useful for recommendation systems, improvements in health care and
   counseling, forensics, job screening, to name a few applications. Most
   of the works on personality detection use traditional machine learning
   approaches which rely on open dictionaries and tokenizers resulting in
   low performance and replication issues. In contrast, Deep Learning
   Transformer models have gained popularity for their high performance. In
   this research, we propose several Transformer approaches for detecting
   personality according to the MBTI personality model and compare them to
   find out the most suitable for this task. In our experiments on the MBTI
   Kaggle benchmark dataset, we achieved 88.63\% in terms of accuracy and
   88.97\% of F1-Score which allow us to outperform current
   state-of-the-art results.},
