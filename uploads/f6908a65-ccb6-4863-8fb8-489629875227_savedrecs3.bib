@inproceedings{ WOS:000810167700003,
Author = {Pradhan, Isha and Potika, Katerina and Eirinaki, Magdalini and Potikas,
   Petros},
Editor = {Desai, BC},
Title = {Exploratory Data Analysis and Crime Prediction for Smart Cities},
Booktitle = {IDEAS `19: PROCEEDINGS OF THE 23RD INTERNATIONAL DATABASE APPLICATIONS
   \& ENGINEERING SYMPOSIUM (IDEAS 2019)},
