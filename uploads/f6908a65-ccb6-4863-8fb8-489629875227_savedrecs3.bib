@article{ WOS:001538713000003,
Author = {De Mata, Federico Bueno},
Title = {THE USE OF GENERATIVE ARTIFICIAL INTELLIGENCE BY THE UNDERCOVER COMPUTER
   AGENT AS A TOOL AGAINST SEXUAL EXPLOITATION AND TRAFFICKING OF WOMEN
   THROUGH THE INTERNET},
Journal = {REVISTA GENERAL DE DERECHO PROCESAL},
Year = {2025},
Number = {66},
Month = {MAY},
Abstract = {Ten years after the technological reform of the Spanish Criminal
   Procedure Law, the use of advanced tools in criminal investigation has
   evolved significantly. In this context, Generative Artificial
   Intelligence poses new opportunities and challenges for the undercover
   computer agent, especially in the fight against sexual exploitation and
   trafficking of women in digital environments. This article analyzes the
   legal framework and the possibilities of Generative Artificial
   Intelligence in the possible investigative techniques used by the
   undercover agent on the Internet without violating fundamental rights.
   In turn, it addresses a number of legal challenges arising from its
   implementation, such as the use of files of an illicit nature. Finally,
   it reflects on the balance between innovation and procedural safeguards
   in the use of Generative Artificial Intelligence to investigate crimes
   carried out by criminal organizations on the Internet.},
