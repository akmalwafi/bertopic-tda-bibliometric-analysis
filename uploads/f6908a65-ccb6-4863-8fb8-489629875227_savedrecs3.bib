@inproceedings{ WOS:000916958700004,
Author = {Hall, Stuart W. and Sakzad, Amin and Minagar, Sepehr},
Editor = {Yuan, X and Bai, G and Alcaraz, C and Majumdar, S},
Title = {A Proof of Concept Implementation of Explainable Artificial Intelligence
   (XAI) in Digital Forensics},
Booktitle = {NETWORK AND SYSTEM SECURITY, NSS 2022},
Series = {Lecture Notes in Computer Science},
Year = {2022},
Volume = {13787},
Pages = {66-85},
Note = {16th International Conference on Network and System Security (NSS),
   FIJI, DEC 09-12, 2022},
Abstract = {Explainable Artificial Intelligence (XAI) has been a subject of much
   research related to its potential to have a transformative impact on
   industries where AI implementations require a high degree of trust.
   Digital Forensics is one such field, with practitioners dealing with an
   ever-increasing volume of data and a variety of devices. This research
   first examines the concept of XAI and what it could accomplish in the
   Digital Forensics field. Using of series of 23 manufactured virtual hard
   disk (VHD) images, AI models were trained to make predictions on image
   and video file content and file system metadata. The manufactured VHD
   images can be of independent interest for educational purposes as well.
   The predictions were then processed using the Local Interpretable
   Model-Agnostic Explanations (LIME) toolkit. These results were then used
   as the basis for a discussion on the future of XAI in the digital
   forensics industry and potential areas for further research.},
