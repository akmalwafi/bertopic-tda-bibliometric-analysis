@article{ WOS:001407233300001,
Author = {Siwan, Damini and Rana, Akansha and Krishan, Peehul and Sharma, Vishal
   and Krishan, Kewal},
Title = {Artificial Intelligence and Identification of the Deceased: a Narrative
   Review With Implications in Forensic Science},
Journal = {BEHAVIORAL SCIENCES \& THE LAW},
