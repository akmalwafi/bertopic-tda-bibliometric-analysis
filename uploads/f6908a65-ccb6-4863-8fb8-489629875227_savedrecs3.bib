   Hughes, Caitlin E.; Chalmers, Jenny, UNSW Australia, Natl Drug \& Alcohol Res Ctr, Sydney, NSW 2052, Australia.
   Bright, David A., UNSW Australia, Sch Social Sci, Sydney, NSW, Australia.},
DOI = {10.1016/j.socnet.2016.11.004},
ISSN = {0378-8733},
EISSN = {1879-2111},
