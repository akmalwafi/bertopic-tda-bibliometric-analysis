   Didimo, Walter; Liotta, Giuseppe; Montecchiani, Fabrizio, Univ Perugia, Dipartimento Ingn, I-06100 Perugia, Italy.},
DOI = {10.1016/j.jvlc.2014.01.002},
ISSN = {1045-926X},
EISSN = {1095-8533},
