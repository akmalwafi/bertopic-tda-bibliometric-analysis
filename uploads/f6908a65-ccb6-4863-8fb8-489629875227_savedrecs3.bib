@article{ WOS:000875559100011,
Author = {MacDermott, Aine and Motylinski, Michal and Iqbal, Farkhund and Stamp,
   Kellyann and Hussain, Mohammed and Marrington, Andrew},
Title = {Using deep learning to detect social media `trolls'},
Journal = {FORENSIC SCIENCE INTERNATIONAL-DIGITAL INVESTIGATION},
