@article{ WOS:001302370500001,
Author = {Kelling, Claire and Haensch, Anna and Mendible, Ariana and Brooks,
   Spencer and Wiedemann, Alexander and Aminian, Manuchehr and Hasty, Wade
   and Higdon, Jude},
Title = {Data Collection and Analysis for Small-Town Policing: Challenges and
   Recommendations},
Journal = {STATISTICS AND PUBLIC POLICY},
Year = {2024},
Volume = {11},
Number = {1},
Month = {DEC 31},
Abstract = {According to the 2020 U.S. Census more than 60\% of the U.S. population
   lives in towns with fewer than 50,000 residents, yet this is not in
   proportion with the research and public data surrounding policing, which
   focus on large and dense urban areas. One reason for this disparity is
   that studying small-town police departments presents unique obstacles.
   We present some of the challenges that we have encountered in studying
   small-town police activity such as data availability, quality, and
   identifiability, and our solutions to these challenges using
   computational tools. Finally, we give our recommendations in getting
   involved in this space based on our efforts to-date.},
