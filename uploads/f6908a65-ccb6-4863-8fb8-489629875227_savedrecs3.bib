@article{ WOS:001328300400001,
Author = {Screen, Phillip and Bright, David and Aziani, Alberto},
Title = {The criminal activities and operational roles of Australian
   neo-jihadists: a network perspective},
Journal = {GLOBAL CRIME},
Year = {2025},
Volume = {26},
Number = {1},
Pages = {1-29},
Month = {JAN 2},
Abstract = {Despite the significant global repercussions of terrorism, including
   loss of lives and economic resources, research on its relationship with
   crime has been limited to group-level analyses. This study examines the
   individual criminal activities of Australian Neo-Jihadists, via social
   network analysis from an individual perspective. Judicial documents and
   newspaper articles are analysed to determine the criminal activities and
   operational roles of network actors. Findings suggest a prominence of
   criminal activities, and a significant relationship between market
   criminal activities and facilitation of terrorist operations. The study
   concludes with suggestions for future research, emphasising the
   potential for disrupting terrorist networks by focusing on the new
   crime-terror nexus.},
Publisher = {ROUTLEDGE JOURNALS, TAYLOR \& FRANCIS LTD},
