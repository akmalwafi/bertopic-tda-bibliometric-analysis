Year = {2015},
Volume = {46},
Pages = {182-189},
Month = {AUG},
Abstract = {This paper considers how predictive analytics might inform, assist, and
   improve decision making in child protection. Predictive analytics
   represents recent increases in data quantity and data diversity, along
   with advances in computing technology. While the use of data and
   statistical modeling is not new to child protection decision making, its
   use in child protection is experiencing growth, and efforts to leverage
   predictive analytics for better decision-making in child protection are
   increasing. Past experiences, constraints and opportunities are
   reviewed. For predictive analytics to make the most impact on child
   protection practice and outcomes, it must embrace established criteria
   of validity, equity, reliability, and usefulness. (C) 2015 Elsevier Ltd.
   All rights reserved.},
