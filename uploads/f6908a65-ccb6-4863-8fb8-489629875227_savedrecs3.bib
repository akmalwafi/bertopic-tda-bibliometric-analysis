Month = {SEP 1},
Abstract = {A considerable number of papers have been published on the ethics of
   artificial intelligence for the purposes of violence risk assessment. In
   this issue of The Journal, Hogan and colleagues argue that artificial
   intelligence introduces novel concerns for violence risk assessment that
   require consideration. While the concerns that have been raised are
   entirely valid and require consideration, we argue that artificial
   intelligence does not herald a more serious or unique challenge in these
   areas relative to other forms of violence risk assessment.},
