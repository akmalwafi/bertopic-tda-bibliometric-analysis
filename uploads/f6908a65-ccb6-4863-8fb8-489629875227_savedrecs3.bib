@inproceedings{ WOS:000977253400031,
Author = {Ingram, Eric and Gursoy, Furkan and Kakadiaris, Ioannis A.},
Book-Group-Author = {IEEE},
Title = {Accuracy, Fairness, and Interpretability of Machine Learning Criminal
   Recidivism Models},
Booktitle = {2022 IEEE/ACM INTERNATIONAL CONFERENCE ON BIG DATA COMPUTING,
   APPLICATIONS AND TECHNOLOGIES, BDCAT},
Year = {2022},
Pages = {233-241},
Note = {IEEE/ACM 15th International Conference on Utility and Cloud Computing
   (UCC) / 9th International Conference on Big Data Computing, Applications
   and Technologies (BDCAT), Vancouver, WA, DEC 06-09, 2022},
Organization = {IEEE; IEEE Comp Soc; Assoc Comp Machinery},
Abstract = {Criminal recidivism models are tools that have gained widespread
   adoption by parole boards across the United States to assist with parole
   decisions. These models take in large amounts of data about an
   individual and then predict whether an individual would commit a crime
   if released on parole. Although such models are not the only or primary
   factor in making the final parole decision, questions have been raised
   about their accuracy, fairness, and interpretability. In this paper,
   various machine learning-based criminal recidivism models are created
   based on a real-world parole decision dataset from the state of Georgia
   in the United States. The recidivism models are comparatively evaluated
   for their accuracy, fairness, and interpretability. It is found that
   there are noted differences and trade-offs between accuracy, fairness,
   and being inherently interpretable. Therefore, choosing the best model
   depends on the desired balance between accuracy, fairness, and
   interpretability, as no model is perfect or consistently the best across
   different criteria.},
