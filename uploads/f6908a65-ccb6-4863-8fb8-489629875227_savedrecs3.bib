@article{ WOS:001500427500001,
Author = {Qiu, Yaxian},
Title = {Policing AI-generated crimes: an ethnographic study on anti-cybercrime
   police in China},
Journal = {SECURITY JOURNAL},
Year = {2025},
Volume = {38},
Number = {1},
Month = {MAR},
Abstract = {The growing threat of cybercrime poses significant challenges for police
   organizations, particularly in a society where artificial intelligence
   (AI) is rapidly advancing and widely adopted. This paper presents
   original empirical research on specialist cybercrime units in China,
   aiming to highlight the key issues and challenges faced by frontline
   police officers and staff in combating online unlawful behavior and
   AI-generated crimes. Through in-depth interviews and participant
   observations involving cyber-policing officers, staff, supervisors from
   a police bureau, and judges from an Intermediate People's Court, this
   study outlines the primary challenges identified by these law
   enforcement professionals. While officers generally express satisfaction
   with their roles in policing cybercrime, concerns about the future
   implications of AI-generated crimes and disinformation are notably
   prevalent. Fieldwork findings reveal three major themes: (a) the
   potential for AI-generated crimes to become a significant social issue
   in the future; (b) the challenges AI-generated unlawful behaviors pose
   to cybersecurity and law enforcement efforts; and (c) the inadequacies
   of existing laws and the lag in technological advancements-particularly
   in AI and big data-that hinder effective cyber policing. Additionally,
   interviewees highlighted concerns about insufficient skills and training
   within cybercrime units, which limit their ability to address the unique
   complexities of AI-driven cybercrime. Suggestions provided by officers
   and staff to improve this situation are also discussed in the paper.},
Publisher = {PALGRAVE MACMILLAN LTD},
