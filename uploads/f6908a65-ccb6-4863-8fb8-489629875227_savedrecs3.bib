@article{ WOS:001506213200005,
Author = {Hassan, Salam and Ali, Ahmad and Mousa, Kawar Mohammed},
Title = {The role of forensic DNA experts and Artificial Intelligence in
   enhancing the effectiveness of wildlife crime investigations in Cyprus},
Journal = {JOURNAL OF WILDLIFE AND BIODIVERSITY},
Year = {2025},
Volume = {9},
Number = {2},
Abstract = {The increasing prevalence of wildlife crimes globally and in Cyprus
   presents an urgent need for more effective investigation methods. This
   study explores the factors that influence the effectiveness of wildlife
   crime investigations, focusing on the role of forensic DNA experts,
   different forensic methods, inter-agency relationships, and the
   incorporation of Artificial Intelligence (AI)-based tools. Employing a
   quantitative approach and a sample of 560 respondents, the study finds
   that all the posited variables involvement of forensic DNA experts,
   types of forensic methods used, organizational and operational
   relationships, and AI-based forensic tools significantly influence the
   outcome of investigations. Forensic DNA experts and AI-based forensic
   tools are key contributors to investigation success. These findings show
   that forensic DNA experts ((3 = 0.60), modern forensic methods ((3 =
   0.30), inter-agency relationships ((3 = 0.20), and AI-based tools ((3 =
   0.40) significantly enhance wildlife crime investigations, highlighting
   the need for specialized training, advanced forensic techniques, and AI
   integration. The study fills an existing gap in research by focusing on
   Cyprus, an area underrepresented in previous studies. It also introduces
   AI-based tools such as machine learning algorithms for pattern
   recognition, automated DNA analysis, facial and species recognition
   software, and predictive analytics as a novel factor in enhancing the
   effectiveness of wildlife crime investigations.},
Publisher = {ARAK UNIV, ARAK},
Address = {DEPT ENVIRONMENTAL SCIENCES, FAC AGRICULTURE \& NATURAL RESOURCES, ARAK,
   00000, IRAN},
Type = {Article},
Language = {English},
Affiliation = {Ali, A (Corresponding Author), Near East Univ, Dept Publ law, Via Mersin 10, TR-99138 Nicosia, North Cyprus, Turkiye.
   Hassan, Salam; Ali, Ahmad, Near East Univ, Dept Publ law, Via Mersin 10, TR-99138 Nicosia, North Cyprus, Turkiye.
   Mousa, Kawar Mohammed, Near East Univ, Dept Business Adm, Via Mersin 10, TR-99138 Nicosia, North Cyprus, Turkiye.},
DOI = {10.5281/zenodo.15510998},
EISSN = {2588-3526},
