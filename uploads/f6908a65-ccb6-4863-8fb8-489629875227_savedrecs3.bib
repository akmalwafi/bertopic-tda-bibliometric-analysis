Pages = {85-100},
Month = {APR},
Abstract = {The prediction of crime in time and space, as advocated in Predictive
   Policing, is an innovation driven by method and technology that updates
   the logic of 19th century social physics for a Big Data context. Based
   on an analysis of criminological thinking underlying recent Anglo
   American scholarship on Predictive Policing it is argued that a triple
   abstraction from social structures, subjectivations and political
   strategies is performed.},
