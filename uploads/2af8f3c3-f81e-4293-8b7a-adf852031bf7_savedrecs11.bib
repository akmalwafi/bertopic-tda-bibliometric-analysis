Organization = {European Soc Computat Methods Sci \& Engn},
Abstract = {The paper is devoted to the issues of data mining methods usage for
   money laundering detecting. The object of analysis is the information of
   the Federal Financial Monitoring Service of the Russian Federation on
   financial transactions in the banking system. As a research tool, the
   analysis of network graphs of financial transactions data is used. The
   aim is to identify organizations whose activities do not comply with the
   requirements of the legislation on money laundering counteraction and
   terrorism financing. The proposed method allows identifying the main
   actors of criminal schemes and determining the nature of their
   interconnections in order to increase the efficiency of the measures
   aimed at money laundering combating.},
