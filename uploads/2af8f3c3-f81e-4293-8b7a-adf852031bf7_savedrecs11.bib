@inproceedings{ WOS:000946564100159,
Author = {Roelofs, Lilly and Weissman, Claire and Raicu, Daniela and Furst, Jacob
   and Tchoua, Roselyne},
Book-Group-Author = {ACM},
Title = {Similarity-Based Uncertainty Scores for Interpretable Deep Learning in
   Scientific Applications},
Booktitle = {37TH ANNUAL ACM SYMPOSIUM ON APPLIED COMPUTING},
Year = {2022},
Pages = {1152-1155},
Note = {37th Annual ACM Symposium on Applied Computing, ELECTR NETWORK, APR
   25-29, 2022},
Organization = {Microsoft Res},
Abstract = {There is a significant effort to increase the adoption of Deep Neural
   Networks (DNNs) in fields such as criminal justice and medicine. Yet,
   DNNs commonly fall short in these applications due to their ``black
   box{''} nature. DNN research often focuses more on achieving a higher
   classification accuracy than traditional Machine Learning (ML)
   algorithms, but this does not apply well to data sets that are
   inherently difficult to label and classify, hence interpretability is
   crucial. In such cases, scientists not only expect a prediction but also
   an explanation and/or a measure of confidence per prediction. In this
   work, we propose a novel uncertainty metric based on clustering and data
   similarity learned through a Siamese Convolutional Neural Network
   (SCNN). Rather than using the silhouette coefficient as a quality metric
   for clustering, we use it to independently provide an uncertainty score
   and supplement each prediction. These uncertainty scores serve to better
   inform the end-user's decision, in our case an application domain
   expert. We evaluate our uncertainty scores using a K-Nearest Neighbors
   (KNN) classifier built on top of SCNN features. We show that the top
   15\% most uncertain points-flagged per our metric-capture over 50\% of
   KNN errors (misclassified cases) for three different data sets,
   exhibiting the versatility and functionality of our uncertainty metric
   in detecting difficult-to-classify samples.},
