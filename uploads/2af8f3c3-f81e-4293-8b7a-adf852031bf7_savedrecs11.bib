@inproceedings{ WOS:000398765700107,
Author = {Abiodun, Modupe and Oludayo, O. Olugbara and Sunday, O. Ojo},
Editor = {Zhang, Y and Tan, H},
Title = {Identifying Advanced Fee Fraud Activities on Internet Using Machine
   Learning Algorithms},
Booktitle = {2010 THE 3RD INTERNATIONAL CONFERENCE ON COMPUTATIONAL INTELLIGENCE AND
   INDUSTRIAL APPLICATION (PACIIA2010), VOL V},
Year = {2010},
Pages = {419-422},
Note = {3rd International Conference on Computational Intelligence and
   Industrial Application (PACIIA2010), Wuhan, PEOPLES R CHINA, DEC 04-05,
   2010},
Organization = {Wuhan Inst Technol; Huazhong Univ Sci \& Technol; Huazhong Normal Univ;
   CCF Young Comp Sci \& Engn Forum Wuhan Branch; IEEE Ind Elect Soc; IEEE
   Ind Elect Soc Beijing Shenzhen Chapter},
Abstract = {This study develops a model that attempts to mine advanced fee fraud
   activities through internet based emails correspondence for the purpose
   of forensic investigation. We extract various email document
   stylometrics, header and textural body content features that are used
   with support vector machine and Logistics regression machine learning
   algorithms to classify email documents into binary categories. Automatic
   word clustering algorithm is applied to partition a set of distinct
   words into clusters of semantically similar words to achieve space
   dimension reduction and classification efficiency. The classification
   accuracies of support vector machine and Logistics regression are
   compared. The results of this comparison show that the mean accuracy for
   support vector machine (M=95.20, SD=2.85) is not significantly different
   from the mean accuracy for Logistics regression (M=93.70, SD=2.51) using
   two sample t test for equal variance. Conclusively, support vector
   machine and Logistics regression are useful machine learning algorithms
   for identifying advanced fee fraud activities on the internet.},
