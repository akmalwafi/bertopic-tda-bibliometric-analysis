@inproceedings{ WOS:001324620600018,
Author = {Yau, Jia Xin and Chia, Kai Lin},
Editor = {Ghazali, R and Nawi, NM and Deris, MM and Abawajy, JH and Arbaiy, N},
Title = {Machine Learning-Based Phishing Website Detection: A Comparative
   Analysis and Web Application Development},
Booktitle = {RECENT ADVANCES ON SOFT COMPUTING AND DATA MINING, SCDM 2024},
Series = {Lecture Notes in Networks and Systems},
