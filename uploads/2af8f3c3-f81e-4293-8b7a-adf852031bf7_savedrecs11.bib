@article{ WOS:000842825000001,
Author = {Rani, Vinjamuri Usha and Burthi, Loveswara Rao},
Title = {An efficient FBI-iForest approach- based home energy management system
   with RES under internet of things framework},
Journal = {INTERNATIONAL JOURNAL OF ENERGY RESEARCH},
