@inproceedings{ WOS:000426969400019,
Author = {Arnob, Samin Yeasar and Ohib, Riyasat and Muhaisin, Md. Muhtady and Bin
   Hassan, Tanzil},
Book-Group-Author = {IEEE},
Title = {Power File Extraction Process from Bangladesh Grid and Exploring ENF
   Based Classification Accuracy using Machine Learning},
Booktitle = {2017 IEEE REGION 10 HUMANITARIAN TECHNOLOGY CONFERENCE (R10-HTC)},
Series = {IEEE Region 10 Humanitarian Technology Conference},
