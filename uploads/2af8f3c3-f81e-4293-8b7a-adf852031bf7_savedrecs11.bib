@inproceedings{ WOS:000796420200011,
Author = {Nascimento, Bruno S. and Maia, Denis and Almada, Lucas},
Book-Group-Author = {IEEE},
Title = {Applying Machine Learning to Improve Collection and to Reduce Write-Offs
   in Utilities},
Booktitle = {2021 INTERNATIONAL CONFERENCE ON ARTIFICIAL INTELLIGENCE AND BLOCKCHAIN
   TECHNOLOGY (AIBT 2021)},
Year = {2021},
Pages = {59-63},
Note = {International Conference on Artificial Intelligence and Blockchain
   Technology (AIBT), ELECTR NETWORK, DEC 04-06, 2021},
Abstract = {Up to 2\% of utilities' bills become bad debt and write-offs, meaning
   tens of billion dollars annually. Collection of unpaid invoices is a
   complex task for power, gas and water companies that continuously search
   for improvement. The goal of our research was to investigate utilities'
   payment behavior and how they respond to collection actions, in order
   that could be possible optimize the capital allocation to recover more
   revenue. Therefore, we selected 43 features, none external to the
   utility, and applied machine learning algorithms to 300 thousand
   utility's customers with unpaid invoices in the last 3 years to evaluate
   results. For this, we proposed a framework for the scoring models of
   default prediction, spontaneous payments, and payment through response
   to collection actions. The approach was divided into three phases
   consisting of carrying out the pre-processing of data, feature selection
   and evaluation of the approach through AUC, Accuracy and ROC curve. Our
   work achieved an AUC of 0.9222 and Accuracy of 0.8696 for payment
   propensity in the next 30 days (similar results for next 60 and 90
   days). Comparing to the Financial industry, a study that applied machine
   learning techniques to predict payment delinquency for bank loans, using
   345 features, achieved AUC of 0.8748 with Deeper MLP with sigmoid and
   Accuracy of 0.8650 with XGBoost, after NAP algorithm for feature
   selection {[}1].},
