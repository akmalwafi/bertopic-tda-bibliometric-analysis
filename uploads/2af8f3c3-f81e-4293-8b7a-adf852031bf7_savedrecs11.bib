@article{ WOS:000894579500001,
Author = {Thapaliya, Suman and Sharma, Pawan Kumar},
Title = {Cyber Forensic Investigation in IoT Using Deep Learning Based Feature
   Fusion in Big Data},
Journal = {INTERNATIONAL JOURNAL OF WIRELESS INFORMATION NETWORKS},
