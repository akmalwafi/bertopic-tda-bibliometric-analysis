@inproceedings{ WOS:000923472200003,
Author = {Edwards, Tiffanie and McCullough, Syria and Nassar, Mohamed and Baggili,
   Ibrahim},
Editor = {Gladyshev, P and Goel, S and James, J and Markowsky, G and Johnson, D},
Title = {On Exploring the Sub-domain of Artificial Intelligence (AI) Model
   Forensics},
Booktitle = {DIGITAL FORENSICS AND CYBER CRIME, ICDF2C 2021},
