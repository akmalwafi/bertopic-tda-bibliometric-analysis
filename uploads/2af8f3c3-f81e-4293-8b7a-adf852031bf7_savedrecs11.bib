Title = {Using the Activity Theory to Identify the Challenges of Designing
   Elearning Tools based on Machine Learning for Security Operations
   Centers},
Booktitle = {NEW TECHNOLOGIES AND REDESIGNING LEARNING SPACES, VOL I},
Series = {eLearning and Software for Education},
