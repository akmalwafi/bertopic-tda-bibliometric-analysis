@inproceedings{ WOS:000257944200036,
Author = {Ku, Chih Hao and Iriberri, Alicia and Leroy, Gondy},
Book-Group-Author = {IEEE},
Title = {Crime information extraction from police and witness narrative reports},
Booktitle = {2008 IEEE CONFERENCE ON TECHNOLOGIES FOR HOMELAND SECURITY, VOLS 1 AND 2},
Year = {2008},
Pages = {193-198},
Note = {IEEE Conference on Technologies for Homeland Security, Waltham, MA, MAY
   12-13, 2008},
Organization = {IEEE; Massachusetts Port Author; SAIC; Raytheon; EADS N Amer; ARES Corp;
   AVERT; Appl Signal Technol; Homeland Secur Daily Wire; Sugarspun Ind},
Abstract = {To solve crimes, investigators often rely on interviews with witnesses,
   victims, or criminals themselves. The interviews are transcribed and the
   pertinent data is contained in narrative form. To solve one crime,
   investigators may need to interview multiple people and then analyze the
   narrative reports. There are several difficulties with this process:
   interviewing people is time consuming, the interviews - sometimes
   conducted by multiple officers - need to be combined and the resulting
   information may still be incomplete. For example, victims or witnesses
   are often too scared or embarrassed to report or prefer to remain
   anonymous. We are developing an online reporting system that combines
   natural language processing with insights from the cognitive interview
   approach to obtain more information from witnesses and victims. We
   report here on information extraction from police and witness
   narratives. We achieved high precision, 94\% and 96\% and recall, 85\%
   and 90\%, for both narrative types.},
