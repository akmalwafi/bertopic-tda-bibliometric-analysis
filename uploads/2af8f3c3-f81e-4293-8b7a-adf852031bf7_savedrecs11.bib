Title = {Identifying Cannabis Use Risk Through Social Media Based on Deep
   Learning Methods},
Booktitle = {ARTIFICIAL INTELLIGENCE AND SOFT COMPUTING, ICAISC 2022, PT II},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2023},
