@inproceedings{ WOS:000869745400010,
Author = {Moreira, Nidia Andrade},
Editor = {Marreiros, G and Martins, B and Paiva, A and Ribeiro, B and Sardinha, A},
Title = {The Compatibility of AI in Criminal System with the ECHR and ECtHR
   Jurisprudence},
