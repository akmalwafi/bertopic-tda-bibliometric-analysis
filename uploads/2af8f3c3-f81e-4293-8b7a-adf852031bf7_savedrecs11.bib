@inproceedings{ WOS:001450692200010,
Author = {Qin, Shengzhi and Chow, Kam-Pui},
Editor = {Kurkowski, E and Shenoi, S},
Title = {Improving Android Malware Detection in Imbalanced Data Scenarios},
Booktitle = {ADVANCES IN DIGITAL FORENSICS XX},
