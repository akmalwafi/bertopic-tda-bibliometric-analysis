Pages = {305-311},
Note = {6th IEEE International Conference on Fuzzy Systems (FUZZ-IEEE 97),
   BARCELONA, SPAIN, JUL 01-05, 1997},
Organization = {IEEE, Neural Network Council},
Abstract = {This paper derails research undertaken at Bournemouth University into
   the use of a fuzzy development system called Matcher to build an
   offender profiling system. A brief introduction is given on the
   background and uses for offender profiling and the Marcher tool used to
   build the Match'em system. A description of the design of the system and
   its evaluation is provided. The emphasis of the system is on
   functionality and usability and these are assessed by a quantitative
   summary of rest results and a questionnaire presented to experimental
   users. Empirical results are shown to illustrate the usefulness and
   usability of this fuzzy. logic system for offender profiling. Adaptation
   to other domains where profiling might be used are also considered.},
