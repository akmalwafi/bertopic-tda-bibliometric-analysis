@article{ WOS:000618321700009,
Author = {Ortiz, A. G. and Costa, C. and Silva, R. H. A. and Biazevic, M. G. H.
   and Michel-Crosato, E.},
Title = {Sex estimation: Anatomical references on panoramic radiographs using
   Machine Learning},
Journal = {FORENSIC IMAGING},
Year = {2020},
Volume = {20},
Month = {MAR},
Abstract = {Context: Panoramic radiographs may aid in forensic practice and are
   commonly used tests in dental documentation. This study presents a new
   method of estimating sex through anatomical points visible on panoramic
   radiographs, using Machine Learning.
   Objective: To verify the accuracy of the sex estimation from anatomical
   points in panoramic radiographs using Machine Learning.
   Material and methods: This is a cross-sectional study. 100 panoramic
   radiographs from a radiological service were examined, at two different
   times, using 13 linear and angular measures in the mandible, which
   served as the basis for the analysis. Measurements were taken in pixels.
   To verify the reliability of the method, the intraclass coefficient
   (ICC), the coefficient of variation (CV) and the statistical technique
   of Bland-Altman were calculated. The adhesion of the data to the normal
   curve was tested using the Shapiro-Wilk test. The Mann-Whitney test was
   used to verify the difference between the measurements for male and
   female radiographs. Discriminant analysis was also calculated to predict
   the participants' sex and utilizing Machine Learning techniques.
   Results: The ICC was above 0.90 for all measurements and the CV was
   below 5\%. In the Bland-Altman analysis, the measurements were within
   the set confidence intervals. Regarding sex estimation, the variables
   that presented statistical differences were the measurements 1, 5, 7, 8,
   12 and 13 and index 2. The accuracy of the discriminant analysis test
   was above 70\%. When utilizing Machine Learning techniques, the accuracy
   rose to 95\%.
   Conclusions: Sex estimation can be performed by anatomical points
   visible in panoramic radiographs},
