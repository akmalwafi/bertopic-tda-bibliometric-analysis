@article{ WOS:001411108800001,
Author = {Alasiry, Areej and Qayyum, Mohammed},
Title = {A Region based Salient Stacking Optimized Detector (ReSOD) for an
   effective anomaly detection and video tracking in surveillance systems},
Journal = {NEUROCOMPUTING},
Year = {2025},
Volume = {622},
Month = {MAR 14},
Abstract = {Identifying unusual occurrences in videos is among one of the most
   frequently addressed topics in the field of computer vision. Because of
   its personal or context-specific definitions, it is regarded as a
   challenging endeavor in the field of video analysis. To deal with the
   identification of anomalies issues, multiple approaches have been put
   forth. The use of deep learning and customized methods are among such
   methods. A large number of investigators have attempted to identify the
   most effective approach for efficiently identifying anomalies in video
   streams with a relatively low risk of false alarms. For use in video
   surveillance applications, this study presents a unique and lightweight
   video tracking technology called Region based Salient Stacking Optimized
   Detector (ReSOD). This framework uses a Correlation based Moving
   Position with Region Tracking Model (CoMP-RT) to perform an efficient
   and precise anomaly identification. In addition, motion prediction is
   carried out using a Salient Point based Stacking Pixel Hypothesis Model
   (S2P2Hypo) technique to provide safety and control. Furthermore, a
   unique optimization method called the hybrid Forensic Choatic Kernel
   Search Optimizer (FCKSO) is presented in order to estimate the optimal
   value and enhance the motion prediction process. Background subtraction
   is then carried out using the optimal value that is acquired.
   Furthermore, system analysis and assessment are being conducted using
   some of the most recent and well-known video surveillance datasets,
   including the mall dataset, UCSD, UMN, ShanghaiTech dataset, and violent
   flow dataset. By integrating CoMPRT, S2P2Hypo, and FCKO techniques, the
   overall anomaly detection efficiency is enhanced to 99\% with high
   accuracy of 99.4\% and error rate of 1.2\%.},
