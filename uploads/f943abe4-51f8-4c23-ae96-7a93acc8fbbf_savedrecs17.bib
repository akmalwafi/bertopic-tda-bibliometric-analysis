@inproceedings{ WOS:000298962502017,
Author = {Saboia, Priscila and Carvalho, Tiago and Rocha, Anderson},
Book-Group-Author = {IEEE},
Title = {EYE SPECULAR HIGHLIGHTS TELLTALES FOR DIGITAL FORENSICS: A MACHINE
   LEARNING APPROACH},
