@inproceedings{ WOS:000679176800001,
Author = {Kirchner, Matthias and Pasquini, Cecilia and Shumailov, Ilia},
Book-Group-Author = {IEEE},
Title = {Information Security Meets Adversarial Examples},
Booktitle = {2019 IEEE INTERNATIONAL WORKSHOP ON INFORMATION FORENSICS AND SECURITY
   (WIFS)},
Series = {IEEE International Workshop on Information Forensics and Security},
Year = {2019},
Note = {IEEE International Workshop on Information Forensics and Security
   (WIFS), Delft, NETHERLANDS, DEC 09-12, 2019},
Organization = {IEEE},
Abstract = {Machine learning (ML) plays a pivotal role in supporting a variety of
   research problems at the core of information security and forensics
   (IFS). ML-based systems have improved overall performance in many
   applications, replacing more and more deterministic rule-based
   approaches with data-driven ones. Yet, enforcing their dependability in
   typical IFS scenarios that include strategic adversaries is a
   challenging open problem.
   This special session aims at strengthening the link between concepts and
   methods developed in the adversarial ML and IFS domains. To this end, it
   gathers contributions exploring implications of and countermeasures to
   adversarial attacks against learning systems. Special emphasis is placed
   on media security applications.},
