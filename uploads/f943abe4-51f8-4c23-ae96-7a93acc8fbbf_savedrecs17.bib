Author = {Suttanuruk, Jakkrit and Jomnonkwao, Sajjakaj and Ratanavaraha,
   Vatanavong and Kanjanawattana, Sarunya},
Title = {Convolutional Neural Network for Overcrowded Public Transportation
   Pickup Truck Detection},
