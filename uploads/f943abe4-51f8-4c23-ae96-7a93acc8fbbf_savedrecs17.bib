
@inproceedings{ WOS:000590395100031,
Author = {Dass, Rahul Kumar and Petersen, Nick and Visser, Ubbo and Omori, Marisa},
Book-Group-Author = {IEEE Comp Soc},
Title = {It's Not Just Black and White: Classifying Defendant Mugshots Based on
   the Multidimensionality of Race and Ethnicity},
Booktitle = {2020 17TH CONFERENCE ON COMPUTER AND ROBOT VISION (CRV 2020)},
Year = {2020},
Pages = {238-245},
Note = {17th Conference on Computer and Robot Vision (CRV), ELECTR NETWORK, MAY
