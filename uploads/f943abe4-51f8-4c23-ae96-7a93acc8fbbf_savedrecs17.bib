@article{ WOS:000564707800001,
Author = {Adjabi, Insaf and Ouahabi, Abdeldjalil and Benzaoui, Amir and
   Taleb-Ahmed, Abdelmalik},
Title = {Past, Present, and Future of Face Recognition: A Review},
