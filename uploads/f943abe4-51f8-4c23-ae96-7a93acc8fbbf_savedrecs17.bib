@article{ WOS:001400324400001,
Author = {Mariotto, Livia Salviano and Rodrigues, Caio Henrique Pinke and Mason,
   Nigel John and Bruni, Aline Thais and Fantuzzi, Felipe},
Title = {Density Functional Theory in Forensic Science: Applications and
   Challenges},
