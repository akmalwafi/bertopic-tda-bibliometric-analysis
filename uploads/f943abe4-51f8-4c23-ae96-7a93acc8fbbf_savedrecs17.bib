@article{ WOS:000753113200004,
Author = {Nikolova, Silviya and Toneva, Diana and Agre, Gennady},
Title = {Reliability of sagittal suture maturation for age-at-death prediction
   assessed by means of machine learning techniques},
Journal = {FORENSIC IMAGING},
Year = {2021},
Volume = {26},
Month = {SEP},
Abstract = {Objectives: The sagittal suture (SS) is one of the major calvarial
   sutures and is used as an age-at-death indicator in forensic and
   bioarchaeological expertise. This study aimed to investigate whether the
   degree of SS closure could be used for a reliable age-at-death
   prediction. For this purpose we investigated the degree of SS closure in
   depth and applied symbolic and sub-symbolic machine learning algorithms
   designed to solve regression tasks.
   Materials and methods: The SS was investigated in 88 dry adult male
   skulls of known age-at-death ranging between 20 and 58 years. The skulls
   were scanned using a mu CT system. The SS closure degree was assessed on
   crosssectional tomograms along the suture length using a scoring scale
   based on the morphological reorganization during SS maturation in each
   of the 3 bone layers. The obtained data were organized into six training
   datasets containing the same set of examples but described by different
   sets of attributes. Linear regression and K-nearest neighbors algorithms
   were applied to learn age-at-death predictive models.
   Results: The learnt models which showed the best predictive age-at-death
   ability were those constructed on the training dataset for the SS
   closure degree at the external table by means of 15-nearest neighbors
   (RMSE = 6.2856) and linear regression (RMSE = 6.2880) algorithms.
   Conclusion: The best age-at-death predictive models have been learnt
   from the dataset in which the examples are described only by the
   external table closure degree along the SS length. The use of other
   attributes worsens the predictive ability of the learnt models.},
