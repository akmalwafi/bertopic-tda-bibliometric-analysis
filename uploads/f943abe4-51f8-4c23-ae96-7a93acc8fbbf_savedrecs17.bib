Title = {Automatic Latent Fingerprint Pose Estimation},
Booktitle = {2022 30TH SIGNAL PROCESSING AND COMMUNICATIONS APPLICATIONS CONFERENCE,
   SIU},
Series = {Signal Processing and Communications Applications Conference},
Year = {2022},
Note = {30th IEEE Signal Processing and Communications Applications Conference
   (SIU), Safranbolu, TURKEY, MAY 15-18, 2022},
Organization = {IEEE; IEEE Turkey Sect; Bahcesehir Univ},
Abstract = {In this study, we propose a novel method towards automatic pose
   estimation in latent fingerprint images. Proposed method utilizes one of
   the most popular models in image classification, namely MobileNetV3, for
   pose estimation using latent images. With the pre-processing steps
   applied before classification, the region where the traces are found in
   the crime scene traces is segmented and the noise level is reduced. The
   proposed method was tested using 2034 tagged latent fingerprints
   obtained from the General Directorate of Security (EGM) in Ankara,
   Turkey. Proposed methods improves the classification accuracy
   considerably compared to an earlier method developed towards this task.},
