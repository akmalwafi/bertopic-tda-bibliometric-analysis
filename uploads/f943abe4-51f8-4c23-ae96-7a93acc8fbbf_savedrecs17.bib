@inproceedings{ WOS:001266125000132,
Author = {Seo, Yuri and Jo, Hyeon-ki and Roh, Seol and Sun, Teh-Jen and Jeong,
   Seung-Woo and Kim, HakHo and Ngo, Thien-Thu and Huh, Eui-Nam},
Book-Group-Author = {IEEE},
Title = {DevoX: Deep Voice Detection MLOps Framework for Crime Prevention in the
   Core-Edge Cloud},
Booktitle = {38TH INTERNATIONAL CONFERENCE ON INFORMATION NETWORKING, ICOIN 2024},
Year = {2024},
