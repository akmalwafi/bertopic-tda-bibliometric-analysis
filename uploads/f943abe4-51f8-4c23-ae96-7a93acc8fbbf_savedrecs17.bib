@article{ WOS:000688411400025,
Author = {Ramzan, Muhammad and Raza, Mudassar and Sharif, Muhammad and Khan,
   Muhammad Attique and Nam, Yunyoung},
Title = {Gastrointestinal Tract Infections Classification Using Deep Learning},
