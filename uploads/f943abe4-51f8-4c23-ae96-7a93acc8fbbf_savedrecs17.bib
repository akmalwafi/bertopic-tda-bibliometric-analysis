Title = {Automated nuclear cloud feature extraction from film},
Booktitle = {CHEMICAL, BIOLOGICAL, RADIOLOGICAL, NUCLEAR, AND EXPLOSIVES, CBRNE
   SENSING XXVI},
Series = {Proceedings of SPIE},
Year = {2025},
