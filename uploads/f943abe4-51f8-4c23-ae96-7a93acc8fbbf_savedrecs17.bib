@inproceedings{ WOS:000976814900025,
Author = {Manhaes, Anderson and Matos, Gabriel and Cardoso, Douglas O. and Pinto,
   Milena F. and Colares, Jeferson and Leitao, Paulo and Brandao, Diego and
   Haddad, Diego},
Editor = {Kosir, A and Fernandes, FP and Pacheco, MF and Teixeira, JP and Lopes, RP and Pereira, AI},
Title = {Long-Term Person Reidentification: Challenges and Outlook},
Booktitle = {OPTIMIZATION, LEARNING ALGORITHMS AND APPLICATIONS, OL2A 2022},
Series = {Communications in Computer and Information Science},
Year = {2022},
Volume = {1754},
Pages = {357-372},
Note = {2nd International Conference on Optimization, Learning Algorithms and
   Applications (OL2A), Povoa de Varzim, PORTUGAL, OCT 24-25, 2022},
Abstract = {Person reidentification, i.e., retrieving a person of interest across
   several non-overlapping cameras, is a task that is far from trivial.
   Despite its great commercial value and wide range of applications (e.g.,
   surveillance, intelligent environments, forensics, service robotics,
   marketing), it remains unsolved, even when the individuals do not change
   clothes during the recognition period. This paper provides an outlook on
   long-term person reidentification, an emerging research topic regarding
   when consecutive acquisitions of an individual can be found apart for
   days or even months, making such a task even more challenging. A
   long-term reidentification system using face recognition is presented to
   emphasize current techniques' limitations.},
Publisher = {SPRINGER INTERNATIONAL PUBLISHING AG},
Address = {GEWERBESTRASSE 11, CHAM, CH-6330, SWITZERLAND},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Haddad, D (Corresponding Author), Celso Suckow Fonseca Fed Ctr Technol Educ, Rio De Janeiro, Brazil.
   Manhaes, Anderson; Matos, Gabriel; Pinto, Milena F.; Colares, Jeferson; Brandao, Diego; Haddad, Diego, Celso Suckow Fonseca Fed Ctr Technol Educ, Rio De Janeiro, Brazil.
   Cardoso, Douglas O., Polytech Inst Tomar, Smart Cities Res Ctr, Tomar, Portugal.
