ISSN = {2212-473X},
EISSN = {2212-4748},
Keywords = {Deepfakes; Synthetic media; Image-based sexual abuse; Content
   moderation; AI regulation; Online Safety Act; Social media platforms;
   United Kingdom},
Keywords-Plus = {VIOLENCE},
Research-Areas = {Government \& Law},
Web-of-Science-Categories  = {Law},
Author-Email = {b.kira@sussex.ac.uk},
Affiliations = {University of Sussex},
ORCID-Numbers = {Kira, Beatriz/0000-0002-7078-8193},
Funding-Acknowledgement = {School of Law, Politics and Sociology of the University of Sussex},
Funding-Text = {The author benefited from financial support provided by the School of
   Law, Politics and Sociology of the University of Sussex for research
   assistance in the preparation of this article. For helpful comments, the
