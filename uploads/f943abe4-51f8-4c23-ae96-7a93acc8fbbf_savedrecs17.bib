@article{ WOS:001544590600001,
Author = {van Horn, Joan and Hutten, Juliette and Eisenberg, Mara and Verschuere,
   Bruno and Vial, Annemiek},
Title = {Central eight risk factors among early dropouts, late dropouts, and
   completers of forensic outpatient care: a network analysis},
Journal = {PSYCHOLOGY CRIME \& LAW},
Year = {2025},
Month = {2025 AUG 6},
Abstract = {Managing risk factors among forensic outpatients is crucial for
   successful treatment outcomes. Previous studies identified the central
   eight risk factors as critical predictors of treatment discontinuation,
   particularly among those dropping out of treatment in early versus later
   stages. This study, conducted on Dutch forensic outpatients,
   hypothesized that early dropouts (n = 1,139) would exhibit higher scores
   and more pronounced interconnections among the central eight risk
   factors than late dropouts (n = 631) and completers (n = 1,063). MANCOVA
   results, controlling for age, indicated shared vulnerabilities among
   dropout groups, with the timing of dropout not directly related to risk
   factor intensity. Both dropout groups had more problematic scores than
   completers on all but one central eight-factor (C7 Family/marital
   circumstances), though differences were small. Network analyses revealed
   no metric and global strength invariance differences across network
   structures. However, significant edge invariance differences were found,
   particularly in the connections of C1 History of antisocial/criminal
   behavior and C2 Antisocial personality pattern with other central eight
   risk factors. These findings did not fully support our expectations,
   suggesting that future research should consider factors beyond the
   central eight, such as offenders' responsivity characteristics
   (motivation, learning style, etc.), when studying dropout stages.},
