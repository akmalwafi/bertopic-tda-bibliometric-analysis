@article{ WOS:000573487900001,
Author = {Gao, Yunyuan and Zhu, Tao and Xu, Xiaohua},
Title = {Bone age assessment based on deep convolution neural network
   incorporated with segmentation},
Journal = {INTERNATIONAL JOURNAL OF COMPUTER ASSISTED RADIOLOGY AND SURGERY},
