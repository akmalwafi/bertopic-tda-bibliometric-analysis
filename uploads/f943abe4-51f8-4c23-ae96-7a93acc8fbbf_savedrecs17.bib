@article{ WOS:000501223700028,
Author = {Eickhoff, Simon B. and Langner, Robert},
Title = {Neuroimaging-based prediction of mental traits: Road to utopia or
   Orwell?},
Journal = {PLOS BIOLOGY},
Year = {2019},
Volume = {17},
Number = {11},
Month = {NOV},
Abstract = {Predicting individual mental traits and behavioral dispositions from
   brain imaging data through machine-learning approaches is becoming a
   rapidly evolving field in neuroscience. Beyond scientific and clinical
   applications, such approaches also hold the potential to gain
   substantial influence in fields such as human resource management,
   education, or criminal law. Although several challenges render real-life
   applications of such tools difficult, future conflicts of individual,
   economic, and public interests are preprogrammed, given the prospect of
   improved personalized predictions across many domains. In this
   Perspective paper, we thus argue for the need to engage in a discussion
   on the ethical, legal, and societal implications of the emergent
   possibilities for brain-based predictions and outline some of the
   aspects for this discourse.},
