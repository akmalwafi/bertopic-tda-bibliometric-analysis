   Thomas M.},
Editor = {Srihari, SN and Franke, K},
Title = {Evaluation of graylevel-features for printing technique classification
   in high-throughput document management systems},
Booktitle = {COMPUTATIONAL FORENSICS, PROCEEDINGS},
Series = {Lecture Notes in Computer Science},
Year = {2008},
Volume = {5158},
Pages = {35-46},
Note = {2nd International Workshop on Computational Forensics, Natl Acad Sci,
   Washington, DC, AUG 07-08, 2008},
Abstract = {The detection of altered or forged documents is ail important tool in
   large scale office automation. Printing technique examination can
   therefore be a valuable source of information to determine a questioned
   documents authenticity. A study of graylevel features for high
   throughput printing technique recognition was undertaken. The evaluation
   included printouts generated by 49 different laser and 13 different
   inkjet printers. Furthermore, the extracted document features were
   classified using three different machine learning approaches. We were
   able to show that, under the given constraints of high-throughput
   systems, it is possible to determine the printing technique used to
   create a document.},
