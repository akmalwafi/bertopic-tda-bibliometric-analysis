@inproceedings{ WOS:001514478300014,
Author = {Poredi, Nihal and Schrader, Paul T. and Cosgrove, G. Makenzie and
   Solomon, Enoch and Chen, Yu},
Editor = {Blowers, M and Wysocki, BT},
Title = {Topological Frequency Feature Analysis for AI-Generated Image
   Authentication},
Booktitle = {DISRUPTIVE TECHNOLOGIES IN INFORMATION SCIENCES IX},
Series = {Proceedings of SPIE},
Year = {2025},
Volume = {13480},
Note = {2025 Conference on Disruptive Technologies in Information Sciences,
   Orlando, FL, APR 14-17, 2025},
Abstract = {The proliferation of AI-generated content (AIGC) brings new challenges
   to digital forensics and the verification of the authenticity of the
   media. This paper proposes a novel Topological Frequency Feature
   Analysis (ToFFA) for AI-generated imagery authentication by combining
   Topological Data Analysis (TDA) with frequency domain feature analysis.
   We hypothesize that the ToFFA method can capture complex, multiscale
   structural information in frequency patterns, potentially offering
   improved robustness over traditional statistical methods. Our study
   empirically and theoretically investigates the unique topological
   fingerprints of diffusion models in the frequency domain. We explore
   various TDA techniques, including persistent homology and filtration,
   applied to frequency representations of images. Experimental results
   demonstrate the effectiveness of our ToFFA scheme in distinguishing
   AI-generated images from authentic content in a diverse data set. We
   quantitatively compared our method performance against state-of-the-art
   AIGC detection techniques, showing significant potential for TDA in this
   area. Furthermore, we discuss the implications of our findings for
   proactive digital space management and responsible AI development. This
   research contributes to the growing knowledge about AIGC detection and
   authentication, offering new insights into the topological structures
   inherent in AI-generated media.},
