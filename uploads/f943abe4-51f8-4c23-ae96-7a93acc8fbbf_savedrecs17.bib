@inproceedings{ WOS:000465249700073,
Author = {Lee, Pin-Xuan and Ding, Jian-Jiun and Wang, Ting-Chih and Lee,
   Yih-Cherng},
Book-Group-Author = {IEEE},
Title = {AUTOMATIC WRITER VERIFICATION ALGORITHM FOR CHINESE CHARACTERS USING
   SEMI-GLOBAL FEATURES AND ADAPTIVE CLASSIFIER},
Booktitle = {2018 IEEE INTERNATIONAL CONFERENCE ON MULTIMEDIA \& EXPO WORKSHOPS
   (ICMEW 2018)},
