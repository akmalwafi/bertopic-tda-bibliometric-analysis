@article{ WOS:001295808400003,
Author = {Mora, Jaime Edison Rojas and Vasquez-Merchan, Irma Liliana and
   Pinto-Quijano, Angela Cristina and Sanchez, Carlos Fernando Morales},
Title = {Measurement and evaluation of criminal governance and its relation to
   drug trafficking in Colombia},
Journal = {REVISTA CIENTIFICA GENERAL JOSE MARIA CORDOVA},
Year = {2023},
Volume = {21},
Number = {44},
Month = {OCT-DEC},
Abstract = {Criminal governance is a phenomenon that is difficult to measure due to
   its clandestine nature, making it equally difficult to study its
   relationship with other problems that, like drug trafficking, severely
   impact particularly vulnerable populations. This article aims to
   investigate the complex relationship between criminal governance and
   drug trafficking in Colombia, through the creation of a Departmental
   Criminal Governance Index (IDGC) and an indicator of drug trafficking
   crimes. This research is novel, as it is based on data mining techniques
   to process large volumes of information. From the definition of
   constructs, the selection of variables and the definition of indicators
   to their measurement, weighting and visualization, this work provides
   inputs for criminal policy and anti-drug policy, including
   differentiated analyzes for each department of Colombia.},
Publisher = {ESCUELA MILITAR CADETES GENERAL JOSE MARIA CORDOVA},
