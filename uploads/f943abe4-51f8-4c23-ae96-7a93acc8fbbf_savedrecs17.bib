@inproceedings{ WOS:000389505000117,
Author = {Jo, WooYeon and Chang, Hyunsoo and Shon, Taeshik},
Editor = {Xu, B},
Title = {Digital Forensic Approach for File Recovery in Unix Systems},
Booktitle = {2016 IEEE INFORMATION TECHNOLOGY, NETWORKING, ELECTRONIC AND AUTOMATION
