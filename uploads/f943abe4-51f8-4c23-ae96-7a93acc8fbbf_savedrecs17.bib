@article{ WOS:001546627900002,
Author = {Abou-zbiba, Wahiba and Benbrahim, Houda and El Bakkali, Hanan and
   Benhaddou, Driss and El Gadi, Hajar},
Title = {To unify or diversify: A systematic literature review of single unified
   models versus multiple models in detecting both copy-move and image
   splicing forgeries},
Journal = {DIGITAL SIGNAL PROCESSING},
Year = {2026},
Volume = {168},
Number = {A},
Month = {JAN},
Abstract = {The proliferation of increasingly widespread and easy-to-use image
   editing tools has led to the spread of image manipulation. As a result,
   the detection of manipulated images has become a key area of research in
   the field of image forensics. Many researchers addressed the detection
   of one specific type of forgery, and a few others addressed the
   detection of more than one type of forgery. The most addressed types of
   image forgery are related to image splicing and copy-move forgeries,
   which have become more prevalent as image editing tools allow more
   sophisticated operations. Although both techniques are common, it is
   often unclear which one was used in a given image. For this reason, this
   paper presents a Systematic Literature Review (SLR), of image splicing
   and copy-move forgeries detection models. A standardized SLR approach
   was performed on papers between 2017 and 2023. This paper examines the
   possibility of incorporating a single model to detect both types of
   forgery. The study evaluates traditional and deep learning-based feature
   extraction techniques for detecting each type of forgery. In addition,
   the paper covers articles presenting a single model for detecting both
   types of forgery. The main contribution of this paper is to provide a
   comparison between the use of a single model and multiple models to
   detect both types of forgeries.},
