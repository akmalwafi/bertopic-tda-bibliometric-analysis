@article{ WOS:001435357300001,
Author = {Barocas, Briana and Shimizu, Rei and Yang, Sejung},
Title = {Social Work Research Using Electronic Health Records and Criminal
   Justice Data: Recommendations and Lessons Learned},
Journal = {JOURNAL OF THE SOCIETY FOR SOCIAL WORK AND RESEARCH},
Year = {2024},
Volume = {15},
Number = {4},
Pages = {823-847},
Month = {DEC 1},
Abstract = {Electronic health records (EHRs) are rich with psychosocial information
   and can be used as secondary data for social work research. This
   methodological report describes the process of a randomized controlled
   trial on interventions to address domestic violence crimes using
   information from EHRs as secondary data matched with criminal justice
   data to examine the effectiveness of the interventions. We illustrate
   the process, highlight the advantages and limitations of this method,
   and provide lessons for applying this method to other studies. Our
   recommendations include the following: (a) have an in-depth
   understanding of the study, (b) be aware of changes, (c) establish a
   timeline and gain access early in the process, (d) determine what data
   should be extracted, (e) consider access and privacy issues, (f)
   determine how EHRs should be stored, (g) develop a mechanism to track
   coding, (h) create a variable ``roadmap{''} in the codebook, (i) have
   one point person, (j) have at least two coders to enhance reliability,
   and (k) consider using artificial intelligence. Understanding the
   strengths and challenges of using EHRs as secondary data can help
   researchers to make more effective use of those technologies. Such
   efforts can enhance the ease and quality of EHR implementation in social
   work research.},
