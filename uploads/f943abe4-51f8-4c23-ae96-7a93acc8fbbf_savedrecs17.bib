@inproceedings{ WOS:000329611508171,
Author = {Barni, Mauro and Perez-Gonzalez, Fernando},
Book-Group-Author = {IEEE},
Title = {COPING WITH THE ENEMY: ADVANCES IN ADVERSARY-AWARE SIGNAL PROCESSING},
