@inproceedings{ WOS:000461290400003,
Author = {Afchar, Darius and Nozick, Vincent and Yamagishi, Junichi and Echizen,
   Isao},
Book-Group-Author = {IEEE},
Title = {MesoNet: a Compact Facial Video Forgery Detection Network},
Booktitle = {2018 10TH IEEE INTERNATIONAL WORKSHOP ON INFORMATION FORENSICS AND
   SECURITY (WIFS)},
Series = {IEEE International Workshop on Information Forensics and Security},
Year = {2018},
Note = {10th IEEE International Workshop on Information Forensics and Security
   (WIFS), Hong Kong, HONG KONG, DEC 11-13, 2018},
Organization = {IEEE; IEEE Signal Proc Soc; IEEE Biometrics Council; IEEE Signal Proc
   Soc, IEEE Informat Forens \& Secur Tech Comm; Dept Comp; Hong Kong
   Polytechn Univ},
Abstract = {This paper presents a method to automatically and efficiently detect
   face tampering in videos, and particularly focuses on two recent
   techniques used to generate hyper-realistic forged videos: Deepfake and
   Face2Face. Traditional image forensics techniques are usually not well
   suited to videos due to the compression that strongly degrades the data.
   Thus, this paper follows a deep learning approach and presents two
   networks, both with a low number of layers to focus on the mesoscopic
   properties of images. We evaluate those fast networks on both an
   existing dataset and a dataset we have constituted from online videos.
   The tests demonstrate a very successful detection rate with more than
   98\% for Deepfake and 95\% for Face2Face.},
