@inproceedings{ WOS:000870296100016,
Author = {Boccignone, Giuseppe and Bursic, Sathya and Cuculo, Vittorio and
   D'Amelio, Alessandro and Grossi, Giuliano and Lanzarotti, Raffaella and
   Patania, Sabrina},
Editor = {Sclaroff, S and Distante, C and Leo, M and Farinella, GM and Tombari, F},
Title = {DeepFakes Have No Heart: A Simple rPPG-Based Method to Reveal Fake
   Videos},
Booktitle = {IMAGE ANALYSIS AND PROCESSING, ICIAP 2022, PT II},
Series = {Lecture Notes in Computer Science},
Year = {2022},
Volume = {13232},
Pages = {186-195},
Note = {21st International Conference on Image Analysis and Processing (ICIAP),
   Lecce, ITALY, MAY 23-27, 2022},
Organization = {NVIDIA; E4 Comp Engn s p a; ImageS s p a; CNR, Lecce Inst Appl Sci \&
   Intelligent Syst; Natl Res Council Italy; Italian Assoc Comp Vis,
   Pattern Recognit \& Machine Learning},
Abstract = {We present a simple, yet general method to detect fake videos displaying
   human subjects, generated via Deep Learning techniques. The method
   relies on gauging the complexity of heart rate dynamics as derived from
   the facial video streams through remote photoplethys-mography (rPPG).
   Features analyzed have a clear semantics as to such physiological
   behaviour. The approach is thus explainable both in terms of the
   underlying context model and the entailed computational steps. Most
   important, when compared to more complex state-of-the-art detection
   methods, results so far achieved give evidence of its capability to cope
   with datasets produced by different deep fake models.},
