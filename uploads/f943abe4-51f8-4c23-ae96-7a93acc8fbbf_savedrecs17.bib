@inproceedings{ WOS:000474345000229,
Author = {Biswas, Arpita and Mukherjee, Suvam},
Book-Group-Author = {Assoc Comp Machinery},
Title = {Fairness Through the Lens of Proportional Equality},
Booktitle = {AAMAS `19: PROCEEDINGS OF THE 18TH INTERNATIONAL CONFERENCE ON
   AUTONOMOUS AGENTS AND MULTIAGENT SYSTEMS},
Year = {2019},
Pages = {1832-1834},
