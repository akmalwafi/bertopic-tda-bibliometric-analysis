@inproceedings{ WOS:000452627900011,
Author = {Isafiade, Omowunmi E. and Baguio, Antoine B.},
Book-Group-Author = {IEEE},
Title = {FOSTERING SMART CITY DEVELOPMENT IN DEVELOPING NATIONS: A CRIME SERIES
   DATA ANALYTICS APPROACH},
Booktitle = {2017 ITU KALEIDOSCOPE: CHALLENGES FOR A DATA-DRIVEN SOCIETY (ITU K)},
Year = {2017},
