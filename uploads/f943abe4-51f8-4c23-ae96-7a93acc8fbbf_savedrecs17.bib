@article{ WOS:001200371600001,
Author = {Pecorari, Natalia and Cuesta, Jose},
Title = {Citizen Participation and Political Trust in Latin America and the
   Caribbean: A Machine Learning Approach},
Journal = {EUROPEAN JOURNAL OF DEVELOPMENT RESEARCH},
Year = {2024},
Volume = {36},
Number = {5},
Pages = {1227-1252},
Month = {OCT},
Abstract = {This paper advances the understanding of the linkages between trust in
   government and citizen participation in Latin America and the Caribbean
   (LAC) using machine learning techniques and Latinobarometro 2023 data.
   Empirically, we predict citizen participation based on trust levels,
   characteristics and circumstances of citizens. Proponents of the concept
   of stealth democracy argue that an inverse relationship exists between
   political trust and citizen participation, while deliberative democracy
   theorists claim the opposite. Based on our estimates, trust in national
   governments and other governmental institutions play neither a dominant
   nor consistent role in driving political participation. Interest in
   politics, personal circumstances such as experience of crime, and
   socioeconomic characteristics appear to drive citizen participation much
   more strongly in LAC. This is true across models imposing simple linear
   trends (Logit and Lasso) and those allowing for complex relations
   (decision trees). Results vary across types of participation-signing a
   petition, participation in demonstrations, or involvement in community
   issues. Ultimately, political trust can only influence political
   participation when certain other drivers are combined in some specific
   ways.
   Ce document approfondit la comprehension des liens entre la confiance
   dans le gouvernement et la participation citoyenne en Amerique latine et
   dans les Caraibes (ALC) en utilisant des techniques d'apprentissage
   automatique et les donnees du Latinobarometro 2023. Empiriquement, nous
   predisons la participation citoyenne en fonction des niveaux de
   confiance, des caracteristiques, et des circonstances des citoyens. Les
   partisans du concept de democratie furtive (en anglaise, stealth
   democracy) soutiennent qu'il existe une relation inverse entre la
   confiance politique et la participation citoyenne, tandis que les
   theoriciens de la democratie deliberative pretendent le contraire. Selon
   nos estimations, la confiance dans les gouvernements nationaux et autres
   institutions gouvernementales ne joue pas un role ni dominant, ni
   constant, dans la stimulation de la participation politique. L'interet
   pour la politique, les circonstances personnelles telles que
   l'experience de la criminalite, et les caracteristiques
   socioeconomiques, semblent beaucoup plus fortement stimuler la
   participation citoyenne en ALC. Ceci est vrai soit avec des modeles
   imposant des tendances lineaires simples (Logit et Lasso) et ceux
   permettant des relations complexes (arbres de decision). Les resultats
   varient selon les types de participation - signature d'une petition,
   participation a des manifestations, ou implication dans les problemes
   communautaires. Finalement, la confiance politique ne peut influencer la
   participation politique que lorsque certains autres moteurs sont
   combines de maniere specifique.
   Este articulo avanza en la comprension de las relaciones entre la
   confianza en el gobierno y la participacion ciudadana en America Latina
   y el Caribe (LAC) utilizando tecnicas de aprendizaje automatico y datos
   del Latinobarometro 2023. Empiricamente, predecimos la participacion
   ciudadana basandonos en los niveles de confianza, caracteristicas, y
   circunstancias de los ciudadanos. Los defensores del concepto de
   democracia sigilosa (en ingles, stealth democracy) argumentan que existe
   una relacion inversa entre la confianza politica y la participacion
   ciudadana, mientras que los teoricos de la democracia deliberativa
   sostienen lo contrario. Basandonos en nuestras estimaciones, la
   confianza en los gobiernos nacionales y otras instituciones
   gubernamentales no juega un papel ni dominante, ni consistente, en
   impulsar la participacion politica. El interes en la politica, las
   circunstancias personales como la experiencia del crimen, y las
   caracteristicas socioeconomicas, parecen impulsar la participacion
   ciudadana de manera mucho mas fuerte en LAC. Esto ocurre con modelos que
   imponen tendencias lineales simples (Logit y Lasso) y tambien con
   aquellos que permiten relaciones complejas (arboles de decision). Los
   resultados varian segun los tipos de participacion: firmar una peticion,
   participar en manifestaciones o involucrarse en problemas comunitarios.
   En ultima instancia, la confianza politica solo puede influir en la
   participacion politica cuando ciertos otros impulsores se combinan de
   algunas formas especificas.},
