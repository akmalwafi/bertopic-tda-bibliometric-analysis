@article{ WOS:001543366300001,
Author = {Mizutani, Kotaro and Akiyama, Yuki and Baba, Hiroki},
Title = {Estimation of priority areas for vacant housing control using government
   statistics},
Journal = {JOURNAL OF HOUSING AND THE BUILT ENVIRONMENT},
Year = {2025},
Month = {2025 AUG 4},
Abstract = {Japan is currently confronting the critical social problem of an
   increasing number of vacant houses, driven by its super-aging society
   and declining birthrate. The proliferation of vacant houses entails
   significant risks, including structural collapse, the deterioration of
   local landscapes, and elevated crime rates, all of which negatively
   impact community welfare. In recent years, various measures have been
   implemented in Japan to tackle this problem. However, assessing the
   current state of vacant houses often requires field surveys, which are
   time-consuming and costly, posing a substantial challenge for
   municipalities. To overcome these challenges, this study proposes a
   novel priority indicator of vacant housing control that enables
   municipalities to effectively allocate limited resources and implement
   targeted control against vacant houses. The proposed indicator utilizes
   nationwide statistical datasets, such as the Population Census and
   Housing and Land Survey, and incorporates machine learning techniques to
   predict priority areas for vacant housing control over a 3-year horizon.
   This approach is anticipated to allow municipalities to preemptively
   evaluate the scale and geographic distribution of measures related to
   the priority indicator of vacant housing control, optimize resource
   allocation, and facilitate proactive efforts to prevent the emergence of
   new vacant houses, potentially reducing reliance on costly and
   labor-intensive field surveys. While developed with Japan's unique
   demographic and social conditions in mind, this methodology is adaptable
   to other countries experiencing similar challenges, such as population
   aging and urbanization. The framework presented in this study provides
   municipalities with a practical, evidence-based approach based on the
   priority of vacant housing control, thereby streamlining the process of
   tackling vacant house problems, promoting sustainable residential
   environments, and improving housing market functionality.},
