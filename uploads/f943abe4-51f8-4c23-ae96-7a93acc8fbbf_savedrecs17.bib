@inproceedings{ WOS:001260867900020,
Author = {Vydelingum, Meaghen and Martin, Miguel Vargas},
Book-Group-Author = {IEEE Comp Soc},
Title = {How Password Strength Becomes a Weak Link for Honeywords},
Booktitle = {2023 11TH INTERNATIONAL CONFERENCE IN SOFTWARE ENGINEERING RESEARCH AND
   INNOVATION, CONISOFT 2023},
Year = {2023},
Pages = {99-107},
Note = {11th International Conference in Software Engineering Research and
   Innovation (CONISOFT), Leon, MEXICO, NOV 06-10, 2023},
Organization = {IEEE},
Abstract = {Passwords are used as the first layer of security in today's society. As
   cybercrime increases, the need for password security increases. The
   objective of this report is to share some progress on password security,
   specifically on honeywords, and their techniques. State-of-the-art
   honeyword generation techniques (HGT) are using newer machine learning
   models, such as Generative Adversarial Network (GAN), to create
   honeywords. One HGT, called HoneyGAN, was used to generate honeywords,
   in order to analyze the relationship between honeywords strength and
   password strength. Overall, it was determined that the weaker the
   password inputted, the weaker the honeyword generated with HoneyGAN,
   which suggests a limitation on the effectiveness of honeyword
   authentication systems.},
