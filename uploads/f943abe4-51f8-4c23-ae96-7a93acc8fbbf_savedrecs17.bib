   Camille L. and Quijada, Rea Meliza F. and Purio, Mark Angelo C. and
   Ramos, Anna May A.},
Book-Group-Author = {IEEE},
Title = {GIS-BASED CRIME DENSITY MAPPING USING DATA ANALYTICS: A CASE STUDY FOR
   MANILA CITY},
Booktitle = {2024 IEEE INTERNATIONAL GEOSCIENCE AND REMOTE SENSING SYMPOSIUM (IGARSS
   2024)},
