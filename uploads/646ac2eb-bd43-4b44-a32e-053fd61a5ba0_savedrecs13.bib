@article{ WOS:000414151200001,
Author = {Kostyuchenko, Yuriy V. and Yuschenko, Maxim},
Title = {Toward Approaches to Big Data Analysis for Terroristic Behavior
   Identification: Child Soldiers in Illegal Armed Groups During the
   Conflict in the Donbas Region (East Ukraine)},
Journal = {INTERNATIONAL JOURNAL OF CYBER WARFARE AND TERRORISM},
