Author = {Sun, Zhaohui H. and Baumes, Jeff and Tunison, Paul and Turek, Matt and
   Hoogs, Anthony},
Book-Group-Author = {IEEE},
Title = {Tattoo Detection and Localization using Region-based Deep Learning},
