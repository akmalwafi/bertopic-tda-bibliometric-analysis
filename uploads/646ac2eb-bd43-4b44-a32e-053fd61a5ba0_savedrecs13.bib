@inproceedings{ WOS:001510213100078,
Author = {Mule, Emanuele and Pannacci, Matteo and Goudarzi, Ali Ghasemi and Pro,
   Francesco and Papa, Lorenzo and Maiano, Luca and Amerini, Irene},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {Enhancing Ground-to-Aerial Image Matching for Visual Misinformation
   Detection Using Semantic Segmentation},
Booktitle = {2025 IEEE/CVF WINTER CONFERENCE ON APPLICATIONS OF COMPUTER VISION
   WORKSHOPS, WACVW},
