@article{ WOS:001488243800002,
Author = {Deng, Mingyan and Liang, Xinggong and Wu, Hao and Chen, Run and Li,
   Yuqian and Zhu, Zhengyang and Luo, Jianliang and Zhang, Wanqing and
   Wang, Han and Xie, Shiyang and Qin, Yudong and Zhang, Letong and Wang,
   Gongji and Sun, Qinru and Zhang, Kai and Wang, Zhenyuan},
Title = {A new perspective: ATR-FTIR spectroscopy combined with machine learning
   for gender determination of human skin},
Journal = {MICROCHEMICAL JOURNAL},
Year = {2025},
Volume = {213},
Month = {JUN},
Abstract = {In the field of forensic individual identification, the determination of
   gender is a critical aspect. Human keratinized tissues, particularly
   skin, can yield extremely significant information as evidence at crime
   scenes, especially in instances characterized by extensive degradation
   and disintegration. Nevertheless, the research on the integration of
   skin analysis with spectroscopy and machine learning for the purposes of
   gender determination remains relatively insufficient. To address this
   research gap, the present study gathered a substantial collection of
   human skin samples and employed four supervised classification
   algorithms-namely partial least squares discriminant analysis (PLS-DA),
   support vector machine (SVM), k-nearest neighbor (KNN), and extreme
   gradient boosting (XGB)-to analyze the subtle spectral differences in
   skin between human males and females at various postmortem intervals
   (PMIs). The findings indicate that the spectral distinctions between
   male and female skin predominantly pertain to lipid and protein content.
   Specifically, the lipid absorption peaks in females are significantly
   elevated compared to that in males, whereas the protein absorption peaks
   in males are marginally higher than that in females. These results hold
   considerable implications for gender determination. The SVM model is the
   best of the four models in terms of prediction capacity, with a
   sensitivity of 1.000, specificity of 0.902, and accuracy of 0.976. It
   can also resolve the issue of gender determination in the advanced
   decomposition period. ATR-FTIR spectroscopy has enormous potential and
   practical utility for forensic gender determination because of its ease
   of use, high efficiency, and affordability.},
