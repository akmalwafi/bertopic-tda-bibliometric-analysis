@article{ WOS:001493905900002,
Author = {Fan, Zehua and Li, Chenyu and Sun, Qiran and Luo, Yiwen and Lin,
   Hancheng and Cong, Bin and Huang, Ping},
Title = {Integrated analysis of restraint stress in rat serum using ATR-FTIR and
   Raman spectroscopy with Machine learning},
Journal = {SPECTROCHIMICA ACTA PART A-MOLECULAR AND BIOMOLECULAR SPECTROSCOPY},
Year = {2025},
Volume = {340},
Month = {NOV 5},
Abstract = {In forensic practice, accurately determining whether an individual has
   been subjected to prolonged restraint or assessing injuries resulting
   from restraint can be challenging. To address this, we explored a novel
   approach using attenuated total reflection Fourier transform infrared
   (ATR-FTIR) spectroscopy and Raman spectroscopy combined with machine
   learning to jointly identify restraint stress. We randomly assigned rats
   into three experimental groups: a restraint stress group (subjected to
   fasting and water deprivation), a control group (subjected to fasting
   and water deprivation without restraint), and a normal group. After
   collecting the serum spectra of the animals, a principal component
   analysis (PCA) model was established to explore the separation trends
   among the groups and to identify relevant characteristic peaks.
   Subsequently, a random forest (RF) model was established to compare the
   restraint stress group with the other two groups. The analysis
   identified key substances that indicated the presence of restraint
   stress: 1161 cm- 1, 1167 cm- 1 (anti-symmetric C-O-C stretch) and 980
   cm- 1, 976 cm- 1, 974 cm- 1 (-N+(CH3)3, antisymmetric stretch). And the
   RF model was used to compare the restraint stress groups at different
   time points, revealing substances that may help determine the duration
   of restraint stress: 1747 cm- 1 (ester carbonyl band), 1626 cm- 1
   (R-pleated sheet), 1211 cm- 1 (Amide III, -N+(CH3)3, antisymmetric
   stretch), 1180 cm- 1 (phosphodiester), 1128 cm- 1 (- C-C-), 1024 cm- 1
   (C-O stretching coupled with C-O bending) and 1389 cm- 1, 1335 cm- 1,
   1321 cm- 1 (Trp, alpha helix, phospholipids), 710 cm- 1
   (Polysaccharides), 1266 cm- 1 (Amide III), 1015 cm-1 (R-carotene). These
   findings suggest that ATR-FTIR and Raman spectroscopy together, when
   combined with machine learning, has significant potential as a powerful
   tool for analyzing and characterizing restraint stress, offering new
   insights and directions for future research in this area.},
Publisher = {PERGAMON-ELSEVIER SCIENCE LTD},
Address = {THE BOULEVARD, LANGFORD LANE, KIDLINGTON, OXFORD OX5 1GB, ENGLAND},
