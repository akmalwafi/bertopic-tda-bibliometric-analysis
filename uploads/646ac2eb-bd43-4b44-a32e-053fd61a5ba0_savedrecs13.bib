@inproceedings{ WOS:001479724400002,
Author = {Nwachukwu, Chukwuemeka and Akwiwu-Uzoma, Chukwuebuka and Ovuehor, Samuel
   and Durodola-Tunde, Kehinde},
Editor = {Huang, KW and Cao, Q and Su, R},
Title = {Improved Machine Learning Algorithms for Fraud Detection in Fintech
   Companies},
Booktitle = {FINANCIAL TECHNOLOGY, ICFT 2024},
