@article{ WOS:000909132000001,
Author = {Srokosz, Michal and Bobyk, Andrzej and Ksiezopolski, Bogdan and Wydra,
   Michal},
Title = {Machine-Learning-Based Scoring System for Antifraud CISIRTs in Banking
   Environment},
Journal = {ELECTRONICS},
Year = {2023},
