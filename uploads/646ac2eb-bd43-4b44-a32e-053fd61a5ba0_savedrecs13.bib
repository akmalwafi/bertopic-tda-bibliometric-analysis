@inproceedings{ WOS:001420304200037,
Author = {Feng, Disheng and Lu, Xuequan and Lin, Xufeng},
Editor = {Yang, H and Pasupa, K and Leung, ACS and Kwok, JT and Chan, JH and King, I},
Title = {Deep Detection for Face Manipulation},
