@article{ WOS:000313810900005,
Author = {Ang, Rebecca P. and Goh, Dion H.},
Title = {Predicting Juvenile Offending: A Comparison of Data Mining Methods},
Journal = {INTERNATIONAL JOURNAL OF OFFENDER THERAPY AND COMPARATIVE CRIMINOLOGY},
