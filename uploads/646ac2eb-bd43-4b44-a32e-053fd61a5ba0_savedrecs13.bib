Title = {Machine learning methods for quantitative analysis of Raman spectroscopy
   data},
Booktitle = {OPTO-IRELAND 2002: OPTICS AND PHOTONICS TECHNOLOGIES AND APPLICATIONS,
   PTS 1 AND 2},
Series = {Proceedings of SPIE},
Year = {2003},
Volume = {4876},
Number = {1\&2},
