   Varsha and Attar, Razaz Waheeb and Chui, Kwok Tai},
Book-Group-Author = {IEEE},
Title = {AI-Powered Intrusion Detection for Secure and Efficient SDN in Network
   Virtualization},
Booktitle = {2025 IEEE 26TH INTERNATIONAL CONFERENCE ON HIGH PERFORMANCE SWITCHING
   AND ROUTING, HPSR},
Series = {IEEE International Conference on High Performance Switching and Routing},
Year = {2025},
