@article{ WOS:000885577400001,
Author = {Cao, Lin and Chen, Changwu and Guo, Yanan and Du, Kangning},
Title = {Sketch face recognition based on domain adaptation scaled entropy
   meta-network},
Journal = {MEASUREMENT \& CONTROL},
