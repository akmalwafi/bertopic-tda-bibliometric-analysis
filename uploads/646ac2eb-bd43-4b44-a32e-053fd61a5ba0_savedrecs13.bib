Organization = {IEEE, Los Angeles Bay Area Council; IEEE, San Francisco Bay Area
   Council; ERA, So Calif Chapter; ERA, No Calif Chapter},
Abstract = {As the nation's largest independent mortgage banker, Countrywide is
   committed to using advanced information technology to maintain its
   competitive edge. For almost five years Countrywide has been using Al to
   improve its efficiency in originating mortgages, with its automated
   underwriting system (CLUES(TM)) evaluating 600 loans a day. Out of this,
   many lessons have been learned about developing and maintaining a large
   expert system in a dynamic and competitive financial industry. In
   addition, Countrywide has embarked on other Al projects, including:
   predicting delinquency, automatic property valuation, help desk
   assistants and neural network applications in secondary marketing.},
