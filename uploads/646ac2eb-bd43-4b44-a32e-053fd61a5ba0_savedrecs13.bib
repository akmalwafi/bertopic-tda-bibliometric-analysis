@article{ WOS:001435572400001,
Author = {Chernysheva, Anastasia and Gundler, Christopher and Wiederhold,
   Alexander Johannes and Jopp-van Well, Eilin and Heinemann, Axel and
   Ondruschka, Benjamin},
Title = {Latent spaces of generative models for forensic age estimation},
Journal = {RECHTSMEDIZIN},
Year = {2025},
Volume = {35},
Number = {2, SI},
Pages = {101-110},
Month = {APR},
Abstract = {BackgroundMachine learning may significantly support forensic medicine,
   particularly in age estimation through medical imaging soon. This
   technology offers great potential for supporting decisions especially
   when age documentation is missing or disputed.ObjectiveThis study
   investigates the potential of generative models for forensic age
   estimation. The focus is on addressing the challenges of
   interpretability and generalizability commonly faced by traditional
   discriminative models.MethodsWe applied a family of generative models to
   postmortem computed tomography (PMCT) scans, focusing on the
   ossification of the medial clavicular epiphysis for age prediction. The
   latent space representations from these models were analyzed for their
   ability to predict age accurately and interpretably across different
   datasets.ResultsWhile the methods did not perform as well as
   discriminative state of the art approaches using German Working Group
   for Forensic Age Diagnostics (AGFAD) guidelines, the variational
   autoencoders were able to learn a meaningful latent space. The age of
   the participants could even be visualized within a two-dimensional
   projection. Additionally, the re-use of the learned space led to high
   performance on a smaller dataset collected from a forensic
   center.ConclusionThe consideration of ``soft factors{''}, such as
   explainability in addition to absolute performance remains crucial for
   bringing machine learning methods into forensic practice. Depending on
   the set-up, generative models might be attractive for assessing the
   reasoning within models and sharing information between datasets.
   HintergrundMaschinelles Lernen wird die forensische Medizin,
   insbesondere die Altersbestimmung durch medizinische Bildgebung, schon
   bald weiter voranbringen. Diese Technologie bietet gro ss es Potenzial
   zur Unterst \& uuml;tzung, insbesondere wenn amtliche Dokumente zum
   Alter fehlen oder in Rede stehen.Ziel der ArbeitDiese Studie untersucht
   das Potenzial von generativen Modellen zur forensischen
   Altersbestimmung. Der Fokus liegt bei der Bew \& auml;ltigung der
   Herausforderungen der Interpretierbarkeit und Generalisierbarkeit, die
   bei traditionellen diskriminativen Modellen h \& auml;ufig
   auftreten.MethodenWir wenden generative Modelle auf
   Post-mortem-Computertomographie (PMCT)-Scans an, mit Fokus auf die
   Ossifikation der medialen Klavikulaepiphyse zur Altersvorhersage. Die
   Darstellungen der latenten R \& auml;ume dieser Modelle wurden
   dahingehen analysiert, ob sie das Lebensalter der Personen genau und
   interpretierbar vorhersagen k \& ouml;nnen.ErgebnisseAuch wenn die
   Ergebnisse zur direkten Altersvorhersage innerhalb der latenten R \&
   auml;ume nicht mit den diskriminativen Modellen und den Ergebnissen der
   Untersuchungen der Arbeitsgemeinschaft f \& uuml;r Forensische
   Altersdiagnostik (AGFAD) mithalten k \& ouml;nnen, so lernen die
   Verfahren robuste latente R \& auml;ume. Diese erm \& ouml;glichen bei
   Projektionen in den zweidimensionalen Raum auch direkte Interpretationsm
   \& ouml;glichkeiten und Entscheidungsunterst \& uuml;tzungen. Die
   Nutzung des integrierten Wissens f \& uuml;r eine Klassifikation auf
   einem deutlich kleineren Datensatz resultierte in sehr guten
   Ergebnissen.DiskussionDie Ber \& uuml;cksichtigung ,,weicher
   Faktoren{''} wie der Interpretierbarkeit ist neben der absoluten
   Performance von gro ss er Wichtigkeit, um Systeme des maschinellen
   Lernens in die forensische Realit \& auml;t zu integrieren. In Abh \&
   auml;ngigkeit der Zielsetzung sind die vorgestellten generativen Modelle
   eine attraktive M \& ouml;glichkeit, die Entscheidungsgrundlage von
   KI-Systemen zu verstehen und Wissen zwischen verschiedenen Datens \&
   auml;tzen nutzbar zu machen.},
