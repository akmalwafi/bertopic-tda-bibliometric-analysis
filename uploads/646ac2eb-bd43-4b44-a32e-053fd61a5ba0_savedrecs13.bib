@inproceedings{ WOS:000387119900081,
Author = {Mircea, Ioan Gabriel},
Book-Group-Author = {IEEE},
Title = {A Fuzzy Decision Tree Based Method For Skeletal Sex Determination},
Booktitle = {2016 IEEE 11TH INTERNATIONAL SYMPOSIUM ON APPLIED COMPUTATIONAL
   INTELLIGENCE AND INFORMATICS (SACI)},
Year = {2016},
Pages = {447-452},
Note = {11th IEEE International Symposium on Applied Computational Intelligence
   and Informatics (SACI), Timisoara, ROMANIA, MAY 12-14, 2016},
Organization = {IEEE},
Abstract = {Sex determination from skeletal measurements is an important problem in
   both a forensic and bioarchaeological context. Since the majority of the
   approaches in the literature employ traditional methods using
   discriminant functions, a computational machine learning method is
   proposed based on a fuzzy decision tree implementation presuming it will
   better overcome the problem's populational dependency, its sensibility
   to uncertainty and it will also be a valid computational option to the
   forensic or bioarchaeologic researchers especially for large
   osteological collections. Constructing fuzzy functions on available
   statistical information regarding skeletal measurements as basis for the
   fuzzy decisional process, the proposed method manages to improve by
   coping with uncertain situations and corroborating the classification
   factors only at the end of the training process.},
