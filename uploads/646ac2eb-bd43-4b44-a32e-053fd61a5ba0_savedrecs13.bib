@inproceedings{ WOS:001212380000006,
Author = {Dumitrasc, Valentina and Serral-Gracia, Rene},
Editor = {Katsikas, S and Abie, H and Ranise, S and Verderame, L and Cambiaso, E and Ugarelli, R and Praca, I and Li, W and Meng, W and Furnell, S and Katt, B and Pirbhulal, S and Shukla, A and Ianni, M and Preda, MD and Choo, KKR and Correia, MP and Abhishta, A and Sileno, G and Alishahi, M and Kalutarage, H and Yanai, N},
Title = {User Behavior Analysis for Malware Detection},
