Year = {2018},
Volume = {5},
Number = {2},
Pages = {287-317},
Month = {JUL-DEC},
Abstract = {The Hard Problem of consciousness has been dismissed as an illusion. By
   showing that computers are capable of experiencing, we show that they
   are at least rudimentarily conscious with potential to eventually reach
   superconsciousness.The main contribution of the paper is a test for
   confirming certain subjective experiences in a tested agent We follow
   with analysis of benefits and problems with conscious machines and
   implications of such capability on future of computing, machine rights
   and artificial intelligence safety.},
