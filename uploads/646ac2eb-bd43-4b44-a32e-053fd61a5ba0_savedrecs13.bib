@incollection{ WOS:000357607500013,
Author = {Pileggi, Salvatore F. and Amor, Robert},
Editor = {Hassanien, AE and Azar, AT and Snasel, V and Kacprzyk, J and Abawajy, JH},
Title = {Semantic Geographic Space: From Big Data to Ecosystems of Data},
Booktitle = {BIG DATA IN COMPLEX SYSTEMS: CHALLENGES AND OPPORTUNITIES},
Series = {Studies in Big Data},
Year = {2015},
Volume = {9},
Pages = {351-374},
Abstract = {Enhancing the physical view of a geographic space through the
   integration of semantic models enables a novel extended logic context
   for geographic data infrastructures that are modelled as an ecosystem of
   data in which semantic properties and relations are defined with the
   concepts composing the model. The signigicant capabilities of current
   semantic technology allow the implementation of rich data models
   according to an ontological approach that assures competitive
   interoperable solutions in the context of environments for general
   purpose (e.g. the Semantic Web) as well as inside more specific systems
   (e.g. Geographic Information Systems). Extended capabilities in terms of
   expressivity have strong implications also for data/information
   processing, especially on a large scale (Big Data). Semantic spaces can
   play a critical role in those processes contrasting the mostly passive
   role of models simply reflecting a geographic perspective. This chapter
   proposes a short overview of a simple model for semantic geographic
   space and a number of its applications, mostly focusing on the added
