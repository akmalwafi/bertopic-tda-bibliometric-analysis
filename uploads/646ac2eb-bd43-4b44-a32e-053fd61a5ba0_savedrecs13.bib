@article{ WOS:001504617600012,
Author = {Li, Changsheng and Gao, Shuhui},
Title = {Determining line-crossing sequences between stamp inks and laser
   printing toner based on Vis-NIR hyperspectral imaging technology},
Journal = {MICROCHEMICAL JOURNAL},
Year = {2025},
Volume = {214},
Month = {JUL},
Abstract = {Determining the line-crossing sequences between stamp inks and laser
   printing toners provides crucial evidence for forensic document
   examination. However, traditional methods show subjectivity and
   decreased accuracy, especially when ink-toner intermixing happens in
   crossing areas. This study presents an automated approach combining
   visible-near infrared hyperspectral imaging (Vis-NIR HSI) with machine
   learning to determine the line-crossing sequences between stamp inks and
   laser printing toner. The experimental design included analyzing 15
   stamp inks and two laser printers, collecting 10,000-pixel spectral data
   for each sample group. In developing the Spectral Difference Models
   (SDM), three methods for calculating spectral differences were employed.
   The innovative integration of iVISSA for characteristic wavelength
   selection, combined with SNV spectral preprocessing, significantly
   enhanced model performance by optimizing noise suppression. A
   comparative evaluation of six machine learning classifiers showed that
   SVM achieved an accuracy of 98.73 \% after SNV pretreatment, while
   iVISSA reduced spectral dimensions from 462 to 112 without compromising
   classification accuracy. The near-infrared region (780-1000 nm)
   exhibited optimal discriminative power for determining line-crossing
   sequences. This method allows for rapid, dependable authentication of
   questioned documents, greatly improving efficiency while ensuring high
   accuracy in identifying document forgery for judicial purposes.},
