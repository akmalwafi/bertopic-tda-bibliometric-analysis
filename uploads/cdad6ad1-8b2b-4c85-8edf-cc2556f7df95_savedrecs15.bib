@inproceedings{ WOS:001478676500068,
Author = {Xiao, Ruoyao and Luo, Yu and Xu, Weifeng and Lamba, Harshmeet and Xu,
   Dianxiang},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {Analyzing Relationship Consistency in Digital Forensic Knowledge Graphs
   with Graph Learning},
Booktitle = {2024 IEEE 23RD INTERNATIONAL CONFERENCE ON TRUST, SECURITY AND PRIVACY
   IN COMPUTING AND COMMUNICATIONS, TRUSTCOM},
Series = {IEEE International Conference on Trust Security and Privacy in Computing
   and Communications},
Year = {2024},
Pages = {590-599},
Note = {23rd International Conference on Trust Security and Privacy in Computing
   and Communications-TRUSTCOM-Annual, Sanya, PEOPLES R CHINA, DEC 17-21,
   2024},
Organization = {Xidian University; Zhengzhou University; IEEE Computer Society},
Abstract = {Graph representation is an invaluable tool in digital forensics,
   offering the flexibility to depict diverse objects and relationships.
   This capability empowers investigators to model and analyze a broad
   spectrum of scenarios. This paper focuses on Digital Forensic Knowledge
   Graphs (DFKGs), an extension of the STIX standard language designed for
   digital forensic cases. DFKGs tailor STIX objects (nodes) and
   relationships (edges) to enhance their relevance in the digital forensic
   context. However, building the DFKGs of real-world cases is error-prone.
   Common issues include inconsistencies where edges fail to align with
   attributes in associated nodes. This paper introduces a machine
   learning-based approach to address the problem of relationship
   inconsistency in real-world DFKGs. The proposed method utilizes a Graph
   Neural Network (GNN) model trained on a case repository to evaluate
   relationship consistency in new cases. We evaluated the model with the
   DFKGs of 10 real-world cases, containing diverse inconsistent
   relationships. The accuracy scores range from 68\% to 84\% and the F1
   scores from 78\% to 89\%. The results indicate that the approach can be
   promising to improve the quality of DFKGs.},
