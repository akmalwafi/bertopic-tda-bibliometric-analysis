@article{ WOS:000403523500004,
Author = {Mamonov, Stanislav and Benbunan-Fich, Raquel},
Title = {What Can We Learn from Past Mistakes? Lessons from Data Mining the
   Fannie Mae Mortgage Portfolio},
Journal = {JOURNAL OF REAL ESTATE RESEARCH},
Year = {2017},
Volume = {39},
Number = {2},
Pages = {235-262},
Month = {APR-JUN},
Abstract = {Fannie Mae has been widely criticized for its role in the recent
   financial crisis, yet no detailed analysis of the systematic patterns of
   the mortgage defaults that occurred has been published. To address this
   knowledge gap, we perform data mining on the Fannie Mae mortgage
   portfolio of the fourth quarter of 2007, which includes 340,537
   mortgages with a total principal value of \$69.8 billion. This portfolio
   had the highest delinquency rate in the agency's history: 19.4\% versus
   the historical average of 1.7\%. We find that although a number of
   information variables that were available at the time of mortgage
   acquisition are correlated with the subsequent delinquencies, building
   an accurate model proves challenging. Identification of the majority of
   delinquencies in the historical data comes at a cost of low precision.},
