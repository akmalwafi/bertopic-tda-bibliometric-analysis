@inproceedings{ WOS:001155257400014,
Author = {McConnell, Benjamin and Del Monaco, Daniel and Zabihimayvan, Mahdieh and
   Abdollahzadeh, Fatemeh and Hamada, Samir},
Editor = {Rutkowski, L and Scherer, R and Korytkowski, M and Pedrycz, W and Tadeusiewicz, R and Zurada, JM},
Title = {Phishing Attack Detection: An Improved Performance Through Ensemble
   Learning},
Booktitle = {ARTIFICIAL INTELLIGENCE AND SOFT COMPUTING, ICAISC 2023, PT II},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2023},
