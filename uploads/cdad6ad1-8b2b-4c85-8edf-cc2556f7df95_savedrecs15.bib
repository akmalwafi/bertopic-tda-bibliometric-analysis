@inproceedings{ WOS:001416103200034,
Author = {An, Yanqing and Yue, Linan and Gao, Weibo and Zhang, Kai and Liu, Qi},
Editor = {Onizuka, M and Lee, JG and Tong, Y and Xiao, C and Ishikawa, Y and Amer-Yahia, S and Jagadish, HV and Lu, K},
Title = {Post-hoc Facts augmented Legal Judgment Prediction},
