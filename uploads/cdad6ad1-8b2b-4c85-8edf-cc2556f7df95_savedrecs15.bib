@article{ WOS:000467011900013,
Author = {Brown, Michelle and Carrabine, Eamonn},
Title = {The Critical Foundations of Visual Criminology: The State, Crisis, and
   the Sensory},
Journal = {CRITICAL CRIMINOLOGY},
Year = {2019},
Volume = {27},
Number = {1, SI},
Pages = {191-205},
Month = {MAR},
Abstract = {This article considers the manner in which visual criminology has
   flourished in the current moment, while exploring its foundational
   relations and points of distinction as a form of critical criminology.
   In particular, we devote attention to the relationship of images to
   control, power and resistance at a time defined by the spectacular
   proliferation of media. We also discuss new and recent directions in
   visual criminology that enlarge our understandings of both critical and
   visual work, including forensic architecture and sensory criminology.},
