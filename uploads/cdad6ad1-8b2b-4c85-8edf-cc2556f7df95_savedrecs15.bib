@article{ WOS:001561613700001,
Author = {Zhou, Peng and Zhang, Jia and Wu, Xiangjun and Zhang, Leilei and Liu,
   Qinlai and Xiong, Ruotong and Wang, Yujie and Li, Min and Wei, Ran and
   Xu, Xiaoqun and Meng, Deping and Yu, Chunjiang and Yan, Jiangwei and
   Fang, Chen},
Title = {Differential diagnosis of acute myocardial infarction based on plasma
   Exosomal MicroRNA},
Journal = {INTERNATIONAL JOURNAL OF LEGAL MEDICINE},
Year = {2025},
Month = {2025 AUG 25},
Abstract = {ObjectThe differentiation of acute myocardial infarction (AMI) has long
   been a challenging problem in clinical diagnosis and forensic
   identification. Recent studies have shown that microRNAs (miRNAs) in
   exosomes are involved in the development and progression of AMI. results
   indicated that plasma exosomal miRNAs can be considered as novel
   biomarkers for early AMI recognition.MethodIn this study, exosomal
   miRNAs in plasma associated with the pathogenesis of AMI was explored
   and AMI identification model based on these miRNAs were established
   using machine learning technology.ResultFollowing the analysis of
   differentially expressed miRNAs in plasma-derived exosomes, the
   expression levels of 36 miRNAs increase with the passage of time,
   including miR-3473, miR-504, miR-490-5p, miR-218a-2-3p, and miR-760-3p,
   showed an increasing trend over time in the plasma exosomes of AMI rats.
   Based on machine learning techniques, miR-3473, miR-504, miR-490-5p,
   miR-218a-2-3p were used to construct a model for recognizing early AMI.
   The precision of the AMI identification model reached
   0.955.ConclusionThe results indicated that plasma exosomal miRNAs can be
   considered as novel biomarkers for early AMI recognition.},
