@inproceedings{ WOS:000724610300006,
Author = {Yau, Ken and Chow, Kam-Pui and Yiu, Siu-Ming},
Editor = {Peterson, G and Shenoi, S},
Title = {DETECTING ATTACKS ON A WATER TREATMENT SYSTEM USING ONE-CLASS SUPPORT
   VECTOR MACHINES},
