@inproceedings{ WOS:000474685800150,
Author = {Morshed, Ahsan and Forkan, Abdur Rahim Mohammad and Tsai, Pei-Wei and
   Jayaraman, Prem Prakash and Sellis, Timos and Georgakopoulos, Dimitrios
   and Moser, Irene and Ranjan, Rajiv},
Book-Group-Author = {Assoc Comp Machinery},
Title = {VisCrimePredict: A System for Crime Trajectory Prediction and
   Visualisation from Heterogeneous data sources},
Booktitle = {SAC `19: PROCEEDINGS OF THE 34TH ACM/SIGAPP SYMPOSIUM ON APPLIED
   COMPUTING},
