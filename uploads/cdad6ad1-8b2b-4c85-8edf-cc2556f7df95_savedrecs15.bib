@inproceedings{ WOS:001445506200045,
Author = {Srivastav, Ambrish and Prajapat, Shaligram},
Editor = {Naik, N and Jenkins, P and Prajapat, S and Grace, P},
Title = {A Decision Tree Approach for Identifying Indian Penal Code Sections
   Across Different Crime Aspects},
Booktitle = {CONTRIBUTIONS PRESENTED AT THE INTERNATIONAL CONFERENCE ON COMPUTING,
   COMMUNICATION, CYBERSECURITY AND AI, C3AI 2024},
Series = {Lecture Notes in Networks and Systems},
Year = {2024},
Volume = {884},
Pages = {773-782},
Note = {2024 International Conference on Computing, Communication, Cybersecurity
   and AI, London, ENGLAND, JUL 03-04, 2024},
Abstract = {The accurate classification of Indian PenalCode (IPC) sections in
   criminal cases is complex due to the intricate legal framework,
   subjective interpretation, evolving legal precedents, diverse case
   facts, and the potential for human error. As crime reports and IPC
   (Indian Penal Code) documents belong to distinct document types,
   assessing the availability of specific sections becomes a challenging
   task due to their inherent differences. This study addresses this
   challenge by proposing a GINI index-based decision tree model to
   determine the applicability of IPC Sect. 323 which deals with the
   offense of voluntarily causing hurt. The proposed model aims to enhance
   the consistency and transparency of legal decision-making, providing a
   valuable tool for legal practitioners, investigators, and policymakers
   involved in the criminal justice system. The interpretability of the
   decision tree ensures that the rationale behind the IPC section
   classification is accurate and comprehensible, contributing to a more
   effective and equitable administration of justice. The report
   comprehensively gathers information on various facets of the crime,
   demonstrating the relevance of each section based on its accessibility.},
Publisher = {SPRINGER INTERNATIONAL PUBLISHING AG},
Address = {GEWERBESTRASSE 11, CHAM, CH-6330, SWITZERLAND},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Srivastav, A (Corresponding Author), Devi Ahilya Vishwavidyalya, Int Inst Profess Studies, Indore, MP, India.
   Srivastav, Ambrish; Prajapat, Shaligram, Devi Ahilya Vishwavidyalya, Int Inst Profess Studies, Indore, MP, India.},
DOI = {10.1007/978-3-031-74443-3\_45},
ISSN = {2367-3370},
