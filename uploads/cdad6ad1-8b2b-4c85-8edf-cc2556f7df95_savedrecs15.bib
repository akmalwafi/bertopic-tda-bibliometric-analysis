@inproceedings{ WOS:000539633500003,
Author = {Antinori, Arije},
Editor = {Griffiths, P and Kabir, MN},
Title = {Terrorism and DeepFake: from Hybrid Warfare to Post-Truth Warfare in a
   Hybrid World},
Booktitle = {PROCEEDINGS OF THE EUROPEAN CONFERENCE ON THE IMPACT OF ARTIFICIAL
   INTELLIGENCE AND ROBOTICS (ECIAIR 2019)},
Year = {2019},
Pages = {23-30},
Note = {European Conference on the Impact of Artificial Intelligence and
   Robotics (ECIAIR), EM Normandie Business Sch, Oxford, ENGLAND, OCT
   31-NOV 01, 2019},
Abstract = {Considering the evolving nature of the terrorism threat and the key-role
   of technology as crucial asset for criminals, it is necessary to explore
   the relation between such phenomenon and technology. Therefore, the
   author proposes his theoretical and qualitative research as a result of
   his studies and participation, as counter-terrorism expert, in several
   EU projects. The purpose of this paper is to focus on the near future
   security scenario, develop knowledge and awareness, and allow policy
   makers, law enforcement agencies and security services to implement more
   effective counterterrorism strategies. The digital convergence and the
   rise of new interaction models has led to the increasing of ever more
   pervasive social mobile media, affected by visual storytelling and live
   streaming. During the last years, terrorist groups have developed a
   sophisticated social media warfare, implemented by the re-mediation and
   dissemination of user generated contents, to spread insecurity, anxiety,
   fear and terror at a global level, as well as, to foster recruitment,
   the use of violence and trigger lone-actors to attack. The globalized
   citizens of the 21st century are on the verge of experiencing the
   transition from e-terrorism to the upcoming ``onlife{''} terrorism, as
   well as, the passage from the linearity to hyper-complexity. Such
   transition, boosted by the malicious use of Artificial Intelligence,
   highlights the high risk of exploiting the vulnerabilities given by the
   impacts of post-truth paradigm in the (cyber-)social ecosystem. Thus, in
   the warfare of post-truth, we consider the DeepFake propaganda a new and
   powerful weapon for terrorists, able to increase their ability to
   destabilize governments and polarize vulnerable audiences through social
   media mobile. In this way, they can even conduct highly tactical
   operations, such as the use of smart, violent and asymmetrical mobs,
   which are becoming a serious threat to democratic institutions and
   political stability.},
