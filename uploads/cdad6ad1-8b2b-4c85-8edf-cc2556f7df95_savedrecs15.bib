@article{ WOS:001414636600001,
Author = {Ao, Yikun and Sun, Tanfeng and Xu, Qiang},
Title = {Detection of fake bitrate videos based on high-frequency and deblocking
   filtering difference map features},
Journal = {NEUROCOMPUTING},
Year = {2025},
Volume = {622},
Month = {MAR 14},
Abstract = {Video bitrate up-conversion is a video processing technique that
   improves the quality by increasing the bitrate, typically for attracting
   more viewers. Detection of fake bitrate videos is beneficial for
   copyright protection and aids in verifying the authenticity of the video
   content. In this work, a novel algorithm is proposed to detect fake
   bitrate videos. Theoretical and statistical analysis of the artifacts in
   compression and decompression domains of fake bitrate video is
   established, which provides a basis for feature modeling. According to
   the analysis, the Difference Map Feature (FDM) which consists of The
   High-frequency Component Difference map Feature FHCD) in I-frames and
   Deblocking Filtering features Difference map Feature (FDFD) in P-frames
   is proposed. The videos undergo an additional compression operation to
   calculate the difference maps which are fed into dual-branch hybrid
   deep-learning network to obtain GOP-wise detection results. Extensive
   experiments have demonstrated that our algorithm has state-of-the-art
   detection capabilities under different encoding parameter settings.},
