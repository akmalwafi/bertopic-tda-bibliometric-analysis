@article{ WOS:000169945100008,
Author = {Brown, DE and Gunderson, LF},
Title = {Using clustering to discover the preferences of computer criminals},
Journal = {IEEE TRANSACTIONS ON SYSTEMS MAN AND CYBERNETICS PART A-SYSTEMS AND
   HUMANS},
Year = {2001},
Volume = {31},
Number = {4},
Pages = {311-318},
Month = {JUL},
Abstract = {The ability to predict computer crimes has become increasingly
   important. This paper describes a method for discovering the preferences
   of computer criminals, This method involves sequential clustering based
   on the variance of clusters discovered in higher order clustering. These
   discovered preferences can be used for the direct protection of computer
