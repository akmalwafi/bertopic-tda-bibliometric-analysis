@article{ WOS:001435581400001,
Author = {Singh, Astha and Singh, Keerti and Kumar, Divya and Prakash, Shiv},
Title = {An Efficient Lie Detection with Movement Tracks of Larynx and Eye
   Flutters During Interrogation Using Machine Learning and Deep-Computing},
Journal = {WIRELESS PERSONAL COMMUNICATIONS},
Year = {2025},
Volume = {140},
Number = {1-2},
Pages = {427-452},
Month = {JAN},
Abstract = {The Lie detection involves studying the behavior of human personality to
   assure the verdict in sophistication criminal case. Suspects generally
   fabricate some false stories to deviate the investigators. The strategy
   of an experienced suspect is to look calm and cooperative. There is a
   need to study the non-verbal signals of suspects from their recorded
   statements without making a violation of a person's civil rights. In
   today's scenario, the crimes are so advanced and sophisticated.
   Researchers map correlations between human expression and the truth. The
   naked eye may not capture the micro-level expressions. The proposed
   model studies the dependency of non-verbal gestures on the authenticity
   of a person's statement. In this paper, flapping eyelids and swallowing
   behaviour are studied. A camera was set up to record interrogation, and
   later, the frames were studied. The eye and neck moments are noticed. A
   novel approach estimates an individual's fear factor based on the
   frequency of eyelids and gulps. The swallow behaviour is tracked through
   the larynx movement of the suspect. The system will count the number of
   times an eye blinks in one minute. It also Figure out the left-right
   moments of an eye while interrogation. The study of non-verbal signals
   precisely helps the agencies to predict accurate verdicts. The proposed
   work also shows the verdict prediction based on the non-verbal movements
   of the suspect.},
