Title = {Classical and Quantum Random Walks to Identify Leaders in Criminal
   Networks},
Booktitle = {COMPLEX NETWORKS AND THEIR APPLICATIONS XI, COMPLEX NETWORKS 2022, VOL 1},
Series = {Studies in Computational Intelligence},
