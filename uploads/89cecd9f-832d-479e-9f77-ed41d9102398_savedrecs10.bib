@article{ WOS:000538088500003,
Author = {Harshany, Edward and Benton, Ryan and Bourrie, David and Glisson,
   William},
Title = {Big Data Forensics: Hadoop 3.2.0 Reconstruction},
Journal = {FORENSIC SCIENCE INTERNATIONAL-DIGITAL INVESTIGATION},
Year = {2020},
Volume = {32},
Number = {S},
Month = {APR},
Note = {7th Annual DFRWS Europe Conference (DFRWS EU), ELECTR NETWORK, JUN
   03-05, 2020},
Organization = {DFRWS},
Abstract = {Conducting digital forensic investigations in a big data distributed
   file system environment presents significant challenges to an
   investigator given the high volume of physical data storage space.
   Presented is an approach from which the Hadoop Distributed File System
   logical file space is mapped to the physical data location. This
   approach uses metadata collection and analysis to reconstruct events in
