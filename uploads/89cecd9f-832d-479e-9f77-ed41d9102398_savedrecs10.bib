@article{ WOS:001283558500001,
Author = {Sukanya, G. and Priyadarshini, J.},
Title = {Hybrid CNN: An Empirical Analysis of Machine Learning Models for
   Predicting Legal Judgments},
Journal = {INTERNATIONAL JOURNAL OF ADVANCED COMPUTER SCIENCE AND APPLICATIONS},
