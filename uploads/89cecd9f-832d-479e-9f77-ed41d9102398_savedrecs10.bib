Language = {English},
Affiliation = {Al-Juhani, AA (Corresponding Author), King Abdulaziz Univ Hosp, Dept Surg, Jeddah, Saudi Arabia.
   Al-Juhani, Abdulkreem Abdullah, King Abdulaziz Univ Hosp, Dept Surg, Jeddah, Saudi Arabia.
   Gaber, Arwa Mohammad; Desoky, Rodan Mahmoud, Alfaisal Univ, Coll Med, Riyadh, Saudi Arabia.
