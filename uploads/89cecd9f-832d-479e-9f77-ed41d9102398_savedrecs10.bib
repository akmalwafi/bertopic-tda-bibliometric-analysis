@inproceedings{ WOS:000804043100083,
Author = {Ao, Wenqun and Sun, Furong and Chen, Zhencai},
Book-Group-Author = {IEEE},
Title = {Investigation of Susceptible Characteristics in Network MLM and Big Data
   Prevention},
Booktitle = {2021 3RD INTERNATIONAL CONFERENCE ON MACHINE LEARNING, BIG DATA AND
   BUSINESS INTELLIGENCE (MLBDBI 2021)},
Year = {2021},
Pages = {444-447},
Note = {3rd International Conference on Machine Learning, Big Data and Business
   Intelligence (MLBDBI), ELECTR NETWORK, DEC 03-05, 2021},
Abstract = {As a new form of crime in the Internet age, college students are the key
   targets of network MLM. In order to study the characteristics of the
   susceptible population of MLM, this article takes college students in
   Nanchang as an example, collects research data using questionnaires, and
   conducts actions on 800 college students. Measurements, using methods
   such as single-factor analysis of variance, multiple comparisons of LSD,
   and self-analysis of big data documents. The study found that the
   difference in grade, major, and employment pressure of college students
   will significantly affect their susceptibility to MLM. Students facing
   high employment pressure are more susceptible to MLM. Sophomores and
   juniors in grades are more susceptible than seniors. Professional
   management Classes and agronomy classes are less susceptible than other
   majors. Finally, relevant big data visualization, knowledge map and
   other prevention and control suggestions are putting forward.},
