@article{ WOS:001409625300001,
Author = {Zainuddin, Muhammad Zaid and Azizan, Azliyana and Yusof, Mohd Yusmiaidil
   Putera Mohd},
Title = {Artificial Intelligence (AI) in Dental Age Estimation Studies: A
   Scientometric Analysis},
Journal = {INTELIGENCIA ARTIFICIAL-IBEROAMERICAN JOURNAL OF ARTIFICIAL INTELLIGENCE},
