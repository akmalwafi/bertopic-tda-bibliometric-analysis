@article{ WOS:000544279200006,
Author = {Ionescu, Bogdan and Ghenescu, Marian and Rastoceanu, Florin and Roman,
   Razvan and Buric, Marian},
Title = {Artificial Intelligence Fights Crime and Terrorism at a New Level},
