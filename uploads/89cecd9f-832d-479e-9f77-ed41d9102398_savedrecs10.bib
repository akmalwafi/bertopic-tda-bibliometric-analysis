Title = {Intelligent analysis of digital evidences in large-scale logs in power
   systems attributed to the attacks},
Booktitle = {2018 IEEE INTERNATIONAL CONFERENCE ON BIG DATA (BIG DATA)},
Series = {IEEE International Conference on Big Data},
Year = {2018},
