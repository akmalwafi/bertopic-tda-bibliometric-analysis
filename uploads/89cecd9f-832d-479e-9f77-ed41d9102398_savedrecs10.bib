@article{ WOS:000949923700001,
Author = {Singh, Arpit and Dwivedi, Ashish and Agrawal, Dindayal and Singh,
   Durgesh},
Title = {Identifying issues in adoption of AI practices in construction supply
   chains: towards managing sustainability},
