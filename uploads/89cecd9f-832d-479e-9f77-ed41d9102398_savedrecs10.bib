@article{ WOS:000555102200011,
Author = {Nemzer, Louis R. and Neymotin, Florence},
Title = {How words matter: machine learning \& movie success},
Journal = {APPLIED ECONOMICS LETTERS},
Year = {2020},
Volume = {27},
Number = {15},
Pages = {1272-1276},
Month = {SEP 1},
Abstract = {We employed a machine learning structure to examine the relationships
   between word choice in Internet Movie Database (IMDB) comedy movie
   descriptions and overall performance. Our measures of success were
   ticket sales, user ratings, and Metacritic scores. We used linear
   regressions, along with recurrent neural networks implementing a Long
   Short-Term Memory framework, for textual sentiment analysis. Employing
   conservative p-values, our results revealed the possible influence of
   gender bias in movies that favoured male-centric themes, as well as
   negative effects for holiday comedies, paranormal movies, and crime
   films.},
