@article{ WOS:001329047900014,
Author = {Park, Jin-Hwi and Park, Young-Jae and Cheong, Ilyung and Lee, Junoh and
   Huh, Young Eun and Jeon, Hae-Gon},
Title = {What Makes Deviant Places?},
