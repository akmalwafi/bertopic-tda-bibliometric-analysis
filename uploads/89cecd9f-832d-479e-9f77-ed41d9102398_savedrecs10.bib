@inproceedings{ WOS:000329976600001,
Author = {Pollitt, Mark},
Editor = {Peterson, G and Shenoi, S},
Title = {HISTORY, HISTORIOGRAPHY AND THE HERMENEUTICS OF THE HARD DRIVE},
Booktitle = {ADVANCES IN DIGITAL FORENSICS IX},
