@inproceedings{ WOS:001527231000011,
Author = {Kotal, Akash and Mitra, Arkadeep and Bhattacharya, Preetam and Karar,
   Sayak and Roy, Sinjini Hom and Saha, Suranjan and Chatterjee, Debraj},
Editor = {Nanda, U and Tripathy, AK and Sahoo, JP and Sarkar, M and Li, KC},
Title = {Nayantara: Crime Analysis from CCTV Footage Using MobileNet-V2 and
   Transfer Learning},
Booktitle = {ADVANCES IN DISTRIBUTED COMPUTING AND MACHINE LEARNING, VOL 2, ICADCML
   2024},
