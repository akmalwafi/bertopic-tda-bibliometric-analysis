@article{ WOS:001005877300001,
Author = {Markkandeyan, S. and Selvam, L. and Tamizharasu, K. and Aandi,
   Senthilkumar},
Title = {Experimental Analysis of the Machine Learning Algorithms for Crime Web
   Page Classification},
Journal = {IETE JOURNAL OF RESEARCH},
Year = {2024},
Volume = {70},
Number = {5},
Pages = {4890-4902},
Month = {MAY 3},
Abstract = {The evolution of web 3.0 results in storing data in plenty in the web
   which are huge as that of hard to search and its specific classification
   and this sort of issue attracts research attention. This task
   specifically addresses the problem of classifying web documents covering
   the crime data in it. Manual classification of crime related documents
   from the available ones is unimaginable and also observed that the
   existing models have not produced considerable results. It is obvious
   that machine learning approaches performs well in handling large amount
   of data. Hence, the problem of crime related web document classification
   is handled with an automated web page classification technique based on
   word similarity. The baseline is to identify the best performing feature
   selection approaches and combine them with machine learning models for
   isolating the best performing combination. The feature selection methods
   used are Jaccard Similarity, Information Gain, Gain Ratio and Chi Square
   Analysis and each of them is individually combined with four machine
   learning classifiers such as Support Vector Machine, K-Nearest Neighbor,
   J48 and Naive Bayes. The models are tested with the data set containing
   Web documents pertaining to Crime, Politics, Sports and Terrorism
   collected from different sources. The models have proved better
   performance when added with feature selection approaches than without
   them. When it comes for comparing different combinations of feature
   selection approaches and machine learning models, Support vector machine
   combined with Jaccard Similarity is found to perform well than the other
   approaches with an accuracy of 98.74\%.},
