Title = {A research on application of data mining in Cyber-Pursuit},
Journal = {INTERNATIONAL JOURNAL OF MANAGEMENT SCIENCE AND ENGINEERING MANAGEMENT},
Year = {2011},
Volume = {6},
Number = {2},
Pages = {123-129},
Abstract = {Data mining has been preliminary applied in public security in China. It
   shows significant potential in the fields of crime analysis, information
   evaluation, data quality analysis, process modification. Under the use
   of SPSS Clementine software, this thesis constructed a classification
   model on capture areas of escaped criminals by decision-tree algorithm,
   compared C5.0, CART, CHAID and QUEST, and then put forward suggestions
   about Cyber-Pursuit, specifically, query comparison is suitable for
   searching non-local escaped criminals, special catch for local escaped
   criminals and most of the captured criminals by deeply digging clues are
   local. These suggestions could provide useful decision making support
   for criminal investigation unit.},
