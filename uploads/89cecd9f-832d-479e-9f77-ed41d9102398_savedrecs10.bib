@inproceedings{ WOS:001178562004066,
Author = {Patra, Chanchal and Giri, Debasis and Obaidat, Mohammad S. and Maitra,
   Tanmoy},
Book-Group-Author = {IEEE},
Title = {SMSDect: A Prediction Model for Smishing Attack Detection using
   Machine Learning and Text Analysis},
Booktitle = {IEEE CONFERENCE ON GLOBAL COMMUNICATIONS, GLOBECOM},
Series = {IEEE Global Communications Conference},
Year = {2023},
Pages = {3837-3842},
Note = {IEEE Conference on Global Communications (IEEE GLOBECOM) - Intelligent
   Communications for Shared Prosperity, Kuala Lumpur, MALAYSIA, DEC 04-08,
   2023},
Organization = {IEEE; Huawei; Technol Innovat Inst; ZTE; Intel; Rohde \& Schwarz; NL;
   VLAVI},
Abstract = {Smishing is a type of cyberattack that includes delivering a fake
   messages to normal users in order to get their personal information.
   Cybersecurity experts are now concerned about this sort of assault
   because, both the individuals and companies are loosing their money by
   this attack. This article presents a machine learning base comparison
   approach using different text analysis features (i.e., Discourse,
   Linguistic, Psycholinguistic, Persuasion Principle and Statistics based
   features). Here, different Machine Learning classifiers (i.e., Logistic
   Regression, Naive Bayes, K-Nearest Neighbors, Random Forest, Support
   Vector Machine and XGBoost) have been used for smishing detection. The
   evaluation was performed on a prepared dataset. The dataset includes
   both smishing and normal messages. According to the comparative
   experimental results from the implemented classification algorithms,
   Random Forest classifier gives the best performance with the 99\%
   accuracy.},
