Pages = {124-128},
Note = {2015 First International Conference on Anti-Cybercrime (ICACC), Riyadh,
   SAUDI ARABIA, NOV 10-12, 2015},
Organization = {IEEE},
Abstract = {In today's fast changing world, cybercrimes are growing at perturbing
   pace. At the very definition of it, cybercrimes get engendered by
   capitalizing on threats and exploitation of vulnerabilities. However,
   recent history reveals that such crimes often come with surprises and
   seldom follow the trends. This puts the defense systems behind in the
   race, because of their inability to identify new patters of cybercrime
   and to ameliorate to the required levels of security. This paper
   visualizes the empowerment of security systems through real-time data
   mining by the virtue of which these systems will be able to dynamically
   identify patterns of cybercrimes. This will help those security systems
   stepping up their defense capabilities, while adapting to the required
   levels posed by newly germinating patterns. In order to confine within
   scope of this paper, the application of this approach is being discussed
   in the context of selected scenarios ofcybercrime.},
