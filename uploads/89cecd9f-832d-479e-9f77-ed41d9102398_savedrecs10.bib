   Bin Abdul and Hashim, Haslina Binti},
Book-Group-Author = {IEEE},
Title = {Copy-Move Image Forgery Detection Using Deep Learning Methods: A Review},
Booktitle = {2019 6TH INTERNATIONAL CONFERENCE ON RESEARCH AND INNOVATION IN
   INFORMATION SYSTEMS: EMPOWERING DIGITAL INNOVATION (ICRIIS 2019)},
Series = {International Conference on Research and Innovation in Information
