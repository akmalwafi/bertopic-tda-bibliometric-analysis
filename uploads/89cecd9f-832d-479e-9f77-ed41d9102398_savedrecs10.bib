@article{ WOS:001567641200001,
Author = {Vochozka, Marek and Raj, Robin Kunju Mol},
Title = {Framing Justice: A Sentiment Analysis of Law and Responsibility in
   Contemporary News Discourse},
Journal = {INTERNATIONAL JOURNAL FOR THE SEMIOTICS OF LAW-REVUE INTERNATIONALE DE
   SEMIOTIQUE JURIDIQUE},
Year = {2025},
Month = {2025 SEP 10},
Abstract = {This study employs sentiment analysis and topic modeling to investigate
   how modern media interprets law and responsibility across a vast corpus
   of worldwide news items. The study's goal is to find sentimental
   patterns in legal narratives and identify topic clusters that dominate
   public discourse. The study examines the polarity of sentiment as well
   as the thematic diversity of legal coverage using a variety of natural
   language processing technologies, including VADER and LDA. The findings
   reveal distinct attitude differences among legal topics: criminal
   justice and international law elicit strong emotional reactions, whereas
   administrative governance is typically described in neutral tones. The
   analysis also highlights the increasingly evident ways in which public
   emotion is linked to shifting socio-political events, and how thematic
   clusters, such as accountability and humanitarian intervention, interact
   with these sentimental trajectories. Using these variables in the
   observation and analysis of patterns, the study has fostered a more
   critical examination of the news media's role in shaping public
   understanding of legality, justice, and civic failure. While some
   methodological limitations have been outlined, and the features of
   language nuance and audience interpretation remain problematic, the
   research can provide a useful outline for future interdisciplinary
   research at the intersection of law, communication, and data science.
   The findings have also been useful to policymakers, journalists, and
   legal educators in bringing further responsibility and informed public
   discourse on legality, justice, and citizenship into the public domain.},
