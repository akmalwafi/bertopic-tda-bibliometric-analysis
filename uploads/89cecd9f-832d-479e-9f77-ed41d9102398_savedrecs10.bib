@inproceedings{ WOS:000531489300096,
Author = {Beheshti, Amin and Moraveji-Hashemi, Vahid and Yakhchi, Shahpar and
   Motahari-Nezhad, Hamid Reza and Ghafari, Seyed Mohssen and Yang, Jian},
Book-Group-Author = {ACM},
Title = {personality2vec: Enabling the Analysis of Behavioral Disorders in Social
   Networks},
Booktitle = {PROCEEDINGS OF THE 13TH INTERNATIONAL CONFERENCE ON WEB SEARCH AND DATA
   MINING (WSDM `20)},
Year = {2020},
Pages = {825-828},
Note = {13th Annual ACM International Conference on Web Search and Data Mining
   (WSDM), Houston, TX, FEB 03-07, 2020},
Organization = {Assoc Comp Machinery; ACM Special Interest Grp Informat Retrieval; ACM
   SIGWEB; ACM SIGKDD; ACM SIGMOD},
Abstract = {Enabling the analysis of behavioral disorders over time in social
   networks, can help in suicide prevention, (school) bullying detection
   and extremist/criminal activity prediction. In this paper, we present a
   novel data analytics pipeline to enable the analysis of patterns of
   behavioral disorders on social networks. We present a Social Behavior
   Graph (sbGraph) model, to enable the analysis of factors that are
   driving behavior disorders over time. We use the golden standards in
   personality, behavior and attitude to build a domain specific Knowledge
   Base (KB). We use this domain knowledge to design cognitive services to
   automatically contextualize the raw social data and to prepare them for
   behavioral analytics. Then we introduce a pattern-based word embedding
   technique, namely personality2vec, on each feature extracted to build
   the sbGraph. The goal is to use mathematical embedding from a space with
   a dimension per feature to a continuous vector space which can be mapped
   to classes of behavioral disorders (such as cyber-bullying and
   radicalization) in the domain specific KB. We implement an interactive
   dashboard to enable social network analysts to analyze and understand
   the patterns of behavioral disorders over time. We focus on a motivating
   scenario in Australian government's office of the e-Safety commissioner,
   where the goal is to empowering all citizens to have safer, more
   positive experiences online.},
