@article{ WOS:001520902400001,
Author = {Oh, Junghoon},
Title = {A practical approach to detecting file timestamp manipulation for
   digital forensic investigations},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2025},
Volume = {293},
Month = {DEC 1},
Abstract = {The timestamp of a file is important information employed for
   reconstructing the events in chronological order in the timeline
   analysis during digital forensic investigation. Therefore, the malicious
   attackers may manipulate the file timestamps to avoid detection by
   timeline analysis. Among the existing methods for detecting the
   timestamp manipulation in Windows systems, the most direct one is to
   utilize \$LogFile and \$UsnJrnl, which are the New Technology File
   System (NTFS) journals. However, the methods of previous studies that
   detected the timestamp manipulation through \$LogFile and \$UsnJrnl are
   only applicable in limited experimental environments and are difficult
   to use in real-world environments since they generate many false
   positives. To address these limitations, this paper proposes a data
   preprocessing and feature extraction methodology leveraging contextual
   and statistical information for machine learning-based detection. The
   machine learning model built with the extracted features effectively
   detected timestamp manipulation and significantly reduced false
   positives compared to previous methods. In addition, the machine
   learning model identified key details such as the type of timestamp
   manipulation tool and the associated attack group, aiding digital
   forensic investigations. Finally, this paper proposes a decision-making
   process for identifying file timestamp manipulation using the developed
   machine learning model.},
Publisher = {PERGAMON-ELSEVIER SCIENCE LTD},
