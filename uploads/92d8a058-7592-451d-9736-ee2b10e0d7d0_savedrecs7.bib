@article{ WOS:001482883300001,
Author = {Ni, Yuhan and Huang, Yingshi and Zhao, Shuqi and Ma, Yuqing and Fang,
   Mengru},
Title = {Development and Evaluation of the Shortened Chinese Version of School
   Social Behavior Scales-2 Using Item Response Theory and Psychometric
   Network Analysis},
Journal = {MEASUREMENT AND EVALUATION IN COUNSELING AND DEVELOPMENT},
Year = {2025},
Volume = {58},
Number = {4},
Pages = {307-325},
Month = {OCT 2},
Abstract = {Objective: To provide researchers with flexibility in selecting scale
   lengths, this study aimed to develop two shortened Chinese versions of
   the School Social Behavior Scales-2 (SSBS-2), including Social
   Competence Scale (SCS) and Antisocial Behavior Scale (ABS). Method:
   Participants included 21,542 Chinese students who were randomly divided
   into two equal-sized subsamples. The development sample was used to
   reduce the number of items via item response theory and psychometric
   network analysis, while the validation sample was used to evaluate
   reliability and multiple sources of validity evidence. Results: Two
   versions of shortened scales were developed: one with 32 items (SCS-16
   and ABS-16) and the other with 20 items (SCS-10 and ABS-10). Compared to
   the original scale, both shortened scales demonstrated good reliability
   and strong levels of validity evidence. Conclusions: The shortened
   Chinese versions of SSBS-2 can be effectively utilized to assess social
   skills among children and adolescents in large-scale studies.},
