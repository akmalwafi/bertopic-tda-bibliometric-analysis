Title = {Classifying Pastebin Content Through the Generation of PasteCC Labeled
   Dataset},
Booktitle = {HYBRID ARTIFICIAL INTELLIGENT SYSTEMS, HAIS 2019},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2019},
Volume = {11734},
