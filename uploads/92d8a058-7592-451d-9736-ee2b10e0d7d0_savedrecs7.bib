@article{ WOS:000465517500005,
Author = {Francois, Axelle and Nolet, Anne-Marie and Morselli, Carlo},
Title = {Prison sociability and reintegration},
Journal = {DEVIANCE ET SOCIETE},
Year = {2018},
Volume = {42},
Number = {2},
Pages = {389-419},
Month = {JUN},
Abstract = {Based on past research on offender interventions and the use of social
   network analysis, this article examines the influence of carceral
   sociability on individual perceptions on reinsertion. The results of a
   survey conducted on 22 residents of a Montreal halfway house illustrate
   that the residents with closer social ties with other residents were
   more likely to have negative outlooks on their social reinsertion at the
   end of their halfway tenure. This finding and overall study is
   consistent with the general institutionalization phenomenon, while also
   shedding light on various offender-based interventions.},
