@inproceedings{ WOS:000722624000006,
Author = {Battaglia, Elena and Bioglio, Livio and Pensa, Ruggero G.},
Editor = {Berthold, MR and Feelders, A and Krempl, G},
Title = {Towards Content Sensitivity Analysis},
Booktitle = {ADVANCES IN INTELLIGENT DATA ANALYSIS XVIII, IDA 2020},
Series = {Lecture Notes in Computer Science},
Year = {2020},
Volume = {12080},
Pages = {67-79},
Note = {18th International Symposium on Intelligent Data Analysis (IDA), ELECTR
   NETWORK, APR 27-29, 2020},
Abstract = {With the availability of user-generated content in the Web, malicious
   users dispose of huge repositories of private (and often sensitive)
   information regarding a large part of the world's population. The
   self-disclosure of personal information, in the form of text, pictures
   and videos, exposes the authors of such contents (and not only them) to
   many criminal acts such as identity thefts, stalking, burglary, frauds,
   and so on. In this paper, we propose a way to evaluate the harmfulness
   of any form of content by defining a new data mining task called content
   sensitivity analysis. According to our definition, a score can be
   assigned to any object (text, picture, video ...) according to its
   degree of sensitivity. Even though the task is similar to sentiment
   analysis, we show that it has its own peculiarities and may lead to a
   new branch of research. Thanks to some preliminary experiments, we show
   that content sensitivity analysis can not be addressed as a simple
   binary classification task.},
