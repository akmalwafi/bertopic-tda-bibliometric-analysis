@inproceedings{ WOS:001170169300036,
Author = {Melanitis, N. and Giannakopoulos, G. and Stamatakis, K.},
Book-Group-Author = {IOP},
Title = {NAVMAT: an AI-powered pathway to knowledge sharing on material failures},
Booktitle = {7TH INTERNATIONAL CONFERENCE OF ENGINEERING AGAINST FAILURE},
Series = {Journal of Physics Conference Series},
Year = {2024},
