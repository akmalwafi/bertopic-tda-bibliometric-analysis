@article{ WOS:001403144200001,
Author = {Ibora, Melisa Williams and Talley, Amelia E.},
Title = {Alcohol Use and Peer Victimization Among U.S. Bisexual Youth and Other
   Sexual Orientations: A National Study on Individual and State-Level
   Factors},
Journal = {TRANSLATIONAL ISSUES IN PSYCHOLOGICAL SCIENCE},
Year = {2025},
Volume = {11},
Number = {1, SI},
Pages = {67-79},
Month = {MAR},
Abstract = {As time goes on, the United States is becoming more sexually diverse.
   Therefore, it is crucial to examine the populations of interest in
   anticipation of these changes. We examined differences in recent alcohol
   use outcomes (past month use and heavy episodic use) among bisexual
   youth (i.e., reporting attraction to more than one sex or gender)
   compared to their gay and lesbian counterparts as well as their
   heterosexual peers. Peer victimization was evaluated as a moderator of
   differences in risk for recent alcohol use (i.e., a state's peer
   victimization climate and individual-level victimization). Data were
   obtained from recent Youth Risk Behavior Surveys (2015, 2017, and 2019).
   All analyses utilized hierarchical linear modeling (i.e., students
   nested within states). Overall, it was found that gay youth reported
   more past month use and heavy episodic drinking than lesbian youth and
   bisexual youth. Compared to their White heterosexual peers, sexually
   diverse youth of color and White bisexual youth showed a lower
   likelihood of reporting past month alcohol use and heavy episodic
   drinking. However, compared to White gay and lesbian youth, sexually
   diverse youth of color and White bisexual youth were more likely to
   report both recent alcohol use behaviors. Regardless of sexual
   orientation, youth who reported being victimized by their peers were
   more likely to report past month heavy episodic drinking. In addition,
   states in which a greater proportion of youth who reported recent peer
   victimization showed lower odds of reporting recent alcohol use.},
Publisher = {EDUCATIONAL PUBLISHING FOUNDATION-AMERICAN PSYCHOLOGICAL ASSOC},
Address = {750 FIRST ST, NE, WASHINGTON, DC 20002-4242 USA},
Type = {Article},
Language = {English},
Affiliation = {Ibora, MW (Corresponding Author), Texas Tech Univ, Dept Psychol Sci, POB 42051, Lubbock, TX 79409 USA.
   Ibora, Melisa Williams; Talley, Amelia E., Texas Tech Univ, Dept Psychol Sci, POB 42051, Lubbock, TX 79409 USA.},
DOI = {10.1037/tps0000443},
EarlyAccessDate = {JAN 2025},
ISSN = {2332-2136},
EISSN = {2332-2179},
Keywords = {big data; peer victimization; marginalized youth},
Keywords-Plus = {SUBSTANCE USE; SOCIAL DESIRABILITY; EARLY ADOLESCENCE; GENDER; GAY;
   HEALTH; POPULATIONS; IDENTITY; STUDENTS; TRAJECTORIES},
Research-Areas = {Psychology},
Web-of-Science-Categories  = {Psychology; Psychology, Multidisciplinary},
Author-Email = {melisawi@ttu.edu},
Affiliations = {Texas Tech University System; Texas Tech University},
