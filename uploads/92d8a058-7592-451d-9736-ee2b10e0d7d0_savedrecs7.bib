Booktitle = {2020 IEEE 17TH INTERNATIONAL CONFERENCE ON SMART COMMUNITIES: IMPROVING
   QUALITY OF LIFE USING ICT, IOT AND AI (IEEEHONET 2020)},
Series = {International Symposium on High Capacity Optical Networks and Enabling
