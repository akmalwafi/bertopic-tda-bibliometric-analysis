
@inproceedings{ WOS:000836390500106,
Author = {Murphy, Eva and Goodman, Lizbeth},
Editor = {Kallel, I and Kammoun, HM and Akkari, A and Hsairi, L},
Title = {Unintended Consequences when the Engineering Design Team is
   Noninclusive: An Exploration of the Literature},
Booktitle = {PROCEEDINGS OF THE 2022 IEEE GLOBAL ENGINEERING EDUCATION CONFERENCE
   (EDUCON 2022)},
Series = {IEEE Global Engineering Education Conference},
Year = {2022},
