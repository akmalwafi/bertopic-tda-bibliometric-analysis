@article{ WOS:001110825800005,
Author = {Galarza, Mario Santisteban and Aguerri, Jesus C.},
Title = {Does ChatGPT-4 dream of offensive tweets?An approximation to the
   potential contributions of generative models in detecting illicit
   speeches},
Journal = {IDP-INTERNET LAW AND POLITICS},
Year = {2023},
Number = {39},
Month = {NOV},
Abstract = {The latest advances in generative artificial intelligence appear to
   allow artificial intelligence models to be equipped with capabilities as
   relevant to the legal field as to arguing their own decisions. This
   study approximates the capabilities of the ChatGPT-4 model in the
   context of the detection of hate speeches according to their
   conceptualization in article 510.1. a) of the Spanish Criminal Code. For
   this purpose, ChatGPT-4's reasoning and decisions will be compared from
   proven factual accounts with the decisions of the bodies that judged the
   respective cases, studying the limits and potential of these systems in
   the legal field.},
