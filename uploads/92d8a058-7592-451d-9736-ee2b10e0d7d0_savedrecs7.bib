Title = {ARTIFICIAL INTELLIGENCE AND GENDER PERSPECTIVE: PROGRAMMING,
   INVESTIGATING AND JUDGING WITH PURPLE FILTER},
Journal = {REVISTA GENERAL DE DERECHO PROCESAL},
Year = {2021},
Number = {55},
Month = {SEP},
Abstract = {How can Artificial Intelligence improve the law? The legal system is
   full of gender stereotypes inherited from the legislation and that do
   not take into account these social problems. If we want to use
   Artificial Intelligence in the criminal system, we must be aware that no
   risk management tool will be able to reverse and change centuries of
   racial injustice and gender inequality. The analysis of the massive data
   that we use is not neutral. Algorithms reproduce our prejudices. We
   cannot assume that numbers are impartial. Numbers have been fed with
   biased data due to our way of seeing reality through centuries of
   history.},
