@inproceedings{ WOS:001157520100006,
Author = {Ameli, Leila and Chowdhury, Md Shah Alam and Farid, Farnaz and Bello,
   Abubakar and Sabrina, Fariza and Maurushat, Alana},
Book-Group-Author = {ACM},
Title = {AI and Fake News: A Conceptual Framework for Fake News Detection},
Booktitle = {PROCEEDINGS OF THE 2022 INTERNATIONAL CONFERENCE ON CYBER SECURITY, CSW
   2022},
Year = {2022},
