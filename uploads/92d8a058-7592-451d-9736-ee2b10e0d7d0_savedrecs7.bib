@article{ WOS:001001117700012,
Author = {Hoelscher, Jamie and Shonhiwa, Trevor},
Title = {J\&S Publisher Problems: A Diagnostic Analytics Case Exploring Employee
   Expense Reimbursement},
Journal = {JOURNAL OF EMERGING TECHNOLOGIES IN ACCOUNTING},
Year = {2023},
Volume = {20},
Number = {1},
Pages = {213-221},
Abstract = {This paper aims to help students further understand employee
   reimbursement schemes, while simultaneously advancing the integration of
   data analytics in the accounting curriculum. The learning activity takes
   students through a comprehensive data analytics cycle to determine the
   root cause of employee expense reimbursement increases. The ability to
   leverage data analytics and possess technological agility to address
   business questions is an important skillset. Our paper contributes to
   the literature by presenting a resource that promotes the acceleration
   of integrating data analytics across the curriculum. The case topic is
   applicable to many classes, including audit (both external and
   internal), accounting information systems (AIS), financial, or forensic
   accounting, thereby promoting compliance with new accreditation
   standards requiring analytics throughout the curriculum. This case study
   helps expand the coverage of data analytics and learning experiences
   that emphasize the integration of information technology in the
   accounting curriculum.},
