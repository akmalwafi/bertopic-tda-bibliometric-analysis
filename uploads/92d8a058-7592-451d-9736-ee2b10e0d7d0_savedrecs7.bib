@article{ WOS:001134233000007,
Author = {Verdugo, R. Rebeca Cordero and Suarez, Jorge Ramiro Perez and Herradon,
   David Pavon and Esquinas, Antonio Silva},
Title = {Crime and safety of sexual affective apps, based on the ethnography
   conducted in the Enrolla2 Project},
Journal = {CADERNOS DE DEREITO ACTUAL},
Year = {2023},
Number = {22},
Pages = {232-250},
Abstract = {The Projects ``Enrolla2 Generation X Security Perceptions and Risk
   Attitudes in individuals belonging to the Generation X linked to the use
   of affective-sexual computer applications (CIPI / 20/091){''} and ``The
   management of desire in times of COVID (CIPI / 20/159) ``had as their
   respective objectives, to study the perception of security, its
   incidence in the level of victimization and the risks to the health of
   individuals in affective-sexual applications; and to know the
   motivations that have led them to use affective-sexual apps during
   lockdown. Different levels of security were observed in the apps,
   depending on the treatment of user data, the existence of harassing
   attitudes and the emergence of a digital drug market. Legally, it is
   understood as necessary to improve the protection of users, potential
   victims of crime -individually identified, especially striking in the
   case of the revelation of intimacy- and, likewise, encourage the culture
   of prevention or compliance with respect to the companies that own said
   platforms. Precisely for this reason, on this occasion special emphasis
   will be placed on this last aspect, the responsibility of the legal
   entity, Business Ethics, the Compliance Program and Artificial
   Intelligence.},
