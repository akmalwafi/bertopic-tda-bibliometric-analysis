@inproceedings{ WOS:001094862603150,
Author = {Hu, Xiaoyan and Li, Ning and Cheng, Guang and Li, Ruidong and Wu, Hua},
Book-Group-Author = {IEEE},
Title = {A Novel Darknet Traffic Classification Method based on Knowledge Graph
   with Dynamic Embedding Learning},
Booktitle = {ICC 2023-IEEE INTERNATIONAL CONFERENCE ON COMMUNICATIONS},
Series = {IEEE International Conference on Communications},
Year = {2023},
Pages = {3799-3804},
Note = {IEEE International Conference on Communications (IEEE ICC), Rome, ITALY,
   MAY 28-JUN 01, 2023},
Organization = {IEEE; IEEE Commun Soc},
Abstract = {Darknet is described as an individual encrypted part of the Internet
   that can only be accessed with specific anonymity tools. Achieving
   accurate classification of darknet traffic is crucial for identifying
   anonymous network applications and combating cybercrimes. Machine
   learning-based and deep learning-based classifiers have achieved decent
   results in darknet traffic classification. However, these methods can
   not learn global and distinctive darknet flow embedding representations,
   resulting in limited classification performance. To tackle these issues,
   we propose Dark-DKGC, a novel darknet traffic classification method
   based on Knowledge Graph (KG) with Dynamic Knowledge Graph (DKG)
   embedding learning. Dark-DKGC first constructs Darknet Traffic Dynamic
   Knowledge Graph (Dark-DKG). Then Dark-DKGC utilizes the DKG embedding
   method to effectively learn the embedding representations of all flows.
   Finally, machine learning-based classifiers are trained based on the
   embedding representations of flows to identify darknet traffic. Our
   experimental studies suggest that Dark-DKGC can effectively capture
   distinguishable embedding representations for darknet flows. In
   multiclass classification scenario, its average accuracy is about
   7\%-13\% higher than state-of-the-art methods and 1\% higher than the
   static KG embedding-based classifier. Besides, compared to the static KG
   embedding method, Dark-DKGC takes advantage of its online embedding
   learning to improve test efficiency significantly. Moreover, the
   visualization of Dark-DKG allows a certain degree of interpretability
   for the classification results.},
