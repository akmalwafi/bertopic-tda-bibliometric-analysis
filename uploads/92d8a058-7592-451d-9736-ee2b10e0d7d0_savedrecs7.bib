Title = {LEGAL IMPLICATIONS OF WEB SCRAPING IN THE TRAINING OF GENERATIVE
   ARTIFICIAL INTELLIGENCE MODELS},
Journal = {REVISTA LA PROPIEDAD INMATERIAL},
