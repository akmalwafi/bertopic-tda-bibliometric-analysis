@inproceedings{ WOS:001062819300031,
Author = {Davis, Jenny L.},
Book-Group-Author = {ASSOC COMPUTING MACHINERY},
Title = {`Affordances' for Machine Learning},
Booktitle = {PROCEEDINGS OF THE 6TH ACM CONFERENCE ON FAIRNESS, ACCOUNTABILITY, AND
   TRANSPARENCY, FACCT 2023},
Year = {2023},
Pages = {324-332},
Note = {6th ACM Conference on Fairness, Accountability, and Transparency
   (FAccT), Chicago, IL, JUN 12-15, 2023},
Organization = {Assoc Comp Machinery},
Abstract = {The field of machine learning (ML) has long struggled with a
   principles-to-practice gap, whereby careful codes and commitments
   dissipate on their way to practical application. The present work
   bridges this gap through an applied affordance framework. `Affordances'
   are how the features of a technology shape, but do not determine, the
   functions and effects of that technology. Here, I demonstrate the value
   of an affordance framework as applied to ML, considering ML systems
   through the prism of design studies. Specifically, I apply the
   mechanisms and conditions framework of affordances, which models the way
   technologies request, demand, encourage, discourage, refuse, and allow
   technical and social outcomes. Illustrated through three case examples
   across work, policing, and housing justice, the mechanisms and
   conditions framework reveals the social nature of technical choices,
   clarifying how and for whom those choices manifest. This approach
   displaces vagaries and general claims with the particularities of
   systems in context, empowering critically minded practitioners while
   holding power-and the systems power relations produce-to account. More
   broadly, this work pairs the design studies tradition with the ML
   domain, setting a foundation for deliberate and considered (re)making of
   sociotechnical futures.},
Publisher = {ASSOC COMPUTING MACHINERY},
Address = {1601 Broadway, 10th Floor, NEW YORK, NY, UNITED STATES},
