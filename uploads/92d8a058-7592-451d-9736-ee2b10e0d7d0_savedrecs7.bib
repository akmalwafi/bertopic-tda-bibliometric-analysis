@incollection{ WOS:001170145400004,
Author = {Willekes, Carolyn},
Editor = {Dharamsi, K and Clemis, D},
Title = {Deus ex Machina: From the Ancient World to AI},
Booktitle = {LIBERAL EDUCATION: Analog Dreams in a Digital Age},
Series = {Series in Education},
Year = {2023},
Pages = {19-34},
Abstract = {The ancient world might seem to be a strange place to look for questions
   and answers about artificial intelligence and its role in both education
   and society. Although the Greeks and their neighbours made no shortage
   of discoveries and technological innovations, AI was not something they
   encountered in their daily lives. Instead, their actions and routines
   were dictated by the gods. The pantheon of Greek deities and the cult
   practices associated with them were intimately intertwined with every
   moment of the day, whether in the privacy of the home, at the civic
   level, or celebrated on a grand scale at the Panhellenic festivals. The
   powers and quirks of the gods provided the Greeks with explanations for
   everything: from earthquakes to illness. The Greeks were reliant on
   their gods to guide them through life, and they feared committing hubris
   or accidentally offending a deity, thereby incurring divine wrath.
   Essentially the gods became scapegoats: a useful explanation to explain
   the less salubrious aspects of human behaviour. How does this relate to
   AI? Well, what if we become too reliant on it? When does AI change from
   being a useful tool in the classroom and society to something that we
   are completely reliant on to teach and live? What are the risks inherent
   in this? This chapter will explore these questions by looking at how
   Greek society and behaviour were shaped by their interactions with the
   gods and comparing it to our evolving relationship with AI in the
   twenty-first century.},
