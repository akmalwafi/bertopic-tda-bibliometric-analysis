@inproceedings{ WOS:000783304700011,
Author = {Emarat, Anawin and Manaskasemsak, Bundit and Rungsawang, Arnon},
Editor = {Meesad, P and Sodsee, S and Jitsakul, W and Tangwannawit, S},
Title = {Prediction of Thai Court Judgments in Criminal Cases Using Deep Neural
   Networks},
Booktitle = {PROCEEDINGS OF THE 18TH INTERNATIONAL CONFERENCE ON COMPUTING AND
   INFORMATION TECHNOLOGY (IC2IT 2022)},
Series = {Lecture Notes in Networks and Systems},
Year = {2022},
Volume = {453},
Pages = {111-118},
Note = {18th International Conference on Computing and Information Technology
   (IC2IT), Kanchanaburi, THAILAND, MAY 19-20, 2022},
Abstract = {The Court of Justice currently applies information technology (IT) to
   support trials and to enhance operational efficiency. Various forms of
   innovations and information systems have been developed for operational
   responses, such as judgments, that require professionalism in trails and
   decisions of judges. Therefore, supporting information is important and
   necessary. This paper proposes a machine learning approach to support
   judges' decisions by predicting the outcome of a defendant's judgment in
   a criminal case. The profiles of previous defendants were thoroughly
   analyzed and presented with a set of features. Then, a deep neural
   networks (DNN) model was proposed to classify the judgment outcomes. We
   compared the performance of the proposed DNN with five traditional
   learning algorithms, i.e., decision tree, k-nearest neighbors, support
   vector machine, Naive Bayes, and logistic regression. The results show
   that the proposed approach can predict judgment outcomes more accurately
   than the baseline approaches with an accuracy of 93.88\%.},
