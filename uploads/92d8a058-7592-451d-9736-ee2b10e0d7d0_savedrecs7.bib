@article{ WOS:001461323300001,
Author = {Gangadharan, Anusree S. and Venu, V. M. Adhithya and Thangadurai, T.
   Daniel and Lee, Yong-Ill},
Title = {Exploring spectroscopy's impact in pharmaceutical, and biomedical
   sciences: an insightful review},
Journal = {APPLIED SPECTROSCOPY REVIEWS},
Year = {2025},
Month = {2025 MAR 26},
Abstract = {The integration of spectroscopic techniques across the pharmaceutical,
   biomedical, and forensic disciplines enables precise, accurate, and
   reliable evaluations. Techniques such as UV-Vis, FTIR, Raman, SERS,
   mass, photoacoustic, THz-TDS, and NMR spectroscopies have transformed
   various fields, showcasing the potential of these methods for disease
   detection, drug efficacy monitoring, and optimization of pharmaceutical
   formulations. Recently, advanced spectroscopic analyses have enhanced
   pharmaceutical quality control by facilitating rapid, nondestructive
   detection and quantification of critical quality attributes, thereby
   ensuring authenticity and regulatory compliance. Likewise, the
   application of spectroscopy in biomedical sciences has markedly improved
   detection and identification capabilities. The integration of artificial
   intelligence (AI) and machine learning (ML) with spectroscopic
   techniques represents a paradigm shift in data analysis and prediction
   within pharmaceutical, and biomedical, research. Therefore, acquiring
   knowledge of recent advancements in spectroscopic methods within these
   fields is essential. This comprehensive review effectively integrates
   spectroscopic techniques in the context of pharmaceutical, and
   biomedical research, exploring their potential applications in drug
   discovery, and diagnostics.},
