@article{ WOS:001149823800021,
Author = {Zhukova, L. V. and Kovalchuk, I. M. and Kochnev, A. A. and Chugunov, V.
   R.},
Title = {Building a Scale for Internet Fraud Detection Using Machine Learning},
Journal = {PROGRAMMING AND COMPUTER SOFTWARE},
