@inproceedings{ WOS:001440422700031,
Author = {Blancaflor, Eric and Deldacan, Lianne Francheska and Hunat, Shane and
   Rivera, Bea Marga and Liberato, Enrique Karl},
Book-Group-Author = {ASSOC COMPUTING MACHINERY},
Title = {AI-Driven Phishing Detection: Combating Cyber Threats Through Homoglyph
   Recognition and User Awareness},
Booktitle = {6TH WORLD SYMPOSIUM ON SOFTWARE ENGINEERING, WSSE 2024},
Year = {2024},
Pages = {226-231},
Note = {6th World Symposium on Software Engineering, Kyoto, JAPAN, SEP 13-15,
   2024},
Organization = {Wuhan University; University of Houston; Huaqiao University; University
   Of North Dakota},
Abstract = {Cybersecurity remains a global concern, with phishing attacks posing
   significant threats. This study investigates cybersecurity awareness in
   the Philippines, focusing on phishing and homoglyphs. Using experimental
   designs and cross-sectional surveys, the research examines user
   awareness, cybercrime knowledge, email usage patterns, and abilities to
   filter phishing emails and detect homoglyphs. Findings reveal a high
   prevalence of phishing attacks, despite respondents' confidence in
   cybercrime knowledge. Variability in filtering and detection skills
   underscores the need for targeted awareness initiatives. Awareness of
   homoglyphs correlates with individuals' perceived detection ability,
   highlighting education's importance. Preemptive warnings effectively
   reduce phishing susceptibility, emphasizing proactive measures' value in
   cybersecurity. Additionally, AI algorithms show promise in detecting
   homoglyphs, offering potential enhancements for email security. This
   comprehensive approach underscores the importance of continuous
   education, proactive measures, and technological advancements in
   safeguarding users against evolving cyber threats.},
