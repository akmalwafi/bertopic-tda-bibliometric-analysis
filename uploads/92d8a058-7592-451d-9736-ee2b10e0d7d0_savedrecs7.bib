@inproceedings{ WOS:000779244300019,
Author = {Suvarna, Ashima and Bhalla, Grusha and Kumar, Shailender and Bhardwaj,
   Ashi},
Book-Group-Author = {ACM},
Title = {Identifying Victim Blaming Language in Discussions about Sexual Assaults
   on Twitter},
Booktitle = {11TH INTERNATIONAL CONFERENCE ON SOCIAL MEDIA \& SOCIETY (SMSOCIETY')},
Year = {2020},
Pages = {156-163},
Note = {11th International Conference on Social Media and Society (SMSociety),
   ELECTR NETWORK, JUL 22-24, 2020},
Organization = {Ryerson Univ; Ted Rogers Sch Management; SocialMediaLab Ca; Social Media
   \& Soc Org; DePaul Univ, Coll Commun; Studio Chi; DePaul Univ, Coll Comp
   \& Digital Media},
Abstract = {Increasing instances of sexual assault have presented an opportunity for
   these heinous crimes to be discussed on social platforms. Oftentimes,
   victims are slut shamed and held culpable for the assault by the
   community which further discourages such personal disclosures and
   assault reporting. Victim Blaming has multiple psychological effects on
   the victim and further discourages formal reporting of such crimes.
   Therefore, it is important to devise computationally relevant methods to
   identify and prevent victim blaming to protect the victims.
   Additionally, specific datasets to devise models should also be
   developed. In our work, we present an exhaustive statistical analysis of
   victim blaming and gender attributes along with a single step transfer
   learning based classification method to identify victim blaming language
   on Twitter. Finally, we compare the performance of the proposed model
   against various deep learning and machine learning models on a manually
   annotated domain-specific dataset.},
Publisher = {ASSOC COMPUTING MACHINERY},
Address = {1601 Broadway, 10th Floor, NEW YORK, NY, UNITED STATES},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Suvarna, A (Corresponding Author), Delhi Technol Univ, New Delhi, India.
   Suvarna, Ashima; Bhalla, Grusha; Kumar, Shailender; Bhardwaj, Ashi, Delhi Technol Univ, New Delhi, India.},
DOI = {10.1145/3400806.3400825},
ISBN = {978-1-4503-7688-4},
Keywords = {Sexual assault; victim blame; Twitter; social media; deep learning; text
   classification},
