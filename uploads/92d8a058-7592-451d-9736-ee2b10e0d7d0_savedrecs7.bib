@inproceedings{ WOS:001481352700033,
Author = {Fausak, Andrew R. and Tunc, Cihan and Fausak, Andrew T.},
Book-Group-Author = {IEEE},
Title = {Malicious Intent Detection Framework For Social Networks},
Booktitle = {2024 IEEE/ACS 21ST INTERNATIONAL CONFERENCE ON COMPUTER SYSTEMS AND
   APPLICATIONS, AICCSA},
