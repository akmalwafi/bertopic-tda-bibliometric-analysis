@inproceedings{ WOS:001202259102047,
Author = {Kim, Kwangho and Kennedy, Edward H. and Zubizarreta, Jose R.},
Editor = {Koyejo, S and Mohamed, S and Agarwal, A and Belgrave, D and Cho, K and Oh, A},
Title = {Doubly Robust Counterfactual Classification},
Booktitle = {ADVANCES IN NEURAL INFORMATION PROCESSING SYSTEMS 35, NEURIPS 2022},
Series = {Advances in Neural Information Processing Systems},
Year = {2022},
Note = {36th Conference on Neural Information Processing Systems (NeurIPS),
   ELECTR NETWORK, NOV 28-DEC 09, 2022},
Abstract = {We study counterfactual classification as a new tool for decision-making
   under hypothetical (contrary to fact) scenarios. We propose a
   doubly-robust nonparametric estimator for a general counterfactual
   classifier, where we can incorporate flexible constraints by casting the
   classification problem as a nonlinear mathematical program involving
   counterfactuals. We go on to analyze the rates of convergence of the
   estimator and provide a closed-form expression for its asymptotic
   distribution. Our analysis shows that the proposed estimator is robust
   against nuisance model misspecification, and can attain fast v n rates
   with tractable inference even when using nonparametric machine learning
   approaches. We study the empirical performance of our methods by
   simulation and apply them for recidivism risk prediction.},
Publisher = {NEURAL INFORMATION PROCESSING SYSTEMS (NIPS)},
Address = {10010 NORTH TORREY PINES RD, LA JOLLA, CALIFORNIA 92037 USA},
Type = {Proceedings Paper},
