@article{ WOS:001010203500014,
Author = {Zhang, Zhaogong and An, Guoli},
Title = {Depression emotion image recognition based on MRI intelligent device and
   deep learning technology},
Journal = {ARCHIVES OF CLINICAL PSYCHIATRY},
Year = {2022},
Volume = {49},
Number = {1},
Pages = {98-108},
Month = {JAN-FEB},
Abstract = {Depression is a clinical disease, mainly accompanied by mood or
   emotional abnormalities, mainly depression, slow thinking, often
   accompanied by emotional abnormalities. Here, using static and
   task-state MRI data, we present a comprehensive study of abnormal neural
   activity in patients with depression through spatiotemporal, static, and
   dynamic measures, demonstrating its validity as an underlying biological
   trait. We selected data on the mental state of 45 patients from a
   hospital's psychiatric disease control center. They had no history of
   hearing impairment and normal (or corrected) vision. All procedures are
   agreed in writing by each participant. We collected MRI data from
   subjects and conducted experiments on subjects with a machine
   learning-based approach to emotion regulation. The results show that
   this method can effectively reduce the depression degree of the
   subjects, and the multi-level features of the integration of task
   activation and task regulation connection reach 81\% (<0.0010, surrogate
   test) and 83\% (<0.0016, surrogate test), respectively.},
