@article{ WOS:001439808600025,
Author = {Dobson, Kyle S. H. and Dittmann, Andrea G. and Yeager, David S.},
Title = {A transparency statement improves trust in community-police interactions},
Journal = {NATURE COMMUNICATIONS},
Year = {2025},
Volume = {16},
Number = {1},
Month = {MAR 7},
Abstract = {Over the past three decades, billions have been invested in community
   policing to foster positive interactions between officers and community
   members. Yet, public trust in police continues to decline. Our
   qualitative analysis of over 500 hours of naturalistic observations
   suggests a potential reason: the questioning styles of officers in
   community policing may make community members feel threatened.
   Observations also point to a solution: transparent communication of
   benevolent intent. Building on this, a pre-registered field experiment
   (N = 232) finds that community members feel less threatened and report
   greater trust when officers use a brief transparency statement (e.g.,
   ``I'm walking around trying to get to know the community{''}). These
   findings are supported by exploratory natural language processing and
   sympathetic nervous system measures. Six online experiments (total N =
   3210) further show that transparency statements are effective across
   diverse groups and isolate the conditions where they work best. This
   multi-method investigation underscores the importance of transparency in
   fostering positive community-police relations.},
