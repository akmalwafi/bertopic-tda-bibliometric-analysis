DOI = {10.1145/3672919.3673016},
ISBN = {979-8-4007-1821-2},
Keywords = {charge prediction; interpretability; representation learning of legal
   documents; text matching},
Research-Areas = {Computer Science},
Web-of-Science-Categories  = {Computer Science, Artificial Intelligence; Computer Science,
   Interdisciplinary Applications},
Author-Email = {adz6199@gsupl.edu.cn
   296124276@qq.com},
Affiliations = {Gansu University of Political Science \& Law},
Cited-References = {DEMPSTER AP, 1977, J ROY STAT SOC B MET, V39, P1, DOI 10.1111/j.2517-6161.1977.tb01600.x.
