Year = {2017},
Pages = {143-150},
Note = {IEEE International Conference on Big Data and Smart Computing (BigComp),
   Jeju, SOUTH KOREA, FEB 13-16, 2017},
Organization = {IEEE},
Abstract = {Due to the rapid increase of the Internet traffic encryption HTTPS, and
   the newly adopted protocols HTTP2 and SPDY, the need for a comprehensive
   high-level information extraction tool that supports the new protocols
   becomes essential for critical applications such as digital and network
   forensic and web penetration testing. In spite of the availability of
   big data from the Internet traffic, current network data mining tools do
   not support encrypted network traffic and the new protocols. This paper
   proposes a new tool for extracting high-level information such as
   visited links, user credentials and session cookies from HTTP and HTTPS
   protocols. It also allows extraction of user credentials and session
   cookies from HTTP2 and SPDY.},
