Title = {Data Science tools for Crime Investigation, Archival, and Analysis},
Booktitle = {2019 IEEE SMARTWORLD, UBIQUITOUS INTELLIGENCE \& COMPUTING, ADVANCED \&
   TRUSTED COMPUTING, SCALABLE COMPUTING \& COMMUNICATIONS, CLOUD \& BIG
   DATA COMPUTING, INTERNET OF PEOPLE AND SMART CITY INNOVATION
   (SMARTWORLD/SCALCOM/UIC/ATC/CBDCOM/IOP/SCI 2019)},
Year = {2019},
