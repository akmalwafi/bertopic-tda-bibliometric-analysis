@inproceedings{ WOS:000928814300107,
Author = {de Juan Fidalgo, Pablo and Camara, Carmen and Peris-Lopez, Pedro},
Editor = {Bravo, J and Ochoa, S and Favela, J},
Title = {Generation and Classification of Illicit Bitcoin Transactions},
Booktitle = {PROCEEDINGS OF THE INTERNATIONAL CONFERENCE ON UBIQUITOUS COMPUTING \&
   AMBIENT INTELLIGENCE (UCAMI 2022)},
