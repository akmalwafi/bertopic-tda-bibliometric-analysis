@inproceedings{ WOS:000714943300008,
Author = {Bhalerao, Rasika and Aliapoulios, Maxwell and Shumailov, Ilia and Afroz,
   Sadia and McCoy, Damon},
Book-Group-Author = {IEEE},
Title = {Mapping the Underground: Supervised Discovery of Cybercrime Supply
