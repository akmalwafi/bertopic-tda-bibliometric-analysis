@inproceedings{ WOS:000461315900179,
Author = {Petrik, Rachel and Arik, Berat and Smith, Jared M.},
Book-Group-Author = {ACM},
Title = {Towards Architecture and OS-Independent Malware Detection via Memory
   Forensics},
Booktitle = {PROCEEDINGS OF THE 2018 ACM SIGSAC CONFERENCE ON COMPUTER AND
   COMMUNICATIONS SECURITY (CCS'18)},
Year = {2018},
Pages = {2267-2269},
Note = {ACM SIGSAC Conference on Computer and Communications Security (CCS),
   Toronto, CANADA, OCT 15-19, 2018},
Organization = {Assoc Comp Machinery; ACM SIGSAC; NSF; ANT Financil; Baidu; Cisco;
   Samsung Res; BlackBerry; Facebook; IBM Res; Ledger; SAP; Visa Res},
Abstract = {In this work, we take a fundamentally different approach to the problem
   of analyzing a device for compromises via malware; our approach is OS
   and instruction architecture independent and relies only on having the
   raw binary data extracted from the memory dump of a device. Our system
   leverages a multi-hundred TB dataset of both compromised host memory
   dumps extracted from the Mal-Rec dataset {[}8] and the first known
   dataset of benign host memory dumps running normal, non-compromised
   software. After an average of 30 to 45 seconds of pre-processing on a
   single memory dump, our system leverages both traditional machine
   learning and deep learning algorithms to achieve an average of 98\%
   accuracy of detecting a compromised host.},
