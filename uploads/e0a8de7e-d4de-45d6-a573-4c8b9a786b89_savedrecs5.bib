@inproceedings{ WOS:000790983300029,
Author = {Ma, Zeyu},
Book-Group-Author = {IEEE},
Title = {AI Feasibility Study on Case Detection},
Booktitle = {2021 2ND INTERNATIONAL CONFERENCE ON COMPUTER ENGINEERING AND
   INTELLIGENT CONTROL (ICCEIC 2021)},
Year = {2021},
Pages = {143-148},
Note = {2nd International Conference on Computer Engineering and Intelligent
   Control (ICCEIC), ELECTR NETWORK, NOV 12-14, 2021},
Abstract = {In the current academic field, there are few researches on the
   connection between artificial intelligence (AI) and case detection, so
   it needs to find a new direction to make a breakthrough. Existing
   research mainly focuses on the integration of related technologies into
   public security applications, such as identity recognition technology in
   access control systems and image recognition technology for identity
   inspection in the railway station. However, in the deeper field of
   public security, such as criminal investigation, there is no trend to
   popularize the technology. This paper will focus on the principles of
   available AI technology, the problems in the detection of existing
   cases, how to integrate AI technology into the traditional model, and
   the possible hidden dangers in the future. The conclusion is that people
   can apply the existing artificial intelligence technologies such as
   voiceprint recognition and image recognition to criminal investigation},
