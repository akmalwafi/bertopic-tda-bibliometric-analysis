@inproceedings{ WOS:000783390600004,
Author = {Florentino, Erick S. and Goldschmidt, Ronaldo R. and Cavalcanti, Maria
   C.},
Editor = {Filipe, J and Smialek, M and Brodsky, A and Hammoudi, S},
Title = {Identifying Suspects on Social Networks: An Approach based on
   Non-structured and Non-labeled Data},
Booktitle = {PROCEEDINGS OF THE 23RD INTERNATIONAL CONFERENCE ON ENTERPRISE
   INFORMATION SYSTEMS (ICEIS 2021), VOL 1},
Year = {2021},
Pages = {51-62},
Note = {23rd International Conference on Enterprise Information Systems (ICEIS),
   ELECTR NETWORK, APR 26-28, 2021},
Organization = {INSTICC},
Abstract = {The identification of suspects of committing virtual crimes (e.g.,
   pedophilia, terrorism, bullying, among others) has become one of the
   tasks of high relevance when it comes to social network analysis. Most
   of the time, analysis methods use the supervised machine learning (SML)
   approach, which requires a previously labeled set of data, i.e., having
   identified in the network, the users who are and who are not suspects.
   From such a labeled network data, some SML algorithm generates a model
   capable of identifying new suspects. However, in practice, when
   analyzing a social network, one does not know previously who the
   suspects are (i.e., labeled data are rare and difficult to obtain in
   this context). Furthermore, social networks have a very dynamic nature,
   varying significantly, which demands the model to be frequently updated
   with recent data. Thus, this work presents a method for identifying
   suspects based on messages and a controlled vocabulary composed of
   suspicious terms and their categories, according to a given domain.
   Different from the SML algorithms, the proposed method does not demand
   labeled data. Instead, it analyzes the messages exchanged on a given
   social network, and scores people according to the occurrence of the
   vocabulary terms. It is worth to highlight the endurance aspect of the
   proposed method since a controlled vocabulary is quite stable and
   evolves slowly. Moreover, the method was implemented for Portuguese
   texts and was applied to the ``PAN-2012-BR{''} data set, showing some
   promising results in the pedophilia domain.},
Publisher = {SCITEPRESS},
Address = {AV D MANUELL, 27A 2 ESQ, SETUBAL, 2910-595, PORTUGAL},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Florentino, ÉS (Corresponding Author), Mil Inst Engn IME, Def Engn Dept, Praca Gen Tiburcio 80, Rio De Janeiro, Brazil.
   Florentino, Erick S., Mil Inst Engn IME, Def Engn Dept, Praca Gen Tiburcio 80, Rio De Janeiro, Brazil.
   Mil Inst Engn IME, Comp Engn Dept, Praca Gen Tiburcio 80, Rio De Janeiro, Brazil.},
DOI = {10.5220/0010440300510062},
