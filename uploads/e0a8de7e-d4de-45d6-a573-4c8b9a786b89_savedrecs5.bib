Pages = {399-404},
Note = {14th IEEE International Conference on BioInformatics and BioEngineering
   (BIBE), Boca Raton, FL, NOV 10-12, 2014},
Organization = {IEEE; IEEE Comp Soc; Biol and Artificial Intelligence Soc; Florida
   Atlantic Univ; ABI Fdn; Modernizing Med; LexisNexis},
Abstract = {Natural language processing is a field of computer science, which
   focuses on interactions between computers and human (natural) languages.
   The human languages are ambiguous unlike Computer languages, which make
   its analysis and processing difficult. Most of the data present these
   days is in unstructured form (such as: Accident reports, Patient
   discharge summary, Criminal records etc), which makes it hard for
   computers to understand for further use and analysis. This unstructured
   text needs to be converted into structured form by clearly defining the
   sentence boundaries, word boundaries and context dependent character
   boundaries for further analysis. This paper proposes a component-based
   domain-independent text analysis system for processing of the natural
   language known as Domain-independent Natural Language Processing System
   (DINLP). Further the paper discusses the system capability and its
   application in the area of bioinformatics through the case study},
