Title = {A NEEDLE IN A HAYSTACK? HARNESSING ONOMATOPOEIA AND USER-SPECIFIC
   STYLOMETRICS FOR AUTHORSHIP ATTRIBUTION OF MICRO-MESSAGES},
Booktitle = {2019 IEEE INTERNATIONAL CONFERENCE ON ACOUSTICS, SPEECH AND SIGNAL
   PROCESSING (ICASSP)},
