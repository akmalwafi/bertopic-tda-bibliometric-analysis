@inproceedings{ WOS:001046699200025,
Author = {Romanosky, Sasha and Schirmer, Peter},
Book-Group-Author = {IEEE},
Title = {Mapping the Cyberstalking Landscape: An Empirical Analysis of Federal US
   Crimes},
Booktitle = {2023 IEEE EUROPEAN SYMPOSIUM ON SECURITY AND PRIVACY WORKSHOPS,
   EUROS\&PW},
Series = {IEEE European Symposium on Security and Privacy Workshops},
Year = {2023},
