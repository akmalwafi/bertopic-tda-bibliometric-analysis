@article{ WOS:001506683000017,
Author = {Zhang, Xiangqun and Han, Ruize and Wang, Likai and Song, Linqi and Hou,
   Junhui and Feng, Wei},
Title = {Synthetic-to-Real Video Person Re-ID},
