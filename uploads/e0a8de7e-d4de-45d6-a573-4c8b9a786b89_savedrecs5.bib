@inproceedings{ WOS:001480992500003,
Author = {Capozzi, Arthur and Vilella, Salvatore and Moncalvo, Dario and
   Fornasiero, Marco and Ricci, Valeria and Ronchiadin, Silvia and Ruffo,
   Giancarlo},
Editor = {Cherifi, H and Donduran, M and Rocha, LM and Cherifi, C and Varol, O},
Title = {FlowSeries: Anomaly Detection in Financial Transaction Flows},
Booktitle = {COMPLEX NETWORKS \& THEIR APPLICATIONS XIII, COMPLEX NETWORKS 2024-VOL 3},
Series = {Studies in Computational Intelligence},
Year = {2025},
Volume = {1189},
