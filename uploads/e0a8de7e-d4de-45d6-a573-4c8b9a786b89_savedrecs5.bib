   Larson, Jamie, Los Angeles City Attorneys Off, Recidivism Reduct \& Drug Divers Unit R2D2, Los Angeles, CA USA.
   Ghani, Rayid, Carnegie Mellon Univ, Heinz Coll Informat Syst \& Publ Policy, Pittsburgh, PA 15213 USA.},
DOI = {10.1145/3351095.3372863},
