   Yong},
Editor = {Abramson, D and Lees, M and Krzhizhanovskaya, VV and Dongarra, J and Sloot, PMA},
Title = {RETRACTED: A Clustering-based Link Prediction Method in Social Networks
   (Retracted Article)},
Booktitle = {2014 INTERNATIONAL CONFERENCE ON COMPUTATIONAL SCIENCE},
Series = {Procedia Computer Science},
Year = {2014},
Volume = {29},
