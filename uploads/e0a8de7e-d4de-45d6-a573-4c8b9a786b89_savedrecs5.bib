@inproceedings{ WOS:000866386000054,
Author = {Adesina, Ademola Olusola and Ajagbe, Sunday Adeola and Afolabi, Olakunle
   Sunday and Adeniji, Oluwashola David and Ajimobi, Olalekan Ibrahim},
Editor = {Ranganathan, G and Bestak, R and Fernando, X},
Title = {Investigating Data Mining Trend in Cybercrime Among Youths},
Booktitle = {PERVASIVE COMPUTING AND SOCIAL NETWORKING, ICPCSN 2022},
Series = {Lecture Notes in Networks and Systems},
Year = {2023},
Volume = {475},
Pages = {725-741},
Note = {2nd International Conference on Pervasive Computing and Social
   Networking (ICPCSN), Narasus Sarathy Inst Technol, Salem, INDIA, MAR
   03-04, 2022},
Abstract = {This study investigated the emerging trend in cyber dynamics among
   youths using statistical tools. The study adopted a descriptive survey
   design. The population of the study comprised all cybercriminals in
   police custody in Ibadan, Nigeria. A simple random sampling procedure
   was used to select four hundred and eighteen participants for the study.
   The results of the analysis revealed that there was a significant and
   positive relationship between social influence and the prevalence of
   cybercrime among youth in the study area, there was a significant and
   positive relationship between economic influence and prevalence of
   cybercrime among youth in Africa, there was a significant and negative
   relationship between political influence and prevalence of cybercrime
   among youth in Africa and there was a significant and negative
   relationship between religious influence and prevalence of cybercrime
   among youth in Africa. Based on the findings of the study, the
   conclusion was reached that data mining and machine learning have a
   direct pattern on the prevalence of cybercrime and associated factors.
   The recommendation was made that authority in charge of cybercrime
   should ensure that data are available in the database for easy
   accessibility and quality conclusion on the causes of the prevalence of
   cybercrime among Nigeria youth.},
