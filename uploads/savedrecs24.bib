@article{ WOS:000837494600003,
Author = {Schmidt, Alexander F. and Niehaus, Susanna},
Title = {Outpatient Therapists' Perspectives on Working With Persons Who Are
   Sexually Interested in Minors},
Journal = {ARCHIVES OF SEXUAL BEHAVIOR},
Year = {2022},
