@article{ WOS:000591191100004,
Author = {Liu, Yanhua and Liang, Xue and Liu, Jinyue},
Title = {Molecular Phylogeography of China Roe Deer Population Based on MtDNA
   D-Loop Gene},
Journal = {INTERNATIONAL JOURNAL OF AGRICULTURE AND BIOLOGY},
Year = {2020},
Volume = {24},
Number = {4},
Pages = {671-675},
Abstract = {There are different opinions on the phylogeographical pattern of roe
   deer in the world. This study studied some sequence of the mitochondrial
   DNA (mtDNA) control region (420 bp) of 12 wild roe deer from the Greater
   Khingan Mountains, China, compared them with 39 Genebank downloaded
   mtDNA control region sequences around the world, and analyzed the
   phylogeographic status of roe deer. The phylogenetic tree and haplotype
   network analysis results showed that the roe deer were divided into two
   subspecies, European roe deer and Siberian roe deer. The geographical
   distribution of the European roe deer included Austria, France, Crimea,
   Hungary, Lithuania, Romania, Italy and Spain. Among them, the Glade A
   and B were sister branches of Glade C in parallel. The Siberian roe deer
   were geographical distributed in Russia, South Korea, China, Mongolia,
   Poland. The Glade D and E were parallel sister branches. The results of
   this study indicated that the Spanish and Italian roe deer were
   different from the haplotypes of the other European roe deer because of
   the geographic isolation. While the roe deer from Poland and those from
   western Russia and Mongolia were clustered into one branch. It is
   speculated that this might due to introgression of an ancient gene by
   highly differentiated lineages during species expansion, and population
   spread in the ice age may be one of the important reasons for the
   existing distribution pattern. (C) 2020 Friends Science Publishers},
