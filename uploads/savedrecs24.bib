@article{ WOS:000721780500004,
Author = {Bronchain, Jonathan and Raynal, Patrick and Chabrol, Henri},
Title = {Does Sex Influence the Network Structure of Psychopathy?},
Journal = {PERSONALITY DISORDERS-THEORY RESEARCH AND TREATMENT},
Year = {2021},
Volume = {12},
Number = {5},
Pages = {421-427},
Month = {SEP},
Abstract = {Sex-specific manifestations of psychopathy remain highly debated both at
   the dimensional and structural levels. The network theory provides a
   promising framework for investigating this question. Thus, our study
   aimed to explore the network structure of psychopathy across sex.
   Participants were 1,990 college students (male: 43\%, female: 57\%) who
   received the Elemental Psychopathy Assessment-Short Form. We first
   estimated a Gaussian Graphical Model including the 18 Elemental
   Psychopathy Assessment-Short Form facets, separately for men and women.
   We then computed centrality indices (i.e., strength and expected
   influence) and predictability and finally conducted a bootstrapping
   procedure to assess the accuracy of edge weights and the stability of
   the centrality indices. The results of the network comparison test
   provide support for the stability of the network structure of
   psychopathic traits across sex. Self-Centeredness was the most central
   trait in the two networks, followed by Unconcern, Rashness, and Anger
   for women and by Callousness, Unconcern, and Rashness for men. Minor sex
   differences and future directions are discussed.},
Publisher = {EDUCATIONAL PUBLISHING FOUNDATION-AMERICAN PSYCHOLOGICAL ASSOC},
