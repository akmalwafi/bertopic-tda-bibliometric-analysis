@inproceedings{ WOS:001004145900052,
Author = {Huillcen Baca, Herwin Alayn and Palomino Valdivia, Flor de Luz and Soria
   Solis, Ivan and Aquino Cruz, Mario and Gutierrez Caceres, Juan Carlos},
Editor = {Arai, K},
Title = {Human Violence Recognition in Video Surveillance in Real-Time},
