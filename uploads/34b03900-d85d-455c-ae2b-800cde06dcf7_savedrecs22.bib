@article{ WOS:001524319500001,
Author = {Khairwa, Anshul and Thangavelu, Arunkumar},
Title = {Trajectory Smoothing and Transition Prediction-Based Person
   Identification and Tracking in Surveillance Video Using MFBFDP},
Journal = {IETE JOURNAL OF RESEARCH},
Year = {2025},
Month = {2025 JUL 5},
Abstract = {In surveillance video, person identification and tracking have several
   purposes, including security monitoring and crime investigation.
   However, the existing works neglected the dynamic behavioral aspects,
   such as momentum, prior direction, and goal-oriented behavior. To
   address this, a Markov Fourier Basis Function Decision Process
   (MFBFDP)-based transition prediction is proposed in this paper. The
   process begins by converting the Closed-Circuit Television (CCTV) video
   into frames, followed by pre-processing steps, including noise removal
   and contrast enhancement. Then, illumination is normalized using the
   Parabolic Partial Differential Equation-based Retinex Algorithm
   (2PDE-RA) and color consistency is standardized. Next, the person
   detection is achieved using the Non-Local Attention-based You Only Look
   Once (NLA-YOLO) algorithm, while the pose is estimated using the
   3-Dimensional Region of Interest-based Pose Estimation (3DROI-PE). Then,
   the MFBFDP model predicts a smooth and realistic transition for the
   person. Further, by utilizing Deep State Transition Matrix Simple Online
   Real-time Tracking (DeepSTM-SORT), the tracking continuity is done.
   Finally, the features are extracted and anomalies are detected using
   Jenson Quantum Relative Swish Leaky Rectified Linear Unit-based Deep
   Convolutional Neural Network (JQR-SwLReLU-DCNN). The experimental
   outcome shows a detection rate of 98.99\% and a trajectory precision of
   99.27\%, showing the proposed system's robustness in real-time
   surveillance analysis.},
Publisher = {TAYLOR \& FRANCIS LTD},
Address = {2-4 PARK SQUARE, MILTON PARK, ABINGDON OR14 4RN, OXON, ENGLAND},
Type = {Article; Early Access},
Language = {English},
Affiliation = {Thangavelu, A (Corresponding Author), Vellore Inst Technol, Sch Comp Sci \& Engn, Vellore, India.
   Khairwa, Anshul; Thangavelu, Arunkumar, Vellore Inst Technol, Sch Comp Sci \& Engn, Vellore, India.},
DOI = {10.1080/03772063.2025.2523422},
EarlyAccessDate = {JUL 2025},
ISSN = {0377-2063},
EISSN = {0974-780X},
Keywords = {Deep learning in CCTV surveillance; Pose estimation; Real-time person
   tracking; Surveillance video analysis; Suspicious behavior anomaly
   detection; Trajectory smoothing; Transition prediction},
Research-Areas = {Engineering; Telecommunications},
Web-of-Science-Categories  = {Engineering, Electrical \& Electronic; Telecommunications},
Author-Email = {anshul.ahm@gmail.com
