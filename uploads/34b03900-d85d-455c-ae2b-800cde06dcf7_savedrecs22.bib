@article{ WOS:000716900600010,
Author = {Bevilacqua, Solon and Neira Villena, John Edward},
Title = {Administrative Corruption and Terrorism: A Considerable Distancing
   between Interests and Publications},
Journal = {GESTION Y POLITICA PUBLICA},
Year = {2021},
Volume = {30},
Number = {3},
Pages = {267-293},
Abstract = {Research investigating administrative corruption (AC) has changed
   significantly in the last twenty years, but the existing interests are
   still far from being met. From the duster analysis for 253 published
   articles (double review) were shown opportunities and gaps in the work
   of science that investigates the AC in the world. From a content
   analysis and correspondence analysis, it was found that extreme
   violence, such as terrorism and drug trafficking, are not discussed in
   AC research agenda; ``crime and punishment{''} form a historical link in
