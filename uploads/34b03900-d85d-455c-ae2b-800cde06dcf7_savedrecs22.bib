@article{ WOS:000360315900031,
Author = {Navega, David and Coelho, Catarina and Vicente, Ricardo and Ferreira,
   Maria Teresa and Wasterlain, Sofia and Cunha, Eugenia},
Title = {AncesTrees: ancestry estimation with randomized decision trees},
Journal = {INTERNATIONAL JOURNAL OF LEGAL MEDICINE},
