@inproceedings{ WOS:001465963900013,
Author = {Igarashi, Taichi and Matsuura, Kanta},
Editor = {Budurushi, J and Kulyk, O and Allen, S and Diamandis, T and Klages-Mundt, A and Bracciali, A and Goodell, G and Matsuo, S},
Title = {Scam Token Detection Based on Static Analysis Before Contract Deployment},
Booktitle = {FINANCIAL CRYPTOGRAPHY AND DATA SECURITY. FC 2024 INTERNATIONAL
   WORKSHOPS},
Series = {Lecture Notes in Computer Science},
Year = {2025},
Volume = {14746},
