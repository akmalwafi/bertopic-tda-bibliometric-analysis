   Stefano},
Book-Group-Author = {ACM},
Title = {Crime Knowledge Extraction: an Ontology-driven Approach for Detecting
   Abstract Terms in Case Law Decisions},
Booktitle = {PROCEEDINGS OF THE SEVENTEENTH INTERNATIONAL CONFERENCE ON ARTIFICIAL
   INTELLIGENCE AND LAW, ICAIL 2019},
Year = {2019},
