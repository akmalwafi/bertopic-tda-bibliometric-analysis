@inproceedings{ WOS:000411700600022,
Author = {Sakpere, Aderonke Busayo and Kayem, Anne V. D. M.},
Editor = {Camp, O and Weippl, E and Bidan, C and Aimeur, E},
Title = {Adaptive Buffer Resizing for Efficient Anonymization of Streaming Data
   with Minimal Information Loss},
Booktitle = {2015 INTERNATIONAL CONFERENCE ON INFORMATION SYSTEMS SECURITY AND
   PRIVACY (ICISSP)},
Year = {2015},
Pages = {191-201},
Note = {1st International Conference on Information Systems Security and Privacy
   (ICISSP), Angers, FRANCE, FEB 09-11, 2015},
Organization = {Inst Syst \& Technologies Informat, Control \& Commun; ESEO; ACM Special
   Interest Grp Management Informat Syst; IEEE Comp Soc; eema},
Abstract = {Mobile crime reporting systems have emerged as an effective and
   efficient approach to crime data collection in developing countries. The
   collection of this data has raised the need to analyse or mine the data
   to deduce patterns that are helpful in addressing crime. Since data
   analytic expertises are limited in developing nations, outsourcing the
   data to a third-party service provider is a cost effective management
   strategy. However, crime data is inherently privacy sensitive and must
   be protected from ``honest-but-curious{''}service providers. In order to
   speed up real time analysis of the data, streaming data can be used
   instead of static data. Streaming data anonymity schemes based on
   k-anonymity offer fast privacy preservation and query processing but are
   reliant on buffering schemes that incur high information loss rates on
   intermittent data streams. In this paper, we propose a scheme for
   adjusting the size of the buffer based on data arrival rates and use
   k-anonymity to enforce data privacy. Furthermore, in order to handle
   buffered records that are unanonymizable, we use a heuristic that works
   by either delaying the unanonymized record(s) to the next buffering
   cycle or incorporating the record(s) into a cluster of anonymized
   records with similar privacy constraints. The advantage of this approach
   to streaming-data anonymization is two-fold. First, we ensure privacy of
   the data through k-anonymization, and second, we ensure minimal
   information loss from the unanonymized records thereby, offering the
   opportunity for high query result accuracy on the anonymized data.
   Results from our prototype implementation demonstrate that our proposed
   scheme enhances privacy for data analytics. With varied data privacy
   requirement levels, we incur an average information loss in delay of
   1.95\% compared to other solutions that average a loss of 12.7\%.},
