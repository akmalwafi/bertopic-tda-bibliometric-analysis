Title = {A Novel Survival Analysis-Based Approach for Predicting Behavioral
   Probability of Default},
Booktitle = {PATTERN RECOGNITION, MCPR 2022},
Series = {Lecture Notes in Computer Science},
Year = {2022},
Volume = {13264},
