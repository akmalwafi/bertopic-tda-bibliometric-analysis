Pages = {1040-1046},
Note = {Future Technologies Conference (FTC), San Francisco, CA, DEC 06-07, 2016},
Organization = {HPCC Syst; IEEE; IEEE Power \& Energy Soc; IBM Res; IBM Watson AI
   XPRIZE; Brown Univ; IEEE San Francisco PES Chapter; Univ Michigan},
Abstract = {Intelligent automation in accurate targeting is always a challenge in
   cybersecurity. Accurate attribution in digital forensic investigation is
   one of the good examples. How can the most relevant route be identified
   and selected within the first attempt or the first few attempts in
   investigative search without human intervention? What shortcuts can be
   utilized? How effective are these shortcuts? These are the questions
   that this paper intends to explore as the current automated approaches
   are neither sufficient nor intelligent. Resorting to the Contextual
   Binding Conditions, this paper shows that structural relationship, which
   supports automation, can be utilized in providing intelligence not only
   in capturing current status but also in offering intelligent hints or
   guidance in getting closer to the correct target in order to find out
   truth.},
