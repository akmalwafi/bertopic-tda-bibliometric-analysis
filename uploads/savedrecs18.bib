@article{ WOS:000733313600001,
Author = {Barnett-Ryan, Cynthia},
Title = {Crime and place: differences in spatial relationship between calls for
   service and recorded incidents for municipal and campus law enforcement},
Journal = {POLICE PRACTICE AND RESEARCH},
Year = {2022},
Volume = {23},
Number = {4, SI},
Pages = {414-428},
Month = {JUL 4},
Abstract = {With the advent of more law enforcement open data, researchers are
   exploring the use of calls for service (CFS) as a proxy for recorded
   incident information by law enforcement. However, indications are that
   law enforcement activities are mediated by the agency's goals with its
   data. Using data from two different types of law enforcement agencies
   within the same community, CFS and incident reports for property crimes
   were tested for spatial association using the co-location quotient.
   Findings from this study show there is a modest amount of detectable
   clustering of CFS for the municipal law enforcement agency. However, the
   large university campus agency did not show any detectable spatial
   association for these events. This suggests that the movement towards
   using open data in research will need to take greater care in the
   selection of data to understand if assumptions about the data can be
   supported.},
Publisher = {ROUTLEDGE JOURNALS, TAYLOR \& FRANCIS LTD},
