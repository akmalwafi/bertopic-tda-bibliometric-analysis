@inproceedings{ WOS:000533584000022,
Author = {Khalid, Sobia and Khan, Shoab A.},
Book-Group-Author = {IEEE},
Title = {A Framework for Mapping Crime Data on Sociological Hypothesis},
Booktitle = {2019 IEEE 16TH INTERNATIONAL CONFERENCE ON SMART CITIES: IMPROVING
   QUALITY OF LIFE USING ICT, IOT AND AI (IEEE HONET-ICT 2019)},
Year = {2019},
Pages = {135-139},
Note = {IEEE 16th International Conference on Smart Cities - Improving Quality
   of Life Using ICT and IoT and AI (HONET-ICT), UNC Charlotte, Charlotte,
   NC, OCT 06-09, 2019},
Organization = {IEEE; IEEE USA; NUST; IEEE Charlotte Sect},
Abstract = {Data is increasing every second now a days. Interesting facts about the
   societies can be extracted by converting the data into useful
   information as user generated content helps to reveal the audience's
   perception on different social aspects. Crime is a serious concern all
   over the world because it affects humans and also the environment
   surrounding them. Social criminal theories help to identify different
   aspects of humans that cause the person to commit crime. There is a need
   to identify the hidden patterns and also the relationship between the
   data and social theories. In this paper, a framework is proposed that
   maps the crime data on established social criminal theories. A total of
   100 cases have been mapped to check the correctness of the solution.
   This solution can have great impact on the society to counter the
   problems of increasing crime and understand the reasons of crime, and
   also help to take the remedial actions. In this paper, we have
   considered only social criminal theories, in future we will extend this
   research by elaborating more criminal theories.},
Publisher = {IEEE},
Address = {345 E 47TH ST, NEW YORK, NY 10017 USA},
