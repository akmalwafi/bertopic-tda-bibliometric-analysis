@article{ WOS:001531530500001,
Author = {Ghanizadeh, Ali Reza and Firouzranjbar, Shadi and Amlashi, Amir Tavana
   and Eid, Eslam and Dessouky, Samer},
Title = {Novel integration of forensic-based investigation optimization algorithm
   and ensemble learning for estimating hydraulic conductivity of
   coarse-grained road materials},
Journal = {TRANSPORTATION GEOTECHNICS},
Year = {2025},
Volume = {54},
Month = {SEP},
Abstract = {The accurate estimation of hydraulic conductivity (k) in coarse-grained
   materials is paramount for effective hydrological and geotechnical
   engineering applications. This study presents an innovative integration
   of a forensic-based investigation optimization (FBIO) algorithm with
   ensemble learning (EL) techniques to predict k values. The comprehensive
   dataset integrates findings from 37 distinct studies, encompassing a
   wide range of soil characteristics and behaviors, providing a robust
   basis for model development. Various EL models were compared, including
   Random Forest (RF); eXtreme Gradient Boosting (XGBoost); Light Gradient
   Boosting Machine (LightGBM); Gradient Boosting Regression Trees (GBRT);
   and Adaptive Boosting (AdaBoost). These were also evaluated against
   conventional machine learning (ML) methods such as Artificial Neural
   Networks (ANN), Support Vector Machines (SVM), and Gaussian Process
   Regression (GPR). Among the ML models evaluated, the GBRT-FBIO model
   emerged as the most accurate one, effectively handling large and complex
   datasets. The integration of FBIO further optimizes the meta-parameters
   of these models, reducing the computational complexity and manual effort
   required for model tuning. The results of sensitivity analysis, aligning
   with findings from other studies indicating an increase in hydraulic
   conductivity with larger grain sizes, enhances the credibility and
   interpretability of the SHAP analysis in this research. The best
   performing model is then utilized to compare with traditional empirical
   models. Our findings demonstrate that the GBRT-FBIO model significantly
   outperforms these models, as evidenced by superior performance metrics:
   R-value of 0.99, RMSE of 0.073 mm/s, MAE of 0.020 mm/s, and MAPE of
   10.72 \%. This study marks a significant advancement in the field,
   providing a strong and accurate computational technique for estimating
   hydraulic conductivity in diverse coarse-grained soils.},
