@article{ WOS:000500933800001,
Author = {Caianiello, Michele},
Title = {Criminal Process faced with the Challenges of Scientific and
   Technological Development},
Journal = {EUROPEAN JOURNAL OF CRIME CRIMINAL LAW AND CRIMINAL JUSTICE},
