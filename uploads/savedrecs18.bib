@inproceedings{ WOS:000760875500018,
Author = {Philip, Abin Oommen and Saravanaguru, Ra K.},
Book-Group-Author = {IEEE},
Title = {Blockchain based Framework for Investigating Pedestrian and Cyclist Hit
   and Run Cases in the Internet of Vehicles Era},
Booktitle = {PROCEEDINGS OF THE 2021 FIFTH INTERNATIONAL CONFERENCE ON I-SMAC (IOT IN
   SOCIAL, MOBILE, ANALYTICS AND CLOUD) (I-SMAC 2021)},
Year = {2021},
Pages = {110-118},
Note = {5th International Conference on IoT in Social, Mobile, Analytics and
   Cloud (I-SMAC), ELECTR NETWORK, NOV 11-13, 2021},
Organization = {IEEE; SCAD Inst Technol},
Abstract = {Vehicles will become connected via Internet of vehicles as part of
   Intelligent transportation systems in future. The road users like
   pedestrians and cyclist can become part of the connected environment
   using mobile applications. A conceptual framework involving the
   Convergence of emerging technologies like machine learning, blockchain,
   mobile application, Internet of vehicles and Edge computing is
   presented. The work studies how these existing individual technologies
   can converge together to incorporate safety and evidence management in
   the context of pedestrian hit and run cases. Blockchain is used as a
   secure, distributed and immutable forensic log to manage evidence
   related to the incident by various stakeholders for investigation and
   settlements. Smart contract specific to storage and access of evidence
   related to hit and run case is designed and evaluated.},
