Booktitle = {2023 36TH CONFERENCE ON GRAPHICS, PATTERNS AND IMAGES, SIBGRAPI 2023},
Series = {SIBGRAPI - Brazilian Symposium on Computer Graphics and Image Processing},
Year = {2023},
Pages = {205-210},
Note = {36th SIBGRAPI Conference on Graphics, Patterns and Images (SIBGRAPI),
   Fed Univ Rio Grande, Rio Grande, BRAZIL, NOV 06-09, 2023},
Organization = {Univ Fed Rio Grande, Ctr Computat Sci; Brazilian Comp Soc; IEEE Robot \&
   Automat Soc, IEEE S Brazil Chapter; Coordinat Improvement Higher Educ
   Personnel; Fundacao Amparo Pesquisa Estado Rio Grande Sul; Off Naval Res
   Sci \& Technol Global},
Abstract = {Forensic dentistry has traditionally relied on bone or dental
   indicators, primarily utilizing dental radiographs, for age estimation.
   However, limited research has been conducted on automatic age estimation
   on panoramic images, needing a reevaluation of the existing
   methodologies to assess the performance of computer-based methods. This
   study proposes to revisit the analysis of age estimation methods using
   panoramic dental radiographs. We have curated the largest publicly
   available dataset of panoramic dental images, encompassing diverse
   dental conditions and age ranges. Specifically, our study focuses on
   evaluating three distinct classes of deep-learning architectures: ViT,
   ConvNeXt-V2, and EfficientNets, employing a comprehensive to assess
   their performances that better favor reproducibility. By comparing our
   approach with existing studies in the literature, we offer valuable
   insights for forensic investigations in the field of age estimation.},
