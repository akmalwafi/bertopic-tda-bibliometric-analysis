@article{ WOS:A1991GW01000003,
Author = {SPARROW, MK},
Title = {THE APPLICATION OF NETWORK ANALYSIS TO CRIMINAL INTELLIGENCE - AN
   ASSESSMENT OF THE PROSPECTS},
