@inproceedings{ WOS:000634530900004,
Author = {Michelassi, Vittorio},
Editor = {Hoarau, Y and Peng, SH and Schwamborn, D and Revell, A and Mockett, C},
Title = {Turbomachinery Research and Design: The Role of DNS and LES in Industry},
Booktitle = {PROGRESS IN HYBRID RANS-LES MODELLING},
