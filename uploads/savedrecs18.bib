@inproceedings{ WOS:000521353902158,
Author = {Ringenberg, Tatiana R. and Misra, Kanishka and Rayz, Julia Taylor},
Book-Group-Author = {IEEE},
Title = {Not So Cute but Fuzzy: Estimating Risk of Sexual Predation in Online
   Conversations},
Booktitle = {2019 IEEE INTERNATIONAL CONFERENCE ON SYSTEMS, MAN AND CYBERNETICS (SMC)},
Series = {IEEE International Conference on Systems Man and Cybernetics Conference
   Proceedings},
Year = {2019},
Pages = {2946-2951},
Note = {IEEE International Conference on Systems, Man and Cybernetics (SMC),
   Bari, ITALY, OCT 06-09, 2019},
Organization = {IEEE},
Abstract = {The sexual exploitation of minors is a known and persistent problem for
   law enforcement. Assistance in prioritizing cases of sexual exploitation
   of potentially risky conversations is crucial. While attempts to
   automatically triage conversations for the risk of sexual exploitation
   of minors have been attempted in the past, most computational models use
   features which are not representative of the grooming process that is
   used by investigators. Accurately annotating an offender corpus for use
   with machine learning algorithms is difficult because the stages of the
   grooming process feed into one another and are non-linear. In this paper
   we propose a method for labeling risk, tied to stages and themes of the
   grooming process, using fuzzy sets. We develop a neural network model
   that uses these fuzzy membership functions of each line in a chat as
   input and predict the risk of interaction.},
