@inproceedings{ WOS:000848737000025,
Author = {Poursafaei, Farimah and Hamad, Ghaith Bany and Zilic, Zeljko},
Book-Group-Author = {IEEE},
Title = {Detecting Malicious Ethereum Entities via Application of Machine
   Learning Classification},
Booktitle = {2020 2ND CONFERENCE ON BLOCKCHAIN RESEARCH \& APPLICATIONS FOR
   INNOVATIVE NETWORKS AND SERVICES (BRAINS)},
Year = {2020},
Pages = {120-127},
Note = {2nd Conference on Blockchain Research and Applications for Innovative
   Networks and Services (BRAINS), ELECTR NETWORK, SEP 28-30, 2020},
Abstract = {Malicious activities such as scams and frauds have imposed high costs
   for financial systems. The advent of blockchain-based cryptocurrencies
   such as Ethereum provides unprecedented characteristics. On one hand,
   the pseudonymity of the blockchain allows criminals to hide their actual
   identities, which is an appealing feature for conducting malicious
   activities. On the other hand, the public data of blockchain sets forth
   the opportunity for comprehensive forensic analysis. In this paper, we
   present a novel framework to identify malicious entities in the Ethereum
   blockchain network. The proposed framework composes of an efficient
   method for extracting a set of features from the Ethereum blockchain
   data to represent transactional behavior of entities. Our proposed
   solutions for detecting malicious entities employ variations of Logistic
   Regression, Support Vector Machine, Random Forest, and other ensemble
   methods such as Stacking and AdaBoost Classifier. The ensemble methods
   show high performance with F-1 score of 0.996 in average. The results
   also imply that the proposed method of feature extraction is fairly
   efficient in presenting the network characteristics.},
Publisher = {IEEE},
Address = {345 E 47TH ST, NEW YORK, NY 10017 USA},
