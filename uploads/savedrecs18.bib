Author = {Zheng, Wenwen and Xie, Li},
Title = {Global existence and asymptotic behavior of solutions to an urban crime
   model with competition},
Journal = {JOURNAL OF MATHEMATICAL ANALYSIS AND APPLICATIONS},
Year = {2026},
Volume = {554},
Number = {1},
Month = {FEB 1},
Abstract = {In this paper, we are concerned with a cross-diffusion system u(t )=
   Delta u -chi del <middle dot> (u/v del v) + f(u) + g(1), v(t )= Delta v
