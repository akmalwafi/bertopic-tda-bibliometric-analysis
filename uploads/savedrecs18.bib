   and Larson, Catherine A. and Chen, Hsinchun},
Editor = {Glass, K and Colbaugh, R and Sanfillippo, A and Kao, A and Gabbay, M and Corley, C and Li, J and Khan, L and Wynne, A and Coote, L and Mao, W and Zeng, D and Yaghoobi, A},
Title = {Evaluating Text Visualization: An Experiment in Authorship Analysis},
Booktitle = {2013 IEEE INTERNATIONAL CONFERENCE ON INTELLIGENCE AND SECURITY
   INFORMATICS: BIG DATA, EMERGENT THREATS, AND DECISION-MAKING IN SECURITY
   INFORMATICS},
