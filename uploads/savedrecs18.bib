Title = {Determination of Gender from Pelvic Bones and Patella in Forensic
   Anthropology: A Comparison of Classification Techniques},
Booktitle = {2013 FIRST INTERNATIONAL CONFERENCE ON ARTIFICIAL INTELLIGENCE,
   MODELLING AND SIMULATION (AIMS 2013)},
