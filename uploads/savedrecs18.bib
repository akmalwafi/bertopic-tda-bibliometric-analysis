@article{ WOS:000362836100002,
Author = {Montgomery, Jacob M. and Olivella, Santiago and Potter, Joshua D. and
   Crisp, Brian F.},
Title = {An Informed Forensics Approach to Detecting Vote Irregularities},
Journal = {POLITICAL ANALYSIS},
Year = {2015},
Volume = {23},
Number = {4},
Pages = {488-505},
Month = {FAL},
Abstract = {Electoral forensics involves examining election results for anomalies to
   efficiently identify patterns indicative of electoral irregularities.
   However, there is disagreement about which, if any, forensics tool is
   most effective at identifying fraud, and there is no method for
   integrating multiple tools. Moreover, forensic efforts have failed to
   systematically take advantage of country-specific details that might aid
   in diagnosing fraud. We deploy a Bayesian additive regression trees
   (BART) model-a machine-learning technique-on a large cross-national data
   set to explore the dense network of potential relationships between
   various forensic indicators of anomalies and electoral fraud risk
   factors, on the one hand, and the likelihood of fraud, on the other.
   This approach allows us to arbitrate between the relative importance of
   different forensic and contextual features for identifying electoral
   fraud and results in a diagnostic tool that can be relatively easily
   implemented in cross-national research.},
Publisher = {CAMBRIDGE UNIV PRESS},
Address = {EDINBURGH BLDG, SHAFTESBURY RD, CB2 8RU CAMBRIDGE, ENGLAND},
Type = {Article},
Language = {English},
Affiliation = {Montgomery, JM (Corresponding Author), Washington Univ, Polit Sci, St Louis Campus,Box 1063, St Louis, MO 63130 USA.
   Montgomery, Jacob M.; Crisp, Brian F., Washington Univ, Polit Sci, St Louis, MO 63130 USA.
   Olivella, Santiago, Univ Miami, Polit Sci, Coral Gables, FL 33146 USA.
   Potter, Joshua D., Louisiana State Univ, Polit Sci, Baton Rouge, LA 70803 USA.},
DOI = {10.1093/pan/mpv023},
