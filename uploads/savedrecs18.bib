Title = {Ethical and Legal Aspects of Digital Forensics Algorithms: The Case of
   Digital Evidence Acquisition},
Booktitle = {PROCEEDINGS OF THE 15TH INTERNATIONAL CONFERENCE ON THEORY AND PRACTICE
   OF ELECTRONIC GOVERNANCE, ICEGOV 2022},
