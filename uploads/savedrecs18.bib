@article{ WOS:001400123200001,
Author = {Vasavi, J. and Abirami, M. S.},
Title = {Latent lip print classification using mobilenet for Forensic
   Investigations},
Journal = {BIOMEDICAL SIGNAL PROCESSING AND CONTROL},
Year = {2025},
Volume = {103},
Month = {MAY},
Abstract = {With the help of a lip print, it is feasible to differentiate between
   forensic and non-forensic cases. Even though numerous pieces of research
   aimed at recognizing and categorizing lip print patterns have been
   published, it has not yet been decided which classification of lip
   prints from large populations and unconstrained scenarios to detect the
   presence of crimes. In this research paper, we propose an advanced deep
   learning based optimization framework designed to identify the lip
   print, an essential component in forensic investigations. Our approach
   leverages the Large-Scale Multi-Camera Detection dataset. The collected
   lip prints are preprocessed, feature extracted and then classified using
   the MobileNet model with residual learning. The simulation is conducted
   in MATLAB to enhance the robustness of lip print recognition over
   various performance metrics that include accuracy of 99.6 \%, precision
   of 99.21 \%, recall of 99.43 \%, and f-measure of 99.31 \%. The results
   show that the proposed method achieves a higher rate of classification
   accuracy than other methods. Then the results were improved by the
   Particle Swarm Optimization (PSO) technique.},
