Volume = {8857},
Note = {25th SPIE Conference on Signal and Data Processing of Small Targets, San
   Diego, CA, AUG 28-29, 2013},
Organization = {SPIE},
Abstract = {Herein we describe theory and algorithms for detecting covariance
   structures in large, noisy data sets. Our work uses ideas from matrix
   completion and robust principal component analysis to detect the
   presence of low-rank covariance matrices, even when the data is noisy,
   distorted by large corruptions, and only partially observed. In fact,
   the ability to handle partial observations combined with ideas from
   randomized algorithms for matrix decomposition enables us to produce
   asymptotically fast algorithms. Herein we will provide numerical
   demonstrations of the methods and their convergence properties. While
   such methods have applicability to many problems, including mathematical
   finance, crime analysis, and other large- scale sensor fusion problems,
   our inspiration arises from applying these methods in the context of
   cyber network intrusion detection.},
