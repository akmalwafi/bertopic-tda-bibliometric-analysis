@inproceedings{ WOS:000393845100124,
Author = {Dong Yinghong},
Editor = {Esa, R},
Title = {The Research Based on Face Detection and Location System},
Booktitle = {2011 INTERNATIONAL CONFERENCE ON FUTURE COMPUTER SCIENCE AND APPLICATION
   (FCSA 2011), VOL 1},
Year = {2011},
Pages = {502-505},
Note = {International Conference on Future Computer Science and Application
   (FCSA 2011), Kota Kinabalu, MALAYSIA, JUL 16-17, 2011},
Organization = {Univ Malaya; Wuhan Univ; China Univ Geosciences; Huazhong Normal Univ;
   Int Ind Elect Ctr Hong Kong},
Abstract = {In this paper, the algorithm of face recognition technology is made a
   comprehensive study. Firstly studied the methods of face detection,
   facial feature of bottom-up approach, template matching method, the
   method of face appearance, and then focused on color-based face
   detection algorithm. After studied method on face detection, the region
   segmentation of the face and the mark of facial feature are described.
   Finally two methods of face detection are proposed, the first method for
   the similarity-based approach, through similarity calculation, binary
   face region after the mark. The second method is based on areas of skin,
   hair regional approach. It is used to detect the use of color face
   region apporoach. In the face region detection is completed later on
   detected human face of the facial features of the mark. Through the
   above studies facial recognition system in many areas play a significant
   role, especially in the authority with the safety and attendance units;
   network security, banking, customs border control, property management,
   military security, the smart ID card, smart access control, drivers
   license verification, computer sign-on system, credit card verification,
   medical, records management, video conferencing, interactive, public
   security (criminal identification), and so has a great prospect,
   Therefore, the facial recognition technology is increasingly becoming a
   research focus in the area of the current pattern recognition and
