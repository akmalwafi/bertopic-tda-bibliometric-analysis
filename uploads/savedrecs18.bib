Title = {A Conceptual Framework to Determine the Digital Forensic Readiness of a
   Cloud Service Provider},
Booktitle = {2014 PORTLAND INTERNATIONAL CONFERENCE ON MANAGEMENT OF ENGINEERING \&
   TECHNOLOGY (PICMET)},
