Title = {Leveraging Hardware Performance Counters for Efficient Classification of
   Binary Packers},
Booktitle = {2023 IEEE 22ND INTERNATIONAL CONFERENCE ON TRUST, SECURITY AND PRIVACY
   IN COMPUTING AND COMMUNICATIONS, TRUSTCOM, BIGDATASE, CSE, EUC, ISCI
   2023},
