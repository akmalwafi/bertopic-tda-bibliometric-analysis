@inproceedings{ WOS:001443990300256,
Author = {Jiang, Xinqi and Tian, Jinyu},
Book-Group-Author = {IEEE},
Title = {Source Attribution for Images Generated by Diffusion-Based Text-to-Image
   Models: Exploring the Forensics Approach},
Booktitle = {2024 ASIA PACIFIC SIGNAL AND INFORMATION PROCESSING ASSOCIATION ANNUAL
   SUMMIT AND CONFERENCE, APSIPA ASC},
Series = {Asia-Pacific Signal and Information Processing Association Annual Summit
   and Conference},
