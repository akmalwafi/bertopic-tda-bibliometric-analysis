@inproceedings{ WOS:000425928200021,
Author = {Qazi, Nadeem and Wong, B. L. William},
Editor = {Brynielsson, J},
Title = {Behavioural \& Tempo-Spatial Knowledge Graph for Crime matching through
   Graph Theory},
Booktitle = {2017 EUROPEAN INTELLIGENCE AND SECURITY INFORMATICS CONFERENCE (EISIC)},
Series = {European Intelligence and Security Informatics Conference},
Year = {2017},
Pages = {143-146},
Note = {European Intelligence and Security Informatics Conference (EISIC),
   Athens, GREECE, SEP 11-13, 2017},
Organization = {IEEE; IEEE Comp Soc; FOI; KTH; Hellenic Air Force Acad},
Abstract = {Crime matching process usually involves the time tedious and information
   intensive task of eliciting plausible associations among actors of
   crimes to identify potential suspects. Aiming towards the assistance of
   this procedure, we in this paper have exhibited the utilization of
   associative search; a relatively new search mining instrument to evoke
   conceivable associations from the information. We have demonstrated the
   use of three-dimensional, i.e. spatial, temporal, and modus operandi
   based similarity matching of crime pattern to establish hierarchical
   associations among the crime entities. Later we used these to extract
   plausible suspect list for an unsolved crime to facilitate the crime
   matching process. A knowledge graph consisting of tree structure coupled
   with the iconic graphic is used to visualize the plausible list.
   Additionally, a similarity score is calculated to rank the suspect in
   the plausible list. The proposed visualization aims to assist in
   hypothesis formulation reducing computational influence in the decision
