@article{ WOS:000934042400001,
Author = {Abigail Cruz-Najera, Mariel and Guadalupe Trevino-Berrones, Mayra and
   Patricia Ponce-Flores, Mirna and David Teran-Villanueva, Jesus and
   Antonio Castan-Rocha, Jose and Ibarra-Martinez, Salvador and Santiago,
   Alejandro and Laria-Menchaca, Julio},
Title = {Short Time Series Forecasting: Recommended Methods and Techniques},
Journal = {SYMMETRY-BASEL},
Year = {2022},
Volume = {14},
Number = {6},
Month = {JUN},
Abstract = {This paper tackles the problem of forecasting real-life crime. However,
   the recollected data only produced thirty-five short-sized crime time
   series for three urban areas. We present a comparative analysis of four
   simple and four machine-learning-based ensemble forecasting methods.
   Additionally, we propose five forecasting techniques that manage the
   seasonal component of the time series. Furthermore, we used the
   symmetric mean average percentage error and a Friedman test to compare
   the performance of the forecasting methods and proposed techniques. The
   results showed that simple moving average with seasonal removal
   techniques produce the best performance for these series. It is
   important to highlight that a high percentage of the time series has no
   auto-correlation and a high level of symmetry, which is deemed as white
   noise and, therefore, difficult to forecast.},
