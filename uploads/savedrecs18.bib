@article{ WOS:000601108000001,
Author = {Teimouri, Mehdi and Seyedghorban, Zahra and Amirjani, Fatemeh},
Title = {Fragments-Expert: A graphical user interface MATLAB toolbox for
   classification of file fragments},
Journal = {CONCURRENCY AND COMPUTATION-PRACTICE \& EXPERIENCE},
Year = {2021},
Volume = {33},
Number = {9},
Month = {MAY 10},
Abstract = {The classification of file fragments of various file formats is an
   essential task in various applications such as firewalls, intrusion
   detection systems, antiviruses, web content filtering, and digital
   forensics. However, the community lacks a suitable software tool that
   can integrate major methods for feature extraction from file fragments
   and classification among various file formats. In this article, we
   present Fragments-Expert that is a graphical user interface MATLAB
   toolbox for the classification of file fragments. It provides users with
   23 categories of features extracted from file fragments. These features
   can be employed by seven categories of machine learning algorithms for
   the task of classification among various file formats.},
