@article{ WOS:000488238500005,
Author = {da Conceicao Moreira, Paulo Sergio and Tsunoda, Denise Fukumi and
   Bezerra, Cicero Aparecido},
Title = {Crime analysis in global terrorism database},
Journal = {ENCONTROS BIBLI-REVISTA ELETRONICA DE BIBLIOTECONOMIA E CIENCIA DA
   INFORMACAO},
Year = {2018},
Volume = {23},
Number = {1},
Pages = {41-49},
Abstract = {This is a descriptive study from quantitative bivariate and multivariate
   analyzes, which aims to conduct a Crime Analysis in the Global Terrorism
   Database to understand the patterns of terrorist attacks in Brazil. A
   total of 262 records were collected from this database and, on these,
   non-parametric tests and Multiple Correspondence Analysis were applied.
   Using the PASW Statistics 18 (R) and Microsoft Office Excel 2007 (R)
   tools, the results show that the ``Death Squad{''} is the group that
   produce the higher numbers of victims and that armed attacks by firearms
   are the ones with the highest number of fatalities. It is suggested the
   continuation of similar studies on national or international databases,
   using Data Mining heuristics to establish comparisons with the results
   obtained in this study.},
