Volume = {121},
Number = {SI},
Pages = {1-5},
Month = {APR 15},
Abstract = {The theme of this special issue is ``Graphonomics for the e-citizens:
   e-health, e-society and e-education{''}. It aims to bring together the
   works of many experts in this multidisciplinary field that involves
   different competences and knowledge, which span from the study of the
   handwriting generation models to the development of machine learning
   techniques for handwriting recognition and for education and forensic
   applications. The papers included in this special issue allowed us to
   highlight the advances on these topics from a wide-angle perspective, as
   well as to stimulate new theoretical and applied research for better
   characterizing the state of the art in this domain. The special issue
   follows the 18th Conference of the International Graphonomics Society
   (IGS2017) that took place from 18 to 21 June 2017 in Gaeta, Italy, but
   submissions were not restricted to IGS2017 contributors but open to all
