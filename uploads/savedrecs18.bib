@article{ WOS:000492440500011,
Author = {Kasum, Josip and Pilic, Marko and Jovanovic, Nebojsa and Pienaar,
   Harrison},
Title = {Model of Forensic Hydrography},
Journal = {TRANSACTIONS ON MARITIME SCIENCE-TOMS},
Year = {2019},
