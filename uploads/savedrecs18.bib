Organization = {IEEE; IEEE Comp Soc; IEEE TCSC; Fujian Agr \& Forestry Univ; Fuzhou
   Univ; Minjiang Univ},
Abstract = {In order to improve the accuracy of predicting the traffic violations, a
   forecasting model of commercial vehicle violation is proposed based on
   spatio-temporal trajectory of vehicle and K-Nearest Neighbor (KNN).
   Firstly, based on the GPS data of passenger and freight vehicles
   trajectory in Inner Mongolia autonomous region and the spatio-temporal
   features corresponding to the GPS trajectory, analyzing and processing
   the features of vehicle trajectory, a classifier model based on machine
   learning method is developed. Then, we train the vehicle trajectory
   features with the classifier model. Finally, we obtain the forecasting
   model of vehicle violation. Experimental results show that the proposed
   model can accurately classify normal and illegal vehicle, and warn
   potential offending vehicles.},
