@article{ WOS:000503385100070,
Author = {Song, Chunhe and Zeng, Peng and Wang, Zhongfeng and Li, Tong and Qiao,
   Lin and Shen, Li},
Title = {Image Forgery Detection Based on Motion Blur Estimated Using
   Convolutional Neural Network},
Journal = {IEEE SENSORS JOURNAL},
Year = {2019},
Volume = {19},
Number = {23},
Pages = {11601-11611},
Month = {DEC 1},
Abstract = {Currently images are key evidences in many judicial or other
   identification occasions, and image forgery detection has become a
   research hotspot. This paper proposes a novel motion blur based image
   forgery detection method, which includes three steps. First, a
   convolutional neural network (CNN)-based motion blur kernel reliability
   estimation method is proposed, which is used to determine whether an
   image patch should be involved in the image forgery detection process.
   Second, a shared motion blur kernels-based image tamper detection method
   is proposed to detect whether a group of motion blur kernels are
   projected from the same 3D camera trajectory effectively. Third, a
   consistency propagation method is proposed to localize tampered regions
   efficiently. Experiments on synthetic images and natural images show the
   availability of the proposed method.},
