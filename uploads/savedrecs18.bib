@inproceedings{ WOS:000803928000041,
Author = {Li, Yanyan and Zhao, Hong and Zhang, Xuechen},
Book-Group-Author = {IEEE},
Title = {Research on Fines of Dangerous Driving Crime Based on Random Forest and
   Deep Learning},
Booktitle = {2021 INTERNATIONAL SYMPOSIUM ON COMPUTER SCIENCE AND INTELLIGENT
   CONTROLS (ISCSIC 2021)},
Year = {2021},
Pages = {242-247},
Note = {5th International Symposium on Computer Science and Intelligent Controls
   (ISCSIC), ELECTR NETWORK, NOV 12-14, 2021},
Organization = {Int Acad Sci \& Engn Dev; MDPI; Zhejiang Univ},
Abstract = {Fine analysis is a typical problem in criminal crimes, and it is of
   great significance for the judgment of similar cases and the
   recommendation of litigation lawyers. This paper focused on the
   dangerous driving crime, extracted the key features from the
   semi-structured judgment document data (27543 articles in total), used
   keywords matching to identify whether there was a fine in the document,
   and made a preliminary analysis on whether the dangerous driving crime
   was sentenced to a fine by using Decision Tree and Random Forest model.
   The accuracy of classification was 75.23\% and 74.92\% respectively. The
   ranking of feature importance showed that ``Blood alcohol content{''}
   and ``Previous Conviction or not{''} were important influencing factors;
   TextCNN, DPCNN and TextRNN were used to study whether to impose a fine.
   It is verified that TextCNN had the best prediction effect and the
   accuracy was 92\%; The accuracy of DPCNN and TextRNN were 91\% and 88\%
   respectively. The three models performed well in this task and had high
   reference value.},
