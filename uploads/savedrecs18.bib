@inproceedings{ WOS:000658851200031,
Author = {Toledo, A. S. O. and Carpi, Laura C. and Atman, A. P. F.},
Editor = {Barbosa, H and GomezGardenes, J and Goncalves, B and Mangioni, G and Menezes, R and Oliveira, M},
Title = {Diversity Analysis Exposes Unexpected Key Roles in Multiplex Crime
   Networks},
Booktitle = {COMPLEX NETWORKS XI},
Series = {Springer Proceedings in Complexity},
Year = {2020},
Pages = {371-382},
Note = {11th International Conference on Complex Networks (CompleNet), Univ
   Exeter, Exeter, ENGLAND, MAR 31-APR 03, 2020},
Abstract = {The study of criminal networks seeks new approaches and answers to meet
   the growing demand of society. In this paper, we present an innovative
   analysis of crime occurrences in the State of Minas Gerais, Brazil,
   collected from a Public Security Intelligence database, from the point
   of view of statistical physics and complex networks. We built the
   network of these individuals by considering the hierarchy, type of crime
   and relationships reported within criminal organizations. When modeling
   the crime database as a complex network, it was possible to identify
   criminal groups of individuals, and better understand the structure of
   criminal organizations. We apply multiplex and node diversity analysis
   to map the criminal structure in layers according to the type of crime.
   Surprisingly, some key elements pointed out by this analysis had not yet
   been identified previously, as major actors. This work represents a
   significant improvement in the methodology and data mining of the
   criminal database of the state of Minas Gerais and can be applied to any
   similar database.},
