@article{ WOS:001637167100001,
Author = {Liu, Chaoliang and Hao, Dongmin and Wang, Xiaozhen and Wu, Yongtang},
Title = {Design a scalable segmentation joint learning model for the next
   generation animation platform using VAE-GAN model},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {303},
Month = {MAR 25},
Abstract = {Artificial intelligence (AI) is becoming an important trend in the
   animation industry that automates and enhances creativity as well as
   reduces production durations. Nevertheless, the existing AI models have
   many issues that make them unable to produce high-quality and scalable
   results, particularly in forming images, their segmentation precision,
   and temporal consistency across frames. In order to address these
   difficulties, we design a Scalable SegmentationVAEGAN with a Temporal
   Module. Our system uses Generative Adversarial Networks (GAN) together
   with Variational Autoencoders (VAE) alongside a new temporal consistency
   module to deliver seamless motion and consistent sceneries over time.
   The GAN generates the realistic the frames with the help of the latent
   representations once the anime frames have been encoded in the sparse
   latent space by the VAE. The Temporal Module ensures continuity between
   frames by addressing such issues as character flickering and
   intermittent scenes. Our method is tested on Anita Dataset and Anime
   Instance Segmentation Dataset, the results are good segmentation and
   generation quality with IoU of 0.42, FID of 28.7, and SSIM of 0.85.
   Temporal stability of animation sequences is also strong because our
   model has the tLPIPS value of 0.082. Our model is superior in
   segmentation, generation, and temporal coherence to the state-of-the-art
   models and thus is an appropriate choice in generating high-quality
   anime content in large scale. Further studies will be dedicated to
   creating more temporal coherence in complex animations and dividing
   small details in a more efficient way.},
