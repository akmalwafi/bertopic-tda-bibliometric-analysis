@article{ WOS:000678459200001,
Author = {Clyde, Deirdre},
Title = {Flying on borrowed feathers: identity formation among gender-variant
   anime fans in the U.S},
Journal = {FEMINIST MEDIA STUDIES},
Year = {2021},
Volume = {21},
Number = {6, SI},
Pages = {1050-1053},
Month = {AUG 18},
Abstract = {Androgyny and gender ambiguity are common tropes in Japanese comics and
   animation, which may be taken for granted by a Japanese audience but are
   subject to reinterpretation by American fans, especially those who
   identify on the LGBTQ spectrum. These interpretations naturalize a
   concept of gender as flexible and fluid, and an ethos that lionizes and
   defends idiosyncratic self-expression. In the course of my ethnographic
   research at anime fan conventions in the U.S., I have encountered many
   individuals identifying as non-binary, genderfluid, or agendered, who
   use the semiotics they have encountered in Japanese media to resist and
   remix elements of femininity and masculinity as they are understood in
   the West. In this commentary, I explore the experiences of several
   informants who have used anime character tropes, as well as the fan
   practice of cosplay, to re-forge their genders into new molds that allow
   them greater self-expression, and a sense of belonging within an
   inclusive subculture that supports such exploration.},
