@article{ WOS:001571439400003,
Author = {Casale, Cooper},
Title = {The bad stuff},
Journal = {SCIENCE FICTION FILM AND TELEVISION},
Year = {2025},
Volume = {18},
Number = {2},
Pages = {231-248},
Month = {JUL 22},
Abstract = {A commonplace approach to watching a popular anime such as mangaka Akira
   Toriyama's legendary franchise Dragon Ball (1984-) is to skip the
   episodes the fans call ``filler{''}: the narrative byproduct generated
   by the slippage between the original source manga and the anime
   commissioned to concurrently adapt it. When the producers of an anime
   run out of manga to adapt, they must write episodes outside the main
   narrative that are self-consciously ``forgettable{''}; as a result, many
   fans, viewing filler as a distraction from and even a danger to the
   canon storyline, invest an immense amount of labor into creating and
   consuming filler-free versions of the anime. This paper will examine the
   ways the practice of loving a show so much that one demands to watch
   less of it warps warm attachment into a litigious managerial practice
   that not only does violence to the anime but also to the fans
   themselves, who may similarly seek to eradicate filler in themselves,
   purifying the canon of their own private life. Borrowing from Marx's
   concept of the lumpenproletariat and from Vil \& eacute;m Flusser's
   concept of the envisioner, I call these fans who dispose of an anime's
   waste, rather than confronting waste as the fundament of the political
   economy that created that anime, lumpenvisioners. By examining the
   half-forgotten fictive lives of some of Dragon Ball's filler characters,
   this article proposes an alternative to this unhappy labor. It finds, in
   loving Dragon Ball the wrong way, in watching its filler, in leaving
   waste alone, both a critique of capitalist formations of the worthy and
   valuable as well as an argument for a more ethical, more sustainable
   fanhood.},
Publisher = {LIVERPOOL UNIV PRESS},
Address = {4 CAMBRIDGE ST, LIVERPOOL L69 7ZU, ENGLAND},
Type = {Article},
Language = {English},
DOI = {10.3828/sfftv.2025.17},
ISSN = {1754-3770},
EISSN = {1754-3789},
Keywords = {Anime and Manga; Television; Fanhood; Franchise; Dragon Ball},
Research-Areas = {Film, Radio \& Television},
