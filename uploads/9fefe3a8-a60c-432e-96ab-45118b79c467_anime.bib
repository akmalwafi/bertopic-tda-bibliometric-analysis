@article{ WOS:001196529300009,
Author = {de Lucas, Victor Selles and Hernandez-Perez, Victor},
Title = {EXEGESIS AND AUTHORIAL AGENCY THROUGH JUDEOCHRISTIAN ICONOGRAPHY IN
   JAPANESE ANIME: NEON GENESIS EVANGELION (1995-97) AS AN OPEN WORK},
Journal = {IMAFRONTE-REVISTA DE HISTORIA DEL ARTE},
Year = {2024},
Number = {31},
Pages = {224-237},
Abstract = {Exegesis is a common practice when discussing religious texts. It has
   also been employed in the analysis of cultural production to elucidate
   the author's intentions. Japanese animation (anime) is a transnational
   industry with cases such as Neon Genesis Evangelion (1995-1997), in
   which the figure of an individual author, such us the filmmaker Hideaki
   Anno, interacts with the collaborative authorship. The extensive use of
   obscure Judeo-Christian terminology and iconography in this work has
   risen debate about the actual intentions of Japanese author(s) when
   referring to Western culture. Our analysis concludes that the use of
   this iconography is intentional. The ambiguity of the narrative, shaped
   using multiple references, aims to induce the feeling of a complex text
   in the viewer. This would reinforce previous considerations of this
   anime as an ``open work{''}, in the sense defined by post -structural
   semiotic analysis.},
Publisher = {UNIV MURCIA},
Address = {Edificio Pleiades Campus de Espinardo, Murcia, 30071, SPAIN},
