Booktitle = {PROCEEDINGS SIGGRAPH ASIA 2024 TECHNICAL COMMUNICATIONS},
Year = {2024},
Note = {2024 SIGGRAPH Asia Technical Communications, Tokyo, JAPAN, DEC 03-06,
   2024},
Abstract = {We propose a fast leak-resistant automatic segmentation method for line
   art with gaps. Using the existing trapped-ball idea, we develop a fair,
   prioritized flood-fill that avoids artifacts, augment it with a
   heuristic region merging strategy and obtain robust results on anime
   line art minimizing over-segmentation, with consistent performance
   similar to 5-10 times faster than the baseline method.},
