@inproceedings{ WOS:001447627200142,
Author = {Kumari, Vishakha and Bhadoria, Robin Singh},
Editor = {Tomar, GS},
Title = {Exploring Denoising Diffusion Models for Realistic Anime Character
   GenerationVishakha},
Booktitle = {2024 IEEE 16TH INTERNATIONAL CONFERENCE ON COMPUTATIONAL INTELLIGENCE
   AND COMMUNICATION NETWORKS, CICN},
