@article{ WOS:000604147500033,
Author = {Sosa Toranzo, Rodrigo Emanuel},
Title = {Anime, globalization and adaptations},
Journal = {QUESTION},
Year = {2020},
Volume = {2},
Number = {67},
Month = {DEC},
Abstract = {Globalization as a typical modernity phenomenon has allowed a break with
   the limits that we previously closed unbridgeable. Cultures, people,
   money, messages, and politics travel around the world and interwine in
   complex trasnational relationships. The same applies to discourses as
   source of senses that circulate among people and give meaning to their
   pratices.
   Today, the world of manga-anime has been assailed by a constant attempt
   to adapt the successes and themes of these products to the logic of the
   Western film industry.
   With this in mind we propose here an analysis of the phenomenon of
   adptations. First we will reconstruct the historical-commercial
   framework that the anime industry has had and its relationship with the
   western market. Second, we will seek to briefly analyze the film Ghost
   in the Shell by Mamoru Oshii (1995) and its adaptation Ghost in the
   Shell by Rupert Sanders (2017). The aim is to interpret how the changes
   in both films affect the directions proposed by both discourses.},
