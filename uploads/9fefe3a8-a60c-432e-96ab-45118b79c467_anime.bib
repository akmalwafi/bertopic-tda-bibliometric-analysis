@article{ WOS:000229058500030,
Author = {Roth, MB and Nystul, T},
Title = {Suspended animation},
Journal = {SCIENTIFIC AMERICAN},
Year = {2005},
Volume = {292},
Number = {6},
Pages = {49-55},
Month = {JUN},
