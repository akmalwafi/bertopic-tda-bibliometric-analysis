@article{ WOS:001489382500001,
Author = {Mitsuhashi, Yuta and Yamaguchi, Yasumasa},
Title = {Japanese adaptation of the Anime Tourism Motivation Scales},
Journal = {CURRENT ISSUES IN TOURISM},
Year = {2025},
Month = {2025 MAY 16},
Abstract = {This study presents the Japanese translation of the Anime Tourism
   Motivation Scale, which consists of 36 self-report questions and
   provides subscale scores for anime social interest, anime seeking,
   learning novelty, escape/relaxation and exploration into 2D world. The
   translation was validated using 655 native Japanese speakers. The
   results indicated excellent internal consistency and revisit intention
   reliability. Confirmatory factor analysis revealed that the data of the
   current study reasonably maintained the five-factor model structure of
   the original version. The strengths of the scale are that it helps
   tailor marketing strategies, enhances visitor experiences and supports
   economic development. This inventory and its translations increasingly
   contribute to research on tourism management, tourism policy and content
   tourism; thus, the Japanese translation may further enhance research in
   these areas.},
