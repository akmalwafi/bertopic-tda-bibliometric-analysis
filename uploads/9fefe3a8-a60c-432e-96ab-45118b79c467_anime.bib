@article{ WOS:001723836500005,
Author = {Yamada, Fernanda Miyuki and Gois, Joao Paulo and Takahashi, Hiroki},
Title = {The Rise of AI-Generated Anime Avatars: Trends, Challenges, and
   Opportunities},
Journal = {IEEE COMPUTER GRAPHICS AND APPLICATIONS},
Year = {2026},
Volume = {46},
Number = {2},
Pages = {112-119},
Month = {MAR-APR},
Abstract = {The rise of 3-D anime-style avatars in gaming, virtual reality, and
   other digital media has driven significant interest in automated
   generation methods capable of capturing their distinctive visual
   characteristics. These include stylized proportions, expressive
   features, and nonphotorealistic rendering. This article reviews the
   advancements and challenges in using deep learning in 3-D anime-style
   avatar generation. We analyze the strengths and limitations of these
   methods in capturing the aesthetics of anime characters and supporting
   customization and animation. In addition, we identify and discuss open
   problems in the field, such as difficulties in resolution and detail
   preservation, and constraints regarding the animation of hair and loose
   clothing. This article aims to provide a comprehensive overview of the
   current state-of-the-art and identify promising research directions for
   advancing 3-D anime-style avatar generation.},
