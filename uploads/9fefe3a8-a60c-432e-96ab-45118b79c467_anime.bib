@article{ WOS:000422238200011,
Author = {Horno Lopez, Antonio},
Title = {The art of selective animation in contemporary anime series},
Journal = {CON A DE ANIMACION},
Year = {2014},
Number = {4},
Pages = {84+},
Abstract = {This essay exposes the background reasons and the context where limited
   animation was originated, a peculiar Japanese technique of saving costs
   at the production of anime series. Through the analysis of fragments of
   recent anime TV series, the paper will demonstrate how these economical
   processes have evolved over the years into what we can call selective
   animation, which results in a significant improvement in the quality of
   animation images, becoming the greatest asset for its expansion
   worldwide.},
