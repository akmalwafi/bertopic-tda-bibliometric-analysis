Volume = {23},
Number = {3},
Pages = {1091-1104},
Month = {JUL-SEP},
Abstract = {This essay discusses some instances of the presence of sports in animes
   and mangas, here understood as both commodities and confluence points
   for global and local cultural forces. In order to support this
   reflection, it also sets some milestones related to Japanese culture and
   the rise of sports in Japan, It finds that despite strong influence
   exerted by Japanese identity symbols, sports' representation in animes
   and mangas is getting closer to western (post) modernity due to
   globalization and transnationalization of immaterial goods.},
