@article{ WOS:001449613600001,
Author = {Mihara, Ryotaro},
Title = {Decolonising anime studies: a prolegomenon},
Journal = {JAPAN FORUM},
Year = {2025},
Volume = {37},
Number = {1},
Pages = {29-52},
Month = {JAN 1},
Abstract = {This paper argues that the field of Anglophone anime studies is not free
   from decolonisation issues that warrant evaluation, especially from the
   viewpoint of Orientalism proposed by Edward Said. Although more than two
   decades have passed since anime became a popular subject for research
   and teaching in Anglophone higher education institutions, critical
   writings in the field are yet to fully examine the impact of Orientalism
   on the ways in which they try to make intellectual sense of this area of
   Japanese visual culture. This paper argues that the field of Anglophone
   anime studies should itself be scrutinised in relation to how it
   canonises a specific `style of thought' (as Said terms it) in
   understanding anime at the expense of anime itself, against the
   background of its (colonial) power over intellectuals and primary
   sources in Japan/ese. Reviewing the major `canonical' Anglophone texts
   in the field from the viewpoint of Orientalism, this paper highlights
   that the issue of Orientalism remains an `elephant in the room', that
   is, the issue is still persistently at work in the field, even as the
   field itself disavows it as a critical, or even relevant, issue for
   Anglophone anime studies. Reflecting ethno-autobiographically on the
   author's own complexly liminal experience of navigating his academic
   career through Anglophone and Japanophone academia, the paper further
   reveals how this Orientalist `style of thought' subtly executes its
   disciplinary power over academics as they try to secure their
   intellectual as well as professional positions in the field of
   Anglophone anime studies, and, in doing so, how the field normalises the
   style's position of authority by appointing it, arbitrarily, as a
   `sophisticated' approach towards anime.},
Publisher = {ROUTLEDGE JOURNALS, TAYLOR \& FRANCIS LTD},
Address = {2-4 PARK SQUARE, MILTON PARK, ABINGDON OX14 4RN, OXON, ENGLAND},
Type = {Article},
Language = {English},
Affiliation = {Mihara, R (Corresponding Author), Keio Univ, Fac Econ, Yokohama, Japan.
   Mihara, Ryotaro, Keio Univ, Fac Econ, Yokohama, Japan.},
DOI = {10.1080/09555803.2024.2446885},
ISSN = {0955-5803},
EISSN = {1469-932X},
Keywords = {animation; anime; decolonisation; orientalism; japan},
