@article{ WOS:001761735200007,
Author = {Oses, Sebastian Arce},
Title = {Intertextual networks between manga, anime and Costa Rican poetry},
Journal = {CUADERNOS CANELA},
Year = {2026},
Volume = {37},
Pages = {95-113},
Abstract = {This article examines the intertextual relationships established between
   Costa Rican poetry and Japanese manga and anime. Costa Rican poetry has
   not only woven connections with both traditional and avant-garde
   literary texts, but has also drawn from the repertoire of popular
   culture, including film, music, and, notably, comics and animation. The
   analysis focuses on five poems: Felipe Granados's Capit \& aacute;n
   Raimar, Dennis \& Aacute;vila's Los ni \& ntilde;os del Dr. Hell, Mainor
   Vargas's Mazinger Z, Luis Chac \& oacute;n's Mi vida como un manga
   shonen, and Alber Mapache's Gokuuuu !!!. The article addresses the
   central question: how were intertextual networks between manga, anime,
   and Costa Rican poetry woven? To answer this, it first outlines the
   theoretical framework of intertextuality as developed by Julia Kristeva,
   Roland Barthes, and G \& eacute;rard Genette. It then considers the
   emergence and development of manga and anime in Japan, as well as the
   contexts of their reception in Costa Rica and Latin America. Finally, it
   analyzes how the five selected poets appropriate and re-signify the
   resources of manga and anime in order to create a poetry that is open,
   dialogic, and rich in discovery.},
Publisher = {NANZAN UNIV, NANZAN INST RELIGION \& CULTURE},
