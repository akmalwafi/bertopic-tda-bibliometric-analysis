@article{ WOS:000511121500002,
Author = {Ferrera, Daniel},
Title = {ANALYSIS OF ANIME PROGRAMMING IN GENERAL TELEVISION IN SPAIN
   (1990-1999)},
Journal = {ATALANTE-REVISTA DE ESTUDIOS CINEMATOGRAFICOS},
Year = {2020},
Number = {29},
Pages = {25-37},
Month = {JAN-JUN},
Abstract = {The nineties began with the expansion of the Spanish television scene
   through the incorporation of three new channels of private ownership
   (Antena 3, Telecinco and Canal +). In a context of uncertainty and
   changes in broadcast programming, anime became an economic product for
   the networks, producing a boom in their television broadcasts. The
   present investigation analyzes mime programming in Spain between 1990
   and 1999, for which a database of TV broadcast programming of the decade
   has been prepared, consisting of a total of 21,834 records. Complemented
   by a hemerographic analysis. the research concludes that Telecinco (and
   its relationship with the Italian Canale 2 has great importance in the
   implementation of anime in Spanish networks, that all Japanese animation
   is considered a product of child consumption and that the morning
   schedule is the one that concentrates most anime broadcasts.},
