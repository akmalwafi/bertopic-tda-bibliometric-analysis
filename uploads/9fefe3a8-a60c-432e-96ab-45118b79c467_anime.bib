@inproceedings{ WOS:000380485000019,
Author = {Tansuriyavong, Suriyon},
Book-Group-Author = {IEEE},
Title = {The Development of English Learning System by Using Real-Time Subtitle
   Recognition on Japanese Anime},
Booktitle = {2015 INTERNATIONAL CONFERENCE ON INTELLIGENT INFORMATICS AND BIOMEDICAL
   SCIENCES (ICIIBMS)},
Series = {International Conference on Intelligent Informatics and Biomedical
   Sciences ICIIBMS},
Year = {2015},
Pages = {58-61},
Note = {ICIIBMS 2015 Int C Intelligent Inform BioMedical, Okinawa, JAPAN, NOV
   28-30, 2015},
Organization = {ASCS Publications; Orion; University of the Ryukyus; OIST; ONCT; IEEJ;
   IEEE; IEEE COMPUTER SOCIETY},
Abstract = {This paper proposes a new method of learning English for Japanese
   people, by using English-subbed Japanese-sounded cartoons (anime). In
   the proposed system, the English subtitles are recognized into text in
   real time and sent to the text-to-speech system. After that, the sound
   is generated and can be heard immediately, after Japanese sound. It
   means that, while the learner is watching anime, learner can hear the
   sound of English subtitles in immediately after he/she heard the sound
   of original Japanese. By hearing Japanese and English alternately a lot,
   finally the learner will be able to understand English. This system is
   suitable for everyone who wants to learn English while watching anime,
   including the child.},
