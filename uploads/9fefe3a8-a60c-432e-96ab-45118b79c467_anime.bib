@article{ WOS:000264996500002,
Author = {McCrea, Christian},
Title = {Explosive, Expulsive, Extraordinary: The Dimensional Excess of Animated
   Bodies},
Journal = {ANIMATION-AN INTERDISCIPLINARY JOURNAL},
Year = {2008},
Volume = {3},
Number = {1},
Pages = {9-24},
Month = {MAR},
Abstract = {Animation's excursions into the impossible allow bodies to erupt and
   explode, fly and roar. While the histories of animation and special
   effects cinema are deeply linked in this regard, the sensation of
   viewing the physically impossible in animation has its own visual and
   cultural idiosyncrasies. The experience of watching bones splinter to
   thrash metal refuses psychology's primacy and transforms it into a kind
   of pure ornament. This article proposes a specific symbolic discourse of
   violence-animated texts, and more specifically anime via the European
   and Australasian releases of Manga Entertainment.},
