@inproceedings{ WOS:000669709800052,
Author = {Belova, Polina and Urkaeva, Ksenia and Gamova, Anna},
Book-Group-Author = {IEEE},
Title = {Generating ``Ideal{''} Anime Opening Frames Using Neural Networks},
Booktitle = {PROCEEDINGS OF THE 2021 IEEE CONFERENCE OF RUSSIAN YOUNG RESEARCHERS IN
   ELECTRICAL AND ELECTRONIC ENGINEERING (ELCONRUS)},
