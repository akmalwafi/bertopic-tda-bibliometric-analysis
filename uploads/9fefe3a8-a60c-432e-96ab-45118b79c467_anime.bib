@article{ WOS:001446314800001,
Author = {Keene, Andrea},
Title = {Japanese animation: between ecocriticism and protest art},
Journal = {JAPAN FORUM},
Year = {2025},
Volume = {37},
Number = {3},
Pages = {403-425},
Month = {MAY 27},
Abstract = {This article seeks to find how Japanese animation can function as both
   protest art and a valid text of ecocinema. It looks at the advocacy for
   the environment, which can be seen considerably during the late 20th
   century in four anime productions: Pom Poko directed by Isao Takahata,
   Nausica \& auml;: Valley of the Wind and Princess Mononoke directed by
   Hayao Miyazaki and Blue Gender directed by Masashi Abe. The article
   seeks to demonstrate that anime, can go beyond mere banal entertainment,
   acting as protest art and developing a social critique, which creatively
   protests environmental issues in an increasingly striking manner to
   encourage the conversation of a global human responsibility from the
   audience and as a valuable source for ecocriticism.},
