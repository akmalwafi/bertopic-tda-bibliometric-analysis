@article{ WOS:000645655200022,
Author = {Maximiliano Ortiz, Carlos},
Title = {Appropriation and valoration of Anime, Manda and Merchandising in Ciudad
   Autonoma de Buenos Aires},
Journal = {QUESTION},
Year = {2021},
Volume = {3},
Number = {68},
Month = {APR},
Abstract = {The widespread increase of anime and manga in Argentina motivated - and
   was possible because of - the production and commercialization on a
   large scale of objects related to them. We intend to look into the
   motivations that leads these followers to buy, trade and appropriate
   these objects of merchandising, and into the relation that they
   establish with them. Our methodology was based on ethnographic fieldwork
   (participant observation and interviews) and complemented by the
   techniques of virtual etnography. We affirm that fans establish a
   particular relationship with these consumer objects, which is derived of
   their symbolic valuation of them.},
