Title = {Moments of animation metamorphosis in the feature cinema},
Booktitle = {METAMORPHOSES, ART READINGS 2023, VOL II},
Series = {Art Readings},
Year = {2024},
Pages = {509-521},
Note = {International Conference on Art Readings - New Art Module, Bulgarian
   Acad Sci, Inst Art Studies, Sofia, BULGARIA, APR 27-29, 2023},
Abstract = {The animation is immersed in the sphere of rhythmic melodiousness of
   moving lines and images, plastic compositions, colour gradients. On the
   animation screen one often sees the metamorphosis, the transformation of
   one form into another. The process of their blending is accomplished by
   a barely noticeable to the eye deformation of the image. In the process
   of ``animating{''}, of moving animated images, a different kind of
   deformation takes place. The magic of this reimagining is so strong that
   even feature cinema resorts to it, incorporating broad animated episodes
   into its structures, real shapes and volumes flowing naturally into
   others, the character becoming a three-dimensional computer image made
   of every material the human imagination can conjure up.},
