Affiliations = {Keio University},
Funding-Acknowledgement = {Chuo University},
Funding-Text = {I would like to thank Izumi Tsuji from Chuo University for encouraging
   me to publish this boldly `unsophisticated' account of mine regarding
   anime and Orientalism. I also wish to thank Nao Hirasawa, a founder of
