@inproceedings{ WOS:001285850004112,
Author = {Wang, Ning and She, Yifei and Xu, Rui and Bin Liu and Li, Haojie and
   Wang, Zhiyong and Wang, Zhihui},
Book-Group-Author = {IEEE},
Title = {BRIDGING THE GAP: SKETCH TO COLOR DIFFUSION MODEL WITH SEMANTIC PROMPT
   LEARNING},
