@article{ WOS:001606279500001,
Author = {Cho, Lydia Y. and Dougherty, Madeline R. and Roh, Hee Joo and Harriger,
   Jennifer A.},
Title = {Sexual Objectification, Sexualization, and Appearance-Related Themes in
   Anime: A Content Analysis},
Journal = {SEX ROLES},
Year = {2025},
Volume = {91},
Number = {11},
Month = {NOV 3},
Abstract = {Anime is a type of media originating in Japan that has grown
   increasingly popular worldwide in recent years. It has received
   criticism regarding its portrayal of women; however, little empirical
   work has focused on anime. The purpose of this content analysis was to
   examine the prevalence of sexualization and sexual objectification
   themes and the cultural messages regarding appearance ideals in 30
   popular anime series. Most anime episodes included thin female
   characters dressed provocatively and the presence of the male gaze.
   Power over women was also common; however, other toxic masculinity
   themes appeared infrequently, such as playboy behavior, inappropriate
   sexual conduct, and oversexualization/perversion of male characters. The
   most frequently reported appearance themes across the observed anime
   series were related to the female body portrayal and female kawaii
   ideal; however, male muscularity and the male hoso macho ideal also
   appeared often. Future research examining the effects of exposure to
   anime is warranted.},
