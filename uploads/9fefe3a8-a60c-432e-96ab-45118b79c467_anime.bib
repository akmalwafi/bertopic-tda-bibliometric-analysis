@article{ WOS:000617328200016,
Author = {Collier, Aaron and Wilcox, Richie and Hudson, Deonie},
Title = {The Princess Show},
Journal = {CANADIAN THEATRE REVIEW},
Year = {2021},
Volume = {185},
Number = {SI},
Pages = {61-71},
Month = {JAN 1},
Abstract = {The Princess Show is a performance text written and created by Aaron
   Collier, Richie Wilcox and Deonie Hudson. This fully lip-synched live
   anime drag show is a queer performance featuring the characters of
   Princess Edward and Abel T. Suckizone. The story follows Princess Edward
   on a journey of self-acceptance and love as she battles The Beast to win
   her love back. This performance text and its accompanying introduction
   share insight into the early beginnings of this queer work and its
   development with Theatre Outre and Club Didi before moving onto its life
   as a Heist production. The introduction details the journey and power of
   this unabashedly queer multimedia work.},
