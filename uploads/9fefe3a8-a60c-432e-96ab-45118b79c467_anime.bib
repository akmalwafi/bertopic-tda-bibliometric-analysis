Note = {International Conference on Network and Finance Development, Wuhan,
   PEOPLES R CHINA, JUN 06, 2010},
Abstract = {Animation is a good form of representatives; it enables the Chinese
   culture more broadly into the world, but now a lot of Japanese anime is
   filled with the occupation of our country's market. What is the gap
   between Chinese and Japanese in the animation industry? What are the
   reasons for the success of the Japanese anime industry? In the
   dissertation, the author first analyzes the popular and successful
