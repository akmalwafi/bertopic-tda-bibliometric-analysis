@article{ WOS:000422955300008,
Author = {Anderson, David and Shimizu, Hiroyuki and Iwasaki, Shota},
Title = {Memories of Manga: Impact and Nostalgic Recollections of Visiting a
   Manga Museum},
Journal = {CURATOR-THE MUSEUM JOURNAL},
Year = {2017},
Volume = {60},
Number = {4},
Pages = {505-525},
Month = {OCT},
Abstract = {This study investigated the impact of a visit to a Manga museum in Japan
   through nostalgic recollections. Twenty-five adult visitors were
   interviewed about their childhood memories of experiencing manga from
   reading books as well as watching anime on television following a visit
   to the Osamu Tezuka Manga Museum in Takarazuka, Japan. From 76 episodic
   and autobiographical memories, five themes of impact emerged which speak
   powerfully to the significant influence and power of Osamu Tezuka's
   manga and anime on the visitors' lives as children, and of the power of
   the museum experience to unlock distant latent memories and reconnect
   with their own sense of self-identity. Moreover, the visitors' own
   testimony of the impact of manga continued to manifest positively in
   their lives to the present day as life lessons of enjoyment, morality,
   and intergenerational learning.},
