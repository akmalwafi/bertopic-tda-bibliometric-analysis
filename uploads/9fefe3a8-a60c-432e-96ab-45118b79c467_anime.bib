@article{ WOS:000323113300005,
Author = {Fennell, Dana and Liberato, Ana S. Q. and Hayden, Bridget and Fujino,
   Yuko},
Title = {Consuming Anime},
Journal = {TELEVISION \& NEW MEDIA},
Year = {2013},
Volume = {14},
Number = {5},
Pages = {440-456},
Month = {SEP},
Abstract = {Researchers are increasingly recognizing anime and manga as worthy of
   scholarly examination. However, relatively little research examines how
   fans synthesize the cultural content of anime. This paper provides an
   analysis of representations of race/ethnicity and gender in two
   televised anime, and contrasts the understandings of scholars to fans.
   As anime can weave together images from Japanese culture, other
   cultures, as well as fantasy, anime presents many faces to fans. Fans do
   not necessarily see all of these faces at once, and they interpret the
   cultural content of anime differently. As a result, anime has the
   potential to generate different types of cultural influence.},
