Pages = {543-550},
Month = {APR},
Abstract = {Tiddy Smith argues that common consent amongst geographically and
   historically isolated communities provides strong evidence for
   animism-the view that there are nature spirits. In this article, I argue
   that the problem of animistic hiddenness-the lack of widespread belief
   in nature spirits-is at least as strong evidence against animism that
   common consent is evidence for it, meaning that the evidence for animism
   that Smith provides is (at least) neutralized.},
