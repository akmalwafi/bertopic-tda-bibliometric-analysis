@article{ WOS:000943163700010,
Author = {Soni, Badal and Thakuria, Debangan and Nath, Nilutpal and Das, Navarun
   and Boro, Bhaskarananda},
Title = {RikoNet: A Novel Anime Recommendation Engine},
Journal = {MULTIMEDIA TOOLS AND APPLICATIONS},
