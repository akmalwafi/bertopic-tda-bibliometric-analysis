@inproceedings{ WOS:001678540000007,
Author = {Marasco, Alessandra and Pagano, Alfonsina and Sanita, Helga and Dalla
   Longa, Elisa and Pavone, Danilo Paolo and Palombini, Augusto and Cerato,
   Ivana},
