@article{ WOS:001727015500001,
Author = {Zhang, Yang and Fu, Xiaoxiao and Yin, Yue and Wei, Tianming and Zhou,
   Ziyan and Ai, Yingqi},
Title = {The impact of man-made disaster uncertainty on anime pilgrimage
   intentions: The mediating influence of special interest-driven
   motivators},
Journal = {JOURNAL OF DESTINATION MARKETING \& MANAGEMENT},
Year = {2026},
Volume = {41},
Month = {SEP},
Abstract = {Special interest tourism offers a strategic buffer against uncertainty
   due to its unique resilience. This study investigates the impact of
   uncertainty induced by man-made disasters on the travel intentions of
   special interest tourists, specifically focusing on anime pilgrimage.
   Through empirical analysis of Chinese anime fans intending to visit
   Japan amid concerns about radioactive water disposal, the research
   applies the Constraint-EffectMitigation model to construct a structural
   model. It examines how these tourists negotiate disaster-related
   constraints and the roles of intrinsic and extrinsic motivation. Using
   both structural equation modeling and fuzzy-set qualitative comparative
   analysis, the study reveals the causal relationships between these
   factors and their influence on travel intention, with animation
   involvement and destination image playing significant roles.
   Additionally, the study identifies the moderation effect of cultural
   values of individualism, including both traditional and modern
   dimensions, on these causal links. The results offer a clear strategic
   takeaway for destinations facing uncertainty by demonstrating that
   robust destination image overrides safety concerns, suggesting that
   marketers should prioritize immersive storytelling over defensive safety
   assurances.},
