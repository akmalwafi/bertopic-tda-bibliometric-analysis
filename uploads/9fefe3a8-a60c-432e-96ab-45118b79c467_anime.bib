@article{ WOS:A1997YK11000005,
Author = {vandePanne, M},
Title = {From footprints to animation},
Journal = {COMPUTER GRAPHICS FORUM},
Year = {1997},
Volume = {16},
Number = {4},
Pages = {211-223},
Month = {OCT},
Abstract = {A method of using footprints as a basis for generating animated
   locomotion is proposed. An optimization process is used to maximize the
   physical plausibility and perceived comfort of a motion which is
   constrained to match given footprint and timing information. The
   proposed method creates plausible walking, turning, leaping, and running
   motions for bipedal figures at intel active rates. Autonomous motions
   are generated using a planning algorithm which dynamically generates new
   footprints and the associated new motions.},
